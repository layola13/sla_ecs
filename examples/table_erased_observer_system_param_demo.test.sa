@test "component registry defaults to table and supports sparse opt in"():
L_TEST_ENTRY_1766:
    tmp_7451 = call @sla__component_registry_new()
    reg0 = tmp_7451
    tmp_7452 = call @sla__component_register_table(reg0)
    reg1 = load tmp_7452+0 as ptr
    table_info = load tmp_7452+8 as ptr
    !tmp_7452
    tmp_7453 = call @sla__component_register_sparse_set(reg1)
    reg2 = load tmp_7453+0 as ptr
    sparse_info = load tmp_7453+8 as ptr
    !tmp_7453
    tmp_7454 = load table_info+0 as i32
    tmp_7455 = 1
    tmp_7456 = ne tmp_7454, tmp_7455
    !tmp_7454
    !tmp_7455
    br tmp_7456 -> L_THEN_1767, L_ELSE_1768

L_THEN_1767:
    !tmp_7456
    panic(4310)

L_ELSE_1768:
    !tmp_7456
    jmp L_MERGE_1769

L_MERGE_1769:
    tmp_7459 = load sparse_info+0 as i32
    tmp_7460 = 2
    tmp_7461 = ne tmp_7459, tmp_7460
    !tmp_7459
    !tmp_7460
    br tmp_7461 -> L_THEN_1770, L_ELSE_1771

L_THEN_1770:
    !tmp_7461
    panic(4311)

L_ELSE_1771:
    !tmp_7461
    jmp L_MERGE_1772

L_MERGE_1772:
    tmp_7464 = load table_info+8 as ptr
    tmp_7465 = call @sla__storage_kind_is_table(^tmp_7464)
    tmp_7466 = 1
    tmp_7467 = ne tmp_7465, tmp_7466
    !tmp_7465
    !tmp_7466
    br tmp_7467 -> L_THEN_1773, L_ELSE_1774

L_THEN_1773:
    !tmp_7467
    panic(4312)

L_ELSE_1774:
    !tmp_7467
    jmp L_MERGE_1775

L_MERGE_1775:
    tmp_7470 = load sparse_info+8 as ptr
    tmp_7471 = call @sla__storage_kind_is_sparse_set(^tmp_7470)
    tmp_7472 = 1
    tmp_7473 = ne tmp_7471, tmp_7472
    !tmp_7471
    !tmp_7472
    br tmp_7473 -> L_THEN_1776, L_ELSE_1777

L_THEN_1776:
    !tmp_7473
    panic(4313)

L_ELSE_1777:
    !tmp_7473
    jmp L_MERGE_1778

L_MERGE_1778:
    tmp_7476 = 2
    tmp_7477 = call @sla__component_registry_get(reg2, tmp_7476)
    !tmp_7476
    again = tmp_7477
    tmp_7478 = load again+0 as i32
    tmp_7479 = load sparse_info+0 as i32
    tmp_7480 = ne tmp_7478, tmp_7479
    !tmp_7478
    !tmp_7479
    br tmp_7480 -> L_THEN_1779, L_ELSE_1780

L_THEN_1779:
    !tmp_7480
    panic(4314)

L_ELSE_1780:
    !tmp_7480
    jmp L_MERGE_1781

L_MERGE_1781:
    tmp_7483 = load again+8 as ptr
    tmp_7484 = call @sla__storage_kind_is_sparse_set(^tmp_7483)
    tmp_7485 = 1
    tmp_7486 = ne tmp_7484, tmp_7485
    !tmp_7484
