@test "relationship linked despawn follows target collection"():
L_TEST_ENTRY_688:
    tmp_2616 = call @sla__relationship_world_new()
    w0 = tmp_2616
    tmp_2617 = 1
    tmp_2618 = 0
    tmp_2619 = call @sla__relationship_world_register_many(w0, tmp_2617, tmp_2618)
    !tmp_2617
    !tmp_2618
    w1 = load tmp_2619+0 as ptr
    linked = load tmp_2619+8 as ptr
    !tmp_2619
    tmp_2620 = call @sla__relationship_world_spawn(w1)
    w2 = load tmp_2620+0 as ptr
    root = load tmp_2620+8 as ptr
    !tmp_2620
    tmp_2621 = load linked+0 as i32
    tmp_2622 = alloc 8
    tmp_2623 = load root+0 as i32
    store tmp_2622+0, tmp_2623 as i32
