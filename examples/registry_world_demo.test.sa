@test "registry entity query supports for in"():
L_TEST_ENTRY_328:
    entity_slot = stack_alloc 8
    tmp_1050 = call @sla__registry_world_new()
    w0 = tmp_1050
    tmp_1051 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_1051+0 as ptr
    component = load tmp_1051+8 as ptr
    !tmp_1051
    tmp_1052 = call @sla__registry_world_spawn(w1)
    w2 = load tmp_1052+0 as ptr
    e1 = load tmp_1052+8 as ptr
    !tmp_1052
    tmp_1053 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_1053+0 as ptr
    e2 = load tmp_1053+8 as ptr
    !tmp_1053
    tmp_1054 = load component+0 as i32
    tmp_1055 = call @sla__registry_world_insert_component(w3, e1, tmp_1054)
    !tmp_1054
    w4 = tmp_1055
    tmp_1056 = load component+0 as i32
    tmp_1057 = call @sla__registry_world_insert_component(w4, e2, tmp_1056)
    !tmp_1056
    w5 = tmp_1057
    tmp_1058 = load component+0 as i32
    tmp_1059 = call @sla__registry_world_query_component(w5, tmp_1058)
    !tmp_1058
    q = tmp_1059
    tmp_1060 = 0
    total = tmp_1060
    tmp_1061 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_329

L_LOOP_HEAD_329:
    tmp_1062 = load entity_slot+0 as i64
    tmp_1063 = slt tmp_1062, tmp_1061
    br tmp_1063 -> L_LOOP_BODY_330, L_LOOP_COND_FALSE_332

L_LOOP_BODY_330:
    !tmp_1063
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_1062)
    tmp_1064 = load entity+0 as i32
    tmp_1065 = add total, tmp_1064
    !tmp_1064
    !total
    total = tmp_1065
L_LOOP_CONTINUE_331:
    tmp_1066 = add tmp_1062, 1
    store entity_slot+0, tmp_1066 as i64
    !tmp_1066
    !tmp_1062
    !entity
    jmp L_LOOP_HEAD_329

L_LOOP_COND_FALSE_332:
    !tmp_1063
    !tmp_1062
    jmp L_LOOP_EXIT_333

L_LOOP_EXIT_333:
    !tmp_1061
    tmp_1067 = load e1+0 as i32
    tmp_1068 = load e2+0 as i32
    tmp_1069 = add tmp_1067, tmp_1068
    !tmp_1067
    !tmp_1068
    tmp_1070 = ne total, tmp_1069
    !tmp_1069
    br tmp_1070 -> L_THEN_334, L_ELSE_335

L_THEN_334:
    !tmp_1070
    panic(8730)

L_ELSE_335:
    !tmp_1070
    jmp L_MERGE_336

L_MERGE_336:
    !component
    !w0
    !e2
    !w4
    !total
    !w5
    !e1
    !w1
    !w2
    !w3
    !q
    return

