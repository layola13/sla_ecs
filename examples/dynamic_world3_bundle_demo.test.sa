    tmp_1837 = call @sla__dyn_store_new_DynPoint()
    s = tmp_1837
    tmp_1838 = 0
    i = tmp_1838
    jmp L_WHILE_HEAD_482

L_WHILE_HEAD_482:
    tmp_1839 = 20
    tmp_1840 = slt i, tmp_1839
    !tmp_1839
    br tmp_1840 -> L_WHILE_BODY_483, L_WHILE_COND_FALSE_484

L_WHILE_BODY_483:
    !tmp_1840
    tmp_1841 = 1
    tmp_1842 = add i, tmp_1841
    !tmp_1841
    tmp_1843 = call @sla__dyn_point(i, tmp_1842)
    !tmp_1842
    tmp_1844 = call @sla__dyn_store_insert_DynPoint(s, i, tmp_1843)
    !tmp_1843
    !s
    s = tmp_1844
    tmp_1845 = 1
    tmp_1846 = add i, tmp_1845
    !tmp_1845
    !i
    i = tmp_1846
    jmp L_WHILE_HEAD_482

L_WHILE_COND_FALSE_484:
    !tmp_1840
    jmp L_WHILE_EXIT_485

L_WHILE_EXIT_485:
    tmp_1847 = call @sla__dyn_store_count_DynPoint(s)
    tmp_1848 = 20
    tmp_1849 = ne tmp_1847, tmp_1848
    !tmp_1847
    !tmp_1848
    br tmp_1849 -> L_THEN_486, L_ELSE_487

L_THEN_486:
    !tmp_1849
    panic(4210)

L_ELSE_487:
    !tmp_1849
    jmp L_MERGE_488

L_MERGE_488:
    tmp_1852 = 19
    tmp_1853 = call @sla__dyn_store_get_DynPoint(s, tmp_1852)
    !tmp_1852
    p = tmp_1853
    tmp_1854 = load p+0 as i32
    tmp_1855 = 19
    tmp_1856 = ne tmp_1854, tmp_1855
    !tmp_1854
    !tmp_1855
    br tmp_1856 -> L_THEN_489, L_ELSE_490

L_THEN_489:
    !tmp_1856
    panic(4211)

L_ELSE_490:
    !tmp_1856
    jmp L_MERGE_491

L_MERGE_491:
    tmp_1859 = load p+4 as i32
    tmp_1860 = 20
    tmp_1861 = ne tmp_1859, tmp_1860
    !tmp_1859
    !tmp_1860
    br tmp_1861 -> L_THEN_492, L_ELSE_493

L_THEN_492:
    !tmp_1861
    panic(4212)

L_ELSE_493:
    !tmp_1861
    jmp L_MERGE_494

L_MERGE_494:
    !s
    !i
    !p
    return

