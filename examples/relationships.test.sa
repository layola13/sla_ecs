    store tmp_2764+4, tmp_2766 as i32
    tmp_2767 = call @sla__relationship_world_spawn_related(w3, tmp_2763, tmp_2764)
    !tmp_2763
    !tmp_2764
    w4 = load tmp_2767+0 as ptr
    grandchild = load tmp_2767+8 as ptr
    !tmp_2767
    tmp_2768 = alloc 8
    tmp_2769 = load root+0 as i32
    store tmp_2768+0, tmp_2769 as i32
    tmp_2770 = load root+4 as i32
    store tmp_2768+4, tmp_2770 as i32
    tmp_2771 = call @sla__relationship_world_despawn(w4, tmp_2768)
