@test "relationship linked despawn follows target collection"():
L_TEST_ENTRY_709:
    tmp_2753 = call @sla__relationship_world_new()
    w0 = tmp_2753
    tmp_2754 = 1
    tmp_2755 = 0
    tmp_2756 = call @sla__relationship_world_register_many(w0, tmp_2754, tmp_2755)
    !tmp_2754
    !tmp_2755
    w1 = load tmp_2756+0 as ptr
    linked = load tmp_2756+8 as ptr
    !tmp_2756
    tmp_2757 = call @sla__relationship_world_spawn(w1)
    w2 = load tmp_2757+0 as ptr
    root = load tmp_2757+8 as ptr
    !tmp_2757
    tmp_2758 = load linked+0 as i32
    tmp_2759 = alloc 8
    tmp_2760 = load root+0 as i32
    store tmp_2759+0, tmp_2760 as i32
    tmp_2761 = load root+4 as i32
    store tmp_2759+4, tmp_2761 as i32
    tmp_2762 = call @sla__relationship_world_spawn_related(w2, tmp_2758, tmp_2759)
    !tmp_2758
    !tmp_2759
    w3 = load tmp_2762+0 as ptr
    child = load tmp_2762+8 as ptr
    !tmp_2762
    tmp_2763 = load linked+0 as i32
    tmp_2764 = alloc 8
    tmp_2765 = load child+0 as i32
    store tmp_2764+0, tmp_2765 as i32
