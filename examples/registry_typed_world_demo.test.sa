    tmp_3588 = call @sla__reg_typed_world_new()
    w0 = tmp_3588
    tmp_3589 = call @sla__registry_typed_world_spawn_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w0)
    w1 = load tmp_3589+0 as ptr
    e1 = load tmp_3589+8 as ptr
    !tmp_3589
    tmp_3590 = alloc 8
    tmp_3591 = 3
    store tmp_3590+0, tmp_3591 as i32
    !tmp_3591
    tmp_3592 = 0
    store tmp_3590+4, tmp_3592 as i32
    !tmp_3592
    tmp_3593 = call @sla__registry_typed_world_insert_a_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w1, e1, tmp_3590)
    !tmp_3590
    w2 = tmp_3593
    tmp_3594 = alloc 8
    tmp_3595 = 5
    store tmp_3594+0, tmp_3595 as i32
    !tmp_3595
    tmp_3596 = 0
    store tmp_3594+4, tmp_3596 as i32
    !tmp_3596
    tmp_3597 = call @sla__registry_typed_world_insert_b_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w2, e1, tmp_3594)
    !tmp_3594
    w3 = tmp_3597
    tmp_3598 = load w3+0 as ptr
    tmp_3599 = load tmp_3598+24 as i32
    !tmp_3598
    before = tmp_3599
    tmp_3600 = call @sla__registry_typed_world_increment_tick_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w3)
    w4 = tmp_3600
    tmp_3601 = call @sla__registry_typed_world_query_mut_a_b_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w4)
    q = tmp_3601
    tmp_3602 = load q+0 as ptr
    EXPAND VEC_LEN tmp_3603, tmp_3602
    !tmp_3602
    tmp_3604 = 1
    tmp_3605 = ne tmp_3603, tmp_3604
    !tmp_3603
    !tmp_3604
    br tmp_3605 -> L_THEN_1078, L_ELSE_1079

L_THEN_1078:
    !tmp_3605
    panic(8920)

L_ELSE_1079:
    !tmp_3605
    jmp L_MERGE_1080

L_MERGE_1080:
    tmp_3608 = load q+0 as ptr
    tmp_3609 = 0
    EXPAND VEC_GET tmp_3610, tmp_3608, tmp_3609
    !tmp_3609
    !tmp_3608
    tmp_3611 = tmp_3610 as ptr
    pair = tmp_3611
    moved = alloc 8
    tmp_3612 = load pair+0 as ptr
    tmp_3613 = load tmp_3612+16 as ptr
    !tmp_3612
    tmp_3614 = load tmp_3613+0 as i32
    !tmp_3613
    tmp_3615 = load pair+8 as ptr
    tmp_3616 = load tmp_3615+0 as i32
    !tmp_3615
    tmp_3617 = add tmp_3614, tmp_3616
    !tmp_3614
    !tmp_3616
    store moved+0, tmp_3617 as i32
    !tmp_3617
    tmp_3618 = 0
    store moved+4, tmp_3618 as i32
    !tmp_3618
    tmp_3619 = call @sla__registry_typed_world_query_pair_mut_a_write_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w4, pair, moved)
    w5 = tmp_3619
    tmp_3620 = call @sla__registry_typed_world_get_a_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w5, e1)
    out = tmp_3620
    tmp_3621 = load out+0 as i32
    tmp_3622 = 8
    tmp_3623 = ne tmp_3621, tmp_3622
    !tmp_3621
    !tmp_3622
    br tmp_3623 -> L_THEN_1081, L_ELSE_1082

L_THEN_1081:
    !tmp_3623
    panic(8921)

L_ELSE_1082:
    !tmp_3623
    jmp L_MERGE_1083

L_MERGE_1083:
    tmp_3626 = call @sla__registry_typed_world_a_added_since_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w5, e1, before)
    tmp_3627 = 0
    tmp_3628 = ne tmp_3626, tmp_3627
    !tmp_3626
    !tmp_3627
    br tmp_3628 -> L_THEN_1084, L_ELSE_1085

L_THEN_1084:
    !tmp_3628
    panic(8922)

L_ELSE_1085:
    !tmp_3628
    jmp L_MERGE_1086

L_MERGE_1086:
    tmp_3631 = call @sla__registry_typed_world_a_changed_since_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w5, e1, before)
    tmp_3632 = 1
    tmp_3633 = ne tmp_3631, tmp_3632
    !tmp_3631
    !tmp_3632
    br tmp_3633 -> L_THEN_1087, L_ELSE_1088

L_THEN_1087:
    !tmp_3633
    panic(8923)

L_ELSE_1088:
    !tmp_3633
    jmp L_MERGE_1089

L_MERGE_1089:
    !moved
    !out
    !w0
    !pair
    !w4
    !w5
    !before
    !e1
    !w1
    !w2
    !w3
    !q
    return

@test "registry typed world despawn removes registry and values"():
L_TEST_ENTRY_1090:
    tmp_3636 = call @sla__reg_typed_world_new()
    w0 = tmp_3636
    tmp_3637 = call @sla__registry_typed_world_spawn_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w0)
    w1 = load tmp_3637+0 as ptr
    e1 = load tmp_3637+8 as ptr
    !tmp_3637
    tmp_3638 = alloc 8
    tmp_3639 = 9
    store tmp_3638+0, tmp_3639 as i32
    !tmp_3639
    tmp_3640 = 0
    store tmp_3638+4, tmp_3640 as i32
    !tmp_3640
    tmp_3641 = call @sla__registry_typed_world_insert_a_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w1, e1, tmp_3638)
    !tmp_3638
    w2 = tmp_3641
    tmp_3642 = alloc 8
    tmp_3643 = 1
    store tmp_3642+0, tmp_3643 as i32
    !tmp_3643
    tmp_3644 = 0
    store tmp_3642+4, tmp_3644 as i32
    !tmp_3644
    tmp_3645 = call @sla__registry_typed_world_insert_b_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w2, e1, tmp_3642)
    !tmp_3642
    w3 = tmp_3645
    tmp_3646 = call @sla__registry_typed_world_despawn_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w3, e1)
    w4 = tmp_3646
    tmp_3647 = call @sla__registry_typed_world_is_alive_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w4, e1)
    tmp_3648 = 0
    tmp_3649 = ne tmp_3647, tmp_3648
    !tmp_3647
    !tmp_3648
    br tmp_3649 -> L_THEN_1091, L_ELSE_1092

L_THEN_1091:
    !tmp_3649
    panic(8930)

L_ELSE_1092:
    !tmp_3649
    jmp L_MERGE_1093

L_MERGE_1093:
    tmp_3652 = call @sla__registry_typed_world_has_a_RegTypedPos_RegTypedVel_RegTypedTime_RegTypedEvent(w4, e1)
    tmp_3653 = 0
    tmp_3654 = ne tmp_3652, tmp_3653
    !tmp_3652
    !tmp_3653
    br tmp_3654 -> L_THEN_1094, L_ELSE_1095

L_THEN_1094:
    !tmp_3654
    panic(8931)

L_ELSE_1095:
    !tmp_3654
    jmp L_MERGE_1096

L_MERGE_1096:
    tmp_3657 = load w4+24 as ptr
    tmp_3658 = load e1+0 as i32
    tmp_3659 = call @sla__dyn_store_has_RegTypedPos(tmp_3657, tmp_3658)
    !tmp_3657
    !tmp_3658
    tmp_3660 = 0
    tmp_3661 = ne tmp_3659, tmp_3660
    !tmp_3659
    !tmp_3660
    br tmp_3661 -> L_THEN_1097, L_ELSE_1098

L_THEN_1097:
    !tmp_3661
    panic(8932)

L_ELSE_1098:
    !tmp_3661
    jmp L_MERGE_1099

L_MERGE_1099:
    !w0
    !e1
    !w1
    !w2
    !w3
    !w4
    return

