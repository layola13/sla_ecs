@test "relationship linked despawn follows target collection"():
L_TEST_ENTRY_3101:
    tmp_11289 = call @sla__relationship_world_new()
    w0 = tmp_11289
    tmp_11290 = 1
    tmp_11291 = 0
    tmp_11292 = call @sla__relationship_world_register_many(w0, tmp_11290, tmp_11291)
    !tmp_11290
    !tmp_11291
    w1 = load tmp_11292+0 as ptr
    linked = load tmp_11292+8 as ptr
    !tmp_11292
    tmp_11293 = call @sla__relationship_world_spawn(w1)
    w2 = load tmp_11293+0 as ptr
    root = load tmp_11293+8 as ptr
    !tmp_11293
    tmp_11294 = load linked+0 as i32
    tmp_11295 = call @sla__relationship_world_spawn_related(w2, tmp_11294, root)
    !tmp_11294
    w3 = load tmp_11295+0 as ptr
    child = load tmp_11295+8 as ptr
    !tmp_11295
    tmp_11296 = load linked+0 as i32
    tmp_11297 = call @sla__relationship_world_spawn_related(w3, tmp_11296, child)
    !tmp_11296
    w4 = load tmp_11297+0 as ptr
    grandchild = load tmp_11297+8 as ptr
    !tmp_11297
    tmp_11298 = call @sla__relationship_world_despawn(w4, root)
    w5 = tmp_11298
    tmp_11299 = call @sla__relationship_world_is_alive(w5, root)
    tmp_11300 = 0
    tmp_11301 = ne tmp_11299, tmp_11300
    !tmp_11299
    !tmp_11300
    br tmp_11301 -> L_THEN_3102, L_ELSE_3103

L_THEN_3102:
