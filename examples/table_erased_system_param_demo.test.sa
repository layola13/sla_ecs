    !tmp_10515
    jmp L_LOOP_EXIT_2722

L_LOOP_EXIT_2722:
    !tmp_10514
    tmp_10520 = load e1+0 as i32
    tmp_10521 = load e2+0 as i32
    tmp_10522 = add tmp_10520, tmp_10521
    !tmp_10520
    !tmp_10521
    tmp_10523 = ne total, tmp_10522
    !tmp_10522
    br tmp_10523 -> L_THEN_2723, L_ELSE_2724

L_THEN_2723:
