    !tmp_10007
    jmp L_LOOP_EXIT_2563

L_LOOP_EXIT_2563:
    !tmp_10006
    tmp_10012 = load e1+0 as i32
    tmp_10013 = load e2+0 as i32
    tmp_10014 = add tmp_10012, tmp_10013
    !tmp_10012
    !tmp_10013
    tmp_10015 = ne total, tmp_10014
    !tmp_10014
