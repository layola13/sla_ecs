    !tmp_10509
    w5 = tmp_10510
    tmp_10511 = load component+0 as i32
    tmp_10512 = call @sla__registry_world_query_component(w5, tmp_10511)
    !tmp_10511
    q = tmp_10512
    tmp_10513 = 0
    total = tmp_10513
    tmp_10514 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_2718

L_LOOP_HEAD_2718:
    tmp_10515 = load entity_slot+0 as i64
    tmp_10516 = slt tmp_10515, tmp_10514
    br tmp_10516 -> L_LOOP_BODY_2719, L_LOOP_COND_FALSE_2721

L_LOOP_BODY_2719:
    !tmp_10516
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_10515)
    tmp_10517 = load entity+0 as i32
    tmp_10518 = add total, tmp_10517
    !tmp_10517
    !total
    total = tmp_10518
L_LOOP_CONTINUE_2720:
    tmp_10519 = add tmp_10515, 1
    store entity_slot+0, tmp_10519 as i64
    !tmp_10519
    !tmp_10515
    !entity
    jmp L_LOOP_HEAD_2718

L_LOOP_COND_FALSE_2721:
