L_LOOP_HEAD_2115:
    tmp_8407 = load entity_slot+0 as i64
    tmp_8408 = slt tmp_8407, tmp_8406
    br tmp_8408 -> L_LOOP_BODY_2116, L_LOOP_COND_FALSE_2118

L_LOOP_BODY_2116:
