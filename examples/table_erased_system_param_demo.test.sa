    tmp_10004 = call @sla__registry_world_query_component(w5, tmp_10003)
    !tmp_10003
    q = tmp_10004
    tmp_10005 = 0
    total = tmp_10005
    tmp_10006 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_2559

L_LOOP_HEAD_2559:
    tmp_10007 = load entity_slot+0 as i64
    tmp_10008 = slt tmp_10007, tmp_10006
    br tmp_10008 -> L_LOOP_BODY_2560, L_LOOP_COND_FALSE_2562

L_LOOP_BODY_2560:
    !tmp_10008
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_10007)
    tmp_10009 = load entity+0 as i32
    tmp_10010 = add total, tmp_10009
    !tmp_10009
    !total
    total = tmp_10010
L_LOOP_CONTINUE_2561:
