@test "allocator rejects stale generation"():
L_TEST_ENTRY_104:
    tmp_464 = call @sla__allocator_new()
    a0 = tmp_464
    tmp_465 = call @sla__alloc_entity(a0)
    a1 = load tmp_465+0 as ptr
    e1 = load tmp_465+8 as ptr
    !tmp_465
    tmp_466 = alloc 8
    tmp_467 = load e1+0 as i32
    store tmp_466+0, tmp_467 as i32
    tmp_468 = load e1+4 as i32
    store tmp_466+4, tmp_468 as i32
    tmp_469 = call @sla__free_entity(a1, tmp_466)
    !tmp_466
    a2 = tmp_469
    tmp_470 = load e1+0 as i32
    tmp_471 = load e1+4 as i32
    tmp_472 = call @sla__entity_new(tmp_470, tmp_471)
    !tmp_470
    !tmp_471
    stale = tmp_472
    tmp_473 = load e1+0 as i32
    tmp_474 = load e1+4 as i32
    tmp_475 = 1
    tmp_476 = add tmp_474, tmp_475
    !tmp_474
    !tmp_475
    tmp_477 = call @sla__entity_new(tmp_473, tmp_476)
    !tmp_473
    !tmp_476
    fabricated = tmp_477
    tmp_478 = alloc 8
    tmp_479 = load stale+0 as i32
    store tmp_478+0, tmp_479 as i32
    tmp_480 = load stale+4 as i32
    store tmp_478+4, tmp_480 as i32
    tmp_481 = call @sla__is_alive(a2, tmp_478)
    !tmp_478
    tmp_482 = 0
    tmp_483 = ne tmp_481, tmp_482
    !tmp_481
    !tmp_482
    br tmp_483 -> L_THEN_105, L_ELSE_106

L_THEN_105:
    !tmp_483
    panic(2120)

L_ELSE_106:
    !tmp_483
    jmp L_MERGE_107

L_MERGE_107:
    tmp_486 = alloc 8
    tmp_487 = load fabricated+0 as i32
    store tmp_486+0, tmp_487 as i32
    tmp_488 = load fabricated+4 as i32
    store tmp_486+4, tmp_488 as i32
    tmp_489 = call @sla__is_alive(a2, tmp_486)
    !tmp_486
    tmp_490 = 0
    tmp_491 = ne tmp_489, tmp_490
    !tmp_489
    !tmp_490
    br tmp_491 -> L_THEN_108, L_ELSE_109

L_THEN_108:
    !tmp_491
    panic(2121)

L_ELSE_109:
    !tmp_491
    jmp L_MERGE_110

L_MERGE_110:
    tmp_494 = call @sla__alloc_entity(a2)
    a3 = load tmp_494+0 as ptr
    e2 = load tmp_494+8 as ptr
    !tmp_494
    tmp_495 = alloc 8
    tmp_496 = load e2+0 as i32
    store tmp_495+0, tmp_496 as i32
    tmp_497 = load e2+4 as i32
    store tmp_495+4, tmp_497 as i32
    tmp_498 = alloc 8
    tmp_499 = load fabricated+0 as i32
    store tmp_498+0, tmp_499 as i32
    tmp_500 = load fabricated+4 as i32
    store tmp_498+4, tmp_500 as i32
    tmp_501 = call @sla__entity_eq(tmp_495, tmp_498)
    !tmp_495
    !tmp_498
    tmp_502 = 1
    tmp_503 = ne tmp_501, tmp_502
    !tmp_501
    !tmp_502
    br tmp_503 -> L_THEN_111, L_ELSE_112

L_THEN_111:
    !tmp_503
    panic(2122)

L_ELSE_112:
    !tmp_503
    jmp L_MERGE_113

L_MERGE_113:
    tmp_506 = alloc 8
    tmp_507 = load e2+0 as i32
    store tmp_506+0, tmp_507 as i32
    tmp_508 = load e2+4 as i32
    store tmp_506+4, tmp_508 as i32
    tmp_509 = call @sla__is_alive(a3, tmp_506)
    !tmp_506
