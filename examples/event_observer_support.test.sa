    !tmp_548
    observers1 = tmp_549
    tmp_550 = alloc 16
    store tmp_550+0, 0 as ptr
    store tmp_550+8, &SLA_FNPTR_VT_erased_explode_observer as ptr
    tmp_551 = call @sla__erased_observer_new(explode_type, tmp_550)
