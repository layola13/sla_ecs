@test "entity derives value semantics"():
L_TEST_ENTRY_1128:
    tmp_4631 = 42
    tmp_4632 = 7
    tmp_4633 = call @sla__entity_new(tmp_4631, tmp_4632)
    !tmp_4631
    !tmp_4632
    e = tmp_4633
    copied = alloc 8
    tmp_4634 = load e+0 as i32
    store copied+0, tmp_4634 as i32
    tmp_4635 = load e+4 as i32
    store copied+4, tmp_4635 as i32
    tmp_4636 = load copied+0 as i32
    tmp_4637 = load e+0 as i32
    tmp_4638 = eq tmp_4636, tmp_4637
    tmp_4639 = load copied+4 as i32
    tmp_4640 = load e+4 as i32
    tmp_4641 = eq tmp_4639, tmp_4640
    tmp_4642 = and tmp_4638, tmp_4641
    tmp_4643 = ne tmp_4642, 1
