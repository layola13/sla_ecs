    w2 = load tmp_4323+0 as ptr
    e1 = load tmp_4323+8 as ptr
    !tmp_4323
    tmp_4324 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_4324+0 as ptr
    e2 = load tmp_4324+8 as ptr
    !tmp_4324
    tmp_4325 = load component+0 as i32
    tmp_4326 = call @sla__registry_world_insert_component(w3, e1, tmp_4325)
    !tmp_4325
    w4 = tmp_4326
    tmp_4327 = load component+0 as i32
    tmp_4328 = call @sla__registry_world_insert_component(w4, e2, tmp_4327)
    !tmp_4327
    w5 = tmp_4328
    tmp_4329 = load component+0 as i32
    tmp_4330 = call @sla__registry_world_query_component(w5, tmp_4329)
    !tmp_4329
    q = tmp_4330
    tmp_4331 = 0
    total = tmp_4331
    tmp_4332 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1197

L_LOOP_HEAD_1197:
    tmp_4333 = load entity_slot+0 as i64
    tmp_4334 = slt tmp_4333, tmp_4332
    br tmp_4334 -> L_LOOP_BODY_1198, L_LOOP_COND_FALSE_1200

L_LOOP_BODY_1198:
    !tmp_4334
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_4333)
    tmp_4335 = load entity+0 as i32
    tmp_4336 = add total, tmp_4335
    !tmp_4335
    !total
    total = tmp_4336
L_LOOP_CONTINUE_1199:
    tmp_4337 = add tmp_4333, 1
    store entity_slot+0, tmp_4337 as i64
    !tmp_4337
    !tmp_4333
    !entity
    jmp L_LOOP_HEAD_1197

L_LOOP_COND_FALSE_1200:
    !tmp_4334
    !tmp_4333
    jmp L_LOOP_EXIT_1201

L_LOOP_EXIT_1201:
    !tmp_4332
    tmp_4338 = load e1+0 as i32
    tmp_4339 = load e2+0 as i32
    tmp_4340 = add tmp_4338, tmp_4339
    !tmp_4338
    !tmp_4339
    tmp_4341 = ne total, tmp_4340
    !tmp_4340
    br tmp_4341 -> L_THEN_1202, L_ELSE_1203

L_THEN_1202:
    !tmp_4341
    panic(8730)

L_ELSE_1203:
    !tmp_4341
    jmp L_MERGE_1204

L_MERGE_1204:
