    !tmp_3732
    @const SLA_STR_6 = utf8:": "
    tmp_3734 = &SLA_STR_6
    EXPAND FORMAT_PUSH_BYTES tmp_3735, tmp_3719, tmp_3734, 2
    !tmp_3734
    tmp_3736 = load e+4 as i32
    EXPAND FORMAT_PUSH_I64 tmp_3737, tmp_3719, tmp_3736
    @const SLA_STR_7 = utf8:" }"
    tmp_3738 = &SLA_STR_7
    EXPAND FORMAT_PUSH_BYTES tmp_3739, tmp_3719, tmp_3738, 2
    !tmp_3738
    text = tmp_3719
    EXPAND STRING_BUF_AS_STR tmp_3740, text
    EXPAND STRING_LEN tmp_3741, tmp_3740
    !tmp_3740
    tmp_3742 = 0
    tmp_3743 = eq tmp_3741, tmp_3742
