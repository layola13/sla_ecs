    tmp_3688 = load later+0 as i32
    tmp_3689 = slt tmp_3687, tmp_3688
    tmp_3690 = eq tmp_3687, tmp_3688
    tmp_3691 = load e+4 as i32
    tmp_3692 = load later+4 as i32
