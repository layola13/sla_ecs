    tmp_3694 = eq tmp_3691, tmp_3692
    tmp_3695 = and tmp_3690, tmp_3693
    tmp_3696 = or tmp_3689, tmp_3695
    tmp_3697 = and tmp_3690, tmp_3694
    tmp_3698 = or tmp_3696, 0
    tmp_3699 = 1
