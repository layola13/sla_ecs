    !tmp_3724
    @const SLA_STR_3 = utf8:": "
    tmp_3726 = &SLA_STR_3
    EXPAND FORMAT_PUSH_BYTES tmp_3727, tmp_3719, tmp_3726, 2
    !tmp_3726
    tmp_3728 = load e+0 as i32
    EXPAND FORMAT_PUSH_I64 tmp_3729, tmp_3719, tmp_3728
    @const SLA_STR_4 = utf8:", "
    tmp_3730 = &SLA_STR_4
    EXPAND FORMAT_PUSH_BYTES tmp_3731, tmp_3719, tmp_3730, 2
    !tmp_3730
    @const SLA_STR_5 = utf8:"gen"
    tmp_3732 = &SLA_STR_5
