    tmp_3709 = sgt tmp_3707, tmp_3708
    tmp_3710 = eq tmp_3707, tmp_3708
    tmp_3711 = and tmp_3706, tmp_3709
    tmp_3712 = or tmp_3705, tmp_3711
    tmp_3713 = and tmp_3706, tmp_3710
    tmp_3714 = or tmp_3712, 0
