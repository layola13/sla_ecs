    tmp_2413 = load out+4 as i32
    store tmp_2411+4, tmp_2413 as i32
    tmp_2414 = call @sla__entity_eq(tmp_2408, tmp_2411)
    !tmp_2408
    !tmp_2411
    tmp_2415 = 1
    tmp_2416 = ne tmp_2414, tmp_2415
