    !tmp_4772
    tmp_4773 = call @sla__registry_world_spawn(w1)
    w2 = load tmp_4773+0 as ptr
    e1 = load tmp_4773+8 as ptr
    !tmp_4773
    tmp_4774 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_4774+0 as ptr
    e2 = load tmp_4774+8 as ptr
    !tmp_4774
    tmp_4775 = load component+0 as i32
    tmp_4776 = call @sla__registry_world_insert_component(w3, e1, tmp_4775)
    !tmp_4775
    w4 = tmp_4776
    tmp_4777 = load component+0 as i32
    tmp_4778 = call @sla__registry_world_insert_component(w4, e2, tmp_4777)
    !tmp_4777
    w5 = tmp_4778
    tmp_4779 = load component+0 as i32
    tmp_4780 = call @sla__registry_world_query_component(w5, tmp_4779)
    !tmp_4779
    q = tmp_4780
    tmp_4781 = 0
    total = tmp_4781
    tmp_4782 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1281

L_LOOP_HEAD_1281:
    tmp_4783 = load entity_slot+0 as i64
    tmp_4784 = slt tmp_4783, tmp_4782
    br tmp_4784 -> L_LOOP_BODY_1282, L_LOOP_COND_FALSE_1284

L_LOOP_BODY_1282:
    !tmp_4784
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_4783)
    tmp_4785 = load entity+0 as i32
    tmp_4786 = add total, tmp_4785
    !tmp_4785
    !total
    total = tmp_4786
L_LOOP_CONTINUE_1283:
    tmp_4787 = add tmp_4783, 1
    store entity_slot+0, tmp_4787 as i64
    !tmp_4787
    !tmp_4783
    !entity
    jmp L_LOOP_HEAD_1281

L_LOOP_COND_FALSE_1284:
    !tmp_4784
    !tmp_4783
    jmp L_LOOP_EXIT_1285

L_LOOP_EXIT_1285:
    !tmp_4782
    tmp_4788 = load e1+0 as i32
    tmp_4789 = load e2+0 as i32
    tmp_4790 = add tmp_4788, tmp_4789
    !tmp_4788
    !tmp_4789
    tmp_4791 = ne total, tmp_4790
    !tmp_4790
    br tmp_4791 -> L_THEN_1286, L_ELSE_1287

L_THEN_1286:
    !tmp_4791
    panic(8730)

L_ELSE_1287:
    !tmp_4791
    jmp L_MERGE_1288

L_MERGE_1288:
    !component
    !w0
    !e2
    !w4
    !total
    !w5
    !e1
    !w1
    !w2
    !w3
    !q
    return

