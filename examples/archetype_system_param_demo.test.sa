    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1408

L_LOOP_HEAD_1408:
    tmp_5406 = load entity_slot+0 as i64
    tmp_5407 = slt tmp_5406, tmp_5405
    br tmp_5407 -> L_LOOP_BODY_1409, L_LOOP_COND_FALSE_1411

