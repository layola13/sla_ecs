@test "registry entity query supports for in"():
L_TEST_ENTRY_1280:
    entity_slot = stack_alloc 8
    tmp_4771 = call @sla__registry_world_new()
    w0 = tmp_4771
    tmp_4772 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_4772+0 as ptr
