    tmp_4332 = load e1+4 as i32
    tmp_4333 = call @sla__entity_new(tmp_4331, tmp_4332)
    !tmp_4331
    !tmp_4332
    stale = tmp_4333
    tmp_4334 = load e1+0 as i32
    tmp_4335 = load e1+4 as i32
    tmp_4336 = 1
    tmp_4337 = add tmp_4335, tmp_4336
