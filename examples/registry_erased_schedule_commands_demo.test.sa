@test "allocator rejects stale generation"():
L_TEST_ENTRY_1150:
    tmp_4328 = call @sla__allocator_new()
    a0 = tmp_4328
    tmp_4329 = call @sla__alloc_entity(a0)
    a1 = load tmp_4329+0 as ptr
    e1 = load tmp_4329+8 as ptr
    !tmp_4329
    tmp_4330 = call @sla__free_entity(a1, e1)
    a2 = tmp_4330
