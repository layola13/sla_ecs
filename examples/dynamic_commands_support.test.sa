    tmp_2059 = alloc 8
    tmp_2060 = load out+0 as i32
    store tmp_2059+0, tmp_2060 as i32
    tmp_2061 = load out+4 as i32
    store tmp_2059+4, tmp_2061 as i32
    tmp_2062 = call @sla__entity_eq(tmp_2056, tmp_2059)
    !tmp_2056
