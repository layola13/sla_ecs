@test "entity bit roundtrip"():
L_TEST_ENTRY_517:
    tmp_2048 = 42
    tmp_2049 = 7
    tmp_2050 = call @sla__entity_new(tmp_2048, tmp_2049)
    !tmp_2048
    !tmp_2049
    e = tmp_2050
    tmp_2051 = alloc 8
    tmp_2052 = load e+0 as i32
    store tmp_2051+0, tmp_2052 as i32
    tmp_2053 = load e+4 as i32
