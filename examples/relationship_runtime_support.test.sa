    !tmp_1847
    !tmp_1850
    fabricated = tmp_1851
    tmp_1852 = alloc 8
    tmp_1853 = load stale+0 as i32
    store tmp_1852+0, tmp_1853 as i32
    tmp_1854 = load stale+4 as i32
    store tmp_1852+4, tmp_1854 as i32
