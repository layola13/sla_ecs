    w3 = load tmp_3526+0 as ptr
    e2 = load tmp_3526+8 as ptr
    !tmp_3526
    tmp_3527 = load component+0 as i32
    tmp_3528 = call @sla__registry_world_insert_component(w3, e1, tmp_3527)
    !tmp_3527
    w4 = tmp_3528
