    tmp_3500 = call @sla__registry_world_query_component(w5, tmp_3499)
    !tmp_3499
    q = tmp_3500
    tmp_3501 = 0
    total = tmp_3501
    tmp_3502 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_971

L_LOOP_HEAD_971:
    tmp_3503 = load entity_slot+0 as i64
    tmp_3504 = slt tmp_3503, tmp_3502
    br tmp_3504 -> L_LOOP_BODY_972, L_LOOP_COND_FALSE_974

L_LOOP_BODY_972:
