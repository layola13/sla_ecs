    !tmp_3535
    jmp L_LOOP_EXIT_986

L_LOOP_EXIT_986:
    !tmp_3534
    tmp_3540 = load e1+0 as i32
    tmp_3541 = load e2+0 as i32
    tmp_3542 = add tmp_3540, tmp_3541
    !tmp_3540
    !tmp_3541
    tmp_3543 = ne total, tmp_3542
    !tmp_3542
