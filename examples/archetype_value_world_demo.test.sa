    tmp_3530 = call @sla__registry_world_insert_component(w4, e2, tmp_3529)
    !tmp_3529
    w5 = tmp_3530
    tmp_3531 = load component+0 as i32
    tmp_3532 = call @sla__registry_world_query_component(w5, tmp_3531)
    !tmp_3531
    q = tmp_3532
    tmp_3533 = 0
    total = tmp_3533
    tmp_3534 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_982

L_LOOP_HEAD_982:
    tmp_3535 = load entity_slot+0 as i64
    tmp_3536 = slt tmp_3535, tmp_3534
    br tmp_3536 -> L_LOOP_BODY_983, L_LOOP_COND_FALSE_985

L_LOOP_BODY_983:
    !tmp_3536
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_3535)
    tmp_3537 = load entity+0 as i32
    tmp_3538 = add total, tmp_3537
    !tmp_3537
    !total
    total = tmp_3538
L_LOOP_CONTINUE_984:
