@sla__dyn_allocator_new() -> ptr:
L_ENTRY:
    EXPAND VEC_NEW tmp_135
    free_ids = tmp_135
    EXPAND VEC_NEW tmp_136
    generations = tmp_136
    EXPAND VEC_NEW tmp_137
    occupied = tmp_137
    tmp_138 = 0
    EXPAND VEC_PUSH generations, tmp_138, 8
    !tmp_138
    tmp_139 = 0
    EXPAND VEC_PUSH occupied, tmp_139, 8
    !tmp_139
    tmp_140 = alloc 24
    store tmp_140+0, free_ids as ptr
    store tmp_140+8, generations as ptr
    store tmp_140+16, occupied as ptr
    return tmp_140

@sla__dyn_alloc_entity(a: ptr) -> ptr:
L_ENTRY:
    tmp_141 = load a+0 as ptr
    EXPAND VEC_LEN tmp_142, tmp_141
    !tmp_141
    tmp_143 = tmp_142 as i64
    free_len = tmp_143
    tmp_144 = 0
    tmp_145 = sgt free_len, tmp_144
    !tmp_144
    br tmp_145 -> L_THEN_31, L_ELSE_32

L_THEN_31:
    !tmp_145
    tmp_146 = 1
    tmp_147 = sub free_len, tmp_146
