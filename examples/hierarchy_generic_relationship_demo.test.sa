    !tmp_116
    !tmp_126
    tmp_127 = load a+16 as ptr
    tmp_128 = load a+4 as i32
    tmp_129 = mul tmp_128, 4
    tmp_130 = ptr_add tmp_127, tmp_129
    !tmp_129
    !tmp_128
    tmp_131 = load entity+0 as i32
    store tmp_130+0, tmp_131 as i32
    !tmp_130
    !tmp_127
    !tmp_131
    tmp_132 = load a+4 as i32
    tmp_133 = 1
    tmp_134 = add tmp_132, tmp_133
    !tmp_132
