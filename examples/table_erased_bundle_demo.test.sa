    tmp_5492 = call @sla__registry_world_query_component(w5, tmp_5491)
    !tmp_5491
    q = tmp_5492
    tmp_5493 = 0
    total = tmp_5493
    tmp_5494 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1476

L_LOOP_HEAD_1476:
    tmp_5495 = load entity_slot+0 as i64
    tmp_5496 = slt tmp_5495, tmp_5494
    br tmp_5496 -> L_LOOP_BODY_1477, L_LOOP_COND_FALSE_1479

L_LOOP_BODY_1477:
