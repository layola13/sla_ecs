    tmp_5500 = load e1+0 as i32
    tmp_5501 = load e2+0 as i32
    tmp_5502 = add tmp_5500, tmp_5501
    !tmp_5500
    !tmp_5501
    tmp_5503 = ne total, tmp_5502
    !tmp_5502
