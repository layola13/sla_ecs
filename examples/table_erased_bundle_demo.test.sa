    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_5495)
    tmp_5497 = load entity+0 as i32
    tmp_5498 = add total, tmp_5497
    !tmp_5497
    !total
    total = tmp_5498
L_LOOP_CONTINUE_1478:
