L_LOOP_HEAD_1476:
    tmp_5489 = load entity_slot+0 as i64
    tmp_5490 = slt tmp_5489, tmp_5488
    br tmp_5490 -> L_LOOP_BODY_1477, L_LOOP_COND_FALSE_1479

