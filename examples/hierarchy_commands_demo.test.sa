@test "relationship commands defer add insert remove replace"():
L_TEST_ENTRY_845:
    tmp_2784 = call @sla__relationship_world_new()
    w0 = tmp_2784
    tmp_2785 = 0
    tmp_2786 = 0
    tmp_2787 = call @sla__relationship_world_register_many(w0, tmp_2785, tmp_2786)
    !tmp_2785
    !tmp_2786
    w1 = load tmp_2787+0 as ptr
    kind = load tmp_2787+8 as ptr
    !tmp_2787
    tmp_2788 = call @sla__relationship_world_spawn(w1)
    w2 = load tmp_2788+0 as ptr
    target = load tmp_2788+8 as ptr
    !tmp_2788
    tmp_2789 = call @sla__relationship_world_spawn(w2)
    w3 = load tmp_2789+0 as ptr
    e0 = load tmp_2789+8 as ptr
    !tmp_2789
    tmp_2790 = call @sla__relationship_world_spawn(w3)
    w4 = load tmp_2790+0 as ptr
    e1 = load tmp_2790+8 as ptr
    !tmp_2790
    tmp_2791 = call @sla__relationship_world_spawn(w4)
    w5 = load tmp_2791+0 as ptr
    e2 = load tmp_2791+8 as ptr
    !tmp_2791
    tmp_2792 = call @sla__relationship_world_spawn(w5)
    w6 = load tmp_2792+0 as ptr
    e3 = load tmp_2792+8 as ptr
    !tmp_2792
    tmp_2793 = call @sla__relationship_world_spawn(w6)
    w7 = load tmp_2793+0 as ptr
    e4 = load tmp_2793+8 as ptr
    !tmp_2793
    EXPAND VEC_NEW tmp_2794
    initial = tmp_2794
    EXPAND VEC_PUSH initial, e0, 8
    EXPAND VEC_PUSH initial, e1, 8
    EXPAND VEC_PUSH initial, e2, 8
    EXPAND VEC_NEW tmp_2795
    insert = tmp_2795
    EXPAND VEC_PUSH insert, e0, 8
    EXPAND VEC_PUSH insert, e3, 8
    EXPAND VEC_PUSH insert, e4, 8
    EXPAND VEC_PUSH insert, e4, 8
    tmp_2796 = call @sla__relationship_commands_new()
    c0 = tmp_2796
    tmp_2797 = load kind+0 as i32
    tmp_2798 = call @sla__relationship_commands_add_related(c0, tmp_2797, target, initial)
    !tmp_2797
    c1 = tmp_2798
    tmp_2799 = load kind+0 as i32
    tmp_2800 = 1
    tmp_2801 = call @sla__relationship_commands_insert_related(c1, tmp_2799, target, tmp_2800, insert)
    !tmp_2799
    !tmp_2800
