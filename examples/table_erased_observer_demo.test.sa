    entity_slot = stack_alloc 8
    tmp_4408 = call @sla__registry_world_new()
    w0 = tmp_4408
    tmp_4409 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_4409+0 as ptr
    component = load tmp_4409+8 as ptr
    !tmp_4409
    tmp_4410 = call @sla__registry_world_spawn(w1)
    w2 = load tmp_4410+0 as ptr
    e1 = load tmp_4410+8 as ptr
    !tmp_4410
    tmp_4411 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_4411+0 as ptr
    e2 = load tmp_4411+8 as ptr
    !tmp_4411
    tmp_4412 = load component+0 as i32
    tmp_4413 = call @sla__registry_world_insert_component(w3, e1, tmp_4412)
    !tmp_4412
    w4 = tmp_4413
    tmp_4414 = load component+0 as i32
    tmp_4415 = call @sla__registry_world_insert_component(w4, e2, tmp_4414)
    !tmp_4414
    w5 = tmp_4415
    tmp_4416 = load component+0 as i32
    tmp_4417 = call @sla__registry_world_query_component(w5, tmp_4416)
    !tmp_4416
    q = tmp_4417
    tmp_4418 = 0
    total = tmp_4418
    tmp_4419 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1180

L_LOOP_HEAD_1180:
    tmp_4420 = load entity_slot+0 as i64
    tmp_4421 = slt tmp_4420, tmp_4419
    br tmp_4421 -> L_LOOP_BODY_1181, L_LOOP_COND_FALSE_1183

L_LOOP_BODY_1181:
    !tmp_4421
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_4420)
    tmp_4422 = load entity+0 as i32
    tmp_4423 = add total, tmp_4422
    !tmp_4422
    !total
    total = tmp_4423
L_LOOP_CONTINUE_1182:
    tmp_4424 = add tmp_4420, 1
    store entity_slot+0, tmp_4424 as i64
    !tmp_4424
    !tmp_4420
    !entity
    jmp L_LOOP_HEAD_1180

L_LOOP_COND_FALSE_1183:
    !tmp_4421
    !tmp_4420
    jmp L_LOOP_EXIT_1184

L_LOOP_EXIT_1184:
    !tmp_4419
    tmp_4425 = load e1+0 as i32
    tmp_4426 = load e2+0 as i32
    tmp_4427 = add tmp_4425, tmp_4426
    !tmp_4425
    !tmp_4426
    tmp_4428 = ne total, tmp_4427
    !tmp_4427
    br tmp_4428 -> L_THEN_1185, L_ELSE_1186

L_THEN_1185:
    !tmp_4428
    panic(8730)

L_ELSE_1186:
    !tmp_4428
    jmp L_MERGE_1187

L_MERGE_1187:
    !component
    !w0
    !e2
    !w4
    !total
    !w5
    !e1
    !w1
    !w2
    !w3
    !q
    return

