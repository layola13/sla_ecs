@test "allocator rejects stale generation"():
L_TEST_ENTRY_1807:
    tmp_6991 = call @sla__allocator_new()
    a0 = tmp_6991
    tmp_6992 = call @sla__alloc_entity(a0)
    a1 = load tmp_6992+0 as ptr
    e1 = load tmp_6992+8 as ptr
    !tmp_6992
    tmp_6993 = call @sla__free_entity(a1, e1)
    a2 = tmp_6993
    tmp_6994 = load e1+0 as i32
    tmp_6995 = load e1+4 as i32
    tmp_6996 = call @sla__entity_new(tmp_6994, tmp_6995)
    !tmp_6994
    !tmp_6995
    stale = tmp_6996
    tmp_6997 = load e1+0 as i32
    tmp_6998 = load e1+4 as i32
    tmp_6999 = 1
    tmp_7000 = add tmp_6998, tmp_6999
    !tmp_6998
    !tmp_6999
    tmp_7001 = call @sla__entity_new(tmp_6997, tmp_7000)
    !tmp_6997
    !tmp_7000
    fabricated = tmp_7001
    tmp_7002 = call @sla__is_alive(a2, stale)
    tmp_7003 = 0
    tmp_7004 = ne tmp_7002, tmp_7003
    !tmp_7002
    !tmp_7003
    br tmp_7004 -> L_THEN_1808, L_ELSE_1809

L_THEN_1808:
    !tmp_7004
    panic(2120)

L_ELSE_1809:
    !tmp_7004
