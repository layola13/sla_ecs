    tmp_21632 = alloc 8
    tmp_21633 = load e+0 as i32
    store tmp_21632+0, tmp_21633 as i32
    tmp_21634 = load e+4 as i32
    store tmp_21632+4, tmp_21634 as i32
    tmp_21635 = call @sla__entity_to_bits(tmp_21632)
    !tmp_21632
    bits = tmp_21635
    tmp_21636 = call @sla__entity_from_bits(bits)
    out = tmp_21636
    tmp_21637 = alloc 8
