    tmp_21655 = eq tmp_21653, tmp_21654
    tmp_21656 = load copied+4 as i32
    tmp_21657 = load e+4 as i32
    tmp_21658 = eq tmp_21656, tmp_21657
    tmp_21659 = and tmp_21655, tmp_21658
    tmp_21660 = ne tmp_21659, 1
    br tmp_21660 -> L_THEN_4743, L_ELSE_4744

L_THEN_4743:
