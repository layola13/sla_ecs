    jmp L_MERGE_4741

L_MERGE_4741:
    !out
    !bits
    !e
    return

@test "entity derives value semantics"():
L_TEST_ENTRY_4742:
    tmp_21648 = 42
    tmp_21649 = 7
    tmp_21650 = call @sla__entity_new(tmp_21648, tmp_21649)
    !tmp_21648
