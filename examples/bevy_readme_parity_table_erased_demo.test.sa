    store tmp_21637+0, tmp_21638 as i32
    tmp_21639 = load e+4 as i32
    store tmp_21637+4, tmp_21639 as i32
    tmp_21640 = alloc 8
    tmp_21641 = load out+0 as i32
    store tmp_21640+0, tmp_21641 as i32
    tmp_21642 = load out+4 as i32
    store tmp_21640+4, tmp_21642 as i32
    tmp_21643 = call @sla__entity_eq(tmp_21637, tmp_21640)
    !tmp_21637
    !tmp_21640
    tmp_21644 = 1
    tmp_21645 = ne tmp_21643, tmp_21644
    !tmp_21643
    !tmp_21644
    br tmp_21645 -> L_THEN_4739, L_ELSE_4740

L_THEN_4739:
