@import "../lib/hierarchy_relationship_adapter.sla"

fn bevy_style_hierarchy_generic_relationship_demo() -> i32 {
    let w0 = generic_hierarchy_world_new();
    let (w1, root) = generic_hierarchy_world_spawn(w0);
    let (w2, child1) = generic_hierarchy_world_spawn_child(w1, root);
    let (w3, child2) = generic_hierarchy_world_spawn_child(w2, root);
    let (w4, child3) = generic_hierarchy_world_spawn(w3);

    if generic_hierarchy_world_child_count(w4, root) != 2 { panic(9620); };
    if entity_eq(generic_hierarchy_world_parent(w4, child1), root) != true { panic(9621); };

    let w5 = generic_hierarchy_world_insert_child(w4, root, 0, child2);
    if entity_eq(generic_hierarchy_world_child_at(w5, root, 0), child2) != true { panic(9622); };

    let unrelate: Vec<Entity> = Vec::new();
    unrelate.push(child1);
    let relate: Vec<Entity> = Vec::new();
    relate.push(child2);
    relate.push(child3);
    let newly: Vec<Entity> = Vec::new();
    newly.push(child3);
    let w6 = generic_hierarchy_world_replace_children_with_difference(w5, root, unrelate, relate, newly);
    if generic_hierarchy_world_has_parent(w6, child1) != false { panic(9623); };
    if entity_eq(generic_hierarchy_world_child_at(w6, root, 1), child3) != true { panic(9624); };

    if generic_hierarchy_world_is_alive(w6, root) != true { panic(9627); };
    let w7 = generic_hierarchy_world_despawn(w6, child2);
    if generic_hierarchy_world_is_alive(w7, child2) != false { panic(9625); };
    if generic_hierarchy_world_child_count(w7, root) != 1 { panic(9626); };
    return generic_hierarchy_world_child_count(w7, root) as i32;
}

fn main() -> i32 { return bevy_style_hierarchy_generic_relationship_demo(); }

@test "generic relationship hierarchy demo uses typed facade"() {
    if bevy_style_hierarchy_generic_relationship_demo() != 1 { panic(9628); };
}
