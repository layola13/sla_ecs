@test "registry entity query supports for in"():
L_TEST_ENTRY_346:
    entity_slot = stack_alloc 8
    tmp_1322 = call @sla__registry_world_new()
    w0 = tmp_1322
    tmp_1323 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_1323+0 as ptr
    component = load tmp_1323+8 as ptr
    !tmp_1323
    tmp_1324 = call @sla__registry_world_spawn(w1)
    w2 = load tmp_1324+0 as ptr
    e1 = load tmp_1324+8 as ptr
    !tmp_1324
    tmp_1325 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_1325+0 as ptr
    e2 = load tmp_1325+8 as ptr
    !tmp_1325
    tmp_1326 = alloc 8
    tmp_1327 = load e1+0 as i32
    store tmp_1326+0, tmp_1327 as i32
    tmp_1328 = load e1+4 as i32
    store tmp_1326+4, tmp_1328 as i32
    tmp_1329 = load component+0 as i32
    tmp_1330 = call @sla__registry_world_insert_component(w3, tmp_1326, tmp_1329)
    !tmp_1326
    !tmp_1329
    w4 = tmp_1330
    tmp_1331 = alloc 8
    tmp_1332 = load e2+0 as i32
    store tmp_1331+0, tmp_1332 as i32
    tmp_1333 = load e2+4 as i32
    store tmp_1331+4, tmp_1333 as i32
    tmp_1334 = load component+0 as i32
    tmp_1335 = call @sla__registry_world_insert_component(w4, tmp_1331, tmp_1334)
    !tmp_1331
    !tmp_1334
    w5 = tmp_1335
    tmp_1336 = load component+0 as i32
    tmp_1337 = call @sla__registry_world_query_component(w5, tmp_1336)
    !tmp_1336
    q = tmp_1337
    tmp_1338 = 0
    total = tmp_1338
    tmp_1339 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_347

L_LOOP_HEAD_347:
    tmp_1340 = load entity_slot+0 as i64
    tmp_1341 = slt tmp_1340, tmp_1339
    br tmp_1341 -> L_LOOP_BODY_348, L_LOOP_COND_FALSE_351

L_LOOP_BODY_348:
    !tmp_1341
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_1340)
    tmp_1342 = load entity+0 as i32
    tmp_1343 = add total, tmp_1342
    !tmp_1342
    !total
    total = tmp_1343
L_LOOP_CONTINUE_349:
    tmp_1344 = add tmp_1340, 1
    store entity_slot+0, tmp_1344 as i64
    !tmp_1344
    !tmp_1340
    !entity
    jmp L_LOOP_HEAD_347

L_LOOP_COND_FALSE_351:
    !tmp_1341
    !tmp_1340
    jmp L_LOOP_EXIT_353

L_LOOP_EXIT_353:
    !tmp_1339
    tmp_1345 = load e1+0 as i32
    tmp_1346 = load e2+0 as i32
    tmp_1347 = add tmp_1345, tmp_1346
    !tmp_1345
    !tmp_1346
    tmp_1348 = ne total, tmp_1347
    !tmp_1347
    br tmp_1348 -> L_THEN_354, L_ELSE_355

L_THEN_354:
    !tmp_1348
    panic(8730)

L_ELSE_355:
