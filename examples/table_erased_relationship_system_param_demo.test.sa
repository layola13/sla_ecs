    w3 = load tmp_7043+0 as ptr
    e2 = load tmp_7043+8 as ptr
    !tmp_7043
    tmp_7044 = load component+0 as i32
    tmp_7045 = call @sla__registry_world_insert_component(w3, e1, tmp_7044)
    !tmp_7044
    w4 = tmp_7045
