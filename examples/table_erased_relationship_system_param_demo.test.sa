    tmp_7049 = call @sla__registry_world_query_component(w5, tmp_7048)
    !tmp_7048
    q = tmp_7049
    tmp_7050 = 0
    total = tmp_7050
    tmp_7051 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_2010

L_LOOP_HEAD_2010:
    tmp_7052 = load entity_slot+0 as i64
    tmp_7053 = slt tmp_7052, tmp_7051
    br tmp_7053 -> L_LOOP_BODY_2011, L_LOOP_COND_FALSE_2013

L_LOOP_BODY_2011:
