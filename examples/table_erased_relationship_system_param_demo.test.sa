L_LOOP_HEAD_1713:
    tmp_6087 = load entity_slot+0 as i64
    tmp_6088 = slt tmp_6087, tmp_6086
    br tmp_6088 -> L_LOOP_BODY_1714, L_LOOP_COND_FALSE_1716

