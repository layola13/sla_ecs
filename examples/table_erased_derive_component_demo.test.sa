L_MERGE_2080:
    tmp_8012 = load tag+0 as i32
    tmp_8013 = call @sla__registry_world_insert_component(w6, entity, tmp_8012)
    !tmp_8012
    w7 = tmp_8013
    tmp_8014 = call @sla__registry_world_despawn(w7, entity)
    w8 = tmp_8014
    tmp_8015 = call @sla__registry_world_is_alive(w8, entity)
