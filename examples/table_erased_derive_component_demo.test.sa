@test "registry entity query supports for in"():
L_TEST_ENTRY_2090:
    entity_slot = stack_alloc 8
    tmp_8033 = call @sla__registry_world_new()
    w0 = tmp_8033
    tmp_8034 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_8034+0 as ptr
    component = load tmp_8034+8 as ptr
    !tmp_8034
    tmp_8035 = call @sla__registry_world_spawn(w1)
    w2 = load tmp_8035+0 as ptr
    e1 = load tmp_8035+8 as ptr
    !tmp_8035
    tmp_8036 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_8036+0 as ptr
    e2 = load tmp_8036+8 as ptr
    !tmp_8036
    tmp_8037 = load component+0 as i32
    tmp_8038 = call @sla__registry_world_insert_component(w3, e1, tmp_8037)
    !tmp_8037
    w4 = tmp_8038
    tmp_8039 = load component+0 as i32
    tmp_8040 = call @sla__registry_world_insert_component(w4, e2, tmp_8039)
    !tmp_8039
    w5 = tmp_8040
    tmp_8041 = load component+0 as i32
    tmp_8042 = call @sla__registry_world_query_component(w5, tmp_8041)
    !tmp_8041
    q = tmp_8042
    tmp_8043 = 0
    total = tmp_8043
    tmp_8044 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_2091

L_LOOP_HEAD_2091:
    tmp_8045 = load entity_slot+0 as i64
    tmp_8046 = slt tmp_8045, tmp_8044
    br tmp_8046 -> L_LOOP_BODY_2092, L_LOOP_COND_FALSE_2094

L_LOOP_BODY_2092:
    !tmp_8046
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_8045)
    tmp_8047 = load entity+0 as i32
    tmp_8048 = add total, tmp_8047
    !tmp_8047
    !total
    total = tmp_8048
L_LOOP_CONTINUE_2093:
    tmp_8049 = add tmp_8045, 1
    store entity_slot+0, tmp_8049 as i64
    !tmp_8049
    !tmp_8045
    !entity
    jmp L_LOOP_HEAD_2091

L_LOOP_COND_FALSE_2094:
    !tmp_8046
    !tmp_8045
    jmp L_LOOP_EXIT_2095

L_LOOP_EXIT_2095:
    !tmp_8044
    tmp_8050 = load e1+0 as i32
    tmp_8051 = load e2+0 as i32
    tmp_8052 = add tmp_8050, tmp_8051
    !tmp_8050
    !tmp_8051
    tmp_8053 = ne total, tmp_8052
    !tmp_8052
    br tmp_8053 -> L_THEN_2096, L_ELSE_2097

L_THEN_2096:
    !tmp_8053
    panic(8730)

L_ELSE_2097:
    !tmp_8053
    jmp L_MERGE_2098

L_MERGE_2098:
    !component
    !w0
    !e2
    !w4
    !total
    !w5
    !e1
    !w1
    !w2
    !w3
    !q
    return

@test "resource generic constructor"():
