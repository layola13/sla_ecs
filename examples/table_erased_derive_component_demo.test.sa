L_ELSE_2111:
    !tmp_8081
    jmp L_MERGE_2112

L_MERGE_2112:
    tmp_8084 = call @sla__resource_remove_TestTime(r1)
    r2 = tmp_8084
    tmp_8085 = call @sla__resource_has_TestTime(r2)
    tmp_8086 = 0
    tmp_8087 = ne tmp_8085, tmp_8086
    !tmp_8085
    !tmp_8086
    br tmp_8087 -> L_THEN_2113, L_ELSE_2114

L_THEN_2113:
    !tmp_8087
    panic(2303)

L_ELSE_2114:
    !tmp_8087
    jmp L_MERGE_2115

L_MERGE_2115:
    !r1
    !t
    !r2
    !r0
    return

@test "resource replace overwrites value"():
L_TEST_ENTRY_2116:
    tmp_8090 = call @sla__test_time_slot_new()
    r0 = tmp_8090
    tmp_8091 = alloc 4
    tmp_8092 = 1
    store tmp_8091+0, tmp_8092 as i32
    !tmp_8092
    tmp_8093 = call @sla__resource_insert_TestTime(r0, tmp_8091)
    !tmp_8091
    r1 = tmp_8093
    tmp_8094 = alloc 4
    tmp_8095 = 2
    store tmp_8094+0, tmp_8095 as i32
    !tmp_8095
    tmp_8096 = call @sla__resource_insert_TestTime(r1, tmp_8094)
    !tmp_8094
    r2 = tmp_8096
    tmp_8097 = call @sla__resource_get_TestTime(r2)
    t = tmp_8097
    tmp_8098 = load t+0 as i32
    tmp_8099 = 2
    tmp_8100 = ne tmp_8098, tmp_8099
    !tmp_8098
    !tmp_8099
    br tmp_8100 -> L_THEN_2117, L_ELSE_2118

