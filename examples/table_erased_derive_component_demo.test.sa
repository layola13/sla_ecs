@test "dynamic allocator rejects fabricated next generation before reuse"():
L_TEST_ENTRY_2027:
    tmp_7868 = call @sla__dyn_allocator_new()
    a0 = tmp_7868
    tmp_7869 = call @sla__dyn_alloc_entity(a0)
    a1 = load tmp_7869+0 as ptr
    e1 = load tmp_7869+8 as ptr
    !tmp_7869
    tmp_7870 = call @sla__dyn_free_entity(a1, e1)
    a2 = tmp_7870
    tmp_7871 = load e1+0 as i32
    tmp_7872 = load e1+4 as i32
    tmp_7873 = 1
    tmp_7874 = add tmp_7872, tmp_7873
    !tmp_7872
    !tmp_7873
    tmp_7875 = call @sla__entity_new(tmp_7871, tmp_7874)
    !tmp_7871
    !tmp_7874
    fake = tmp_7875
    tmp_7876 = call @sla__dyn_is_alive(a2, e1)
    tmp_7877 = 0
    tmp_7878 = ne tmp_7876, tmp_7877
    !tmp_7876
    !tmp_7877
    br tmp_7878 -> L_THEN_2028, L_ELSE_2029

L_THEN_2028:
    !tmp_7878
    panic(2160)

L_ELSE_2029:
    !tmp_7878
    jmp L_MERGE_2030

L_MERGE_2030:
    tmp_7881 = call @sla__dyn_is_alive(a2, fake)
    tmp_7882 = 0
    tmp_7883 = ne tmp_7881, tmp_7882
    !tmp_7881
    !tmp_7882
    br tmp_7883 -> L_THEN_2031, L_ELSE_2032

L_THEN_2031:
    !tmp_7883
    panic(2161)

L_ELSE_2032:
    !tmp_7883
    jmp L_MERGE_2033

L_MERGE_2033:
    tmp_7886 = call @sla__dyn_alloc_entity(a2)
    a3 = load tmp_7886+0 as ptr
    e2 = load tmp_7886+8 as ptr
    !tmp_7886
    tmp_7887 = call @sla__entity_eq(e2, fake)
    tmp_7888 = 1
    tmp_7889 = ne tmp_7887, tmp_7888
    !tmp_7887
    !tmp_7888
    br tmp_7889 -> L_THEN_2034, L_ELSE_2035

L_THEN_2034:
    !tmp_7889
    panic(2162)

L_ELSE_2035:
    !tmp_7889
    jmp L_MERGE_2036

L_MERGE_2036:
    tmp_7892 = call @sla__dyn_is_alive(a3, e2)
    tmp_7893 = 1
    tmp_7894 = ne tmp_7892, tmp_7893
    !tmp_7892
    !tmp_7893
    br tmp_7894 -> L_THEN_2037, L_ELSE_2038

L_THEN_2037:
    !tmp_7894
    panic(2163)

L_ELSE_2038:
    !tmp_7894
    jmp L_MERGE_2039

L_MERGE_2039:
    !e2
    !a0
    !fake
    !a2
    !e1
    !a3
    !a1
    return

@test "registry world tracks arbitrary component membership"():
L_TEST_ENTRY_2040:
    tmp_7897 = call @sla__registry_world_new()
    w0 = tmp_7897
    tmp_7898 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_7898+0 as ptr
    position = load tmp_7898+8 as ptr
    !tmp_7898
    tmp_7899 = call @sla__registry_world_register_table(w1)
    w2 = load tmp_7899+0 as ptr
    velocity = load tmp_7899+8 as ptr
    !tmp_7899
    tmp_7900 = call @sla__registry_world_register_sparse_set(w2)
    w3 = load tmp_7900+0 as ptr
    marker = load tmp_7900+8 as ptr
    !tmp_7900
    tmp_7901 = call @sla__registry_world_component_count(w3)
    tmp_7902 = 3
    tmp_7903 = ne tmp_7901, tmp_7902
    !tmp_7901
    !tmp_7902
    br tmp_7903 -> L_THEN_2041, L_ELSE_2042

L_THEN_2041:
    !tmp_7903
    panic(8710)

L_ELSE_2042:
    !tmp_7903
    jmp L_MERGE_2043

L_MERGE_2043:
    tmp_7906 = load position+8 as ptr
    tmp_7907 = call @sla__storage_kind_is_table(^tmp_7906)
    tmp_7908 = 1
    tmp_7909 = ne tmp_7907, tmp_7908
    !tmp_7907
    !tmp_7908
    br tmp_7909 -> L_THEN_2044, L_ELSE_2045

L_THEN_2044:
    !tmp_7909
    panic(8711)

L_ELSE_2045:
    !tmp_7909
    jmp L_MERGE_2046

L_MERGE_2046:
    tmp_7912 = load marker+8 as ptr
    tmp_7913 = call @sla__storage_kind_is_sparse_set(^tmp_7912)
    tmp_7914 = 1
    tmp_7915 = ne tmp_7913, tmp_7914
    !tmp_7913
    !tmp_7914
    br tmp_7915 -> L_THEN_2047, L_ELSE_2048

L_THEN_2047:
    !tmp_7915
    panic(8712)

L_ELSE_2048:
    !tmp_7915
    jmp L_MERGE_2049

L_MERGE_2049:
    tmp_7918 = call @sla__registry_world_spawn(w3)
    w4 = load tmp_7918+0 as ptr
    e1 = load tmp_7918+8 as ptr
    !tmp_7918
    tmp_7919 = call @sla__registry_world_spawn(w4)
    w5 = load tmp_7919+0 as ptr
    e2 = load tmp_7919+8 as ptr
    !tmp_7919
    tmp_7920 = load position+0 as i32
    tmp_7921 = call @sla__registry_world_insert_component(w5, e1, tmp_7920)
    !tmp_7920
    w6 = tmp_7921
    tmp_7922 = load velocity+0 as i32
    tmp_7923 = call @sla__registry_world_insert_component(w6, e1, tmp_7922)
    !tmp_7922
    w7 = tmp_7923
    tmp_7924 = load position+0 as i32
    tmp_7925 = call @sla__registry_world_insert_component(w7, e2, tmp_7924)
    !tmp_7924
    w8 = tmp_7925
    tmp_7926 = load marker+0 as i32
    tmp_7927 = call @sla__registry_world_insert_component(w8, e2, tmp_7926)
    !tmp_7926
    w9 = tmp_7927
    tmp_7928 = load position+0 as i32
    tmp_7929 = call @sla__registry_world_has_component(w9, e1, tmp_7928)
    !tmp_7928
    tmp_7930 = 1
    tmp_7931 = ne tmp_7929, tmp_7930
    !tmp_7929
    !tmp_7930
    br tmp_7931 -> L_THEN_2050, L_ELSE_2051

L_THEN_2050:
    !tmp_7931
    panic(8713)

L_ELSE_2051:
    !tmp_7931
    jmp L_MERGE_2052

L_MERGE_2052:
    tmp_7934 = load marker+0 as i32
    tmp_7935 = call @sla__registry_world_has_component(w9, e1, tmp_7934)
    !tmp_7934
    tmp_7936 = 0
    tmp_7937 = ne tmp_7935, tmp_7936
    !tmp_7935
    !tmp_7936
    br tmp_7937 -> L_THEN_2053, L_ELSE_2054

L_THEN_2053:
    !tmp_7937
    panic(8714)

L_ELSE_2054:
    !tmp_7937
    jmp L_MERGE_2055

L_MERGE_2055:
    tmp_7940 = load position+0 as i32
    tmp_7941 = call @sla__registry_world_query_component(w9, tmp_7940)
    !tmp_7940
    q = tmp_7941
    tmp_7942 = load q+0 as ptr
    EXPAND VEC_LEN tmp_7943, tmp_7942
    !tmp_7942
    tmp_7944 = 2
    tmp_7945 = ne tmp_7943, tmp_7944
    !tmp_7943
    !tmp_7944
    br tmp_7945 -> L_THEN_2056, L_ELSE_2057

L_THEN_2056:
    !tmp_7945
    panic(8715)

L_ELSE_2057:
    !tmp_7945
    jmp L_MERGE_2058

L_MERGE_2058:
    tmp_7948 = load position+0 as i32
    tmp_7949 = load marker+0 as i32
    tmp_7950 = call @sla__registry_world_query_with_without(w9, tmp_7948, tmp_7949)
    !tmp_7948
    !tmp_7949
    filtered = tmp_7950
    tmp_7951 = load filtered+0 as ptr
    EXPAND VEC_LEN tmp_7952, tmp_7951
    !tmp_7951
    tmp_7953 = 1
    tmp_7954 = ne tmp_7952, tmp_7953
    !tmp_7952
    !tmp_7953
    br tmp_7954 -> L_THEN_2059, L_ELSE_2060

L_THEN_2059:
    !tmp_7954
    panic(8716)

L_ELSE_2060:
    !tmp_7954
    jmp L_MERGE_2061

L_MERGE_2061:
    tmp_7957 = load filtered+0 as ptr
    tmp_7958 = 0
    EXPAND VEC_GET tmp_7959, tmp_7957, tmp_7958
    !tmp_7958
    !tmp_7957
    tmp_7960 = tmp_7959 as ptr
    tmp_7961 = load tmp_7960+0 as i32
    !tmp_7960
    tmp_7962 = load e1+0 as i32
    tmp_7963 = ne tmp_7961, tmp_7962
    !tmp_7961
    !tmp_7962
    br tmp_7963 -> L_THEN_2062, L_ELSE_2063

L_THEN_2062:
    !tmp_7963
    panic(8717)

L_ELSE_2063:
    !tmp_7963
    jmp L_MERGE_2064

L_MERGE_2064:
    !e2
    !position
    !e1
    !w3
    !velocity
    !marker
    !w6
    !w8
    !w7
    !w0
    !q
    !w4
    !filtered
    !w5
    !w9
    !w1
    !w2
    return

@test "registry world added changed and despawn cleanup"():
L_TEST_ENTRY_2065:
    tmp_7966 = call @sla__registry_world_new()
    w0 = tmp_7966
    tmp_7967 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_7967+0 as ptr
    health = load tmp_7967+8 as ptr
    !tmp_7967
    tmp_7968 = call @sla__registry_world_register_sparse_set(w1)
    w2 = load tmp_7968+0 as ptr
    tag = load tmp_7968+8 as ptr
    !tmp_7968
    tmp_7969 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_7969+0 as ptr
    entity = load tmp_7969+8 as ptr
    !tmp_7969
    tmp_7970 = load w3+24 as i32
    before = tmp_7970
    tmp_7971 = load health+0 as i32
    tmp_7972 = call @sla__registry_world_insert_component(w3, entity, tmp_7971)
    !tmp_7971
    w4 = tmp_7972
    tmp_7973 = load health+0 as i32
    tmp_7974 = 1
    tmp_7975 = sub before, tmp_7974
    !tmp_7974
    tmp_7976 = call @sla__registry_world_component_added_since(w4, entity, tmp_7973, tmp_7975)
    !tmp_7973
    !tmp_7975
    tmp_7977 = 1
    tmp_7978 = ne tmp_7976, tmp_7977
    !tmp_7976
    !tmp_7977
    br tmp_7978 -> L_THEN_2066, L_ELSE_2067

L_THEN_2066:
    !tmp_7978
    panic(8720)

L_ELSE_2067:
    !tmp_7978
    jmp L_MERGE_2068

L_MERGE_2068:
    tmp_7981 = load health+0 as i32
    tmp_7982 = 1
    tmp_7983 = sub before, tmp_7982
    !tmp_7982
    tmp_7984 = call @sla__registry_world_component_changed_since(w4, entity, tmp_7981, tmp_7983)
    !tmp_7981
    !tmp_7983
    tmp_7985 = 1
    tmp_7986 = ne tmp_7984, tmp_7985
    !tmp_7984
    !tmp_7985
    br tmp_7986 -> L_THEN_2069, L_ELSE_2070

L_THEN_2069:
    !tmp_7986
    panic(8721)

L_ELSE_2070:
    !tmp_7986
    jmp L_MERGE_2071

L_MERGE_2071:
    tmp_7989 = call @sla__registry_world_increment_tick(w4)
    w5 = tmp_7989
    tmp_7990 = load health+0 as i32
    tmp_7991 = call @sla__registry_world_insert_component(w5, entity, tmp_7990)
    !tmp_7990
    w6 = tmp_7991
    tmp_7992 = load health+0 as i32
    tmp_7993 = call @sla__registry_world_component_added_since(w6, entity, tmp_7992, before)
    !tmp_7992
    tmp_7994 = 0
    tmp_7995 = ne tmp_7993, tmp_7994
    !tmp_7993
    !tmp_7994
    br tmp_7995 -> L_THEN_2072, L_ELSE_2073

L_THEN_2072:
    !tmp_7995
    panic(8722)

L_ELSE_2073:
    !tmp_7995
    jmp L_MERGE_2074

L_MERGE_2074:
    tmp_7998 = load health+0 as i32
    tmp_7999 = call @sla__registry_world_component_changed_since(w6, entity, tmp_7998, before)
    !tmp_7998
    tmp_8000 = 1
    tmp_8001 = ne tmp_7999, tmp_8000
    !tmp_7999
    !tmp_8000
    br tmp_8001 -> L_THEN_2075, L_ELSE_2076

L_THEN_2075:
    !tmp_8001
    panic(8723)

L_ELSE_2076:
    !tmp_8001
    jmp L_MERGE_2077

L_MERGE_2077:
    tmp_8004 = load health+0 as i32
    tmp_8005 = call @sla__registry_world_query_changed_since(w6, tmp_8004, before)
    !tmp_8004
