    jmp L_MERGE_2106

L_MERGE_2106:
    tmp_8070 = alloc 4
    tmp_8071 = 7
    store tmp_8070+0, tmp_8071 as i32
    !tmp_8071
    tmp_8072 = call @sla__resource_insert_TestTime(r0, tmp_8070)
    !tmp_8070
    r1 = tmp_8072
