@import "../lib/system_param_table_erased_relationship.sla"

fn table_erased_relationship_system_param_demo_move(world: TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> {
    return table_erased_relationship_run_pair_mut_system_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(world, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, table_erased_relationship_param_movement_system);
}

fn table_erased_relationship_system_param_demo_count(world: TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> {
    if len(world.relationships.targets) <= 0 { return world; };
    let target_entry = world.relationships.targets[0];
    return table_erased_relationship_run_relation_resource_system<TableErasedTime, TableErasedEvent>(world, target_entry.kind_id, target_entry.target, table_erased_relationship_param_count_system);
}

fn table_erased_relationship_system_param_demo_writer(world: TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> {
    return table_erased_relationship_run_message_writer_system<TableErasedTime, TableErasedEvent>(world, table_erased_relationship_param_writer_system);
}

fn bevy_style_table_erased_relationship_system_param_demo() -> i32 {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, position) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, velocity) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, ecs_box_drop<TableErasedVel>);
    let (w3, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w2, true, false);
    let (w4, root) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let (w5, child) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let w6 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, child, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 5, y: 0 });
    let w7 = table_erased_relationship_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w6, child, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 4, y: 0 });
    let w8 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w7, kind.id, child, root);
    w8.table = table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(w8.table, TableErasedTime { tick: 0 });
    let move_access = table_erased_relationship_access_read_component(table_erased_relationship_access_write_component(table_erased_relationship_system_access_none(), position.id), velocity.id);
    let count_access = table_erased_relationship_access_write_resource(table_erased_relationship_access_read_relationship(table_erased_relationship_system_access_none(), kind.id));
    let writer_access = table_erased_relationship_access_write_messages(table_erased_relationship_system_access_none());
    let s0 = table_erased_relationship_schedule_default<TableErasedTime, TableErasedEvent>();
    let s1 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s0, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_relationship_system_param_demo_move, move_access));
    let s2 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s1, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_relationship_system_param_demo_count, count_access));
    let s3 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s2, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_relationship_system_param_demo_writer, writer_access));
    let w9 = table_erased_relationship_schedule_run_planned<TableErasedTime, TableErasedEvent>(s3, w8);
    let read = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w9.table, message_reader_new(), table_erased_event_default());
    if table_erased_relationship_schedule_batch_count<TableErasedTime, TableErasedEvent>(s3) != 1 { panic(12530); };
    if table_erased_relationship_schedule_max_parallel_width<TableErasedTime, TableErasedEvent>(s3) != 3 { panic(12531); };
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, child, position.id, TABLE_ERASED_POS_TYPE).x != 9 { panic(12532); };
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(w9.table).tick != 1 { panic(12533); };
    if read.value.amount != 2 { panic(12534); };
    return 1;
}

fn main() -> i32 { return bevy_style_table_erased_relationship_system_param_demo(); }

@test "table erased relationship system param demo runs scheduled pipeline"() {
    if bevy_style_table_erased_relationship_system_param_demo() != 1 { panic(12535); };
}
