@import "../lib/commands_table_erased_relationship.sla"

fn bevy_style_table_erased_relationship_commands_demo() -> i32 {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, position) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w1, true, false);
    let c0 = table_erased_relationship_commands_test_commands_new();
    let (w3, c1, root) = table_erased_relationship_commands_reserve_entity<TableErasedTime, TableErasedEvent>(w2, c0);
    let (w4, c2, child) = table_erased_relationship_commands_spawn_related<TableErasedTime, TableErasedEvent>(w3, c1, kind.id, root);
    let (w4a, c2a, second) = table_erased_relationship_commands_reserve_entity<TableErasedTime, TableErasedEvent>(w4, c2);
    let (w4b, c2b, third) = table_erased_relationship_commands_reserve_entity<TableErasedTime, TableErasedEvent>(w4a, c2a);
    let c3 = table_erased_relationship_commands_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(c2b, child, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 34, y: 0 });
    let c4 = table_erased_relationship_commands_set_related<TableErasedTime, TableErasedEvent>(c3, kind.id, second, root);
    let c5 = table_erased_relationship_commands_set_related_at<TableErasedTime, TableErasedEvent>(c4, kind.id, third, root, 1);
    let (w5, c6) = table_erased_relationship_commands_apply<TableErasedTime, TableErasedEvent>(w4b, c5);
    if table_erased_relationship_commands_len<TableErasedTime, TableErasedEvent>(c6) != 0 { panic(12330); };
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w5, kind.id, root) != 3 { panic(12331); };
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, child, position.id, TABLE_ERASED_POS_TYPE).x != 34 { panic(12332); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w5, kind.id, root, 0), child) != true { panic(12337); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w5, kind.id, root, 1), third) != true { panic(12338); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w5, kind.id, root, 2), second) != true { panic(12339); };
    let remove: Vec<Entity> = Vec::new();
    remove.push(second);
    let c7 = table_erased_relationship_commands_remove_related<TableErasedTime, TableErasedEvent>(c6, kind.id, root, remove);
    let replacement: Vec<Entity> = Vec::new();
    replacement.push(third);
    replacement.push(child);
    replacement.push(second);
    let c8 = table_erased_relationship_commands_replace_related<TableErasedTime, TableErasedEvent>(c7, kind.id, root, replacement);
    let unrelate: Vec<Entity> = Vec::new();
    unrelate.push(child);
    let relate: Vec<Entity> = Vec::new();
    relate.push(third);
    relate.push(second);
    let newly: Vec<Entity> = Vec::new();
    let c9 = table_erased_relationship_commands_replace_related_with_difference<TableErasedTime, TableErasedEvent>(c8, kind.id, root, unrelate, relate, newly);
    let (w6, c10) = table_erased_relationship_commands_apply<TableErasedTime, TableErasedEvent>(w5, c9);
    if table_erased_relationship_commands_len<TableErasedTime, TableErasedEvent>(c10) != 0 { panic(12342); };
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w6, kind.id, root) != 2 { panic(12343); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w6, kind.id, root, 0), third) != true { panic(12344); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w6, kind.id, root, 1), second) != true { panic(12345); };
    let c11 = table_erased_relationship_commands_despawn<TableErasedTime, TableErasedEvent>(c10, root);
    let (w7, c12) = table_erased_relationship_commands_apply<TableErasedTime, TableErasedEvent>(w6, c11);
    if table_erased_relationship_commands_len<TableErasedTime, TableErasedEvent>(c12) != 0 { panic(12333); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w7, root) != false { panic(12334); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w7, child) != true { panic(12335); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w7, second) != false { panic(12340); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w7, third) != false { panic(12341); };

    let dw0 = table_erased_relationship_test_world_new();
    let (dw1, dposition) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(dw0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (dw2, dkind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(dw1, true, false);
    let dc0 = table_erased_relationship_commands_test_commands_new();
    let (dw3, dc1, droot) = table_erased_relationship_commands_reserve_entity<TableErasedTime, TableErasedEvent>(dw2, dc0);
    let (dw4, dc2, dchild) = table_erased_relationship_commands_spawn_related<TableErasedTime, TableErasedEvent>(dw3, dc1, dkind.id, droot);
    let (dw5, dc3, dgrandchild) = table_erased_relationship_commands_spawn_related<TableErasedTime, TableErasedEvent>(dw4, dc2, dkind.id, dchild);
    let dc4 = table_erased_relationship_commands_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(dc3, dchild, dposition.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 61, y: 0 });
    let dc5 = table_erased_relationship_commands_despawn_related<TableErasedTime, TableErasedEvent>(dc4, dkind.id, droot);
    let (dw6, dc6) = table_erased_relationship_commands_apply<TableErasedTime, TableErasedEvent>(dw5, dc5);
    if table_erased_relationship_commands_len<TableErasedTime, TableErasedEvent>(dc6) != 0 { panic(12346); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(dw6, droot) != true { panic(12347); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(dw6, dchild) != false { panic(12348); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(dw6, dgrandchild) != false { panic(12349); };
    if table_erased_relationship_world_has<TableErasedTime, TableErasedEvent>(dw6, dchild, dposition.id) != false { panic(12371); };
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(dw6, dkind.id, droot) != 0 { panic(12372); };
    return 2;
}

fn main() -> i32 { return bevy_style_table_erased_relationship_commands_demo(); }

@test "table erased relationship commands demo applies ordered ECS and relation mutations"() {
    if bevy_style_table_erased_relationship_commands_demo() != 2 { panic(12336); };
}
