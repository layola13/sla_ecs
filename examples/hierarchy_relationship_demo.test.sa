L_ELSE_402:
    !tmp_1361
    jmp L_MERGE_403

L_MERGE_403:
    tmp_1364 = 1
    tmp_1365 = add i, tmp_1364
    !tmp_1364
    !i
    i = tmp_1365
    !entity
    jmp L_WHILE_HEAD_394

L_WHILE_COND_FALSE_396:
    !tmp_1351
    jmp L_WHILE_EXIT_397

L_WHILE_EXIT_397:
    tmp_1366 = load a+8 as ptr
    EXPAND VEC_LEN tmp_1367, tmp_1366
    !tmp_1366
