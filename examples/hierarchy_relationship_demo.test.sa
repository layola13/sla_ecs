    next_a = load tmp_1352+0 as ptr
    entity = load tmp_1352+8 as ptr
    !tmp_1352
    !a
    a = next_a
    tmp_1353 = load entity+0 as i32
    tmp_1354 = 1
    tmp_1355 = add i, tmp_1354
    !tmp_1354
