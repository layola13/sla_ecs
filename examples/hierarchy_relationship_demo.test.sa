@test "entity placeholder is never allocated"():
L_TEST_ENTRY_588:
    tmp_1986 = call @sla__entity_placeholder()
    placeholder = tmp_1986
    tmp_1987 = call @sla__allocator_new()
    a = tmp_1987
    tmp_1988 = call @sla__alloc_entity(a)
    a1 = load tmp_1988+0 as ptr
    e1 = load tmp_1988+8 as ptr
    !tmp_1988
    tmp_1989 = load placeholder+0 as i32
    tmp_1990 = load e1+0 as i32
    tmp_1991 = eq tmp_1989, tmp_1990
    !tmp_1989
    !tmp_1990
    br tmp_1991 -> L_THEN_589, L_ELSE_590

L_THEN_589:
    !tmp_1991
    panic(2100)

L_ELSE_590:
    !tmp_1991
    jmp L_MERGE_591

L_MERGE_591:
    tmp_1994 = call @sla__is_alive(a1, placeholder)
    tmp_1995 = 0
    tmp_1996 = ne tmp_1994, tmp_1995
    !tmp_1994
    !tmp_1995
    br tmp_1996 -> L_THEN_592, L_ELSE_593

L_THEN_592:
    !tmp_1996
    panic(2101)

L_ELSE_593:
    !tmp_1996
    jmp L_MERGE_594

L_MERGE_594:
    !a
    !placeholder
    !e1
    !a1
    return

@test "entity bit roundtrip"():
L_TEST_ENTRY_595:
    tmp_1999 = 42
    tmp_2000 = 7
    tmp_2001 = call @sla__entity_new(tmp_1999, tmp_2000)
    !tmp_1999
    !tmp_2000
    e = tmp_2001
    tmp_2002 = call @sla__entity_to_bits(e)
    bits = tmp_2002
    tmp_2003 = call @sla__entity_from_bits(bits)
    out = tmp_2003
    tmp_2004 = call @sla__entity_eq(e, out)
    tmp_2005 = 1
    tmp_2006 = ne tmp_2004, tmp_2005
    !tmp_2004
    !tmp_2005
    br tmp_2006 -> L_THEN_596, L_ELSE_597

L_THEN_596:
    !tmp_2006
    panic(2110)

L_ELSE_597:
    !tmp_2006
    jmp L_MERGE_598

L_MERGE_598:
    !out
    !bits
    !e
    return

