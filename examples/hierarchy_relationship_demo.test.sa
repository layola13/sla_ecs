@test "hierarchy invalid target and self relation are discarded"():
L_TEST_ENTRY_871:
    tmp_2690 = call @sla__hierarchy_world_new()
    w0 = tmp_2690
    tmp_2691 = call @sla__hierarchy_world_spawn(w0)
    w1 = load tmp_2691+0 as ptr
    parent = load tmp_2691+8 as ptr
    !tmp_2691
    tmp_2692 = call @sla__hierarchy_world_spawn(w1)
    w2 = load tmp_2692+0 as ptr
    child = load tmp_2692+8 as ptr
    !tmp_2692
    tmp_2693 = call @sla__hierarchy_world_add_child(w2, parent, child)
    w3 = tmp_2693
    tmp_2694 = call @sla__hierarchy_world_add_child(w3, child, child)
    w4 = tmp_2694
    tmp_2695 = call @sla__hierarchy_world_has_parent(w4, child)
    tmp_2696 = 0
    tmp_2697 = ne tmp_2695, tmp_2696
    !tmp_2695
    !tmp_2696
    br tmp_2697 -> L_THEN_872, L_ELSE_873

L_THEN_872:
