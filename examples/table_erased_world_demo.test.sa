@test "allocator rejects stale generation"():
L_TEST_ENTRY_1262:
    tmp_4866 = call @sla__allocator_new()
    a0 = tmp_4866
    tmp_4867 = call @sla__alloc_entity(a0)
    a1 = load tmp_4867+0 as ptr
    e1 = load tmp_4867+8 as ptr
    !tmp_4867
    tmp_4868 = call @sla__free_entity(a1, e1)
    a2 = tmp_4868
    tmp_4869 = load e1+0 as i32
    tmp_4870 = load e1+4 as i32
    tmp_4871 = call @sla__entity_new(tmp_4869, tmp_4870)
    !tmp_4869
    !tmp_4870
    stale = tmp_4871
    tmp_4872 = load e1+0 as i32
    tmp_4873 = load e1+4 as i32
    tmp_4874 = 1
    tmp_4875 = add tmp_4873, tmp_4874
    !tmp_4873
    !tmp_4874
    tmp_4876 = call @sla__entity_new(tmp_4872, tmp_4875)
    !tmp_4872
    !tmp_4875
    fabricated = tmp_4876
    tmp_4877 = call @sla__is_alive(a2, stale)
    tmp_4878 = 0
    tmp_4879 = ne tmp_4877, tmp_4878
    !tmp_4877
    !tmp_4878
    br tmp_4879 -> L_THEN_1263, L_ELSE_1264

L_THEN_1263:
