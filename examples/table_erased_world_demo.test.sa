@test "registry world added changed and despawn cleanup"():
L_TEST_ENTRY_1334:
    tmp_5033 = call @sla__registry_world_new()
    w0 = tmp_5033
    tmp_5034 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_5034+0 as ptr
    health = load tmp_5034+8 as ptr
    !tmp_5034
    tmp_5035 = call @sla__registry_world_register_sparse_set(w1)
    w2 = load tmp_5035+0 as ptr
    tag = load tmp_5035+8 as ptr
    !tmp_5035
    tmp_5036 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_5036+0 as ptr
    entity = load tmp_5036+8 as ptr
    !tmp_5036
    tmp_5037 = load w3+24 as i32
    before = tmp_5037
    tmp_5038 = load health+0 as i32
    tmp_5039 = call @sla__registry_world_insert_component(w3, entity, tmp_5038)
    !tmp_5038
    w4 = tmp_5039
    tmp_5040 = load health+0 as i32
    tmp_5041 = 1
