L_WHILE_BODY_1284:
    !tmp_4914
    tmp_4915 = call @sla__dyn_alloc_entity(a)
    next_a = load tmp_4915+0 as ptr
    entity = load tmp_4915+8 as ptr
    !tmp_4915
    !a
    a = next_a
    tmp_4916 = load entity+0 as i32
    tmp_4917 = 1
    tmp_4918 = add i, tmp_4917
    !tmp_4917
    tmp_4919 = ne tmp_4916, tmp_4918
    !tmp_4916
    !tmp_4918
    br tmp_4919 -> L_THEN_1287, L_ELSE_1288

L_THEN_1287:
