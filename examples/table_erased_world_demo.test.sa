    panic(2120)

L_ELSE_1264:
    !tmp_4879
    jmp L_MERGE_1265

L_MERGE_1265:
    tmp_4882 = call @sla__is_alive(a2, fabricated)
    tmp_4883 = 0
    tmp_4884 = ne tmp_4882, tmp_4883
    !tmp_4882
    !tmp_4883
    br tmp_4884 -> L_THEN_1266, L_ELSE_1267

L_THEN_1266:
    !tmp_4884
    panic(2121)

L_ELSE_1267:
    !tmp_4884
    jmp L_MERGE_1268

L_MERGE_1268:
    tmp_4887 = call @sla__alloc_entity(a2)
    a3 = load tmp_4887+0 as ptr
    e2 = load tmp_4887+8 as ptr
    !tmp_4887
    tmp_4888 = call @sla__entity_eq(e2, fabricated)
    tmp_4889 = 1
    tmp_4890 = ne tmp_4888, tmp_4889
    !tmp_4888
    !tmp_4889
    br tmp_4890 -> L_THEN_1269, L_ELSE_1270

L_THEN_1269:
    !tmp_4890
    panic(2122)

L_ELSE_1270:
    !tmp_4890
    jmp L_MERGE_1271

L_MERGE_1271:
    tmp_4893 = call @sla__is_alive(a3, e2)
    tmp_4894 = 1
    tmp_4895 = ne tmp_4893, tmp_4894
    !tmp_4893
    !tmp_4894
    br tmp_4895 -> L_THEN_1272, L_ELSE_1273

L_THEN_1272:
    !tmp_4895
    panic(2123)

L_ELSE_1273:
    !tmp_4895
    jmp L_MERGE_1274

L_MERGE_1274:
    !e2
    !a0
    !a2
    !fabricated
    !stale
    !e1
    !a3
    !a1
    return

