L_ELSE_1291:
    !tmp_4924
    jmp L_MERGE_1292

L_MERGE_1292:
    tmp_4927 = 1
    tmp_4928 = add i, tmp_4927
    !tmp_4927
    !i
    i = tmp_4928
    !entity
    jmp L_WHILE_HEAD_1283

L_WHILE_COND_FALSE_1285:
    !tmp_4914
    jmp L_WHILE_EXIT_1286

L_WHILE_EXIT_1286:
    tmp_4929 = load a+8 as ptr
    EXPAND VEC_LEN tmp_4930, tmp_4929
    !tmp_4929
    tmp_4931 = 21
    tmp_4932 = ne tmp_4930, tmp_4931
    !tmp_4930
    !tmp_4931
    br tmp_4932 -> L_THEN_1293, L_ELSE_1294

L_THEN_1293:
