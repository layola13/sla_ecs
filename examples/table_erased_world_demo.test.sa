L_TEST_ENTRY_1232:
    tmp_4805 = call @sla__component_registry_new()
    reg0 = tmp_4805
    tmp_4806 = call @sla__component_register_table(reg0)
    reg1 = load tmp_4806+0 as ptr
    table_info = load tmp_4806+8 as ptr
    !tmp_4806
    tmp_4807 = call @sla__component_register_sparse_set(reg1)
    reg2 = load tmp_4807+0 as ptr
    sparse_info = load tmp_4807+8 as ptr
    !tmp_4807
    tmp_4808 = load table_info+0 as i32
    tmp_4809 = 1
    tmp_4810 = ne tmp_4808, tmp_4809
    !tmp_4808
    !tmp_4809
    br tmp_4810 -> L_THEN_1233, L_ELSE_1234

L_THEN_1233:
    !tmp_4810
    panic(4310)

L_ELSE_1234:
    !tmp_4810
    jmp L_MERGE_1235

L_MERGE_1235:
    tmp_4813 = load sparse_info+0 as i32
    tmp_4814 = 2
    tmp_4815 = ne tmp_4813, tmp_4814
    !tmp_4813
    !tmp_4814
    br tmp_4815 -> L_THEN_1236, L_ELSE_1237

L_THEN_1236:
    !tmp_4815
    panic(4311)

L_ELSE_1237:
    !tmp_4815
    jmp L_MERGE_1238

L_MERGE_1238:
    tmp_4818 = load table_info+8 as ptr
    tmp_4819 = call @sla__storage_kind_is_table(^tmp_4818)
    tmp_4820 = 1
    tmp_4821 = ne tmp_4819, tmp_4820
    !tmp_4819
    !tmp_4820
    br tmp_4821 -> L_THEN_1239, L_ELSE_1240

L_THEN_1239:
    !tmp_4821
    panic(4312)

L_ELSE_1240:
    !tmp_4821
    jmp L_MERGE_1241

L_MERGE_1241:
    tmp_4824 = load sparse_info+8 as ptr
    tmp_4825 = call @sla__storage_kind_is_sparse_set(^tmp_4824)
    tmp_4826 = 1
    tmp_4827 = ne tmp_4825, tmp_4826
    !tmp_4825
    !tmp_4826
    br tmp_4827 -> L_THEN_1242, L_ELSE_1243

L_THEN_1242:
    !tmp_4827
    panic(4313)

L_ELSE_1243:
    !tmp_4827
    jmp L_MERGE_1244

L_MERGE_1244:
    tmp_4830 = 2
    tmp_4831 = call @sla__component_registry_get(reg2, tmp_4830)
    !tmp_4830
    again = tmp_4831
    tmp_4832 = load again+0 as i32
    tmp_4833 = load sparse_info+0 as i32
    tmp_4834 = ne tmp_4832, tmp_4833
    !tmp_4832
    !tmp_4833
    br tmp_4834 -> L_THEN_1245, L_ELSE_1246

L_THEN_1245:
    !tmp_4834
    panic(4314)

L_ELSE_1246:
    !tmp_4834
    jmp L_MERGE_1247

L_MERGE_1247:
    tmp_4837 = load again+8 as ptr
    tmp_4838 = call @sla__storage_kind_is_sparse_set(^tmp_4837)
    tmp_4839 = 1
    tmp_4840 = ne tmp_4838, tmp_4839
    !tmp_4838
    !tmp_4839
    br tmp_4840 -> L_THEN_1248, L_ELSE_1249

L_THEN_1248:
