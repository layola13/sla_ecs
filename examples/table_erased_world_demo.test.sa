L_LOOP_HEAD_1744:
    tmp_6393 = load entity_slot+0 as i64
    tmp_6394 = slt tmp_6393, tmp_6392
    br tmp_6394 -> L_LOOP_BODY_1745, L_LOOP_COND_FALSE_1747

L_LOOP_BODY_1745:
