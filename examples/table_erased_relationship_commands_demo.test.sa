    tmp_21745 = call @sla__relationship_world_is_alive(w5, tmp_21742)
    !tmp_21742
    tmp_21746 = 0
    tmp_21747 = ne tmp_21745, tmp_21746
    !tmp_21745
    !tmp_21746
    br tmp_21747 -> L_THEN_5443, L_ELSE_5444

L_THEN_5443:
