@test "relationship linked despawn follows target collection"():
L_TEST_ENTRY_5442:
    tmp_21723 = call @sla__relationship_world_new()
    w0 = tmp_21723
    tmp_21724 = 1
    tmp_21725 = 0
    tmp_21726 = call @sla__relationship_world_register_many(w0, tmp_21724, tmp_21725)
    !tmp_21724
    !tmp_21725
    w1 = load tmp_21726+0 as ptr
    linked = load tmp_21726+8 as ptr
    !tmp_21726
    tmp_21727 = call @sla__relationship_world_spawn(w1)
    w2 = load tmp_21727+0 as ptr
    root = load tmp_21727+8 as ptr
    !tmp_21727
    tmp_21728 = load linked+0 as i32
    tmp_21729 = alloc 8
    tmp_21730 = load root+0 as i32
    store tmp_21729+0, tmp_21730 as i32
    tmp_21731 = load root+4 as i32
    store tmp_21729+4, tmp_21731 as i32
    tmp_21732 = call @sla__relationship_world_spawn_related(w2, tmp_21728, tmp_21729)
    !tmp_21728
    !tmp_21729
    w3 = load tmp_21732+0 as ptr
    child = load tmp_21732+8 as ptr
    !tmp_21732
    tmp_21733 = load linked+0 as i32
    tmp_21734 = alloc 8
    tmp_21735 = load child+0 as i32
    store tmp_21734+0, tmp_21735 as i32
    tmp_21736 = load child+4 as i32
    store tmp_21734+4, tmp_21736 as i32
    tmp_21737 = call @sla__relationship_world_spawn_related(w3, tmp_21733, tmp_21734)
    !tmp_21733
    !tmp_21734
    w4 = load tmp_21737+0 as ptr
    grandchild = load tmp_21737+8 as ptr
    !tmp_21737
    tmp_21738 = alloc 8
    tmp_21739 = load root+0 as i32
    store tmp_21738+0, tmp_21739 as i32
    tmp_21740 = load root+4 as i32
    store tmp_21738+4, tmp_21740 as i32
    tmp_21741 = call @sla__relationship_world_despawn(w4, tmp_21738)
    !tmp_21738
    w5 = tmp_21741
    tmp_21742 = alloc 8
