@test "relationship many target syncs source and target"():
L_TEST_ENTRY_2399:
    tmp_8390 = call @sla__relationship_world_new()
    w0 = tmp_8390
    tmp_8391 = 0
    tmp_8392 = 0
    tmp_8393 = call @sla__relationship_world_register_many(w0, tmp_8391, tmp_8392)
    !tmp_8391
