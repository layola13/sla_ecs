@test "registry value schedule records component id conflicts"():
L_TEST_ENTRY_1494:
    tmp_5134 = call @sla__registry_value_system_access_none()
    tmp_5135 = 1
    tmp_5136 = call @sla__registry_value_access_write_component(tmp_5134, tmp_5135)
    !tmp_5134
    !tmp_5135
    write_health = tmp_5136
    tmp_5137 = call @sla__registry_value_system_access_none()
    tmp_5138 = 1
    tmp_5139 = call @sla__registry_value_access_read_component(tmp_5137, tmp_5138)
    !tmp_5137
    !tmp_5138
    read_health = tmp_5139
    tmp_5140 = call @sla__registry_value_system_access_none()
    tmp_5141 = call @sla__registry_value_access_write_messages(tmp_5140)
    !tmp_5140
    write_message = tmp_5141
    tmp_5142 = call @sla__registry_value_schedule_default_RegValueScheduleData_RegValueScheduleTime_RegValueScheduleEvent()
    s0 = tmp_5142
    tmp_5143 = alloc 16
    store tmp_5143+0, 0 as ptr
    store tmp_5143+8, &SLA_FNPTR_VT_reg_value_schedule_move_system as ptr
    tmp_5144 = call @sla__registry_value_system_new_RegValueScheduleData_RegValueScheduleTime_RegValueScheduleEvent(tmp_5143, write_health)
    !tmp_5143
    tmp_5145 = call @sla__registry_value_schedule_add_systems_RegValueScheduleData_RegValueScheduleTime_RegValueScheduleEvent(s0, tmp_5144)
    !tmp_5144
    s1 = tmp_5145
    tmp_5146 = alloc 16
    store tmp_5146+0, 0 as ptr
    store tmp_5146+8, &SLA_FNPTR_VT_reg_value_schedule_move_system as ptr
    tmp_5147 = call @sla__registry_value_system_new_RegValueScheduleData_RegValueScheduleTime_RegValueScheduleEvent(tmp_5146, read_health)
    !tmp_5146
    tmp_5148 = call @sla__registry_value_schedule_add_systems_RegValueScheduleData_RegValueScheduleTime_RegValueScheduleEvent(s1, tmp_5147)
    !tmp_5147
    s2 = tmp_5148
    tmp_5149 = alloc 16
    store tmp_5149+0, 0 as ptr
    store tmp_5149+8, &SLA_FNPTR_VT_reg_value_schedule_message_system as ptr
    tmp_5150 = call @sla__registry_value_system_new_RegValueScheduleData_RegValueScheduleTime_RegValueScheduleEvent(tmp_5149, write_message)
    !tmp_5149
    tmp_5151 = call @sla__registry_value_schedule_add_systems_RegValueScheduleData_RegValueScheduleTime_RegValueScheduleEvent(s2, tmp_5150)
    !tmp_5150
