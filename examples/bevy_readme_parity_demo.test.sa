    tmp_5152 = call @sla__registry_value_schedule_conflict_count_RegValueScheduleData_RegValueScheduleTime_RegValueScheduleEvent(s3)
    tmp_5153 = 1
    tmp_5154 = ne tmp_5152, tmp_5153
    !tmp_5152
