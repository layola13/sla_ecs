@test "entity placeholder is never allocated"():
L_TEST_ENTRY_340:
    tmp_1400 = call @sla__entity_placeholder()
    placeholder = tmp_1400
    tmp_1401 = call @sla__allocator_new()
    a = tmp_1401
    tmp_1402 = call @sla__alloc_entity(a)
    a1 = load tmp_1402+0 as ptr
    e1 = load tmp_1402+8 as ptr
    !tmp_1402
    tmp_1403 = load placeholder+0 as i32
    tmp_1404 = load e1+0 as i32
    tmp_1405 = eq tmp_1403, tmp_1404
    !tmp_1403
    !tmp_1404
    br tmp_1405 -> L_THEN_341, L_ELSE_342

L_THEN_341:
    !tmp_1405
    panic(2100)

L_ELSE_342:
    !tmp_1405
    jmp L_MERGE_343

L_MERGE_343:
    tmp_1408 = alloc 8
    tmp_1409 = load placeholder+0 as i32
    store tmp_1408+0, tmp_1409 as i32
    tmp_1410 = load placeholder+4 as i32
    store tmp_1408+4, tmp_1410 as i32
    tmp_1411 = call @sla__is_alive(a1, tmp_1408)
    !tmp_1408
    tmp_1412 = 0
    tmp_1413 = ne tmp_1411, tmp_1412
    !tmp_1411
    !tmp_1412
    br tmp_1413 -> L_THEN_344, L_ELSE_345

L_THEN_344:
    !tmp_1413
    panic(2101)

L_ELSE_345:
    !tmp_1413
    jmp L_MERGE_346

L_MERGE_346:
    !a
    !placeholder
    !e1
    !a1
    return

@test "entity bit roundtrip"():
L_TEST_ENTRY_347:
    tmp_1416 = 42
    tmp_1417 = 7
    tmp_1418 = call @sla__entity_new(tmp_1416, tmp_1417)
    !tmp_1416
    !tmp_1417
    e = tmp_1418
    tmp_1419 = alloc 8
    tmp_1420 = load e+0 as i32
    store tmp_1419+0, tmp_1420 as i32
    tmp_1421 = load e+4 as i32
    store tmp_1419+4, tmp_1421 as i32
    tmp_1422 = call @sla__entity_to_bits(tmp_1419)
    !tmp_1419
    bits = tmp_1422
    tmp_1423 = call @sla__entity_from_bits(bits)
    out = tmp_1423
    tmp_1424 = alloc 8
    tmp_1425 = load e+0 as i32
    store tmp_1424+0, tmp_1425 as i32
    tmp_1426 = load e+4 as i32
    store tmp_1424+4, tmp_1426 as i32
    tmp_1427 = alloc 8
    tmp_1428 = load out+0 as i32
    store tmp_1427+0, tmp_1428 as i32
    tmp_1429 = load out+4 as i32
    store tmp_1427+4, tmp_1429 as i32
    tmp_1430 = call @sla__entity_eq(tmp_1424, tmp_1427)
    !tmp_1424
    !tmp_1427
    tmp_1431 = 1
    tmp_1432 = ne tmp_1430, tmp_1431
    !tmp_1430
    !tmp_1431
    br tmp_1432 -> L_THEN_348, L_ELSE_349

L_THEN_348:
