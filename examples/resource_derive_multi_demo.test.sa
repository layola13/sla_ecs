@test "erased resources store multiple unique resources by type"():
L_TEST_ENTRY_560:
    tmp_1918 = call @sla__ErasedResourceTime_resource_type_id()
    time_type = tmp_1918
    tmp_1919 = call @sla__ErasedResourceScore_resource_type_id()
    score_type = tmp_1919
    tmp_1920 = 0
    tmp_1921 = sle time_type, tmp_1920
    !tmp_1920
    br tmp_1921 -> L_THEN_561, L_ELSE_562

L_THEN_561:
    !tmp_1921
    panic(12310)

L_ELSE_562:
    !tmp_1921
    jmp L_MERGE_563

L_MERGE_563:
    tmp_1924 = 0
    tmp_1925 = sle score_type, tmp_1924
    !tmp_1924
    br tmp_1925 -> L_THEN_564, L_ELSE_565

L_THEN_564:
    !tmp_1925
    panic(12311)

L_ELSE_565:
    !tmp_1925
    jmp L_MERGE_566

L_MERGE_566:
    tmp_1928 = eq time_type, score_type
    br tmp_1928 -> L_THEN_567, L_ELSE_568

L_THEN_567:
    !tmp_1928
    panic(12312)

L_ELSE_568:
    !tmp_1928
    jmp L_MERGE_569

L_MERGE_569:
    tmp_1931 = call @sla__erased_resources_new()
    r0 = tmp_1931
    tmp_1932 = alloc 16
    store tmp_1932+0, 0 as ptr
    store tmp_1932+8, &SLA_FNPTR_VT_erased_resource_time_drop as ptr
    tmp_1933 = alloc 4
    tmp_1934 = 1
    store tmp_1933+0, tmp_1934 as i32
    !tmp_1934
    tmp_1935 = call @sla__erased_resources_insert_ErasedResourceTime(r0, time_type, tmp_1932, tmp_1933)
    !tmp_1932
    !tmp_1933
    r1 = tmp_1935
    tmp_1936 = alloc 16
    store tmp_1936+0, 0 as ptr
    store tmp_1936+8, &SLA_FNPTR_VT_erased_resource_score_drop as ptr
    tmp_1937 = alloc 4
    tmp_1938 = 7
    store tmp_1937+0, tmp_1938 as i32
    !tmp_1938
    tmp_1939 = call @sla__erased_resources_insert_ErasedResourceScore(r1, score_type, tmp_1936, tmp_1937)
    !tmp_1936
    !tmp_1937
    r2 = tmp_1939
    tmp_1940 = call @sla__erased_resources_count(r2)
    tmp_1941 = 2
    tmp_1942 = ne tmp_1940, tmp_1941
    !tmp_1940
    !tmp_1941
    br tmp_1942 -> L_THEN_570, L_ELSE_571

L_THEN_570:
    !tmp_1942
    panic(12313)

L_ELSE_571:
    !tmp_1942
    jmp L_MERGE_572

L_MERGE_572:
    tmp_1945 = call @sla__erased_resources_has(r2, time_type)
    tmp_1946 = 1
    tmp_1947 = ne tmp_1945, tmp_1946
    !tmp_1945
    !tmp_1946
    br tmp_1947 -> L_THEN_573, L_ELSE_574

L_THEN_573:
    !tmp_1947
    panic(12314)

L_ELSE_574:
    !tmp_1947
    jmp L_MERGE_575

L_MERGE_575:
    tmp_1950 = call @sla__erased_resources_has(r2, score_type)
    tmp_1951 = 1
    tmp_1952 = ne tmp_1950, tmp_1951
    !tmp_1950
    !tmp_1951
    br tmp_1952 -> L_THEN_576, L_ELSE_577

L_THEN_576:
    !tmp_1952
    panic(12315)

L_ELSE_577:
    !tmp_1952
    jmp L_MERGE_578

L_MERGE_578:
    tmp_1955 = call @sla__erased_resources_get_ErasedResourceTime(r2, time_type)
    tmp_1956 = load tmp_1955+0 as i32
    !tmp_1955
    tmp_1957 = 1
    tmp_1958 = ne tmp_1956, tmp_1957
    !tmp_1956
    !tmp_1957
    br tmp_1958 -> L_THEN_579, L_ELSE_580

L_THEN_579:
    !tmp_1958
    panic(12316)

L_ELSE_580:
    !tmp_1958
    jmp L_MERGE_581

L_MERGE_581:
    tmp_1961 = call @sla__erased_resources_get_ErasedResourceScore(r2, score_type)
    tmp_1962 = load tmp_1961+0 as i32
    !tmp_1961
    tmp_1963 = 7
    tmp_1964 = ne tmp_1962, tmp_1963
    !tmp_1962
    !tmp_1963
    br tmp_1964 -> L_THEN_582, L_ELSE_583

L_THEN_582:
    !tmp_1964
    panic(12317)

L_ELSE_583:
    !tmp_1964
    jmp L_MERGE_584

L_MERGE_584:
    !r1
    !time_type
    !score_type
    !r2
    !r0
    return

@test "erased resources replace track changes and remove independently"():
L_TEST_ENTRY_585:
    tmp_1967 = call @sla__ErasedResourceTime_resource_type_id()
    time_type = tmp_1967
    tmp_1968 = call @sla__ErasedResourceScore_resource_type_id()
    score_type = tmp_1968
    tmp_1969 = call @sla__erased_resources_new()
    r0 = tmp_1969
    tmp_1970 = alloc 16
    store tmp_1970+0, 0 as ptr
    store tmp_1970+8, &SLA_FNPTR_VT_erased_resource_time_drop as ptr
    tmp_1971 = alloc 4
    tmp_1972 = 1
    store tmp_1971+0, tmp_1972 as i32
    !tmp_1972
    tmp_1973 = call @sla__erased_resources_insert_ErasedResourceTime(r0, time_type, tmp_1970, tmp_1971)
    !tmp_1970
    !tmp_1971
    r1 = tmp_1973
    tmp_1974 = alloc 16
    store tmp_1974+0, 0 as ptr
    store tmp_1974+8, &SLA_FNPTR_VT_erased_resource_score_drop as ptr
    tmp_1975 = alloc 4
    tmp_1976 = 7
    store tmp_1975+0, tmp_1976 as i32
    !tmp_1976
    tmp_1977 = call @sla__erased_resources_insert_ErasedResourceScore(r1, score_type, tmp_1974, tmp_1975)
    !tmp_1974
    !tmp_1975
    r2 = tmp_1977
    tmp_1978 = load r2+8 as i32
    before = tmp_1978
    tmp_1979 = call @sla__erased_resources_increment_tick(r2)
    r3 = tmp_1979
    tmp_1980 = alloc 16
    store tmp_1980+0, 0 as ptr
    store tmp_1980+8, &SLA_FNPTR_VT_erased_resource_time_drop as ptr
    tmp_1981 = alloc 4
    tmp_1982 = 3
    store tmp_1981+0, tmp_1982 as i32
    !tmp_1982
    tmp_1983 = call @sla__erased_resources_insert_ErasedResourceTime(r3, time_type, tmp_1980, tmp_1981)
    !tmp_1980
    !tmp_1981
    r4 = tmp_1983
    tmp_1984 = call @sla__erased_resources_added_since(r4, time_type, before)
    tmp_1985 = 0
    tmp_1986 = ne tmp_1984, tmp_1985
    !tmp_1984
    !tmp_1985
    br tmp_1986 -> L_THEN_586, L_ELSE_587

L_THEN_586:
    !tmp_1986
    panic(12320)

L_ELSE_587:
    !tmp_1986
    jmp L_MERGE_588

L_MERGE_588:
    tmp_1989 = call @sla__erased_resources_changed_since(r4, time_type, before)
    tmp_1990 = 1
    tmp_1991 = ne tmp_1989, tmp_1990
    !tmp_1989
    !tmp_1990
    br tmp_1991 -> L_THEN_589, L_ELSE_590

L_THEN_589:
    !tmp_1991
    panic(12321)

L_ELSE_590:
    !tmp_1991
    jmp L_MERGE_591

L_MERGE_591:
    tmp_1994 = call @sla__erased_resources_changed_since(r4, score_type, before)
    tmp_1995 = 0
    tmp_1996 = ne tmp_1994, tmp_1995
    !tmp_1994
    !tmp_1995
    br tmp_1996 -> L_THEN_592, L_ELSE_593

L_THEN_592:
    !tmp_1996
    panic(12322)

L_ELSE_593:
    !tmp_1996
    jmp L_MERGE_594

L_MERGE_594:
    tmp_1999 = call @sla__erased_resources_res_ErasedResourceScore(r4, score_type)
    score_res = tmp_1999
    tmp_2000 = load score_res+0 as ptr
    tmp_2001 = load tmp_2000+0 as i32
    !tmp_2000
    tmp_2002 = 7
    tmp_2003 = ne tmp_2001, tmp_2002
    !tmp_2001
    !tmp_2002
    br tmp_2003 -> L_THEN_595, L_ELSE_596

L_THEN_595:
    !tmp_2003
    panic(12323)

L_ELSE_596:
    !tmp_2003
    jmp L_MERGE_597

L_MERGE_597:
    tmp_2006 = call @sla__erased_resources_res_mut_ErasedResourceScore(r4, score_type)
    score_mut = tmp_2006
    tmp_2007 = alloc 4
    tmp_2008 = 8
    store tmp_2007+0, tmp_2008 as i32
    !tmp_2008
    tmp_2009 = call @sla__erased_resources_res_mut_write_ErasedResourceScore(r4, score_type, score_mut, tmp_2007)
    !tmp_2007
    r5 = tmp_2009
    tmp_2010 = call @sla__erased_resources_changed_since(r5, score_type, before)
    tmp_2011 = 1
    tmp_2012 = ne tmp_2010, tmp_2011
    !tmp_2010
    !tmp_2011
    br tmp_2012 -> L_THEN_598, L_ELSE_599

L_THEN_598:
    !tmp_2012
    panic(12324)

L_ELSE_599:
    !tmp_2012
    jmp L_MERGE_600

L_MERGE_600:
    tmp_2015 = call @sla__erased_resources_remove(r5, time_type)
    r6 = tmp_2015
    tmp_2016 = call @sla__erased_resources_has(r6, time_type)
    tmp_2017 = 0
    tmp_2018 = ne tmp_2016, tmp_2017
    !tmp_2016
    !tmp_2017
    br tmp_2018 -> L_THEN_601, L_ELSE_602

L_THEN_601:
    !tmp_2018
    panic(12325)

L_ELSE_602:
    !tmp_2018
    jmp L_MERGE_603

L_MERGE_603:
    tmp_2021 = call @sla__erased_resources_has(r6, score_type)
    tmp_2022 = 1
    tmp_2023 = ne tmp_2021, tmp_2022
    !tmp_2021
    !tmp_2022
    br tmp_2023 -> L_THEN_604, L_ELSE_605

L_THEN_604:
    !tmp_2023
    panic(12326)

L_ELSE_605:
    !tmp_2023
    jmp L_MERGE_606

L_MERGE_606:
    tmp_2026 = call @sla__erased_resources_count(r6)
    tmp_2027 = 1
    tmp_2028 = ne tmp_2026, tmp_2027
    !tmp_2026
    !tmp_2027
    br tmp_2028 -> L_THEN_607, L_ELSE_608

L_THEN_607:
    !tmp_2028
    panic(12327)

L_ELSE_608:
    !tmp_2028
    jmp L_MERGE_609

L_MERGE_609:
    tmp_2031 = call @sla__erased_resources_get_ErasedResourceScore(r6, score_type)
    tmp_2032 = load tmp_2031+0 as i32
    !tmp_2031
    tmp_2033 = 8
    tmp_2034 = ne tmp_2032, tmp_2033
    !tmp_2032
    !tmp_2033
    br tmp_2034 -> L_THEN_610, L_ELSE_611

L_THEN_610:
    !tmp_2034
    panic(12328)

L_ELSE_611:
    !tmp_2034
    jmp L_MERGE_612

L_MERGE_612:
    !r5
    !time_type
    !score_res
    !score_mut
    !score_type
    !r4
    !r1
    !before
    !r6
    !r3
    !r2
    !r0
    return

@test "derive resource multi store demo"():
L_TEST_ENTRY_613:
    tmp_2037 = call @sla__resource_derive_multi_demo()
    tmp_2038 = 47
    tmp_2039 = ne tmp_2037, tmp_2038
    !tmp_2037
    !tmp_2038
    br tmp_2039 -> L_THEN_614, L_ELSE_615

L_THEN_614:
    !tmp_2039
    panic(12408)

L_ELSE_615:
    !tmp_2039
    jmp L_MERGE_616

L_MERGE_616:
    return
