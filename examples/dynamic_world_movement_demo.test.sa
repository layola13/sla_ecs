@sla__entity_new(id: i32, gen: i32) -> ptr:
L_ENTRY:
    tmp_0 = alloc 8
    store tmp_0+0, id as i32
    store tmp_0+4, gen as i32
    return tmp_0

@sla__entity_placeholder() -> ptr:
L_ENTRY:
    tmp_1 = alloc 8
    tmp_2 = 0
    store tmp_1+0, tmp_2 as i32
    !tmp_2
    tmp_3 = 0
    tmp_4 = 1
    tmp_5 = sub tmp_3, tmp_4
    !tmp_3
    !tmp_4
    store tmp_1+4, tmp_5 as i32
    !tmp_5
    return tmp_1

@sla__entity_index(entity: ptr) -> i32:
L_ENTRY:
