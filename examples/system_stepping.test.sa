    !tmp_2534
    tmp_2536 = load e+0 as i32
    EXPAND FORMAT_PUSH_I64 tmp_2537, tmp_2527, tmp_2536
    @const SLA_STR_4 = utf8:", "
    tmp_2538 = &SLA_STR_4
