    !tmp_2542
    tmp_2544 = load e+4 as i32
    EXPAND FORMAT_PUSH_I64 tmp_2545, tmp_2527, tmp_2544
    @const SLA_STR_7 = utf8:" }"
    tmp_2546 = &SLA_STR_7
    EXPAND FORMAT_PUSH_BYTES tmp_2547, tmp_2527, tmp_2546, 2
    !tmp_2546
    text = tmp_2527
    EXPAND STRING_BUF_AS_STR tmp_2548, text
    EXPAND STRING_LEN tmp_2549, tmp_2548
    !tmp_2548
    tmp_2550 = 0
    tmp_2551 = eq tmp_2549, tmp_2550
