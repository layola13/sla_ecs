    tmp_2456 = load copied+0 as i32
    tmp_2457 = load e+0 as i32
    tmp_2458 = eq tmp_2456, tmp_2457
    tmp_2459 = load copied+4 as i32
    tmp_2460 = load e+4 as i32
    tmp_2461 = eq tmp_2459, tmp_2460
