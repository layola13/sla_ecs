    tmp_2474 = xor tmp_2471, tmp_2473
    tmp_2475 = mul tmp_2474, 1099511628211
    tmp_2476 = load copied+4 as i32
    tmp_2477 = tmp_2476 as u64
    tmp_2478 = xor tmp_2475, tmp_2477
    tmp_2479 = mul tmp_2478, 1099511628211
    tmp_2480 = 1469598103934665603
    tmp_2481 = load e+0 as i32
    tmp_2482 = tmp_2481 as u64
    tmp_2483 = xor tmp_2480, tmp_2482
    tmp_2484 = mul tmp_2483, 1099511628211
    tmp_2485 = load e+4 as i32
    tmp_2486 = tmp_2485 as u64
    tmp_2487 = xor tmp_2484, tmp_2486
