L_TEST_ENTRY_641:
    tmp_2432 = 42
    tmp_2433 = 7
    tmp_2434 = call @sla__entity_new(tmp_2432, tmp_2433)
    !tmp_2432
    !tmp_2433
    e = tmp_2434
    tmp_2435 = alloc 8
    tmp_2436 = load e+0 as i32
    store tmp_2435+0, tmp_2436 as i32
    tmp_2437 = load e+4 as i32
    store tmp_2435+4, tmp_2437 as i32
    tmp_2438 = call @sla__entity_to_bits(tmp_2435)
    !tmp_2435
    bits = tmp_2438
    tmp_2439 = call @sla__entity_from_bits(bits)
    out = tmp_2439
    tmp_2440 = alloc 8
    tmp_2441 = load e+0 as i32
    store tmp_2440+0, tmp_2441 as i32
    tmp_2442 = load e+4 as i32
    store tmp_2440+4, tmp_2442 as i32
    tmp_2443 = alloc 8
    tmp_2444 = load out+0 as i32
    store tmp_2443+0, tmp_2444 as i32
    tmp_2445 = load out+4 as i32
    store tmp_2443+4, tmp_2445 as i32
    tmp_2446 = call @sla__entity_eq(tmp_2440, tmp_2443)
    !tmp_2440
    !tmp_2443
    tmp_2447 = 1
    tmp_2448 = ne tmp_2446, tmp_2447
    !tmp_2446
    !tmp_2447
    br tmp_2448 -> L_THEN_642, L_ELSE_643

L_THEN_642:
    !tmp_2448
    panic(2110)

L_ELSE_643:
    !tmp_2448
    jmp L_MERGE_644

L_MERGE_644:
    !out
    !bits
    !e
    return

