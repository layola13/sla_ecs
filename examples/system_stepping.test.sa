    tmp_2512 = load e+0 as i32
    tmp_2513 = sgt tmp_2511, tmp_2512
    tmp_2514 = eq tmp_2511, tmp_2512
    tmp_2515 = load later+4 as i32
    tmp_2516 = load e+4 as i32
