    tmp_2498 = eq tmp_2495, tmp_2496
    tmp_2499 = load e+4 as i32
    tmp_2500 = load later+4 as i32
    tmp_2501 = slt tmp_2499, tmp_2500
    tmp_2502 = eq tmp_2499, tmp_2500
    tmp_2503 = and tmp_2498, tmp_2501
    tmp_2504 = or tmp_2497, tmp_2503
    tmp_2505 = and tmp_2498, tmp_2502
