@sla__allocator_id_is_free(a: ptr, id: i32) -> u8:
L_ENTRY:
    tmp_73 = 0
    i = tmp_73
    jmp L_WHILE_HEAD_6

L_WHILE_HEAD_6:
    tmp_74 = load a+4 as i32
    tmp_75 = slt i, tmp_74
