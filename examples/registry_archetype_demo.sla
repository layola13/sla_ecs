@import "../lib/archetype_registry.sla"

fn bevy_style_registry_archetype_demo() -> i32 {
    let w0 = registry_archetype_world_new();
    let (w1, position) = registry_archetype_world_register_table(w0);
    let (w2, velocity) = registry_archetype_world_register_table(w1);
    let (w3, marker) = registry_archetype_world_register_sparse_set(w2);
    let (w4, first) = registry_archetype_world_spawn(w3);
    let (w5, second) = registry_archetype_world_spawn(w4);
    let w6 = registry_archetype_world_insert_component(w5, first, position.id);
    let w7 = registry_archetype_world_insert_component(w6, first, velocity.id);
    let w8 = registry_archetype_world_insert_component(w7, second, velocity.id);
    let w9 = registry_archetype_world_insert_component(w8, second, position.id);
    let shared_group = registry_archetype_world_entity_archetype_id(w9, first);
    if shared_group != registry_archetype_world_entity_archetype_id(w9, second) { panic(9820); };
    if registry_archetype_world_archetype_entity_count(w9, shared_group) != 2 { panic(9821); };
    let w10 = registry_archetype_world_insert_component(w9, second, marker.id);
    if registry_archetype_world_entity_archetype_id(w10, first) == registry_archetype_world_entity_archetype_id(w10, second) { panic(9822); };
    let w11 = registry_archetype_world_remove_component(w10, second, marker.id);
    if registry_archetype_world_entity_archetype_id(w11, first) != registry_archetype_world_entity_archetype_id(w11, second) { panic(9823); };
    let w12 = registry_archetype_world_despawn(w11, first);
    let q = registry_archetype_world_query_component(w12, position.id);
    if len(q.items) != 1 { panic(9824); };
    if q.items[0].id != second.id { panic(9825); };
    return registry_archetype_world_archetype_entity_count(w12, registry_archetype_world_entity_archetype_id(w12, second)) as i32;
}

fn main() -> i32 { return bevy_style_registry_archetype_demo(); }

@test "registry archetype demo migrates component signatures"() {
    if bevy_style_registry_archetype_demo() != 1 { panic(9826); };
}
