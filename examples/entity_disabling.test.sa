@test "registry entity query supports for in"():
L_TEST_ENTRY_349:
    entity_slot = stack_alloc 8
    tmp_1343 = call @sla__registry_world_new()
    w0 = tmp_1343
    tmp_1344 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_1344+0 as ptr
    component = load tmp_1344+8 as ptr
    !tmp_1344
    tmp_1345 = call @sla__registry_world_spawn(w1)
    w2 = load tmp_1345+0 as ptr
    e1 = load tmp_1345+8 as ptr
    !tmp_1345
    tmp_1346 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_1346+0 as ptr
    e2 = load tmp_1346+8 as ptr
    !tmp_1346
    tmp_1347 = alloc 8
    tmp_1348 = load e1+0 as i32
    store tmp_1347+0, tmp_1348 as i32
    tmp_1349 = load e1+4 as i32
    store tmp_1347+4, tmp_1349 as i32
    tmp_1350 = load component+0 as i32
    tmp_1351 = call @sla__registry_world_insert_component(w3, tmp_1347, tmp_1350)
    !tmp_1347
    !tmp_1350
    w4 = tmp_1351
    tmp_1352 = alloc 8
    tmp_1353 = load e2+0 as i32
    store tmp_1352+0, tmp_1353 as i32
    tmp_1354 = load e2+4 as i32
    store tmp_1352+4, tmp_1354 as i32
    tmp_1355 = load component+0 as i32
    tmp_1356 = call @sla__registry_world_insert_component(w4, tmp_1352, tmp_1355)
    !tmp_1352
    !tmp_1355
    w5 = tmp_1356
    tmp_1357 = load component+0 as i32
    tmp_1358 = call @sla__registry_world_query_component(w5, tmp_1357)
    !tmp_1357
    q = tmp_1358
    tmp_1359 = 0
    total = tmp_1359
    tmp_1360 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_350

L_LOOP_HEAD_350:
    tmp_1361 = load entity_slot+0 as i64
    tmp_1362 = slt tmp_1361, tmp_1360
    br tmp_1362 -> L_LOOP_BODY_351, L_LOOP_COND_FALSE_354

L_LOOP_BODY_351:
    !tmp_1362
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_1361)
    tmp_1363 = load entity+0 as i32
    tmp_1364 = add total, tmp_1363
    !tmp_1363
    !total
    total = tmp_1364
L_LOOP_CONTINUE_352:
    tmp_1365 = add tmp_1361, 1
    store entity_slot+0, tmp_1365 as i64
    !tmp_1365
    !tmp_1361
    !entity
    jmp L_LOOP_HEAD_350

L_LOOP_COND_FALSE_354:
    !tmp_1362
    !tmp_1361
    jmp L_LOOP_EXIT_356

L_LOOP_EXIT_356:
    !tmp_1360
    tmp_1366 = load e1+0 as i32
    tmp_1367 = load e2+0 as i32
    tmp_1368 = add tmp_1366, tmp_1367
    !tmp_1366
    !tmp_1367
