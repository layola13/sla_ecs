@import "../lib/world_table_erased_relationship.sla"

fn bevy_style_table_erased_relationship_demo() -> i32 {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, position) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w1, true, false);
    let (w3, root) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w2);
    let (w4, child) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let w5 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w4, child, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 11, y: 0 });
    let w6 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w5, kind.id, child, root);
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w6, kind.id, root) != 1 { panic(12240); };
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w6, child, position.id, TABLE_ERASED_POS_TYPE).x != 11 { panic(12241); };
    let w7 = table_erased_relationship_world_despawn<TableErasedTime, TableErasedEvent>(w6, root);
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w7, root) != false { panic(12242); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w7, child) != false { panic(12243); };
    return 1;
}

fn main() -> i32 { return bevy_style_table_erased_relationship_demo(); }

@test "table erased relationship demo links components and relationships"() {
    if bevy_style_table_erased_relationship_demo() != 1 { panic(12244); };
}
