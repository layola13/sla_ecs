@import "lib/filtered_entity.sla"

// === Access ===

@test "access new and has_read none"() {
    let a = ecs_access_new();
    if ecs_access_has_read(a, 5) != false { panic(68001); };
    if ecs_access_has_write(a, 5) != false { panic(68002); };
    if ecs_access_has_read_all(a) != false { panic(68003); };
    if ecs_access_has_write_all(a) != false { panic(68004); };
}

@test "access add_read"() {
    let a = ecs_access_new();
    let a2 = ecs_access_add_read(a, 3);
    if ecs_access_has_read(a2, 3) != true { panic(68010); };
    if ecs_access_has_read(a2, 5) != false { panic(68011); };
}

@test "access add_write"() {
    let a = ecs_access_new();
    let a2 = ecs_access_add_write(a, 7);
    if ecs_access_has_write(a2, 7) != true { panic(68020); };
    if ecs_access_has_write(a2, 9) != false { panic(68021); };
}

@test "access read_all"() {
    let a = ecs_access_new();
    let a2 = ecs_access_set_read_all(a);
    if ecs_access_has_read(a2, 1) != true { panic(68030); };
    if ecs_access_has_read(a2, 99) != true { panic(68031); };
    if ecs_access_has_read_all(a2) != true { panic(68032); };
}

@test "access write_all"() {
    let a = ecs_access_new();
    let a2 = ecs_access_set_write_all(a);
    if ecs_access_has_write(a2, 1) != true { panic(68040); };
    if ecs_access_has_write(a2, 99) != true { panic(68041); };
    if ecs_access_has_write_all(a2) != true { panic(68042); };
}

@test "access clone"() {
    let a = ecs_access_new();
    let a2 = ecs_access_add_read(a, 3);
    let a3 = ecs_access_add_write(a2, 5);
    let a4 = ecs_access_clone(a3);
    if ecs_access_has_read(a4, 3) != true { panic(68050); };
    if ecs_access_has_write(a4, 5) != true { panic(68051); };
}

// === TryFromFilteredError ===

@test "try from filtered error ok"() {
    let e = ecs_try_from_filtered_error_ok();
    if ecs_try_from_filtered_error_is_ok(e) != true { panic(68060); };
    let e2 = ecs_try_from_filtered_error_missing_read_all();
    if ecs_try_from_filtered_error_is_ok(e2) != false { panic(68061); };
    if ecs_try_from_filtered_error_code(e2) != 1 { panic(68062); };
    let e3 = ecs_try_from_filtered_error_missing_write_all();
    if ecs_try_from_filtered_error_code(e3) != 2 { panic(68063); };
}

// === EntityComponents ===

@test "entity components insert and get"() {
    let ec = ecs_entity_components_new(42);
    let ec2 = ecs_entity_components_insert(ec, 5, 100);
    let g = ecs_entity_components_get(ec2, 5);
    if g.0 != true { panic(68070); };
    if g.1 != 100 { panic(68071); };
}

@test "entity components contains and count"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 1, 10);
    let ec3 = ecs_entity_components_insert(ec2, 2, 20);
    if ecs_entity_components_contains(ec3, 1) != true { panic(68080); };
    if ecs_entity_components_contains(ec3, 3) != false { panic(68081); };
    if ecs_entity_components_count(ec3) != 2 { panic(68082); };
    if ecs_entity_components_id(ec3) != 1 { panic(68083); };
}

// === FilteredEntityRef ===

@test "filtered entity ref get allowed"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 3, 300);
    let access = ecs_access_new();
    let access2 = ecs_access_add_read(access, 3);
    let f = ecs_filtered_entity_ref_new(ec2, access2);
    let g = ecs_filtered_entity_ref_get(f, 3);
    if g.0 != true { panic(68090); };
    if g.1 != 300 { panic(68091); };
}

@test "filtered entity ref get not allowed"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 3, 300);
    let access = ecs_access_new();
    let access2 = ecs_access_add_read(access, 5);
    let f = ecs_filtered_entity_ref_new(ec2, access2);
    let g = ecs_filtered_entity_ref_get(f, 3);
    if g.0 != false { panic(68100); };
}

@test "filtered entity ref get_ref and get_by_id"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 7, 700);
    let access = ecs_access_new();
    let access2 = ecs_access_add_read(access, 7);
    let f = ecs_filtered_entity_ref_new(ec2, access2);
    let gr = ecs_filtered_entity_ref_get_ref(f, 7);
    if gr.0 != true { panic(68110); };
    if gr.1 != 700 { panic(68111); };
    let gb = ecs_filtered_entity_ref_get_by_id(f, 7);
    if gb.0 != true { panic(68112); };
}

@test "filtered entity ref contains unfiltered"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 3, 300);
    let access = ecs_access_new();
    let f = ecs_filtered_entity_ref_new(ec2, access);
    // contains works even without access (checks entity storage)
    if ecs_filtered_entity_ref_contains(f, 3) != true { panic(68120); };
    if ecs_filtered_entity_ref_contains_id(f, 3) != true { panic(68121); };
    if ecs_filtered_entity_ref_contains_type_id(f, 3) != true { panic(68122); };
}

@test "filtered entity ref id location archetype"() {
    let ec = ecs_entity_components_new(42);
    let access = ecs_access_new();
    let f = ecs_filtered_entity_ref_new(ec, access);
    if ecs_filtered_entity_ref_id(f) != 42 { panic(68130); };
    let loc = ecs_filtered_entity_ref_location(f);
    if loc.0 != 0 { panic(68131); };
    if loc.1 != 0 { panic(68132); };
    if ecs_filtered_entity_ref_archetype(f) != 0 { panic(68133); };
}

@test "filtered entity ref try_into_all fail"() {
    let ec = ecs_entity_components_new(1);
    let access = ecs_access_new();
    let f = ecs_filtered_entity_ref_new(ec, access);
    let r = ecs_filtered_entity_ref_try_into_all(f);
    if r.0 != false { panic(68140); };
    if r.1 != 1 { panic(68141); };
}

@test "filtered entity ref try_into_all success"() {
    let ec = ecs_entity_components_new(1);
    let access = ecs_access_new();
    let access2 = ecs_access_set_read_all(access);
    let f = ecs_filtered_entity_ref_new(ec, access2);
    let r = ecs_filtered_entity_ref_try_into_all(f);
    if r.0 != true { panic(68150); };
}

// === FilteredEntityMut ===

@test "filtered entity mut get allowed"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 3, 300);
    let access = ecs_access_new();
    let access2 = ecs_access_add_read(access, 3);
    let f = ecs_filtered_entity_mut2_new(ec2, access2);
    let g = ecs_filtered_entity_mut2_get(f, 3);
    if g.0 != true { panic(68160); };
    if g.1 != 300 { panic(68161); };
}

@test "filtered entity mut get_mut allowed"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 3, 300);
    let access = ecs_access_new();
    let access2 = ecs_access_add_write(access, 3);
    let f = ecs_filtered_entity_mut2_new(ec2, access2);
    let g = ecs_filtered_entity_mut2_get_mut(f, 3);
    if g.0 != true { panic(68170); };
    if g.1 != 300 { panic(68171); };
}

@test "filtered entity mut get_mut denied (only read)"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 3, 300);
    let access = ecs_access_new();
    let access2 = ecs_access_add_read(access, 3);
    let f = ecs_filtered_entity_mut2_new(ec2, access2);
    let g = ecs_filtered_entity_mut2_get_mut(f, 3);
    if g.0 != false { panic(68180); };
}

@test "filtered entity mut get denied (only write)"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 3, 300);
    let access = ecs_access_new();
    let access2 = ecs_access_add_write(access, 3);
    let f = ecs_filtered_entity_mut2_new(ec2, access2);
    let g = ecs_filtered_entity_mut2_get(f, 3);
    if g.0 != false { panic(68190); };
}

@test "filtered entity mut try_into_all fail read"() {
    let ec = ecs_entity_components_new(1);
    let access = ecs_access_new();
    let f = ecs_filtered_entity_mut2_new(ec, access);
    let r = ecs_filtered_entity_mut2_try_into_all(f);
    if r.0 != false { panic(68200); };
    if r.1 != 1 { panic(68201); };
}

@test "filtered entity mut try_into_all fail write"() {
    let ec = ecs_entity_components_new(1);
    let access = ecs_access_new();
    let access2 = ecs_access_set_read_all(access);
    let f = ecs_filtered_entity_mut2_new(ec, access2);
    let r = ecs_filtered_entity_mut2_try_into_all(f);
    if r.0 != false { panic(68210); };
    if r.1 != 2 { panic(68211); };
}

@test "filtered entity mut try_into_all success"() {
    let ec = ecs_entity_components_new(1);
    let access = ecs_access_new();
    let access2 = ecs_access_set_read_all(access);
    let access3 = ecs_access_set_write_all(access2);
    let f = ecs_filtered_entity_mut2_new(ec, access3);
    let r = ecs_filtered_entity_mut2_try_into_all(f);
    if r.0 != true { panic(68220); };
}

@test "filtered entity mut reborrow and into_readonly"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 3, 300);
    let access = ecs_access_new();
    let access2 = ecs_access_add_write(access, 3);
    let f = ecs_filtered_entity_mut2_new(ec2, access2);
    let rb = ecs_filtered_entity_mut2_reborrow(f);
    if ecs_filtered_entity_mut2_id(rb) != 1 { panic(68230); };
    let fro = ecs_filtered_entity_mut2_into_readonly(f);
    if ecs_filtered_entity_ref_id(fro) != 1 { panic(68231); };
    let fro2 = ecs_filtered_entity_mut2_as_readonly(rb);
    if ecs_filtered_entity_ref_id(fro2) != 1 { panic(68232); };
}

// === UnsafeFilteredEntityMut ===

@test "unsafe filtered entity mut new and into_mut"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 3, 300);
    let access = ecs_access_new();
    let access2 = ecs_access_add_write(access, 3);
    let f = ecs_filtered_entity_mut2_new(ec2, access2);
    let u = ecs_unsafe_filtered_entity_mut_new_readonly(f);
    let f2 = ecs_unsafe_filtered_entity_mut_into_mut(u);
    let g = ecs_filtered_entity_mut2_get_mut(f2, 3);
    if g.0 != true { panic(68240); };
    if g.1 != 300 { panic(68241); };
}

// === PartialEq / Ord ===

@test "filtered entity ref eq"() {
    let ec1 = ecs_entity_components_new(5);
    let ec2 = ecs_entity_components_new(5);
    let access = ecs_access_new();
    let f1 = ecs_filtered_entity_ref_new(ec1, access);
    let f2 = ecs_filtered_entity_ref_new(ec2, access);
    if ecs_filtered_entity_ref_eq(f1, f2) != true { panic(68250); };
}

@test "filtered entity ref cmp"() {
    let ec1 = ecs_entity_components_new(3);
    let ec2 = ecs_entity_components_new(7);
    let access = ecs_access_new();
    let f1 = ecs_filtered_entity_ref_new(ec1, access);
    let f2 = ecs_filtered_entity_ref_new(ec2, access);
    if ecs_filtered_entity_ref_cmp(f1, f2) != -1 { panic(68260); };
    if ecs_filtered_entity_ref_cmp(f2, f1) != 1 { panic(68261); };
    if ecs_filtered_entity_ref_cmp(f1, f1) != 0 { panic(68262); };
}

@test "filtered entity mut eq and cmp"() {
    let ec1 = ecs_entity_components_new(5);
    let ec2 = ecs_entity_components_new(8);
    let access = ecs_access_new();
    let f1 = ecs_filtered_entity_mut2_new(ec1, access);
    let f2 = ecs_filtered_entity_mut2_new(ec2, access);
    if ecs_filtered_entity_mut2_eq(f1, f2) != false { panic(68270); };
    if ecs_filtered_entity_mut2_cmp(f1, f2) != -1 { panic(68271); };
}

@test "filtered entity ref get_change_ticks_by_id"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 5, 500);
    let access = ecs_access_new();
    let access2 = ecs_access_add_read(access, 5);
    let f = ecs_filtered_entity_ref_new(ec2, access2);
    let t = ecs_filtered_entity_ref_get_change_ticks_by_id(f, 5);
    if t.0 != true { panic(68280); };
    if t.1 != 500 { panic(68281); };
}

@test "filtered entity mut get_change_ticks_by_id"() {
    let ec = ecs_entity_components_new(1);
    let ec2 = ecs_entity_components_insert(ec, 5, 500);
    let access = ecs_access_new();
    let access2 = ecs_access_add_read(access, 5);
    let f = ecs_filtered_entity_mut2_new(ec2, access2);
    let t = ecs_filtered_entity_mut2_get_change_ticks_by_id(f, 5);
    if t.0 != true { panic(68290); };
    if t.1 != 500 { panic(68291); };
}
