// === query (from lens) ===

@test "query lens query"() {
    let access_ids = Vec::new();
    access_ids.push(1);
    let writes = Vec::new();
    writes.push(false);
    let entities = Vec::new();
    entities.push(10);
    let values = Vec::new();
    values.push(100);
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    let q = ecs_query_lens_query(lens);
    if ecs_query_lens_matched_count(q) != 1 { panic(79140); };
}
