@import "lib/query_lens.sla"

// === Basic ===

@test "query lens new"() {
    let access_ids = Vec::new();
    access_ids.push(1);
    let writes = Vec::new();
    writes.push(false);
    let entities = Vec::new();
    entities.push(10);
    let values = Vec::new();
    values.push(100);
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    if ecs_query_lens_access_count(lens) != 1 { panic(79001); };
    if ecs_query_lens_matched_count(lens) != 1 { panic(79002); };
}

@test "query lens has_access"() {
    let access_ids = Vec::new();
    access_ids.push(1);
    access_ids.push(2);
    let writes = Vec::new();
    writes.push(false);
    writes.push(true);
    let entities = Vec::new();
    let values = Vec::new();
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    if ecs_query_lens_has_access(lens, 1) != true { panic(79010); };
    if ecs_query_lens_has_access(lens, 3) != false { panic(79011); };
}

@test "query lens has_write"() {
    let access_ids = Vec::new();
    access_ids.push(1);
    access_ids.push(2);
    let writes = Vec::new();
    writes.push(false);
    writes.push(true);
    let entities = Vec::new();
    let values = Vec::new();
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    if ecs_query_lens_has_write(lens, 1) != false { panic(79020); };
    if ecs_query_lens_has_write(lens, 2) != true { panic(79021); };
    if ecs_query_lens_has_write(lens, 3) != false { panic(79022); };
}

// === transmute ===

@test "query lens transmute subset"() {
    let access_ids = Vec::new();
    access_ids.push(1);
    access_ids.push(2);
    access_ids.push(3);
    let writes = Vec::new();
    writes.push(false);
    writes.push(true);
    writes.push(false);
    let entities = Vec::new();
    entities.push(10);
    let values = Vec::new();
    values.push(100);
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    let new_ids = Vec::new();
    new_ids.push(1);
    new_ids.push(3);
    let new_writes = Vec::new();
    new_writes.push(false);
    new_writes.push(true);
    let transmuted = ecs_query_lens_transmute(lens, new_ids, new_writes);
    if ecs_query_lens_access_count(transmuted) != 2 { panic(79030); };
    if ecs_query_lens_has_access(transmuted, 1) != true { panic(79031); };
    if ecs_query_lens_has_access(transmuted, 2) != false { panic(79032); };
}

@test "query lens transmute invalid ignored"() {
    let access_ids = Vec::new();
    access_ids.push(1);
    let writes = Vec::new();
    writes.push(false);
    let entities = Vec::new();
    let values = Vec::new();
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    let new_ids = Vec::new();
    new_ids.push(1);
    new_ids.push(99);
    let new_writes = Vec::new();
    new_writes.push(false);
    new_writes.push(true);
    let transmuted = ecs_query_lens_transmute(lens, new_ids, new_writes);
    // Only 1 should be valid (id 1), 99 is not in original
    if ecs_query_lens_access_count(transmuted) != 1 { panic(79040); };
}

// === transmute_filtered ===

@test "query lens transmute_filtered"() {
    let access_ids = Vec::new();
    access_ids.push(1);
    let writes = Vec::new();
    writes.push(false);
    let entities = Vec::new();
    let values = Vec::new();
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    let new_ids = Vec::new();
    new_ids.push(1);
    let new_writes = Vec::new();
    new_writes.push(false);
    let filter_ids = Vec::new();
    filter_ids.push(5);
    let result = ecs_query_lens_transmute_filtered(lens, new_ids, new_writes, filter_ids);
    if ecs_query_lens_filter_count(result) != 1 { panic(79050); };
}

// === join ===

@test "query lens join"() {
    let a_ids = Vec::new();
    a_ids.push(1);
    let a_writes = Vec::new();
    a_writes.push(false);
    let a_entities = Vec::new();
    a_entities.push(10);
    a_entities.push(20);
    let a_values = Vec::new();
    a_values.push(100);
    a_values.push(200);
    let lens_a = ecs_query_lens_new(a_ids, a_writes, a_entities, a_values);

    let b_ids = Vec::new();
    b_ids.push(2);
    let b_writes = Vec::new();
    b_writes.push(true);
    let b_entities = Vec::new();
    b_entities.push(20);
    b_entities.push(30);
    let b_values = Vec::new();
    b_values.push(300);
    b_values.push(400);
    let lens_b = ecs_query_lens_new(b_ids, b_writes, b_entities, b_values);

    let joined = ecs_query_lens_join(lens_a, lens_b);
    // Only entity 20 is in both
    if ecs_query_lens_matched_count(joined) != 1 { panic(79060); };
    // Accesses from both lenses
    if ecs_query_lens_access_count(joined) != 2 { panic(79061); };
    if ecs_query_lens_has_access(joined, 1) != true { panic(79062); };
    if ecs_query_lens_has_access(joined, 2) != true { panic(79063); };
}

@test "query lens join no overlap"() {
    let a_ids = Vec::new();
    a_ids.push(1);
    let a_writes = Vec::new();
    a_writes.push(false);
    let a_entities = Vec::new();
    a_entities.push(10);
    let a_values = Vec::new();
    a_values.push(100);
    let lens_a = ecs_query_lens_new(a_ids, a_writes, a_entities, a_values);

    let b_ids = Vec::new();
    b_ids.push(2);
    let b_writes = Vec::new();
    b_writes.push(true);
    let b_entities = Vec::new();
    b_entities.push(20);
    let b_values = Vec::new();
    b_values.push(200);
    let lens_b = ecs_query_lens_new(b_ids, b_writes, b_entities, b_values);

    let joined = ecs_query_lens_join(lens_a, lens_b);
    if ecs_query_lens_matched_count(joined) != 0 { panic(79070); };
}

// === join_filtered ===

@test "query lens join_filtered"() {
    let a_ids = Vec::new();
    a_ids.push(1);
    let a_writes = Vec::new();
    a_writes.push(false);
    let a_entities = Vec::new();
    a_entities.push(10);
    let a_values = Vec::new();
    a_values.push(100);
    let lens_a = ecs_query_lens_new(a_ids, a_writes, a_entities, a_values);

    let b_ids = Vec::new();
    b_ids.push(2);
    let b_writes = Vec::new();
    b_writes.push(true);
    let b_entities = Vec::new();
    b_entities.push(10);
    let b_values = Vec::new();
    b_values.push(200);
    let lens_b = ecs_query_lens_new(b_ids, b_writes, b_entities, b_values);

    let filter_ids = Vec::new();
    filter_ids.push(5);
    let joined = ecs_query_lens_join_filtered(lens_a, lens_b, filter_ids);
    if ecs_query_lens_filter_count(joined) != 1 { panic(79080); };
    if ecs_query_lens_matched_count(joined) != 1 { panic(79081); };
}

// === get ===

@test "query lens get"() {
    let access_ids = Vec::new();
    access_ids.push(1);
    let writes = Vec::new();
    writes.push(false);
    let entities = Vec::new();
    entities.push(10);
    let values = Vec::new();
    values.push(100);
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    let g = ecs_query_lens_get(lens, 10);
    if g.0 != true { panic(79090); };
    if g.1 != 100 { panic(79091); };
    let g2 = ecs_query_lens_get(lens, 99);
    if g2.0 != false { panic(79092); };
}

// === is_empty ===

@test "query lens is_empty"() {
    let access_ids = Vec::new();
    let writes = Vec::new();
    let entities = Vec::new();
    let values = Vec::new();
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    if ecs_query_lens_is_empty(lens) != true { panic(79100); };
}

@test "query lens not empty"() {
    let access_ids = Vec::new();
    let writes = Vec::new();
    let entities = Vec::new();
    entities.push(1);
    let values = Vec::new();
    values.push(10);
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    if ecs_query_lens_is_empty(lens) != false { panic(79110); };
}

// === as/into query_lens ===

@test "query lens as_query_lens"() {
    let access_ids = Vec::new();
    access_ids.push(1);
    let writes = Vec::new();
    writes.push(false);
    let entities = Vec::new();
    let values = Vec::new();
    let lens = ecs_query_lens_new(access_ids, writes, entities, values);
    let lens2 = ecs_query_lens_as_query_lens(lens);
    if ecs_query_lens_access_count(lens2) != 1 { panic(79120); };
}

