@import "lib/schedule_config.sla"
@import "lib/schedule_set.sla"

@test "graph info new and in set"() {
    let g = ecs_graph_info_new();
    g = ecs_graph_info_in_set(g, 5);
    if ecs_graph_info_set_count(g) != 1 { panic(50001); };
}

@test "graph info before and after"() {
    let g = ecs_graph_info_new();
    g = ecs_graph_info_before(g, 1);
    g = ecs_graph_info_after(g, 2);
    if ecs_graph_info_set_count(g) != 0 { panic(50002); };
}

@test "graph info run if"() {
    let g = ecs_graph_info_new();
    g = ecs_graph_info_run_if(g, 10);
    if ecs_graph_info_condition_count(g) != 1 { panic(50003); };
}

@test "schedule config new and in set"() {
    let c = ecs_schedule_config_new(42);
    if ecs_schedule_config_system_id(c) != 42 { panic(50004); };
    c = ecs_schedule_config_in_set(c, 5);
    if ecs_schedule_config_set_count(c) != 1 { panic(50005); };
}

@test "schedule config run if"() {
    let c = ecs_schedule_config_new(42);
    c = ecs_schedule_config_run_if(c, 10);
    if ecs_schedule_config_condition_count(c) != 1 { panic(50006); };
}

@test "schedule config with name"() {
    let c = ecs_schedule_config_new(42);
    let c2 = ecs_schedule_config_with_name(c, 99);
    if ecs_schedule_config_name(c2) != 99 { panic(50007); };
}

@test "schedule configs noop"() {
    let c = ecs_schedule_configs_noop();
    if ecs_schedule_configs_kind(c) != ECS_SCHEDULE_CONFIGS_NOOP { panic(50008); };
}

@test "schedule configs single"() {
    let cfg = ecs_schedule_config_new(1);
    let c = ecs_schedule_configs_single(cfg);
    if ecs_schedule_configs_kind(c) != ECS_SCHEDULE_CONFIGS_SINGLE { panic(50009); };
    if ecs_schedule_configs_len(c) != 1 { panic(50010); };
}

@test "schedule configs group"() {
    let v: Vec<EcsScheduleConfig> = Vec::new();
    v.push(ecs_schedule_config_new(1));
    v.push(ecs_schedule_config_new(2));
    let c = ecs_schedule_configs_group(v, true);
    if ecs_schedule_configs_kind(c) != ECS_SCHEDULE_CONFIGS_GROUP { panic(50011); };
    if ecs_schedule_configs_len(c) != 2 { panic(50012); };
    if ecs_schedule_configs_is_chain(c) != true { panic(50013); };
}

@test "schedule configs in set applies to all"() {
    let v: Vec<EcsScheduleConfig> = Vec::new();
    v.push(ecs_schedule_config_new(1));
    v.push(ecs_schedule_config_new(2));
    let c = ecs_schedule_configs_group(v, false);
    let c2 = ecs_schedule_configs_in_set(c, 7);
    if ecs_schedule_config_set_count(c2.configs[0]) != 1 { panic(50014); };
    if ecs_schedule_config_set_count(c2.configs[1]) != 1 { panic(50015); };
}

@test "system set anonymous"() {
    let s = ecs_system_set_anonymous(5);
    if ecs_system_set_is_anonymous(s) != true { panic(50016); };
    if ecs_system_set_id(s) != 5 { panic(50017); };
}

@test "system set system type"() {
    let s = ecs_system_set_system_type(3);
    if ecs_system_set_is_system_type(s) != true { panic(50018); };
}

@test "system set base"() {
    let s = ecs_system_set_base(7, 100);
    if ecs_system_set_is_base(s) != true { panic(50019); };
    if ecs_system_set_name(s) != 100 { panic(50020); };
}

@test "system set eq"() {
    if ecs_system_set_eq(ecs_system_set_anonymous(5), ecs_system_set_anonymous(5)) != true { panic(50021); };
    if ecs_system_set_eq(ecs_system_set_anonymous(5), ecs_system_set_anonymous(6)) != false { panic(50022); };
}

@test "set membership add and contains"() {
    let m = ecs_set_membership_new();
    m = ecs_set_membership_add(m, 1);
    m = ecs_set_membership_add(m, 2);
    if ecs_set_membership_contains(m, 1) != true { panic(50023); };
    if ecs_set_membership_contains(m, 3) != false { panic(50024); };
    if ecs_set_membership_len(m) != 2 { panic(50025); };
}
