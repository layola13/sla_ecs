@import "lib/observer_condition.sla"

// === ObserverCondition ===

@test "observer condition new"() {
    let c = ecs_observer_condition_new();
    if ecs_observer_condition_is_initialized(c) != false { panic(80001); };
}

@test "observer condition initialize"() {
    let c = ecs_observer_condition_new();
    let c2 = ecs_observer_condition_initialize(c);
    if ecs_observer_condition_is_initialized(c2) != true { panic(80010); };
}

@test "observer condition check uninitialized"() {
    let c = ecs_observer_condition_new();
    let result = ecs_observer_condition_check(c, true);
    if result.1 != false { panic(80020); };
}

@test "observer condition check true"() {
    let c = ecs_observer_condition_new();
    let c2 = ecs_observer_condition_initialize(c);
    let result = ecs_observer_condition_check(c2, true);
    if result.1 != true { panic(80030); };
}

@test "observer condition check false"() {
    let c = ecs_observer_condition_new();
    let c2 = ecs_observer_condition_initialize(c);
    let result = ecs_observer_condition_check(c2, false);
    if result.1 != false { panic(80040); };
}

@test "observer condition last_result"() {
    let c = ecs_observer_condition_new();
    let c2 = ecs_observer_condition_initialize(c);
    let r = ecs_observer_condition_check(c2, true);
    if ecs_observer_condition_last_result(r.0) != true { panic(80050); };
}

// === ObserverWithCondition ===

@test "owc new"() {
    let o = ecs_observer_with_condition_new(5);
    if ecs_observer_with_condition_system_id(o) != 5 { panic(80060); };
    if ecs_observer_with_condition_condition_count(o) != 0 { panic(80061); };
}

@test "owc run_if"() {
    let o = ecs_observer_with_condition_new(1);
    let o2 = ecs_observer_with_condition_run_if(o, true);
    let o3 = ecs_observer_with_condition_run_if(o2, true);
    if ecs_observer_with_condition_condition_count(o3) != 2 { panic(80070); };
}

@test "owc check uninitialized"() {
    let o = ecs_observer_with_condition_new(1);
    let o2 = ecs_observer_with_condition_run_if(o, true);
    if ecs_observer_with_condition_check(o2) != false { panic(80080); };
}

@test "owc check all true"() {
    let o = ecs_observer_with_condition_new(1);
    let o2 = ecs_observer_with_condition_run_if(o, true);
    let o3 = ecs_observer_with_condition_run_if(o2, true);
    let o4 = ecs_observer_with_condition_initialize(o3);
    if ecs_observer_with_condition_check(o4) != true { panic(80090); };
}

@test "owc check one false"() {
    let o = ecs_observer_with_condition_new(1);
    let o2 = ecs_observer_with_condition_run_if(o, true);
    let o3 = ecs_observer_with_condition_run_if(o2, false);
    let o4 = ecs_observer_with_condition_initialize(o3);
    if ecs_observer_with_condition_check(o4) != false { panic(80100); };
}

@test "owc check no conditions"() {
    let o = ecs_observer_with_condition_new(1);
    let o2 = ecs_observer_with_condition_initialize(o);
    // No conditions = should pass (vacuously true)
    if ecs_observer_with_condition_check(o2) != true { panic(80110); };
}

@test "owc initialize"() {
    let o = ecs_observer_with_condition_new(1);
    let o2 = ecs_observer_with_condition_initialize(o);
    if ecs_observer_with_condition_is_initialized(o2) != true { panic(80120); };
}

@test "owc take_conditions"() {
    let o = ecs_observer_with_condition_new(7);
    let o2 = ecs_observer_with_condition_run_if(o, true);
    let o3 = ecs_observer_with_condition_run_if(o2, false);
    let result = ecs_observer_with_condition_take_conditions(o3);
    if result.0 != 7 { panic(80130); };
    if len(result.1) as i64 != 2 { panic(80131); };
}

// === Conditions helpers ===

@test "conditions all true"() {
    let c = Vec::new();
    c.push(true);
    c.push(true);
    c.push(true);
    if ecs_observer_conditions_all_true(c) != true { panic(80140); };
}

@test "conditions all false one"() {
    let c = Vec::new();
    c.push(true);
    c.push(false);
    c.push(true);
    if ecs_observer_conditions_all_true(c) != false { panic(80150); };
}

@test "conditions any true"() {
    let c = Vec::new();
    c.push(false);
    c.push(true);
    c.push(false);
    if ecs_observer_conditions_any_true(c) != true { panic(80160); };
}

@test "conditions any all false"() {
    let c = Vec::new();
    c.push(false);
    c.push(false);
    if ecs_observer_conditions_any_true(c) != false { panic(80170); };
}

@test "conditions count"() {
    let c = Vec::new();
    c.push(true);
    c.push(false);
    c.push(true);
    if ecs_observer_conditions_count(c) != 3 { panic(80180); };
}

@test "conditions true_count"() {
    let c = Vec::new();
    c.push(true);
    c.push(false);
    c.push(true);
    c.push(true);
    if ecs_observer_conditions_true_count(c) != 3 { panic(80190); };
}

@test "conditions empty all true"() {
    let c = Vec::new();
    if ecs_observer_conditions_all_true(c) != true { panic(80200); };
}

@test "conditions empty any false"() {
    let c = Vec::new();
    if ecs_observer_conditions_any_true(c) != false { panic(80210); };
}
