// Schedule config completeness: run_if, in_set, chain, before, after,
// ambiguous_with, collective_conditions, distributive_run_if, IgnoreDeferred.
// Bevy schedule/config.rs: ScheduleConfigs methods.

struct EcsDependency {
    kind: i32,    // 0=Before, 1=After, 2=BeforeIgnoreDeferred, 3=AfterIgnoreDeferred
    target_set: i32,
}

struct EcsScheduleConfig {
    system_id: i32,
    set: i32,                 // in_set target
    dependencies: Vec<EcsDependency>,
    conditions: Vec<i32>,     // run condition ids
    ambiguous_with: i32,      // -1 = none, -2 = all, other = specific set
}

struct EcsScheduleConfigs {
    is_single: bool,
    single_config: EcsScheduleConfig,
    configs: Vec<EcsScheduleConfigs>,   // nested for tuples
    collective_conditions: Vec<i32>,
    is_chained: bool,
    chain_ignore_deferred: bool,
}

fn config_new(system_id: i32) -> EcsScheduleConfig {
    let deps: Vec<EcsDependency> = Vec::new();
    let conds: Vec<i32> = Vec::new();
    return EcsScheduleConfig {
        system_id: system_id, set: -1, dependencies: deps,
        conditions: conds, ambiguous_with: -1,
    };
}

fn configs_single(system_id: i32) -> EcsScheduleConfigs {
    return EcsScheduleConfigs {
        is_single: true,
        single_config: config_new(system_id),
        configs: Vec::new(),
        collective_conditions: Vec::new(),
        is_chained: false,
        chain_ignore_deferred: false,
    };
}

// in_set: set the system set
fn configs_in_set(c: EcsScheduleConfigs, set_id: i32) -> EcsScheduleConfigs {
    if c.is_single {
        c.single_config.set = set_id;
    };
    return c;
}

// before: add a Before dependency
fn configs_before(c: EcsScheduleConfigs, target_set: i32) -> EcsScheduleConfigs {
    if c.is_single {
        c.single_config.dependencies.push(EcsDependency { kind: 0, target_set: target_set });
    };
    return c;
}

// after: add an After dependency
fn configs_after(c: EcsScheduleConfigs, target_set: i32) -> EcsScheduleConfigs {
    if c.is_single {
        c.single_config.dependencies.push(EcsDependency { kind: 1, target_set: target_set });
    };
    return c;
}

// before_ignore_deferred
fn configs_before_ignore_deferred(c: EcsScheduleConfigs, target_set: i32) -> EcsScheduleConfigs {
    if c.is_single {
        c.single_config.dependencies.push(EcsDependency { kind: 2, target_set: target_set });
    };
    return c;
}

// after_ignore_deferred
fn configs_after_ignore_deferred(c: EcsScheduleConfigs, target_set: i32) -> EcsScheduleConfigs {
    if c.is_single {
        c.single_config.dependencies.push(EcsDependency { kind: 3, target_set: target_set });
    };
    return c;
}

// run_if: add a run condition
fn configs_run_if(c: EcsScheduleConfigs, condition_id: i32) -> EcsScheduleConfigs {
    if c.is_single {
        c.single_config.conditions.push(condition_id);
    } else {
        c.collective_conditions.push(condition_id);
    };
    return c;
}

// distributive_run_if: same as run_if for single config
fn configs_distributive_run_if(c: EcsScheduleConfigs, condition_id: i32) -> EcsScheduleConfigs {
    return configs_run_if(c, condition_id);
}

// chain: mark as chained
fn configs_chain(c: EcsScheduleConfigs) -> EcsScheduleConfigs {
    c.is_chained = true;
    return c;
}

// chain_ignore_deferred
fn configs_chain_ignore_deferred(c: EcsScheduleConfigs) -> EcsScheduleConfigs {
    c.chain_ignore_deferred = true;
    c.is_chained = true;
    return c;
}

// ambiguous_with: set ambiguity to a specific set
fn configs_ambiguous_with(c: EcsScheduleConfigs, set_id: i32) -> EcsScheduleConfigs {
    if c.is_single {
        c.single_config.ambiguous_with = set_id;
    };
    return c;
}

// ambiguous_with_all: ignore all ambiguities
fn configs_ambiguous_with_all(c: EcsScheduleConfigs) -> EcsScheduleConfigs {
    if c.is_single {
        c.single_config.ambiguous_with = -2;
    };
    return c;
}

// Accessors
fn config_has_set(c: EcsScheduleConfigs) -> bool { return c.single_config.set >= 0; }
fn config_get_set(c: EcsScheduleConfigs) -> i32 { return c.single_config.set; }
fn config_dependency_count(c: EcsScheduleConfigs) -> i64 { return len(c.single_config.dependencies) as i64; }
fn config_condition_count(c: EcsScheduleConfigs) -> i64 { return len(c.single_config.conditions) as i64; }
fn config_is_chained(c: EcsScheduleConfigs) -> bool { return c.is_chained; }
fn config_chain_ignore_deferred(c: EcsScheduleConfigs) -> bool { return c.chain_ignore_deferred; }
fn config_ambiguous_with(c: EcsScheduleConfigs) -> i32 { return c.single_config.ambiguous_with; }

fn config_has_before_dependency(c: EcsScheduleConfigs, target: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(c.single_config.dependencies) as i64;
    while i < cnt {
        let dep = c.single_config.dependencies[i];
        if dep.kind == 0 && dep.target_set == target { return true; };
        i = i + 1;
    }
    return false;
}

fn config_has_after_dependency(c: EcsScheduleConfigs, target: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(c.single_config.dependencies) as i64;
    while i < cnt {
        let dep = c.single_config.dependencies[i];
        if dep.kind == 1 && dep.target_set == target { return true; };
        i = i + 1;
    }
    return false;
}

fn config_has_before_ignore_deferred(c: EcsScheduleConfigs, target: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(c.single_config.dependencies) as i64;
    while i < cnt {
        let dep = c.single_config.dependencies[i];
        if dep.kind == 2 && dep.target_set == target { return true; };
        i = i + 1;
    }
    return false;
}

const SET_A: i32 = 11001;
const SET_B: i32 = 11002;
const COND_X: i32 = 11003;

@test "in_set sets system set"() {
    let c = configs_single(1);
    let c2 = configs_in_set(c, SET_A);
    if config_get_set(c2) != SET_A { panic(11001); };
    if config_has_set(c2) != true { panic(11002); };
}

@test "before adds Before dependency"() {
    let c = configs_single(1);
    let c2 = configs_before(c, SET_B);
    if config_dependency_count(c2) != 1 { panic(11003); };
    if config_has_before_dependency(c2, SET_B) != true { panic(11004); };
}

@test "after adds After dependency"() {
    let c = configs_single(1);
    let c2 = configs_after(c, SET_A);
    if config_has_after_dependency(c2, SET_A) != true { panic(11005); };
}

@test "before_ignore_deferred adds dependency"() {
    let c = configs_single(1);
    let c2 = configs_before_ignore_deferred(c, SET_B);
    if config_has_before_ignore_deferred(c2, SET_B) != true { panic(11006); };
}

@test "run_if adds condition"() {
    let c = configs_single(1);
    let c2 = configs_run_if(c, COND_X);
    if config_condition_count(c2) != 1 { panic(11007); };
}

@test "distributive_run_if adds condition"() {
    let c = configs_single(1);
    let c2 = configs_distributive_run_if(c, COND_X);
    if config_condition_count(c2) != 1 { panic(11008); };
}

@test "chain marks as chained"() {
    let c = configs_single(1);
    let c2 = configs_chain(c);
    if config_is_chained(c2) != true { panic(11009); };
}

@test "chain_ignore_deferred marks both"() {
    let c = configs_single(1);
    let c2 = configs_chain_ignore_deferred(c);
    if config_is_chained(c2) != true { panic(11010); };
    if config_chain_ignore_deferred(c2) != true { panic(11011); };
}

@test "ambiguous_with sets specific set"() {
    let c = configs_single(1);
    let c2 = configs_ambiguous_with(c, SET_B);
    if config_ambiguous_with(c2) != SET_B { panic(11012); };
}

@test "ambiguous_with_all sets -2"() {
    let c = configs_single(1);
    let c2 = configs_ambiguous_with_all(c);
    if config_ambiguous_with(c2) != -2 { panic(11013); };
}

@test "multiple dependencies accumulate"() {
    let c = configs_single(1);
    let c2 = configs_before(c, SET_A);
    let c3 = configs_after(c2, SET_B);
    let c4 = configs_before_ignore_deferred(c3, SET_A);
    if config_dependency_count(c4) != 3 { panic(11014); };
}

@test "multiple conditions accumulate"() {
    let c = configs_single(1);
    let c2 = configs_run_if(c, 1);
    let c3 = configs_run_if(c2, 2);
    let c4 = configs_run_if(c3, 3);
    if config_condition_count(c4) != 3 { panic(11015); };
}

@test "default config has no set"() {
    let c = configs_single(1);
    if config_has_set(c) { panic(11016); };
}

@test "default config has no dependencies"() {
    let c = configs_single(1);
    if config_dependency_count(c) != 0 { panic(11017); };
}

@test "default config has no conditions"() {
    let c = configs_single(1);
    if config_condition_count(c) != 0 { panic(11018); };
}

@test "default config not chained"() {
    let c = configs_single(1);
    if config_is_chained(c) { panic(11019); };
}

@test "default ambiguous_with is -1"() {
    let c = configs_single(1);
    if config_ambiguous_with(c) != -1 { panic(11020); };
}
