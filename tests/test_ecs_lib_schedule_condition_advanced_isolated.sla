@import "lib/schedule_condition_advanced.sla"

// === condition_changed ===

@test "condition_changed first call"() {
    let state = ecs_condition_changed_state_new();
    let result = ecs_condition_changed(state, true);
    if result.0 != true { panic(75001); };
}

@test "condition_changed no change"() {
    let state = ecs_condition_changed_state_new();
    let r1 = ecs_condition_changed(state, true);
    let r2 = ecs_condition_changed(r1.1, true);
    if r2.0 != false { panic(75010); };
}

@test "condition_changed flips"() {
    let state = ecs_condition_changed_state_new();
    let r1 = ecs_condition_changed(state, true);
    let r2 = ecs_condition_changed(r1.1, false);
    if r2.0 != true { panic(75020); };
    let r3 = ecs_condition_changed(r2.1, false);
    if r3.0 != false { panic(75021); };
    let r4 = ecs_condition_changed(r3.1, true);
    if r4.0 != true { panic(75022); };
}

// === condition_changed_to ===

@test "condition_changed_to true first call"() {
    let state = ecs_condition_changed_state_new();
    let result = ecs_condition_changed_to(state, true, true);
    if result.0 != true { panic(75030); };
}

@test "condition_changed_to true no change"() {
    let state = ecs_condition_changed_state_new();
    let r1 = ecs_condition_changed_to(state, true, true);
    let r2 = ecs_condition_changed_to(r1.1, true, true);
    if r2.0 != false { panic(75040); };
}

@test "condition_changed_to true flips"() {
    let state = ecs_condition_changed_state_new();
    let r1 = ecs_condition_changed_to(state, true, true);
    let r2 = ecs_condition_changed_to(r1.1, true, false);
    if r2.0 != false { panic(75050); };
    let r3 = ecs_condition_changed_to(r2.1, true, true);
    if r3.0 != true { panic(75051); };
}

@test "condition_changed_to false"() {
    let state = ecs_condition_changed_state_new();
    let r1 = ecs_condition_changed_to(state, false, true);
    let r2 = ecs_condition_changed_to(r1.1, false, false);
    if r2.0 != true { panic(75060); };
}

// === Combinators ===

@test "combinator and_then"() {
    if ecs_combinator_and_then(true, true) != true { panic(75070); };
    if ecs_combinator_and_then(true, false) != false { panic(75071); };
    if ecs_combinator_and_then(false, true) != false { panic(75072); };
    if ecs_combinator_and_then(false, false) != false { panic(75073); };
}

@test "combinator or_else"() {
    if ecs_combinator_or_else(true, true) != true { panic(75080); };
    if ecs_combinator_or_else(true, false) != true { panic(75081); };
    if ecs_combinator_or_else(false, true) != true { panic(75082); };
    if ecs_combinator_or_else(false, false) != false { panic(75083); };
}

@test "combinator nand_then"() {
    if ecs_combinator_nand_then(true, true) != false { panic(75090); };
    if ecs_combinator_nand_then(true, false) != true { panic(75091); };
    if ecs_combinator_nand_then(false, false) != true { panic(75092); };
}

@test "combinator nor_then"() {
    if ecs_combinator_nor_then(true, true) != false { panic(75100); };
    if ecs_combinator_nor_then(false, false) != true { panic(75101); };
    if ecs_combinator_nor_then(true, false) != false { panic(75102); };
}

@test "combinator xor_then"() {
    if ecs_combinator_xor_then(true, true) != false { panic(75110); };
    if ecs_combinator_xor_then(true, false) != true { panic(75111); };
    if ecs_combinator_xor_then(false, true) != true { panic(75112); };
    if ecs_combinator_xor_then(false, false) != false { panic(75113); };
}

@test "combinator not"() {
    if ecs_combinator_not(true) != false { panic(75120); };
    if ecs_combinator_not(false) != true { panic(75121); };
}

// === combine by kind ===

@test "combinator combine and"() {
    if ecs_combinator_combine(0, true, true) != true { panic(75130); };
    if ecs_combinator_combine(0, true, false) != false { panic(75131); };
}

@test "combinator combine or"() {
    if ecs_combinator_combine(2, false, true) != true { panic(75140); };
    if ecs_combinator_combine(2, false, false) != false { panic(75141); };
}

@test "combinator combine nand"() {
    if ecs_combinator_combine(4, true, true) != false { panic(75150); };
    if ecs_combinator_combine(4, false, false) != true { panic(75151); };
}

@test "combinator combine xor"() {
    if ecs_combinator_combine(8, true, false) != true { panic(75160); };
    if ecs_combinator_combine(8, true, true) != false { panic(75161); };
}

// === resource_exists_and ===

@test "resource_exists_and true"() {
    if ecs_condition_resource_exists_and(true, true) != true { panic(75170); };
}

@test "resource_exists_and false no exist"() {
    if ecs_condition_resource_exists_and(false, true) != false { panic(75180); };
}

@test "resource_exists_and false predicate"() {
    if ecs_condition_resource_exists_and(true, false) != false { panic(75190); };
}

// === condition_changed example matching Bevy docs ===

@test "condition_changed example"() {
    let state = ecs_condition_changed_state_new();
    // First call with true: changed (was uninitialized)
    let r1 = ecs_condition_changed(state, true);
    if r1.0 != true { panic(75200); };
    // Second call with true: not changed
    let r2 = ecs_condition_changed(r1.1, true);
    if r2.0 != false { panic(75201); };
    // Third call with false: changed
    let r3 = ecs_condition_changed(r2.1, false);
    if r3.0 != true { panic(75202); };
}

// === condition_changed_to example matching Bevy docs ===

@test "condition_changed_to example"() {
    let state = ecs_condition_changed_state_new();
    // Resource exists (true), to=true: fires
    let r1 = ecs_condition_changed_to(state, true, true);
    if r1.0 != true { panic(75210); };
    // Still exists: not fires
    let r2 = ecs_condition_changed_to(r1.1, true, true);
    if r2.0 != false { panic(75211); };
    // Removed (false): not fires (to=true)
    let r3 = ecs_condition_changed_to(r2.1, true, false);
    if r3.0 != false { panic(75212); };
    // Re-added (true): fires
    let r4 = ecs_condition_changed_to(r3.1, true, true);
    if r4.0 != true { panic(75213); };
}
