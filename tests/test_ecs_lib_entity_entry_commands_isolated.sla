@import "lib/entity_entry_commands.sla"

// === Basic ===

@test "eec new occupied"() {
    let e = ecs_eec_new(1, 5, true, 42);
    if ecs_eec_entity(e) != 1 { panic(71001); };
    if ecs_eec_component_id(e) != 5 { panic(71002); };
    if ecs_eec_has_component(e) != true { panic(71003); };
    if ecs_eec_current_value(e) != 42 { panic(71004); };
}

@test "eec new vacant"() {
    let e = ecs_eec_new(1, 5, false, 0);
    if ecs_eec_has_component(e) != false { panic(71010); };
}

// === and_modify ===

@test "eec and_modify occupied"() {
    let e = ecs_eec_new(1, 5, true, 10);
    let e2 = ecs_eec_and_modify(e, 5);
    if ecs_eec_current_value(e2) != 15 { panic(71020); };
}

@test "eec and_modify vacant noop"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let e2 = ecs_eec_and_modify(e, 5);
    if ecs_eec_has_component(e2) != false { panic(71030); };
    if ecs_eec_current_value(e2) != 0 { panic(71031); };
}

// === or_insert ===

@test "eec or_insert vacant"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let e2 = ecs_eec_or_insert(e, 99);
    if ecs_eec_has_component(e2) != true { panic(71040); };
    if ecs_eec_current_value(e2) != 99 { panic(71041); };
}

@test "eec or_insert occupied noop"() {
    let e = ecs_eec_new(1, 5, true, 42);
    let e2 = ecs_eec_or_insert(e, 99);
    if ecs_eec_current_value(e2) != 42 { panic(71050); };
}

// === or_try_insert ===

@test "eec or_try_insert vacant"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let e2 = ecs_eec_or_try_insert(e, 77);
    if ecs_eec_current_value(e2) != 77 { panic(71060); };
}

@test "eec or_try_insert occupied noop"() {
    let e = ecs_eec_new(1, 5, true, 42);
    let e2 = ecs_eec_or_try_insert(e, 77);
    if ecs_eec_current_value(e2) != 42 { panic(71070); };
}

// === or_insert_with ===

@test "eec or_insert_with vacant"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let e2 = ecs_eec_or_insert_with(e, 55);
    if ecs_eec_current_value(e2) != 55 { panic(71080); };
}

@test "eec or_insert_with occupied noop"() {
    let e = ecs_eec_new(1, 5, true, 42);
    let e2 = ecs_eec_or_insert_with(e, 55);
    if ecs_eec_current_value(e2) != 42 { panic(71090); };
}

// === or_try_insert_with ===

@test "eec or_try_insert_with vacant"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let e2 = ecs_eec_or_try_insert_with(e, 33);
    if ecs_eec_current_value(e2) != 33 { panic(71100); };
}

// === or_default ===

@test "eec or_default vacant"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let e2 = ecs_eec_or_default(e);
    if ecs_eec_current_value(e2) != 0 { panic(71110); };
    if ecs_eec_has_component(e2) != true { panic(71111); };
}

@test "eec or_default occupied noop"() {
    let e = ecs_eec_new(1, 5, true, 42);
    let e2 = ecs_eec_or_default(e);
    if ecs_eec_current_value(e2) != 42 { panic(71120); };
}

// === or_from_world ===

@test "eec or_from_world vacant"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let e2 = ecs_eec_or_from_world(e, 88);
    if ecs_eec_current_value(e2) != 88 { panic(71130); };
}

@test "eec or_from_world occupied noop"() {
    let e = ecs_eec_new(1, 5, true, 42);
    let e2 = ecs_eec_or_from_world(e, 88);
    if ecs_eec_current_value(e2) != 42 { panic(71140); };
}

// === reborrow ===

@test "eec reborrow"() {
    let e = ecs_eec_new(1, 5, true, 42);
    let rb = ecs_eec_reborrow(e);
    if ecs_eec_entity(rb) != 1 { panic(71150); };
    if ecs_eec_current_value(rb) != 42 { panic(71151); };
}

// === commands (get entity back) ===

@test "eec commands"() {
    let e = ecs_eec_new(42, 5, true, 10);
    if ecs_eec_commands(e) != 42 { panic(71160); };
}

// === resolve ===

@test "eec resolve occupied"() {
    let e = ecs_eec_new(1, 5, true, 42);
    let r = ecs_eec_resolve(e);
    if r.0 != true { panic(71170); };
    if r.1 != 42 { panic(71171); };
}

@test "eec resolve vacant"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let r = ecs_eec_resolve(e);
    if r.0 != false { panic(71180); };
}

// === ops log ===

@test "eec ops log"() {
    let e = ecs_eec_new(1, 5, true, 10);
    let e2 = ecs_eec_and_modify(e, 5);
    let e3 = ecs_eec_or_insert(e2, 99);
    if ecs_eec_ops_len(e3) != 2 { panic(71190); };
}

// === Chained: and_modify then or_insert (occupied path) ===

@test "eec chain and_modify or_insert occupied"() {
    let e = ecs_eec_new(1, 5, true, 10);
    let e2 = ecs_eec_and_modify(e, 1);
    let e3 = ecs_eec_or_insert(e2, 99);
    if ecs_eec_current_value(e3) != 11 { panic(71200); };
}

// === Chained: and_modify then or_insert (vacant path) ===

@test "eec chain and_modify or_insert vacant"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let e2 = ecs_eec_and_modify(e, 1);
    let e3 = ecs_eec_or_insert(e2, 99);
    if ecs_eec_has_component(e3) != true { panic(71210); };
    if ecs_eec_current_value(e3) != 99 { panic(71211); };
}

// === pending value ===

@test "eec pending value after or_insert"() {
    let e = ecs_eec_new(1, 5, false, 0);
    let e2 = ecs_eec_or_insert(e, 77);
    if ecs_eec_has_pending(e2) != true { panic(71220); };
    if ecs_eec_pending_value(e2) != 77 { panic(71221); };
}

@test "eec no pending when occupied"() {
    let e = ecs_eec_new(1, 5, true, 42);
    let e2 = ecs_eec_or_insert(e, 77);
    if ecs_eec_has_pending(e2) != false { panic(71230); };
}
