@import "lib/unique_vec.sla"

// Isolated tests for lib/unique_vec.sla — UniqueEntityEquivalentVec
// Bevy reference: bevy_ecs/src/entity/unique_vec.rs

@test "unique_vec_new_empty"() {
    let v = ecs_unique_vec_new();
    if ecs_unique_vec_len(v) != 0 { panic(82100); };
    if ecs_unique_vec_is_empty(v) != true { panic(82101); };
}

@test "unique_vec_push_unique"() {
    let v = ecs_unique_vec_new();
    let r1 = ecs_unique_vec_push(v, 100);
    if r1.1 != true { panic(82102); };
    let r2 = ecs_unique_vec_push(r1.0, 200);
    if r2.1 != true { panic(82103); };
    if ecs_unique_vec_len(r2.0) != 2 { panic(82104); };
}

@test "unique_vec_push_duplicate"() {
    let v = ecs_unique_vec_new();
    let r1 = ecs_unique_vec_push(v, 100);
    let r2 = ecs_unique_vec_push(r1.0, 100);
    if r2.1 != false { panic(82105); };
    if ecs_unique_vec_len(r2.0) != 1 { panic(82106); };
}

@test "unique_vec_contains"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 42);
    let r2 = ecs_unique_vec_push(r.0, 99);
    if ecs_unique_vec_contains(r2.0, 42) != true { panic(82107); };
    if ecs_unique_vec_contains(r2.0, 99) != true { panic(82108); };
    if ecs_unique_vec_contains(r2.0, 999) != false { panic(82109); };
}

@test "unique_vec_index_of"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let r3 = ecs_unique_vec_push(r2.0, 30);
    if ecs_unique_vec_index_of(r3.0, 10) != 0 { panic(82110); };
    if ecs_unique_vec_index_of(r3.0, 20) != 1 { panic(82111); };
    if ecs_unique_vec_index_of(r3.0, 30) != 2 { panic(82112); };
    if ecs_unique_vec_index_of(r3.0, 999) != -1 { panic(82113); };
}

@test "unique_vec_get"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let g0 = ecs_unique_vec_get(r2.0, 0);
    if g0.0 != true { panic(82114); };
    if g0.1 != 10 { panic(82115); };
    let g1 = ecs_unique_vec_get(r2.0, 1);
    if g1.0 != true { panic(82116); };
    if g1.1 != 20 { panic(82117); };
    let g2 = ecs_unique_vec_get(r2.0, 2);
    if g2.0 != false { panic(82118); };
}

@test "unique_vec_first_last"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let r3 = ecs_unique_vec_push(r2.0, 30);
    let f = ecs_unique_vec_first(r3.0);
    if f.0 != true { panic(82119); };
    if f.1 != 10 { panic(82120); };
    let l = ecs_unique_vec_last(r3.0);
    if l.0 != true { panic(82121); };
    if l.1 != 30 { panic(82122); };
}

@test "unique_vec_first_empty"() {
    let v = ecs_unique_vec_new();
    let f = ecs_unique_vec_first(v);
    if f.0 != false { panic(82123); };
    let l = ecs_unique_vec_last(v);
    if l.0 != false { panic(82124); };
}

@test "unique_vec_swap_remove"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let r3 = ecs_unique_vec_push(r2.0, 30);
    let res = ecs_unique_vec_swap_remove(r3.0, 0);
    if res.1 != true { panic(82125); };
    if res.2 != 10 { panic(82126); };
    if ecs_unique_vec_len(res.0) != 2 { panic(82127); };
    if ecs_unique_vec_contains(res.0, 10) != false { panic(82128); };
    if ecs_unique_vec_contains(res.0, 30) != true { panic(82129); };
}

@test "unique_vec_swap_remove_out_of_range"() {
    let v = ecs_unique_vec_new();
    let res = ecs_unique_vec_swap_remove(v, 0);
    if res.1 != false { panic(82130); };
}

@test "unique_vec_remove"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let r3 = ecs_unique_vec_push(r2.0, 30);
    let res = ecs_unique_vec_remove(r3.0, 1);
    if res.1 != true { panic(82131); };
    if res.2 != 20 { panic(82132); };
    if ecs_unique_vec_len(res.0) != 2 { panic(82133); };
    let g0 = ecs_unique_vec_get(res.0, 0);
    if g0.1 != 10 { panic(82134); };
    let g1 = ecs_unique_vec_get(res.0, 1);
    if g1.1 != 30 { panic(82135); };
}

@test "unique_vec_pop"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let res = ecs_unique_vec_pop(r2.0);
    if res.1 != true { panic(82136); };
    if res.2 != 20 { panic(82137); };
    if ecs_unique_vec_len(res.0) != 1 { panic(82138); };
}

@test "unique_vec_pop_empty"() {
    let v = ecs_unique_vec_new();
    let res = ecs_unique_vec_pop(v);
    if res.1 != false { panic(82139); };
}

@test "unique_vec_clear"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let v2 = ecs_unique_vec_clear(r2.0);
    if ecs_unique_vec_len(v2) != 0 { panic(82140); };
    if ecs_unique_vec_is_empty(v2) != true { panic(82141); };
}

@test "unique_vec_truncate"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let r3 = ecs_unique_vec_push(r2.0, 30);
    let v2 = ecs_unique_vec_truncate(r3.0, 2);
    if ecs_unique_vec_len(v2) != 2 { panic(82142); };
    let g0 = ecs_unique_vec_get(v2, 0);
    if g0.1 != 10 { panic(82143); };
    let g1 = ecs_unique_vec_get(v2, 1);
    if g1.1 != 20 { panic(82144); };
}

@test "unique_vec_truncate_no_change"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let v2 = ecs_unique_vec_truncate(r.0, 5);
    if ecs_unique_vec_len(v2) != 1 { panic(82145); };
}

@test "unique_vec_retain"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 50);
    let r3 = ecs_unique_vec_push(r2.0, 100);
    let v2 = ecs_unique_vec_retain_greater_than(r3.0, 20);
    if ecs_unique_vec_len(v2) != 2 { panic(82146); };
    if ecs_unique_vec_contains(v2, 10) != false { panic(82147); };
    if ecs_unique_vec_contains(v2, 50) != true { panic(82148); };
    if ecs_unique_vec_contains(v2, 100) != true { panic(82149); };
}

@test "unique_vec_split_off"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let r3 = ecs_unique_vec_push(r2.0, 30);
    let res = ecs_unique_vec_split_off(r3.0, 1);
    let head = res.0;
    let tail = res.1;
    if ecs_unique_vec_len(head) != 1 { panic(82150); };
    if ecs_unique_vec_len(tail) != 2 { panic(82151); };
    if ecs_unique_vec_contains(head, 10) != true { panic(82152); };
    if ecs_unique_vec_contains(tail, 20) != true { panic(82153); };
    if ecs_unique_vec_contains(tail, 30) != true { panic(82154); };
}

@test "unique_vec_extend_from_slice"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let items = Vec::new();
    items.push(10);
    items.push(20);
    items.push(30);
    let res = ecs_unique_vec_extend_from_slice(r.0, items);
    if res.1 != 2 { panic(82155); };
    if ecs_unique_vec_len(res.0) != 3 { panic(82156); };
}

@test "unique_vec_from_entity_iter"() {
    let items = Vec::new();
    items.push(1);
    items.push(2);
    items.push(2);
    items.push(3);
    items.push(1);
    let v = ecs_unique_vec_from_entity_iter(items);
    if ecs_unique_vec_len(v) != 3 { panic(82157); };
    if ecs_unique_vec_contains(v, 1) != true { panic(82158); };
    if ecs_unique_vec_contains(v, 2) != true { panic(82159); };
    if ecs_unique_vec_contains(v, 3) != true { panic(82160); };
}

@test "unique_vec_eq"() {
    let v1 = ecs_unique_vec_new();
    let r1a = ecs_unique_vec_push(v1, 10);
    let r1b = ecs_unique_vec_push(r1a.0, 20);

    let v2 = ecs_unique_vec_new();
    let r2a = ecs_unique_vec_push(v2, 10);
    let r2b = ecs_unique_vec_push(r2a.0, 20);

    let v3 = ecs_unique_vec_new();
    let r3a = ecs_unique_vec_push(v3, 10);
    let r3b = ecs_unique_vec_push(r3a.0, 30);

    if ecs_unique_vec_eq(r1b.0, r2b.0) != true { panic(82161); };
    if ecs_unique_vec_eq(r1b.0, r3b.0) != false { panic(82162); };
}

@test "unique_vec_into_inner"() {
    let v = ecs_unique_vec_new();
    let r = ecs_unique_vec_push(v, 10);
    let r2 = ecs_unique_vec_push(r.0, 20);
    let inner = ecs_unique_vec_into_inner(r2.0);
    if len(inner) != 2 { panic(82163); };
    if inner[0] != 10 { panic(82164); };
    if inner[1] != 20 { panic(82165); };
}

@test "unique_vec_dedup"() {
    let items = Vec::new();
    items.push(10);
    items.push(20);
    items.push(10);
    items.push(30);
    items.push(20);
    let v = ecs_unique_vec_from_vec(items);
    let v2 = ecs_unique_vec_dedup(v);
    if ecs_unique_vec_len(v2) != 3 { panic(82166); };
    if ecs_unique_vec_contains(v2, 10) != true { panic(82167); };
    if ecs_unique_vec_contains(v2, 20) != true { panic(82168); };
    if ecs_unique_vec_contains(v2, 30) != true { panic(82169); };
}
