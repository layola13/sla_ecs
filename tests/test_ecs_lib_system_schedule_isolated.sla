@import "lib/system_schedule.sla"

// Isolated tests for lib/system_schedule.sla — SystemSchedule + ApplyDeferred + default_executor
// Bevy reference: bevy_ecs/src/schedule/executor/mod.rs

@test "system_schedule_new"() {
    let s = ecs_system_schedule_new();
    if ecs_system_schedule_system_count(s) != 0 { panic(83100); };
    if ecs_system_schedule_set_count(s) != 0 { panic(83101); };
    if ecs_system_schedule_is_empty(s) != true { panic(83102); };
}

@test "system_schedule_add_system"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_add_system(s, 10, 2, 1);
    if ecs_system_schedule_system_count(s2) != 1 { panic(83103); };
    let sid = ecs_system_schedule_get_system_id(s2, 0);
    if sid.0 != true { panic(83104); };
    if sid.1 != 10 { panic(83105); };
}

@test "system_schedule_add_multiple_systems"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_add_system(s, 10, 0, 0);
    let s3 = ecs_system_schedule_add_system(s2, 20, 1, 1);
    let s4 = ecs_system_schedule_add_system(s3, 30, 2, 2);
    if ecs_system_schedule_system_count(s4) != 3 { panic(83106); };
}

@test "system_schedule_add_set"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_add_set(s, 100, 1);
    if ecs_system_schedule_set_count(s2) != 1 { panic(83107); };
    let sid = ecs_system_schedule_get_set_id(s2, 0);
    if sid.1 != 100 { panic(83108); };
}

@test "system_schedule_get_conditions"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_add_system(s, 10, 3, 0);
    let c = ecs_system_schedule_get_system_conditions(s2, 0);
    if c.0 != true { panic(83109); };
    if c.1 != 3 { panic(83110); };
}

@test "system_schedule_get_dependencies"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_add_system(s, 10, 0, 2);
    let d = ecs_system_schedule_get_system_dependencies(s2, 0);
    if d.0 != true { panic(83111); };
    if d.1 != 2 { panic(83112); };
}

@test "system_schedule_get_out_of_range"() {
    let s = ecs_system_schedule_new();
    let r = ecs_system_schedule_get_system_id(s, 0);
    if r.0 != false { panic(83113); };
    let r2 = ecs_system_schedule_get_system_id(s, -1);
    if r2.0 != false { panic(83114); };
}

@test "system_schedule_mark_run"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_mark_run(s);
    let s3 = ecs_system_schedule_mark_run(s2);
    if ecs_system_schedule_systems_run(s3) != 2 { panic(83115); };
}

@test "system_schedule_mark_skip"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_mark_skip(s);
    if ecs_system_schedule_systems_skipped(s2) != 1 { panic(83116); };
}

@test "system_schedule_reset"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_mark_run(s);
    let s3 = ecs_system_schedule_mark_skip(s2);
    let s4 = ecs_system_schedule_reset(s3);
    if ecs_system_schedule_systems_run(s4) != 0 { panic(83117); };
    if ecs_system_schedule_systems_skipped(s4) != 0 { panic(83118); };
}

@test "system_schedule_clear"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_add_system(s, 10, 0, 0);
    let s3 = ecs_system_schedule_add_set(s2, 100, 0);
    let s4 = ecs_system_schedule_clear(s3);
    if ecs_system_schedule_system_count(s4) != 0 { panic(83119); };
    if ecs_system_schedule_set_count(s4) != 0 { panic(83120); };
}

@test "system_schedule_total_conditions"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_add_system(s, 10, 2, 0);
    let s3 = ecs_system_schedule_add_system(s2, 20, 3, 0);
    let s4 = ecs_system_schedule_add_set(s3, 100, 1);
    if ecs_system_schedule_total_conditions(s4) != 6 { panic(83121); };
}

@test "system_schedule_total_dependencies"() {
    let s = ecs_system_schedule_new();
    let s2 = ecs_system_schedule_add_system(s, 10, 0, 2);
    let s3 = ecs_system_schedule_add_system(s2, 20, 0, 3);
    if ecs_system_schedule_total_dependencies(s3) != 5 { panic(83122); };
}

@test "apply_deferred_marker"() {
    if ECS_APPLY_DEFERRED != 999999 { panic(83123); };
    if ecs_is_apply_deferred(999999) != true { panic(83124); };
    if ecs_is_apply_deferred(0) != false { panic(83125); };
}

@test "default_executor_multi"() {
    if ecs_default_executor_kind(true) != ECS_EXECUTOR_MULTI { panic(83126); };
}

@test "default_executor_single"() {
    if ecs_default_executor_kind(false) != ECS_EXECUTOR_SINGLE { panic(83127); };
}
