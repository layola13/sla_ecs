@import "lib/blob_array.sla"

// Isolated tests for lib/blob_array.sla — BlobArray
// Bevy reference: bevy_ecs/src/storage/blob_array.rs

@test "blob_array_new"() {
    let b = ecs_blob_array_new(16, 8, true);
    if ecs_blob_array_item_size(b) != 16 { panic(82600); };
    if ecs_blob_array_item_align(b) != 8 { panic(82601); };
    if ecs_blob_array_is_zst(b) != false { panic(82602); };
    if ecs_blob_array_get_drop(b) != true { panic(82603); };
    if ecs_blob_array_len(b) != 0 { panic(82604); };
}

@test "blob_array_zst"() {
    let b = ecs_blob_array_new(0, 1, false);
    if ecs_blob_array_is_zst(b) != true { panic(82605); };
}

@test "blob_array_initialize"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 42);
    if ecs_blob_array_len(b2) != 1 { panic(82606); };
    let g = ecs_blob_array_get(b2, 0);
    if g.0 != true { panic(82607); };
    if g.1 != 42 { panic(82608); };
}

@test "blob_array_initialize_multiple"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let b3 = ecs_blob_array_initialize(b2, 1, 20);
    let b4 = ecs_blob_array_initialize(b3, 2, 30);
    if ecs_blob_array_len(b4) != 3 { panic(82609); };
}

@test "blob_array_get_out_of_range"() {
    let b = ecs_blob_array_new(16, 8, true);
    let g = ecs_blob_array_get(b, 0);
    if g.0 != false { panic(82610); };
}

@test "blob_array_replace"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let b3 = ecs_blob_array_initialize(b2, 1, 20);
    let b4 = ecs_blob_array_replace(b3, 0, 99);
    let g = ecs_blob_array_get(b4, 0);
    if g.1 != 99 { panic(82611); };
}

@test "blob_array_replace_out_of_range"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_replace(b, 0, 99);
    if ecs_blob_array_len(b2) != 0 { panic(82612); };
}

@test "blob_array_swap_remove"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let b3 = ecs_blob_array_initialize(b2, 1, 20);
    let b4 = ecs_blob_array_initialize(b3, 2, 30);
    let b5 = ecs_blob_array_swap_remove(b4, 0);
    if ecs_blob_array_len(b5) != 2 { panic(82613); };
    let g0 = ecs_blob_array_get(b5, 0);
    if g0.1 != 30 { panic(82614); };
}

@test "blob_array_swap_remove_last"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let b3 = ecs_blob_array_initialize(b2, 1, 20);
    let b4 = ecs_blob_array_swap_remove(b3, 1);
    if ecs_blob_array_len(b4) != 1 { panic(82615); };
    let g0 = ecs_blob_array_get(b4, 0);
    if g0.1 != 10 { panic(82616); };
}

@test "blob_array_swap_remove_and_drop"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let b3 = ecs_blob_array_initialize(b2, 1, 20);
    let b4 = ecs_blob_array_swap_remove_and_drop(b3, 0);
    if ecs_blob_array_len(b4) != 1 { panic(82617); };
}

@test "blob_array_clear"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let b3 = ecs_blob_array_initialize(b2, 1, 20);
    let b4 = ecs_blob_array_clear(b3, 2);
    if ecs_blob_array_len(b4) != 0 { panic(82618); };
    if ecs_blob_array_is_empty(b4) != true { panic(82619); };
}

@test "blob_array_drop_last"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let b3 = ecs_blob_array_initialize(b2, 1, 20);
    let b4 = ecs_blob_array_drop_last(b3, 1);
    if ecs_blob_array_len(b4) != 1 { panic(82620); };
    let g0 = ecs_blob_array_get(b4, 0);
    if g0.1 != 10 { panic(82621); };
}

@test "blob_array_drop_all"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let b3 = ecs_blob_array_initialize(b2, 1, 20);
    let b4 = ecs_blob_array_drop_all(b3, 10, 2);
    if ecs_blob_array_len(b4) != 0 { panic(82622); };
}

@test "blob_array_get_sub_slice"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let b3 = ecs_blob_array_initialize(b2, 1, 20);
    let b4 = ecs_blob_array_initialize(b3, 2, 30);
    let sub = ecs_blob_array_get_sub_slice(b4, 2);
    if len(sub) != 2 { panic(82623); };
    if sub[0] != 10 { panic(82624); };
    if sub[1] != 20 { panic(82625); };
}

@test "blob_array_get_sub_slice_exceeds"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 10);
    let sub = ecs_blob_array_get_sub_slice(b2, 5);
    if len(sub) != 1 { panic(82626); };
}

@test "blob_array_get_ptr"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 42);
    let p = ecs_blob_array_get_ptr(b2);
    if p.0 != true { panic(82627); };
    if p.1 != 42 { panic(82628); };
}

@test "blob_array_get_ptr_empty"() {
    let b = ecs_blob_array_new(16, 8, true);
    let p = ecs_blob_array_get_ptr(b);
    if p.0 != false { panic(82629); };
}

@test "blob_array_count"() {
    let b = ecs_blob_array_new(16, 8, true);
    let b2 = ecs_blob_array_initialize(b, 0, 42);
    let b3 = ecs_blob_array_initialize(b2, 1, 42);
    let b4 = ecs_blob_array_initialize(b3, 2, 99);
    if ecs_blob_array_count(b4, 42) != 2 { panic(82630); };
    if ecs_blob_array_count(b4, 99) != 1 { panic(82631); };
}

@test "blob_array_with_capacity"() {
    let b = ecs_blob_array_with_capacity(16, 8, true, 100);
    if ecs_blob_array_item_size(b) != 16 { panic(82632); };
    if ecs_blob_array_len(b) != 0 { panic(82633); };
}
