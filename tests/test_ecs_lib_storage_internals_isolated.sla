@import "lib/storage_internals.sla"

@test "blob array new and layout"() {
    let b = ecs_blob_array_new(16, 8, false);
    if ecs_blob_array_layout_size(b) != 16 { panic(49001); };
    if ecs_blob_array_layout_align(b) != 8 { panic(49002); };
    if ecs_blob_array_is_zst(b) != false { panic(49003); };
}

@test "blob array is zst get drop"() {
    let b = ecs_blob_array_new(0, 1, true);
    if ecs_blob_array_is_zst(b) != true { panic(49004); };
    if ecs_blob_array_get_drop(b) != 0 { panic(49005); };
}

@test "blob array push and len"() {
    let b = ecs_blob_array_new(8, 8, false);
    b = ecs_blob_array_push(b, 10);
    b = ecs_blob_array_push(b, 20);
    if ecs_blob_array_len(b) != 2 { panic(49006); };
    if ecs_blob_array_get(b, 0) != 10 { panic(49007); };
    if ecs_blob_array_get(b, 1) != 20 { panic(49008); };
}

@test "blob array swap remove"() {
    let b = ecs_blob_array_new(8, 8, false);
    b = ecs_blob_array_push(b, 10);
    b = ecs_blob_array_push(b, 20);
    b = ecs_blob_array_push(b, 30);
    let r = ecs_blob_array_swap_remove(b, 0);
    if r.1 != 10 { panic(49009); };
    if ecs_blob_array_len(r.0) != 2 { panic(49010); };
}

@test "blob array get drop non zst"() {
    let b = ecs_blob_array_new(8, 8, false);
    if ecs_blob_array_get_drop(b) != 1 { panic(49011); };
}

@test "thin array ptr with capacity"() {
    let t = ecs_thin_array_ptr_with_capacity(10);
    if ecs_thin_array_ptr_capacity(t) != 10 { panic(49012); };
    if ecs_thin_array_ptr_len(t) != 0 { panic(49013); };
}

@test "thin array ptr alloc"() {
    let t = ecs_thin_array_ptr_with_capacity(0);
    t = ecs_thin_array_ptr_alloc(t, 20);
    if ecs_thin_array_ptr_capacity(t) != 20 { panic(49014); };
}

@test "thin array ptr push and get"() {
    let t = ecs_thin_array_ptr_with_capacity(10);
    t = ecs_thin_array_ptr_push(t, 5);
    t = ecs_thin_array_ptr_push(t, 6);
    if ecs_thin_array_ptr_len(t) != 2 { panic(49015); };
    if ecs_thin_array_ptr_get(t, 1) != 6 { panic(49016); };
    if ecs_thin_array_ptr_is_empty(t) != false { panic(49017); };
}

@test "thin array ptr clear"() {
    let t = ecs_thin_array_ptr_with_capacity(10);
    t = ecs_thin_array_ptr_push(t, 5);
    t = ecs_thin_array_ptr_clear(t);
    if ecs_thin_array_ptr_len(t) != 0 { panic(49018); };
    if ecs_thin_array_ptr_is_empty(t) != true { panic(49019); };
}

@test "column with capacity"() {
    let c = ecs_column_with_capacity(3, 16);
    if ecs_column_component_id(c) != 3 { panic(49020); };
    if ecs_column_capacity(c) != 16 { panic(49021); };
    if ecs_column_is_empty(c) != true { panic(49022); };
}

@test "column push and len"() {
    let c = ecs_column_with_capacity(3, 16);
    c = ecs_column_push(c, 10);
    c = ecs_column_push(c, 20);
    if ecs_column_len(c) != 2 { panic(49023); };
    if ecs_column_get(c, 0) != 10 { panic(49024); };
}

@test "column swap"() {
    let c = ecs_column_with_capacity(3, 16);
    c = ecs_column_push(c, 10);
    c = ecs_column_push(c, 20);
    c = ecs_column_swap(c, 0, 1);
    if ecs_column_get(c, 0) != 20 { panic(49025); };
    if ecs_column_get(c, 1) != 10 { panic(49026); };
}

@test "column swap remove"() {
    let c = ecs_column_with_capacity(3, 16);
    c = ecs_column_push(c, 10);
    c = ecs_column_push(c, 20);
    c = ecs_column_push(c, 30);
    let r = ecs_column_swap_remove(c, 0);
    if r.1 != 10 { panic(49027); };
    if ecs_column_len(r.0) != 2 { panic(49028); };
}

@test "column clear"() {
    let c = ecs_column_with_capacity(3, 16);
    c = ecs_column_push(c, 10);
    c = ecs_column_clear(c);
    if ecs_column_is_empty(c) != true { panic(49029); };
}

@test "column get drop"() {
    let c = ecs_column_with_capacity(3, 16);
    if ecs_column_get_drop(c) != 1 { panic(49030); };
}
