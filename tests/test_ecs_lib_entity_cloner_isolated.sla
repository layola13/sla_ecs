@import "lib/entity_cloner.sla"

@test "cloner builder opt out default"() {
    let b = ecs_entity_cloner_build_opt_out();
    if ecs_cloner_builder_is_opt_in(b) != false { panic(44001); };
}

@test "cloner builder opt in"() {
    let b = ecs_entity_cloner_build_opt_in();
    if ecs_cloner_builder_is_opt_in(b) != true { panic(44002); };
}

@test "cloner builder move components"() {
    let b = ecs_entity_cloner_build_opt_out();
    let b2 = ecs_cloner_builder_move_components(b, true);
    if b2.move_components != true { panic(44003); };
}

@test "cloner builder linked cloning"() {
    let b = ecs_entity_cloner_build_opt_out();
    let b2 = ecs_cloner_builder_linked_cloning(b, true);
    if b2.linked_cloning != true { panic(44004); };
}

@test "cloner builder allow and deny"() {
    let b = ecs_entity_cloner_build_opt_in();
    b = ecs_cloner_builder_allow(b, 1);
    b = ecs_cloner_builder_allow(b, 2);
    b = ecs_cloner_builder_deny(b, 3);
    if ecs_cloner_builder_allowed_len(b) != 2 { panic(44005); };
    if ecs_cloner_builder_denied_len(b) != 1 { panic(44006); };
}

@test "cloner builder allow_if_new sets keep existing"() {
    let b = ecs_entity_cloner_build_opt_in();
    let b2 = ecs_cloner_builder_allow_if_new(b, 5);
    if b2.insert_mode != ECS_INSERT_MODE_KEEP_EXISTING { panic(44007); };
}

@test "entity cloner finish"() {
    let b = ecs_entity_cloner_build_opt_in();
    b = ecs_cloner_builder_allow(b, 1);
    let c = ecs_entity_cloner_builder_finish(b);
    if ecs_entity_cloner_linked_cloning(c) != false { panic(44008); };
}

@test "entity cloner opt out should clone"() {
    let b = ecs_entity_cloner_build_opt_out();
    b = ecs_cloner_builder_deny(b, 5);
    let c = ecs_entity_cloner_builder_finish(b);
    if ecs_entity_cloner_should_clone(c, 1) != true { panic(44009); };
    if ecs_entity_cloner_should_clone(c, 5) != false { panic(44010); };
}

@test "entity cloner opt in should clone"() {
    let b = ecs_entity_cloner_build_opt_in();
    b = ecs_cloner_builder_allow(b, 1);
    b = ecs_cloner_builder_allow(b, 2);
    let c = ecs_entity_cloner_builder_finish(b);
    if ecs_entity_cloner_should_clone(c, 1) != true { panic(44011); };
    if ecs_entity_cloner_should_clone(c, 2) != true { panic(44012); };
    if ecs_entity_cloner_should_clone(c, 3) != false { panic(44013); };
}

@test "entity cloner clone entity count"() {
    let b = ecs_entity_cloner_build_opt_out();
    b = ecs_cloner_builder_deny(b, 2);
    let c = ecs_entity_cloner_builder_finish(b);
    let comps: Vec<i32> = Vec::new();
    comps.push(1);
    comps.push(2);
    comps.push(3);
    if ecs_entity_cloner_clone_entity(c, comps) != 2 { panic(44014); };
}

@test "entity cloner spawn clone"() {
    let b = ecs_entity_cloner_build_opt_out();
    let c = ecs_entity_cloner_builder_finish(b);
    let comps: Vec<i32> = Vec::new();
    comps.push(1);
    comps.push(2);
    let r = ecs_entity_cloner_spawn_clone(c, comps, 100);
    if r.0 != 100 { panic(44015); };
    if r.1 != 2 { panic(44016); };
}

@test "entity cloner observers toggle"() {
    let t = ecs_entity_cloner_observers_new();
    if ecs_entity_cloner_observers_get(t) != false { panic(44017); };
    let t2 = ecs_entity_cloner_observers_add(t, true);
    if ecs_entity_cloner_observers_get(t2) != true { panic(44018); };
}
