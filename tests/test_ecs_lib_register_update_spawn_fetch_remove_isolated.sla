@import "lib/component_register.sla"
@import "lib/message_update.sla"
@import "lib/spawn_batch.sla"
@import "lib/entity_component_fetch.sla"
@import "lib/bundle_remove.sla"

@test "component ids peek and next"() {
    let c = ecs_component_ids_new(5);
    if ecs_component_ids_peek(c) != 5 { panic(59001); };
    let r = ecs_component_ids_next(c);
    if r.1 != 5 { panic(59002); };
    if ecs_component_ids_peek(r.0) != 6 { panic(59003); };
}

@test "component ids len and is empty"() {
    let c = ecs_component_ids_new(0);
    if ecs_component_ids_is_empty(c) != true { panic(59004); };
    let r = ecs_component_ids_next(c);
    if ecs_component_ids_len(r.0) != 1 { panic(59005); };
}

@test "components registrator register component"() {
    let r = ecs_components_registrator_new();
    let r2 = ecs_components_registrator_register_component(r, 100);
    if r2.1 != 0 { panic(59006); };
    if ecs_components_registrator_registered_count(r2.0) != 1 { panic(59007); };
}

@test "components registrator queue and apply"() {
    let r = ecs_components_registrator_new();
    r = ecs_components_registrator_queue(r, 1);
    r = ecs_components_registrator_queue(r, 2);
    if ecs_components_registrator_queued_count(r) != 2 { panic(59008); };
    let r2 = ecs_components_registrator_apply_queued(r);
    if r2.1 != 2 { panic(59009); };
    if ecs_components_registrator_registered_count(r2.0) != 2 { panic(59010); };
    if ecs_components_registrator_queued_count(r2.0) != 0 { panic(59011); };
}

@test "components registrator is registered"() {
    let r = ecs_components_registrator_new();
    let r2 = ecs_components_registrator_register_component(r, 100);
    if ecs_components_registrator_is_registered(r2.0, 100) != true { panic(59012); };
    if ecs_components_registrator_is_registered(r2.0, 200) != false { panic(59013); };
}

@test "components registrator as queued"() {
    let r = ecs_components_registrator_new();
    r = ecs_components_registrator_queue(r, 5);
    let q = ecs_components_registrator_as_queued(r);
    if len(q) as i64 != 1 { panic(59014); };
    if q[0] != 5 { panic(59015); };
}

@test "message update systems new"() {
    let s = ecs_message_update_systems_new();
    if ecs_message_update_last_change_tick(s) != 0 { panic(59016); };
    if ecs_message_update_count(s) != 0 { panic(59017); };
}

@test "signal message update system"() {
    let s = ecs_message_update_systems_new();
    let s2 = ecs_signal_message_update_system(s, true);
    if ecs_message_update_signal_present(s2) != true { panic(59018); };
    if ecs_message_update_condition(s2) != true { panic(59019); };
}

@test "message update system run"() {
    let s = ecs_message_update_systems_new();
    let s2 = ecs_signal_message_update_system(s, true);
    let s3 = ecs_message_update_system(s2, 10);
    if ecs_message_update_last_change_tick(s3) != 10 { panic(59020); };
    if ecs_message_update_count(s3) != 1 { panic(59021); };
    if ecs_message_update_signal_present(s3) != false { panic(59022); };
}

@test "spawn batch iter new and len"() {
    let items: Vec<i64> = Vec::new();
    items.push(1);
    items.push(2);
    items.push(3);
    let s = ecs_spawn_batch_iter_new(items, 100);
    if ecs_spawn_batch_iter_len(s) != 3 { panic(59023); };
    if ecs_spawn_batch_iter_is_empty(s) != false { panic(59024); };
}

@test "spawn batch iter next"() {
    let items: Vec<i64> = Vec::new();
    items.push(1);
    items.push(2);
    let s = ecs_spawn_batch_iter_new(items, 100);
    let r = ecs_spawn_batch_iter_next(s);
    if r.1 != true { panic(59025); };
    if r.2 != 100 { panic(59026); };
    if ecs_spawn_batch_iter_spawned_count(r.0) != 1 { panic(59027); };
}

@test "spawn batch iter collect"() {
    let items: Vec<i64> = Vec::new();
    items.push(1);
    items.push(2);
    items.push(3);
    let s = ecs_spawn_batch_iter_new(items, 100);
    let r = ecs_spawn_batch_iter_collect(s);
    if len(r.1) as i64 != 3 { panic(59028); };
    if r.1[0] != 100 { panic(59029); };
    if r.1[2] != 102 { panic(59030); };
}

@test "spawn batch iter next exhausted"() {
    let items: Vec<i64> = Vec::new();
    let s = ecs_spawn_batch_iter_new(items, 100);
    let r = ecs_spawn_batch_iter_next(s);
    if r.1 != false { panic(59031); };
}

@test "entity component fetch new and add"() {
    let f = ecs_entity_component_fetch_new(5);
    f = ecs_entity_component_fetch_add(f, 1, 100);
    f = ecs_entity_component_fetch_add(f, 2, 200);
    if ecs_entity_component_fetch_entity(f) != 5 { panic(59032); };
    if ecs_entity_component_fetch_len(f) != 2 { panic(59033); };
}

@test "entity component fetch get"() {
    let f = ecs_entity_component_fetch_new(5);
    f = ecs_entity_component_fetch_add(f, 1, 100);
    let g = ecs_entity_component_fetch_get(f, 1);
    if g.0 != true { panic(59034); };
    if g.1 != 100 { panic(59035); };
    let g2 = ecs_entity_component_fetch_get(f, 99);
    if g2.0 != false { panic(59036); };
}

@test "entity component fetch contains"() {
    let f = ecs_entity_component_fetch_new(5);
    f = ecs_entity_component_fetch_add(f, 1, 100);
    if ecs_entity_component_fetch_contains(f, 1) != true { panic(59037); };
    if ecs_entity_component_fetch_contains(f, 2) != false { panic(59038); };
}

@test "bundle remover new and count"() {
    let ids: Vec<i32> = Vec::new();
    ids.push(1);
    ids.push(2);
    let r = ecs_bundle_remover_new(ids);
    if ecs_bundle_remover_component_count(r) != 2 { panic(59039); };
}

@test "bundle remover remove"() {
    let ids: Vec<i32> = Vec::new();
    ids.push(1);
    ids.push(3);
    let r = ecs_bundle_remover_new(ids);
    let entity_comps: Vec<i32> = Vec::new();
    entity_comps.push(1);
    entity_comps.push(2);
    entity_comps.push(3);
    entity_comps.push(4);
    let r2 = ecs_bundle_remover_remove(r, entity_comps);
    if r2.1 != 2 { panic(59040); };
    if ecs_bundle_remover_removed_count(r2.0) != 2 { panic(59041); };
}

@test "bundle remover pre remove"() {
    let r = ecs_empty_pre_remove();
    let r2 = ecs_bundle_remover_pre_remove(r, 5);
    if ecs_bundle_remover_component_count(r2) != 1 { panic(59042); };
}
