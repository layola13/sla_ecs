@import "lib/schedules.sla"
@import "lib/schedule_pass.sla"

@test "schedules new and contains"() {
    let s = ecs_schedules_new();
    if ecs_schedules_contains(s, 1) != false { panic(54001); };
    if ecs_schedules_len(s) != 0 { panic(54002); };
}

@test "schedules insert new"() {
    let s = ecs_schedules_new();
    let r = ecs_schedules_insert(s, 1, 100);
    if r.1 != false { panic(54003); };
    if ecs_schedules_contains(r.0, 1) != true { panic(54004); };
    if ecs_schedules_len(r.0) != 1 { panic(54005); };
}

@test "schedules insert replace"() {
    let s = ecs_schedules_new();
    let r1 = ecs_schedules_insert(s, 1, 100);
    let r2 = ecs_schedules_insert(r1.0, 1, 200);
    if r2.1 != true { panic(54006); };
    let g = ecs_schedules_get(r2.0, 1);
    if g.1 != 200 { panic(54007); };
}

@test "schedules get"() {
    let s = ecs_schedules_new();
    let r = ecs_schedules_insert(s, 1, 100);
    let g = ecs_schedules_get(r.0, 1);
    if g.0 != true { panic(54008); };
    if g.1 != 100 { panic(54009); };
    let g2 = ecs_schedules_get(r.0, 2);
    if g2.0 != false { panic(54010); };
}

@test "schedules remove"() {
    let s = ecs_schedules_new();
    let r = ecs_schedules_insert(s, 1, 100);
    let r2 = ecs_schedules_remove(r.0, 1);
    if r2.1 != true { panic(54011); };
    if ecs_schedules_contains(r2.0, 1) != false { panic(54012); };
}

@test "schedules remove missing"() {
    let s = ecs_schedules_new();
    let r = ecs_schedules_remove(s, 1);
    if r.1 != false { panic(54013); };
}

@test "schedules remove temporarily"() {
    let s = ecs_schedules_new();
    let r = ecs_schedules_insert(s, 1, 100);
    let r2 = ecs_schedules_remove_temporarily(r.0, 1);
    if r2.1 != true { panic(54014); };
    if ecs_schedules_temporarily_removed_count(r2.0) != 1 { panic(54015); };
    if ecs_schedules_contains(r2.0, 1) != false { panic(54016); };
}

@test "schedules reinsert"() {
    let s = ecs_schedules_new();
    let r = ecs_schedules_insert(s, 1, 100);
    let r2 = ecs_schedules_remove_temporarily(r.0, 1);
    let r3 = ecs_schedules_reinsert(r2.0, 1, 100);
    if r3.1 != true { panic(54017); };
    if ecs_schedules_contains(r3.0, 1) != true { panic(54018); };
    if ecs_schedules_temporarily_removed_count(r3.0) != 0 { panic(54019); };
}

@test "schedules entry existing"() {
    let s = ecs_schedules_new();
    let r = ecs_schedules_insert(s, 1, 100);
    let e = ecs_schedules_entry(r.0, 1);
    if e.1 != 100 { panic(54020); };
}

@test "schedules entry new"() {
    let s = ecs_schedules_new();
    let e = ecs_schedules_entry(s, 1);
    if ecs_schedules_contains(e.0, 1) != true { panic(54021); };
}

@test "schedules mark empty"() {
    let s = ecs_schedules_new();
    s = ecs_schedules_mark_empty(s, 1);
    if ecs_schedules_empty_count(s) != 1 { panic(54022); };
}

@test "system key new and eq"() {
    let k = ecs_system_key_new(5);
    if ecs_system_key_id(k) != 5 { panic(54023); };
    if ecs_system_key_eq(ecs_system_key_new(5), ecs_system_key_new(5)) != true { panic(54024); };
}

@test "flattened deps add node and edge"() {
    let d = ecs_flattened_deps_new();
    d = ecs_flattened_deps_add_node(d, 1);
    d = ecs_flattened_deps_add_node(d, 2);
    d = ecs_flattened_deps_add_node(d, 3);
    d = ecs_flattened_deps_add_edge(d, 1, 2);
    d = ecs_flattened_deps_add_edge(d, 2, 3);
    if ecs_flattened_deps_node_count(d) != 3 { panic(54025); };
    if ecs_flattened_deps_edge_count(d) != 2 { panic(54026); };
}

@test "flattened deps remove edge"() {
    let d = ecs_flattened_deps_new();
    d = ecs_flattened_deps_add_edge(d, 1, 2);
    d = ecs_flattened_deps_add_edge(d, 2, 3);
    let r = ecs_flattened_deps_remove_edge(d, 1, 2);
    if r.1 != true { panic(54027); };
    if ecs_flattened_deps_edge_count(r.0) != 1 { panic(54028); };
}

@test "flattened deps toposort acyclic"() {
    let d = ecs_flattened_deps_new();
    d = ecs_flattened_deps_add_node(d, 1);
    d = ecs_flattened_deps_add_node(d, 2);
    d = ecs_flattened_deps_add_node(d, 3);
    d = ecs_flattened_deps_add_edge(d, 1, 2);
    d = ecs_flattened_deps_add_edge(d, 2, 3);
    let r = ecs_flattened_deps_toposort(d);
    if r.0 != true { panic(54029); };
    if len(r.1) as i64 != 3 { panic(54030); };
    if r.1[0] != 1 { panic(54031); };
    if r.1[1] != 2 { panic(54032); };
    if r.1[2] != 3 { panic(54033); };
}

@test "flattened deps toposort cyclic"() {
    let d = ecs_flattened_deps_new();
    d = ecs_flattened_deps_add_node(d, 1);
    d = ecs_flattened_deps_add_node(d, 2);
    d = ecs_flattened_deps_add_edge(d, 1, 2);
    d = ecs_flattened_deps_add_edge(d, 2, 1);
    let r = ecs_flattened_deps_toposort(d);
    if r.0 != false { panic(54034); };
}

@test "schedule build pass build"() {
    let p = ecs_schedule_build_pass_new(1);
    p = ecs_schedule_build_pass_add_node(p, 1);
    p = ecs_schedule_build_pass_add_node(p, 2);
    p = ecs_schedule_build_pass_add_edge(p, 1, 2);
    let r = ecs_schedule_build_pass_build(p);
    if r.0 != true { panic(54035); };
    if len(r.1) as i64 != 2 { panic(54036); };
}

@test "schedule build pass analyze"() {
    let p = ecs_schedule_build_pass_new(1);
    p = ecs_schedule_build_pass_add_node(p, 1);
    p = ecs_schedule_build_pass_add_node(p, 2);
    p = ecs_schedule_build_pass_add_edge(p, 1, 2);
    let a = ecs_schedule_build_pass_analyze(p);
    if ecs_dag_analysis_is_acyclic(a) != true { panic(54037); };
    if ecs_dag_analysis_node_count(a) != 2 { panic(54038); };
    if ecs_dag_analysis_edge_count(a) != 1 { panic(54039); };
}
