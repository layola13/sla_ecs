@import "lib/entity_commands_conditional.sla"

// === Basic ===

@test "ec2 new and id"() {
    let c = ecs_ec2_new(42);
    if ecs_ec2_id(c) != 42 { panic(70001); };
    if ecs_ec2_is_spawned(c) != true { panic(70002); };
    if ecs_ec2_component_count(c) != 0 { panic(70003); };
}

@test "ec2 insert and get"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 50);
    if ecs_ec2_contains(c2, 5) != true { panic(70010); };
    let g = ecs_ec2_get(c2, 5);
    if g.0 != true { panic(70011); };
    if g.1 != 50 { panic(70012); };
}

@test "ec2 insert overwrite"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 10);
    let c3 = ecs_ec2_insert(c2, 5, 20);
    let g = ecs_ec2_get(c3, 5);
    if g.1 != 20 { panic(70020); };
    if ecs_ec2_component_count(c3) != 1 { panic(70021); };
}

// === insert_if ===

@test "ec2 insert_if true"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert_if(c, 5, 50, true);
    if ecs_ec2_contains(c2, 5) != true { panic(70030); };
}

@test "ec2 insert_if false noop"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert_if(c, 5, 50, false);
    if ecs_ec2_contains(c2, 5) != false { panic(70040); };
}

// === insert_if_new ===

@test "ec2 insert_if_new new"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert_if_new(c, 5, 50);
    if ecs_ec2_contains(c2, 5) != true { panic(70050); };
    let g = ecs_ec2_get(c2, 5);
    if g.1 != 50 { panic(70051); };
}

@test "ec2 insert_if_new existing noop"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 50);
    let c3 = ecs_ec2_insert_if_new(c2, 5, 99);
    let g = ecs_ec2_get(c3, 5);
    if g.1 != 50 { panic(70060); };
}

// === insert_if_new_and ===

@test "ec2 insert_if_new_and true"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert_if_new_and(c, 5, 50, true);
    if ecs_ec2_contains(c2, 5) != true { panic(70070); };
}

@test "ec2 insert_if_new_and false noop"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert_if_new_and(c, 5, 50, false);
    if ecs_ec2_contains(c2, 5) != false { panic(70080); };
}

// === insert_if_neq ===

@test "ec2 insert_if_neq different"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 10);
    let c3 = ecs_ec2_insert_if_neq(c2, 5, 20);
    let g = ecs_ec2_get(c3, 5);
    if g.1 != 20 { panic(70090); };
}

@test "ec2 insert_if_neq same noop"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 10);
    let c3 = ecs_ec2_insert_if_neq(c2, 5, 10);
    let g = ecs_ec2_get(c3, 5);
    if g.1 != 10 { panic(70100); };
}

@test "ec2 insert_if_neq new component"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert_if_neq(c, 5, 10);
    if ecs_ec2_contains(c2, 5) != true { panic(70110); };
}

// === try_insert ===

@test "ec2 try_insert spawned"() {
    let c = ecs_ec2_new(1);
    let result = ecs_ec2_try_insert(c, 5, 50);
    if result.1 != 0 { panic(70120); };
    if ecs_ec2_contains(result.0, 5) != true { panic(70121); };
}

@test "ec2 try_insert despawned"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_despawn(c);
    let result = ecs_ec2_try_insert(c2, 5, 50);
    if result.1 != 1 { panic(70130); };
}

// === try_insert_if ===

@test "ec2 try_insert_if true"() {
    let c = ecs_ec2_new(1);
    let result = ecs_ec2_try_insert_if(c, 5, 50, true);
    if result.1 != 0 { panic(70140); };
    if ecs_ec2_contains(result.0, 5) != true { panic(70141); };
}

@test "ec2 try_insert_if false noop"() {
    let c = ecs_ec2_new(1);
    let result = ecs_ec2_try_insert_if(c, 5, 50, false);
    if result.1 != 0 { panic(70150); };
    if ecs_ec2_contains(result.0, 5) != false { panic(70151); };
}

// === try_insert_if_new ===

@test "ec2 try_insert_if_new"() {
    let c = ecs_ec2_new(1);
    let result = ecs_ec2_try_insert_if_new(c, 5, 50);
    if result.1 != 0 { panic(70160); };
    if ecs_ec2_contains(result.0, 5) != true { panic(70161); };
}

// === try_insert_if_new_and ===

@test "ec2 try_insert_if_new_and"() {
    let c = ecs_ec2_new(1);
    let result = ecs_ec2_try_insert_if_new_and(c, 5, 50, true);
    if result.1 != 0 { panic(70170); };
    let result2 = ecs_ec2_try_insert_if_new_and(c, 6, 60, false);
    if result2.1 != 0 { panic(70171); };
    if ecs_ec2_contains(result2.0, 6) != false { panic(70172); };
}

// === Remove ===

@test "ec2 remove"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 1, 10);
    let c3 = ecs_ec2_insert(c2, 2, 20);
    let c4 = ecs_ec2_remove(c3, 1);
    if ecs_ec2_contains(c4, 1) != false { panic(70180); };
    if ecs_ec2_contains(c4, 2) != true { panic(70181); };
}

@test "ec2 remove_by_id"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 1, 10);
    let c3 = ecs_ec2_remove_by_id(c2, 1);
    if ecs_ec2_contains(c3, 1) != false { panic(70190); };
}

@test "ec2 remove_with_requires"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 1, 10);
    let c3 = ecs_ec2_remove_with_requires(c2, 1);
    if ecs_ec2_contains(c3, 1) != false { panic(70200); };
}

// === remove_if ===

@test "ec2 remove_if true"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 50);
    let c3 = ecs_ec2_remove_if(c2, 5, true);
    if ecs_ec2_contains(c3, 5) != false { panic(70210); };
}

@test "ec2 remove_if false noop"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 50);
    let c3 = ecs_ec2_remove_if(c2, 5, false);
    if ecs_ec2_contains(c3, 5) != true { panic(70220); };
}

// === try_remove ===

@test "ec2 try_remove spawned"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 50);
    let result = ecs_ec2_try_remove(c2, 5);
    if result.1 != 0 { panic(70230); };
    if ecs_ec2_contains(result.0, 5) != false { panic(70231); };
}

@test "ec2 try_remove despawned"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_despawn(c);
    let result = ecs_ec2_try_remove(c2, 5);
    if result.1 != 1 { panic(70240); };
}

// === try_remove_if ===

@test "ec2 try_remove_if"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 50);
    let result = ecs_ec2_try_remove_if(c2, 5, true);
    if result.1 != 0 { panic(70250); };
    if ecs_ec2_contains(result.0, 5) != false { panic(70251); };
}

// === retain ===

@test "ec2 retain"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 1, 10);
    let c3 = ecs_ec2_insert(c2, 2, 20);
    let c4 = ecs_ec2_insert(c3, 3, 30);
    let retain_ids = Vec::new();
    retain_ids.push(2);
    let c5 = ecs_ec2_retain(c4, retain_ids);
    if ecs_ec2_contains(c5, 1) != false { panic(70260); };
    if ecs_ec2_contains(c5, 2) != true { panic(70261); };
    if ecs_ec2_contains(c5, 3) != false { panic(70262); };
    if ecs_ec2_component_count(c5) != 1 { panic(70263); };
}

// === clear ===

@test "ec2 clear"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 1, 10);
    let c3 = ecs_ec2_insert(c2, 2, 20);
    let c4 = ecs_ec2_clear(c3);
    if ecs_ec2_component_count(c4) != 0 { panic(70270); };
    if ecs_ec2_is_spawned(c4) != true { panic(70271); };
}

// === despawn ===

@test "ec2 despawn"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 1, 10);
    let c3 = ecs_ec2_despawn(c2);
    if ecs_ec2_is_spawned(c3) != false { panic(70280); };
    if ecs_ec2_component_count(c3) != 0 { panic(70281); };
}

// === try_despawn ===

@test "ec2 try_despawn spawned"() {
    let c = ecs_ec2_new(1);
    let result = ecs_ec2_try_despawn(c);
    if result.1 != 0 { panic(70290); };
    if ecs_ec2_is_spawned(result.0) != false { panic(70291); };
}

@test "ec2 try_despawn already despawned"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_despawn(c);
    let result = ecs_ec2_try_despawn(c2);
    if result.1 != 1 { panic(70300); };
}

// === entry ===

@test "ec2 entry occupied"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 50);
    let e = ecs_ec2_entry(c2, 5);
    if e.0 != true { panic(70310); };
    if e.1 != 5 { panic(70311); };
    if e.2 != 50 { panic(70312); };
}

@test "ec2 entry vacant"() {
    let c = ecs_ec2_new(1);
    let e = ecs_ec2_entry(c, 5);
    if e.0 != false { panic(70320); };
    if e.1 != 5 { panic(70321); };
}

// === reborrow ===

@test "ec2 reborrow"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 5, 50);
    let rb = ecs_ec2_reborrow(c2);
    if ecs_ec2_id(rb) != 1 { panic(70330); };
    if ecs_ec2_contains(rb, 5) != true { panic(70331); };
}

// === command log ===

@test "ec2 command log"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert(c, 1, 10);
    let c3 = ecs_ec2_insert(c2, 2, 20);
    let c4 = ecs_ec2_remove(c3, 1);
    let c5 = ecs_ec2_clear(c4);
    if ecs_ec2_command_log_len(c5) != 4 { panic(70340); };
}

// === queue ===

@test "ec2 queue"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_queue(c, 99);
    if ecs_ec2_command_log_len(c2) != 1 { panic(70350); };
}

// === multiple insert_if_new chain ===

@test "ec2 insert_if_new chain"() {
    let c = ecs_ec2_new(1);
    let c2 = ecs_ec2_insert_if_new(c, 1, 10);
    let c3 = ecs_ec2_insert_if_new(c2, 2, 20);
    let c4 = ecs_ec2_insert_if_new(c3, 1, 99);
    if ecs_ec2_component_count(c4) != 2 { panic(70360); };
    let g = ecs_ec2_get(c4, 1);
    if g.1 != 10 { panic(70361); };
}
