@import "lib/function_system.sla"
@import "lib/schedule_system.sla"
@import "lib/observer_system.sla"
@import "lib/system_command.sla"
@import "lib/entity_access_except.sla"
@import "lib/relationship_related_methods.sla"
@import "lib/error_command_handling.sla"

@test "system meta new and name"() {
    let m = ecs_system_meta_new(42);
    if ecs_system_meta_name(m) != 42 { panic(58001); };
    let m2 = ecs_system_meta_set_name(m, 99);
    if ecs_system_meta_name(m2) != 99 { panic(58002); };
}

@test "system meta last run"() {
    let m = ecs_system_meta_new(42);
    let m2 = ecs_system_meta_set_last_run(m, 5);
    if ecs_system_meta_get_last_run(m2) != 5 { panic(58003); };
}

@test "system meta non send"() {
    let m = ecs_system_meta_new(42);
    if ecs_system_meta_is_send(m) != true { panic(58004); };
    let m2 = ecs_system_meta_set_non_send(m);
    if ecs_system_meta_is_send(m2) != false { panic(58005); };
}

@test "system meta has deferred"() {
    let m = ecs_system_meta_new(42);
    let m2 = ecs_system_meta_set_has_deferred(m);
    if ecs_system_meta_has_deferred(m2) != true { panic(58006); };
}

@test "function system new and run"() {
    let s = ecs_function_system_new(42);
    let r = ecs_function_system_run(s, 77);
    if r.1 != 77 { panic(58007); };
    if ecs_function_system_last_output(r.0) != 77 { panic(58008); };
    if ecs_function_system_run_count(r.0) != 1 { panic(58009); };
}

@test "function system initialize"() {
    let s = ecs_function_system_new(42);
    if ecs_function_system_is_initialized(s) != false { panic(58010); };
    let s2 = ecs_function_system_initialize(s);
    if ecs_function_system_is_initialized(s2) != true { panic(58011); };
}

@test "system state param validate"() {
    let s = ecs_system_state_param_new(5);
    if ecs_system_state_param_is_valid(s) != false { panic(58012); };
    let s2 = ecs_system_state_param_validate(s);
    if ecs_system_state_param_is_valid(s2) != true { panic(58013); };
}

@test "with input wrapper new and value"() {
    let w = ecs_with_input_wrapper_new(1, 42);
    if ecs_with_input_wrapper_value(w) != 42 { panic(58014); };
    if ecs_with_input_wrapper_system(w) != 1 { panic(58015); };
}

@test "with input wrapper value mut"() {
    let w = ecs_with_input_wrapper_new(1, 42);
    let w2 = ecs_with_input_wrapper_value_mut(w, 99);
    if ecs_with_input_wrapper_value(w2) != 99 { panic(58016); };
}

@test "with input from wrapper new"() {
    let w = ecs_with_input_from_wrapper_new(1);
    let v = ecs_with_input_from_wrapper_value(w);
    if v.0 != false { panic(58017); };
}

@test "with input from wrapper value mut"() {
    let w = ecs_with_input_from_wrapper_new(1);
    let w2 = ecs_with_input_from_wrapper_value_mut(w, 50);
    let v = ecs_with_input_from_wrapper_value(w2);
    if v.0 != true { panic(58018); };
    if v.1 != 50 { panic(58019); };
}

@test "with input from wrapper run"() {
    let w = ecs_with_input_from_wrapper_new(1);
    let r = ecs_with_input_from_wrapper_run(w);
    if r.0 != false { panic(58020); };
    let w2 = ecs_with_input_from_wrapper_value_mut(w, 50);
    let r2 = ecs_with_input_from_wrapper_run(w2);
    if r2.0 != true { panic(58021); };
    if r2.1 != 50 { panic(58022); };
}

@test "observer system new"() {
    let s = ecs_observer_system_new(7, 3, 100);
    if ecs_observer_system_event(s) != 7 { panic(58023); };
    if ecs_observer_system_bundle(s) != 3 { panic(58024); };
    if ecs_observer_system_runner(s) != 100 { panic(58025); };
}

@test "observer system run"() {
    let s = ecs_observer_system_new(7, 3, 100);
    let r = ecs_observer_system_run(s, 55);
    if r.1 != 55 { panic(58026); };
    if ecs_observer_system_run_count(r.0) != 1 { panic(58027); };
}

@test "into observer system into"() {
    let i = ecs_into_observer_system_new(7, 3, 200);
    let s = ecs_into_observer_system_into(i, 100);
    if ecs_observer_system_runner(s) != 100 { panic(58028); };
}

@test "command spawn and insert"() {
    let c = ecs_command_spawn(100);
    if ecs_command_kind(c) != ECS_CMD_SPAWN { panic(58029); };
    let c2 = ecs_command_insert(5, 3, 99);
    if ecs_command_kind(c2) != ECS_CMD_INSERT { panic(58030); };
    if ecs_command_entity(c2) != 5 { panic(58031); };
}

@test "command remove and despawn"() {
    let c = ecs_command_remove(5, 3);
    if ecs_command_kind(c) != ECS_CMD_REMOVE { panic(58032); };
    let c2 = ecs_command_despawn(5);
    if ecs_command_kind(c2) != ECS_CMD_DESPAWN { panic(58033); };
}

@test "command resource insert and custom"() {
    let c = ecs_command_resource_insert(3, 99);
    if ecs_command_kind(c) != ECS_CMD_RESOURCE_INSERT { panic(58034); };
    if ecs_command_value(c) != 99 { panic(58035); };
    let c2 = ecs_command_custom(500);
    if ecs_command_kind(c2) != ECS_CMD_CUSTOM { panic(58036); };
}

@test "command apply"() {
    let c = ecs_command_despawn(5);
    if ecs_command_apply(c) != 1 { panic(58037); };
}

@test "except add and excludes"() {
    let e = ecs_except_new();
    e = ecs_except_add(e, 1);
    e = ecs_except_add(e, 2);
    if ecs_except_excludes(e, 1) != true { panic(58038); };
    if ecs_except_excludes(e, 3) != false { panic(58039); };
    if ecs_except_len(e) != 2 { panic(58040); };
}

@test "except filter"() {
    let e = ecs_except_new();
    e = ecs_except_add(e, 2);
    let ids: Vec<i32> = Vec::new();
    ids.push(1);
    ids.push(2);
    ids.push(3);
    let out = ecs_except_filter(e, ids);
    if len(out) as i64 != 2 { panic(58041); };
    if out[0] != 1 { panic(58042); };
    if out[1] != 3 { panic(58043); };
}

@test "related add and len"() {
    let r = ecs_related_methods_new();
    r = ecs_related_add(r, 1);
    r = ecs_related_add(r, 2);
    if ecs_related_len(r) != 2 { panic(58044); };
}

@test "related add many"() {
    let r = ecs_related_methods_new();
    let entities: Vec<i64> = Vec::new();
    entities.push(1);
    entities.push(2);
    entities.push(3);
    r = ecs_related_add_many(r, entities);
    if ecs_related_len(r) != 3 { panic(58045); };
}

@test "related remove"() {
    let r = ecs_related_methods_new();
    r = ecs_related_add(r, 1);
    r = ecs_related_add(r, 2);
    let r2 = ecs_related_remove(r, 1);
    if r2.1 != true { panic(58046); };
    if ecs_related_len(r2.0) != 1 { panic(58047); };
}

@test "related contains and clear"() {
    let r = ecs_related_methods_new();
    r = ecs_related_add(r, 1);
    if ecs_related_contains(r, 1) != true { panic(58048); };
    let r2 = ecs_related_clear(r);
    if ecs_related_len(r2) != 0 { panic(58049); };
}

@test "related with many"() {
    let r = ecs_related_methods_new();
    let entities: Vec<i64> = Vec::new();
    entities.push(5);
    entities.push(6);
    r = ecs_related_with_many(r, entities);
    if ecs_related_len(r) != 2 { panic(58050); };
    if ecs_related_contains(r, 5) != true { panic(58051); };
}

@test "command output ok and err"() {
    let o = ecs_command_output_ok();
    if ecs_command_output_is_ok(o) != true { panic(58052); };
    let e = ecs_command_output_err(5, 100);
    if ecs_command_output_is_ok(e) != false { panic(58053); };
    if ecs_command_output_error_code(e) != 5 { panic(58054); };
    if ecs_command_output_error_message(e) != 100 { panic(58055); };
}

@test "error handler handle"() {
    let h = ecs_error_handler_new(1);
    let r = ecs_error_handler_handle(h, 5);
    if ecs_command_output_is_ok(r.1) != true { panic(58056); };
    if ecs_error_handler_handled_count(r.0) != 1 { panic(58057); };
}

@test "fallback error handler"() {
    let h = ecs_fallback_error_handler_new();
    let r = ecs_fallback_error_handler_handle(h, 7);
    if ecs_command_output_is_ok(r.1) != false { panic(58058); };
    if ecs_fallback_error_handler_panic_count(r.0) != 1 { panic(58059); };
}
