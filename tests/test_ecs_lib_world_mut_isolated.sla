@import "lib/world_mut.sla"

// === Identity & spawned state ===

@test "ewm2 new and id"() {
    let m = ecs_ewm2_new(42);
    if ecs_ewm2_id(m) != 42 { panic(69001); };
    if ecs_ewm2_is_spawned(m) != true { panic(69002); };
}

@test "ewm2 new empty is despawned"() {
    let m = ecs_ewm2_new_empty(0);
    if ecs_ewm2_is_spawned(m) != false { panic(69010); };
    if ecs_ewm2_is_despawned(m) != true { panic(69011); };
}

@test "ewm2 location and archetype"() {
    let m = ecs_ewm2_new(7);
    if ecs_ewm2_archetype(m) != 0 { panic(69020); };
    let loc = ecs_ewm2_location(m);
    if loc.0 != 0 { panic(69021); };
    if loc.1 != 0 { panic(69022); };
    let m2 = ecs_ewm2_set_archetype(m, 5, 3);
    if ecs_ewm2_archetype(m2) != 5 { panic(69023); };
    let loc2 = ecs_ewm2_location(m2);
    if loc2.0 != 5 { panic(69024); };
    if loc2.1 != 3 { panic(69025); };
}

@test "ewm2 try_location spawned"() {
    let m = ecs_ewm2_new(1);
    let tl = ecs_ewm2_try_location(m);
    if tl.0 != true { panic(69030); };
}

@test "ewm2 try_location despawned"() {
    let m = ecs_ewm2_new_empty(1);
    let tl = ecs_ewm2_try_location(m);
    if tl.0 != false { panic(69040); };
}

@test "ewm2 try_archetype"() {
    let m = ecs_ewm2_new(1);
    let ta = ecs_ewm2_try_archetype(m);
    if ta.0 != true { panic(69050); };
    let m2 = ecs_ewm2_new_empty(2);
    let ta2 = ecs_ewm2_try_archetype(m2);
    if ta2.0 != false { panic(69051); };
}

@test "ewm2 spawned_by and spawn_tick"() {
    let m = ecs_ewm2_new(1);
    if ecs_ewm2_spawned_by(m) != 0 { panic(69060); };
    if ecs_ewm2_spawn_tick(m) != 0 { panic(69061); };
    let m2 = ecs_ewm2_set_spawned_by(m, 99);
    if ecs_ewm2_spawned_by(m2) != 99 { panic(69062); };
    let m3 = ecs_ewm2_set_spawn_tick(m2, 7);
    if ecs_ewm2_spawn_tick(m3) != 7 { panic(69063); };
}

// === Contains ===

@test "ewm2 contains"() {
    let m = ecs_ewm2_new(1);
    if ecs_ewm2_contains(m, 5) != false { panic(69070); };
    let m2 = ecs_ewm2_insert(m, 5, 100);
    if ecs_ewm2_contains(m2, 5) != true { panic(69071); };
    if ecs_ewm2_contains_id(m2, 5) != true { panic(69072); };
    if ecs_ewm2_contains_type_id(m2, 5) != true { panic(69073); };
}

// === Get / get_mut / get_ref ===

@test "ewm2 get"() {
    let m = ecs_ewm2_new(1);
    let g0 = ecs_ewm2_get(m, 3);
    if g0.0 != false { panic(69080); };
    let m2 = ecs_ewm2_insert(m, 3, 77);
    let g1 = ecs_ewm2_get(m2, 3);
    if g1.0 != true { panic(69081); };
    if g1.1 != 77 { panic(69082); };
}

@test "ewm2 get_ref and get_mut"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 4, 50);
    let gr = ecs_ewm2_get_ref(m2, 4);
    if gr.0 != true { panic(69090); };
    if gr.1 != 50 { panic(69091); };
    let gm = ecs_ewm2_get_mut(m2, 4);
    if gm.0 != true { panic(69092); };
    if gm.1 != 50 { panic(69093); };
}

@test "ewm2 get_by_id and get_mut_by_id"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 6, 60);
    let gb = ecs_ewm2_get_by_id(m2, 6);
    if gb.0 != true { panic(69100); };
    if gb.1 != 60 { panic(69101); };
    let gmb = ecs_ewm2_get_mut_by_id(m2, 6);
    if gmb.0 != true { panic(69102); };
}

// === Insert ===

@test "ewm2 insert overwrite"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 2, 10);
    let m3 = ecs_ewm2_insert(m2, 2, 20);
    let g = ecs_ewm2_get(m3, 2);
    if g.1 != 20 { panic(69110); };
    if ecs_ewm2_component_count(m3) != 1 { panic(69111); };
}

@test "ewm2 insert multiple"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_insert(m2, 2, 20);
    let m4 = ecs_ewm2_insert(m3, 3, 30);
    if ecs_ewm2_component_count(m4) != 3 { panic(69120); };
}

@test "ewm2 insert_if_new existing"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 5, 50);
    let m3 = ecs_ewm2_insert_if_new(m2, 5, 99);
    let g = ecs_ewm2_get(m3, 5);
    if g.1 != 50 { panic(69130); };
}

@test "ewm2 insert_if_new new"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert_if_new(m, 5, 99);
    let g = ecs_ewm2_get(m2, 5);
    if g.1 != 99 { panic(69140); };
}

// === Remove ===

@test "ewm2 remove_by_id"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_insert(m2, 2, 20);
    let m4 = ecs_ewm2_remove_by_id(m3, 1);
    if ecs_ewm2_contains(m4, 1) != false { panic(69150); };
    if ecs_ewm2_contains(m4, 2) != true { panic(69151); };
    if ecs_ewm2_component_count(m4) != 1 { panic(69152); };
}

@test "ewm2 remove nonexistent"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_remove_by_id(m2, 99);
    if ecs_ewm2_component_count(m3) != 1 { panic(69160); };
}

@test "ewm2 remove_with_requires"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_remove_with_requires(m2, 1);
    if ecs_ewm2_contains(m3, 1) != false { panic(69170); };
}

// === Retain ===

@test "ewm2 retain"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_insert(m2, 2, 20);
    let m4 = ecs_ewm2_insert(m3, 3, 30);
    let retain_ids = Vec::new();
    retain_ids.push(2);
    let m5 = ecs_ewm2_retain(m4, retain_ids);
    if ecs_ewm2_contains(m5, 1) != false { panic(69180); };
    if ecs_ewm2_contains(m5, 2) != true { panic(69181); };
    if ecs_ewm2_contains(m5, 3) != false { panic(69182); };
    if ecs_ewm2_component_count(m5) != 1 { panic(69183); };
}

// === Take ===

@test "ewm2 take"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 5, 55);
    let result = ecs_ewm2_take(m2, 5);
    let m3 = result.0;
    if result.1 != true { panic(69190); };
    if result.2 != 55 { panic(69191); };
    if ecs_ewm2_contains(m3, 5) != false { panic(69192); };
}

@test "ewm2 take nonexistent"() {
    let m = ecs_ewm2_new(1);
    let result = ecs_ewm2_take(m, 99);
    if result.1 != false { panic(69200); };
}

// === Clear ===

@test "ewm2 clear"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_insert(m2, 2, 20);
    let m4 = ecs_ewm2_clear(m3);
    if ecs_ewm2_component_count(m4) != 0 { panic(69210); };
    if ecs_ewm2_id(m4) != 1 { panic(69211); };
}

// === Despawn ===

@test "ewm2 despawn"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_despawn(m2);
    if ecs_ewm2_is_spawned(m3) != false { panic(69220); };
    if ecs_ewm2_component_count(m3) != 0 { panic(69221); };
}

@test "ewm2 despawn_no_free"() {
    let m = ecs_ewm2_new(1);
    let id = ecs_ewm2_despawn_no_free(m);
    if id != 1 { panic(69230); };
}

@test "ewm2 flush"() {
    let m = ecs_ewm2_new(42);
    if ecs_ewm2_flush(m) != 42 { panic(69240); };
}

// === Components list ===

@test "ewm2 components list"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 10, 100);
    let m3 = ecs_ewm2_insert(m2, 20, 200);
    let comps = ecs_ewm2_components(m3);
    if len(comps) as i64 != 2 { panic(69250); };
}

// === Clone and spawn ===

@test "ewm2 clone_and_spawn"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_insert(m2, 2, 20);
    let clone = ecs_ewm2_clone_and_spawn(m3, 2);
    if ecs_ewm2_id(clone) != 2 { panic(69260); };
    if ecs_ewm2_is_spawned(clone) != true { panic(69261); };
    if ecs_ewm2_component_count(clone) != 2 { panic(69262); };
    if ecs_ewm2_contains(clone, 1) != true { panic(69263); };
    if ecs_ewm2_contains(clone, 2) != true { panic(69264); };
}

// === Clone components ===

@test "ewm2 clone_components"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_insert(m2, 2, 20);
    let target_ids = Vec::new();
    let target_vals = Vec::new();
    let result = ecs_ewm2_clone_components(m3, target_ids, target_vals);
    let rids = result.0;
    let rvals = result.1;
    if len(rids) as i64 != 2 { panic(69270); };
    if len(rvals) as i64 != 2 { panic(69271); };
}

@test "ewm2 clone_components with existing"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_insert(m2, 2, 20);
    let target_ids = Vec::new();
    let target_vals = Vec::new();
    target_ids.push(1);
    target_vals.push(99);
    let result = ecs_ewm2_clone_components(m3, target_ids, target_vals);
    let rids = result.0;
    if len(rids) as i64 != 2 { panic(69280); };
}

// === Move components ===

@test "ewm2 move_components"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 1, 10);
    let m3 = ecs_ewm2_insert(m2, 2, 20);
    let target_ids = Vec::new();
    let target_vals = Vec::new();
    let result = ecs_ewm2_move_components(m3, target_ids, target_vals);
    let m4 = result.0;
    let rids = result.1;
    if ecs_ewm2_component_count(m4) != 0 { panic(69290); };
    if len(rids) as i64 != 2 { panic(69291); };
}

// === Into readonly / mutable ===

@test "ewm2 into_readonly and as_readonly"() {
    let m = ecs_ewm2_new(42);
    if ecs_ewm2_into_readonly(m) != 42 { panic(69300); };
    if ecs_ewm2_as_readonly(m) != 42 { panic(69301); };
    if ecs_ewm2_into_mutable(m) != 42 { panic(69302); };
    if ecs_ewm2_as_mutable(m) != 42 { panic(69303); };
}

// === Entry ===

@test "ewm2 entry occupied"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 5, 50);
    let e = ecs_ewm2_entry(m2, 5);
    if e.0 != 1 { panic(69310); };
    if e.1 != 50 { panic(69311); };
}

@test "ewm2 entry vacant"() {
    let m = ecs_ewm2_new(1);
    let e = ecs_ewm2_entry(m, 5);
    if e.0 != 0 { panic(69320); };
}

// === Resources ===

@test "ewm2 insert and get resource"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert_resource(m, 100, 1000);
    let g = ecs_ewm2_get_resource(m2, 100);
    if g.0 != true { panic(69330); };
    if g.1 != 1000 { panic(69331); };
}

@test "ewm2 resource and resource_mut"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert_resource(m, 100, 500);
    if ecs_ewm2_resource(m2, 100) != 500 { panic(69340); };
    if ecs_ewm2_resource_mut(m2, 100) != 500 { panic(69341); };
}

@test "ewm2 resource nonexistent"() {
    let m = ecs_ewm2_new(1);
    let g = ecs_ewm2_get_resource(m, 99);
    if g.0 != false { panic(69350); };
}

@test "ewm2 resource_count"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert_resource(m, 1, 10);
    let m3 = ecs_ewm2_insert_resource(m2, 2, 20);
    if ecs_ewm2_resource_count(m3) != 2 { panic(69360); };
}

@test "ewm2 resource overwrite"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert_resource(m, 100, 500);
    let m3 = ecs_ewm2_insert_resource(m2, 100, 600);
    if ecs_ewm2_resource(m3, 100) != 600 { panic(69370); };
    if ecs_ewm2_resource_count(m3) != 1 { panic(69371); };
}

// === Modify component ===

@test "ewm2 modify_component"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 5, 50);
    let result = ecs_ewm2_modify_component(m2, 5, 10);
    let m3 = result.0;
    if result.1 != true { panic(69380); };
    if result.2 != 60 { panic(69381); };
    let g = ecs_ewm2_get(m3, 5);
    if g.1 != 60 { panic(69382); };
}

@test "ewm2 modify_component absent"() {
    let m = ecs_ewm2_new(1);
    let result = ecs_ewm2_modify_component(m, 5, 10);
    if result.1 != false { panic(69390); };
}

// === Get change ticks ===

@test "ewm2 get_change_ticks_by_id"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 5, 42);
    let t = ecs_ewm2_get_change_ticks_by_id(m2, 5);
    if t.0 != true { panic(69400); };
    if t.1 != 42 { panic(69401); };
}

// === update_location ===

@test "ewm2 update_location"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_update_location(m, 7, 3);
    if ecs_ewm2_archetype(m2) != 7 { panic(69410); };
    let loc = ecs_ewm2_location(m2);
    if loc.0 != 7 { panic(69411); };
    if loc.1 != 3 { panic(69412); };
}

// === into_borrow ===

@test "ewm2 into_borrow"() {
    let m = ecs_ewm2_new(1);
    let m2 = ecs_ewm2_insert(m, 3, 33);
    let b = ecs_ewm2_into_borrow(m2, 3);
    if b.0 != true { panic(69420); };
    if b.1 != 33 { panic(69421); };
}
