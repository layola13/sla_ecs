@import "lib/query_builder.sla"
@import "lib/query_fetch.sla"

@test "query builder new and world"() {
    let qb = ecs_query_builder_new(7);
    if ecs_query_builder_world(qb) != 7 { panic(47001); };
}

@test "query builder data"() {
    let qb = ecs_query_builder_new(7);
    qb = ecs_query_builder_data(qb, 1);
    qb = ecs_query_builder_data(qb, 2);
    if ecs_query_builder_data_count(qb) != 2 { panic(47002); };
}

@test "query builder ref and mut id"() {
    let qb = ecs_query_builder_new(7);
    qb = ecs_query_builder_ref_id(qb, 1);
    qb = ecs_query_builder_mut_id(qb, 2);
    if ecs_query_builder_data_count(qb) != 2 { panic(47003); };
}

@test "query builder with and without"() {
    let qb = ecs_query_builder_new(7);
    qb = ecs_query_builder_with(qb, 3);
    qb = ecs_query_builder_without(qb, 4);
    if ecs_query_builder_with_count(qb) != 1 { panic(47004); };
    if ecs_query_builder_without_count(qb) != 1 { panic(47005); };
}

@test "query builder or and optional"() {
    let qb = ecs_query_builder_new(7);
    qb = ecs_query_builder_or(qb);
    qb = ecs_query_builder_optional(qb);
    if ecs_query_builder_or_groups(qb) != 1 { panic(47006); };
    if ecs_query_builder_optional_count(qb) != 1 { panic(47007); };
}

@test "query builder extend access"() {
    let qb = ecs_query_builder_new(7);
    qb = ecs_query_builder_data(qb, 1);
    let other = ecs_query_builder_new(7);
    other = ecs_query_builder_data(other, 2);
    other = ecs_query_builder_data(other, 3);
    qb = ecs_query_builder_extend_access(qb, other);
    if ecs_query_builder_data_count(qb) != 3 { panic(47008); };
}

@test "query builder transmute"() {
    let qb = ecs_query_builder_new(7);
    qb = ecs_query_builder_data(qb, 1);
    let new_ids: Vec<i32> = Vec::new();
    new_ids.push(5);
    new_ids.push(6);
    qb = ecs_query_builder_transmute(qb, new_ids);
    if ecs_query_builder_data_count(qb) != 2 { panic(47009); };
}

@test "query builder build"() {
    let qb = ecs_query_builder_new(7);
    qb = ecs_query_builder_data(qb, 1);
    let state = ecs_query_builder_build(qb);
    if ecs_query_builder_data_count(state) != 1 { panic(47010); };
}

@test "spawn details new and is_spawned"() {
    let s = ecs_spawn_details_new(true, 10, 5);
    if ecs_spawn_details_is_spawned(s) != true { panic(47011); };
    if ecs_spawn_details_spawn_tick(s) != 10 { panic(47012); };
    if ecs_spawn_details_spawned_by(s) != 5 { panic(47013); };
}

@test "spawn details is_spawned_after"() {
    let s = ecs_spawn_details_new(true, 10, 5);
    if ecs_spawn_details_is_spawned_after(s, 5) != true { panic(47014); };
    if ecs_spawn_details_is_spawned_after(s, 15) != false { panic(47015); };
    let s2 = ecs_spawn_details_new(false, 10, 5);
    if ecs_spawn_details_is_spawned_after(s2, 5) != false { panic(47016); };
}

@test "fetch entity read only"() {
    let f = ecs_fetch_entity(42);
    if ecs_fetch_is_read_only(f) != true { panic(47017); };
    if ecs_fetch_value(f) != 42 { panic(47018); };
}

@test "fetch write not read only"() {
    let f = ecs_fetch_write(1, 99);
    if ecs_fetch_is_read_only(f) != false { panic(47019); };
    if ecs_fetch_is_write(f) != true { panic(47020); };
}

@test "fetch read and ref"() {
    let f = ecs_fetch_read(3, 50);
    if ecs_fetch_is_read_only(f) != true { panic(47021); };
    let f2 = ecs_fetch_ref(4, 60);
    if ecs_fetch_is_read_only(f2) != true { panic(47022); };
}

@test "fetch has present"() {
    let f = ecs_fetch_has(5, true);
    if ecs_fetch_present(f) != true { panic(47023); };
    let f2 = ecs_fetch_has(5, false);
    if ecs_fetch_present(f2) != false { panic(47024); };
}

@test "fetch option present"() {
    let f = ecs_fetch_option(6, true);
    if ecs_fetch_present(f) != true { panic(47025); };
}

@test "any of any present"() {
    let a = ecs_any_of_new();
    a = ecs_any_of_add(a, 1, false);
    a = ecs_any_of_add(a, 2, true);
    if ecs_any_of_any_present(a) != true { panic(47026); };
    let a2 = ecs_any_of_new();
    a2 = ecs_any_of_add(a2, 1, false);
    if ecs_any_of_any_present(a2) != false { panic(47027); };
}

@test "nested query push and len"() {
    let n = ecs_nested_query_new(1, 2);
    n = ecs_nested_query_push(n, 10);
    n = ecs_nested_query_push(n, 20);
    if ecs_nested_query_len(n) != 2 { panic(47028); };
    if ecs_nested_query_at(n, 1) != 20 { panic(47029); };
}

@test "query item new and read only"() {
    let f = ecs_fetch_read(1, 5);
    let item = ecs_query_item_new(f);
    if ecs_query_item_is_read_only(item) != true { panic(47030); };
    if ecs_query_item_value(item) != 5 { panic(47031); };
}

@test "ro query item"() {
    let f = ecs_fetch_write(1, 5);
    let item = ecs_ro_query_item(f);
    if ecs_query_item_is_read_only(item) != true { panic(47032); };
}
