@import "lib/schedule_executor.sla"
@import "lib/exclusive_system_param.sla"
@import "lib/graph_map.sla"
@import "lib/reflect_resource.sla"

@test "executor single threaded"() {
    let e = ecs_executor_single_threaded();
    if ecs_executor_kind(e) != ECS_EXEC_SINGLE { panic(53001); };
    if ecs_executor_is_multi_threaded(e) != false { panic(53002); };
}

@test "executor multi threaded"() {
    let e = ecs_executor_multi_threaded();
    if ecs_executor_is_multi_threaded(e) != true { panic(53003); };
}

@test "executor run and skip"() {
    let e = ecs_executor_single_threaded();
    e = ecs_executor_run_system(e, 0);
    e = ecs_executor_run_system(e, 1);
    e = ecs_executor_skip_system(e);
    if ecs_executor_applied_count(e) != 2 { panic(53004); };
    if ecs_executor_skipped_count(e) != 1 { panic(53005); };
    if ecs_executor_next_to_run(e) != 2 { panic(53006); };
}

@test "executor apply deferred"() {
    let e = ecs_executor_single_threaded();
    e = ecs_executor_apply_deferred(e);
    if ecs_executor_has_apply_deferred(e) != true { panic(53007); };
}

@test "executor set up and finish"() {
    let e = ecs_executor_single_threaded();
    e = ecs_executor_set_up(e, 5);
    if ecs_executor_iteration_count(e) != 5 { panic(53008); };
    e = ecs_executor_finish(e);
    if ecs_executor_next_to_run(e) != 5 { panic(53009); };
}

@test "exclusive param deferred world"() {
    let p = ecs_exclusive_param_deferred_world();
    if ecs_exclusive_param_kind(p) != ECS_EXP_PARAM_DEFERRED_WORLD { panic(53010); };
    if ecs_exclusive_param_is_mutable(p) != true { panic(53011); };
}

@test "exclusive param system name not mutable"() {
    let p = ecs_exclusive_param_system_name();
    if ecs_exclusive_param_is_mutable(p) != false { panic(53012); };
}

@test "exclusive param resource"() {
    let p = ecs_exclusive_param_resource(7);
    if ecs_exclusive_param_kind(p) != ECS_EXP_PARAM_RESOURCE { panic(53013); };
    if ecs_exclusive_param_state_id(p) != 7 { panic(53014); };
}

@test "exclusive param init state"() {
    let p = ecs_exclusive_param_resource(0);
    let r = ecs_exclusive_param_init_state(p, 99);
    if ecs_exclusive_param_state_id(r.0) != 99 { panic(53015); };
    if r.1 != 99 { panic(53016); };
}

@test "exclusive param commands query nonsend"() {
    if ecs_exclusive_param_kind(ecs_exclusive_param_commands()) != ECS_EXP_PARAM_COMMANDS { panic(53017); };
    if ecs_exclusive_param_kind(ecs_exclusive_param_query()) != ECS_EXP_PARAM_QUERY { panic(53018); };
    if ecs_exclusive_param_kind(ecs_exclusive_param_non_send()) != ECS_EXP_PARAM_NON_SEND { panic(53019); };
}

@test "graph new directed"() {
    let g = ecs_graph_new(true);
    if ecs_graph_is_directed(g) != true { panic(53020); };
    if ecs_graph_node_count(g) != 0 { panic(53021); };
}

@test "graph add and contains node"() {
    let g = ecs_graph_new(true);
    g = ecs_graph_add_node(g, 1);
    g = ecs_graph_add_node(g, 2);
    g = ecs_graph_add_node(g, 1);
    if ecs_graph_node_count(g) != 2 { panic(53022); };
    if ecs_graph_contains_node(g, 1) != true { panic(53023); };
    if ecs_graph_contains_node(g, 3) != false { panic(53024); };
}

@test "graph remove node"() {
    let g = ecs_graph_new(true);
    g = ecs_graph_add_node(g, 1);
    g = ecs_graph_add_node(g, 2);
    let r = ecs_graph_remove_node(g, 1);
    if r.1 != true { panic(53025); };
    if ecs_graph_node_count(r.0) != 1 { panic(53026); };
}

@test "graph add and contains edge"() {
    let g = ecs_graph_new(true);
    g = ecs_graph_add_edge(g, 1, 2);
    g = ecs_graph_add_edge(g, 2, 3);
    if ecs_graph_edge_count(g) != 2 { panic(53027); };
    if ecs_graph_contains_edge(g, 1, 2) != true { panic(53028); };
    if ecs_graph_contains_edge(g, 1, 3) != false { panic(53029); };
}

@test "graph undirected contains edge"() {
    let g = ecs_graph_new(false);
    g = ecs_graph_add_edge(g, 1, 2);
    if ecs_graph_contains_edge(g, 2, 1) != true { panic(53030); };
}

@test "graph remove edge"() {
    let g = ecs_graph_new(true);
    g = ecs_graph_add_edge(g, 1, 2);
    g = ecs_graph_add_edge(g, 2, 3);
    let r = ecs_graph_remove_edge(g, 1, 2);
    if r.1 != true { panic(53031); };
    if ecs_graph_edge_count(r.0) != 1 { panic(53032); };
}

@test "graph neighbors directed"() {
    let g = ecs_graph_new(true);
    g = ecs_graph_add_edge(g, 1, 2);
    g = ecs_graph_add_edge(g, 1, 3);
    g = ecs_graph_add_edge(g, 2, 3);
    let n = ecs_graph_neighbors_directed(g, 1);
    if len(n) as i64 != 2 { panic(53033); };
}

@test "graph neighbors undirected both"() {
    let g = ecs_graph_new(false);
    g = ecs_graph_add_edge(g, 1, 2);
    let n = ecs_graph_neighbors(g, 2);
    if len(n) as i64 != 1 { panic(53034); };
    if n[0] != 1 { panic(53035); };
}

@test "graph degree"() {
    let g = ecs_graph_new(true);
    g = ecs_graph_add_edge(g, 1, 2);
    g = ecs_graph_add_edge(g, 1, 3);
    if ecs_graph_degree(g, 1) != 2 { panic(53036); };
}

@test "graph remove node removes edges"() {
    let g = ecs_graph_new(true);
    g = ecs_graph_add_node(g, 1);
    g = ecs_graph_add_node(g, 2);
    g = ecs_graph_add_node(g, 3);
    g = ecs_graph_add_edge(g, 1, 2);
    g = ecs_graph_add_edge(g, 2, 3);
    let r = ecs_graph_remove_node(g, 2);
    if ecs_graph_edge_count(r.0) != 0 { panic(53037); };
}

@test "reflect resource register and is registered"() {
    let r = ecs_reflect_resource_new();
    r = ecs_reflect_resource_register(r, 5);
    if ecs_reflect_resource_is_registered(r, 5) != true { panic(53038); };
    if ecs_reflect_resource_is_registered(r, 6) != false { panic(53039); };
    if ecs_reflect_resource_count(r) != 1 { panic(53040); };
}

@test "reflect resource insert and get"() {
    let r = ecs_reflect_resource_new();
    r = ecs_reflect_resource_register(r, 5);
    r = ecs_reflect_resource_insert(r, 5);
    let g = ecs_reflect_resource_get(r, 5);
    if g.0 != true { panic(53041); };
    if g.1 != 1 { panic(53042); };
}

@test "reflect resource remove"() {
    let r = ecs_reflect_resource_new();
    r = ecs_reflect_resource_register(r, 5);
    r = ecs_reflect_resource_insert(r, 5);
    r = ecs_reflect_resource_remove(r, 5);
    let g = ecs_reflect_resource_get(r, 5);
    if g.0 != false { panic(53043); };
}

@test "reflect resource get unregistered"() {
    let r = ecs_reflect_resource_new();
    let g = ecs_reflect_resource_get(r, 99);
    if g.0 != false { panic(53044); };
}

@test "reflect resource apply or insert"() {
    let r = ecs_reflect_resource_new();
    r = ecs_reflect_resource_register(r, 5);
    r = ecs_reflect_resource_apply_or_insert(r, 5);
    if ecs_reflect_resource_insert_count(r, 5) != 1 { panic(53045); };
}
