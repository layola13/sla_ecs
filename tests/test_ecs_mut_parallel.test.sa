@test "mut batch parallel sums disjoint systems"():
L_TEST_ENTRY_6942:
    tmp_27678 = 0
    tmp_27679 = 0
    tmp_27680 = call @sla__table_erased_world_new_i32_i32(tmp_27678, tmp_27679)
    !tmp_27678
    !tmp_27679
    w0 = tmp_27680
    tmp_27681 = call @sla__table_erased_system_access_none()
    acc_a = tmp_27681
    tmp_27682 = call @sla__table_erased_system_access_none()
    acc_b = tmp_27682
    tmp_27683 = load acc_a+8 as ptr
    tmp_27684 = 2401
    EXPAND VEC_PUSH tmp_27683, tmp_27684, 8
    !tmp_27683
    tmp_27685 = load acc_b+8 as ptr
    tmp_27686 = 2402
    EXPAND VEC_PUSH tmp_27685, tmp_27686, 8
    !tmp_27685
    tmp_27687 = &SLA_FNPTR_VT_mp_write_a
    tmp_27688 = &SLA_FNPTR_VT_mp_write_b
    tmp_27689 = call @sla__ecs_parallel_run_mut_batch_i32_i32(w0, tmp_27687, tmp_27688, acc_a, acc_b)
    !tmp_27687
    !tmp_27688
    total = tmp_27689
    tmp_27690 = 2
    tmp_27691 = ne total, tmp_27690
    !tmp_27690
    br tmp_27691 -> L_THEN_6943, L_ELSE_6944

L_THEN_6943:
    !tmp_27691
    panic(24001)

L_ELSE_6944:
    !tmp_27691
    jmp L_MERGE_6945

L_MERGE_6945:
    !w0
    !acc_a
    !acc_b
    !total
