@test "messages update drain returns older buffer and keeps current"():
L_TEST_ENTRY_3895:
    tmp_16936 = call @sla__test_damage_messages_new()
    m0 = tmp_16936
    tmp_16937 = call @sla__messages_update_TestDamageMessage(m0)
    m1 = tmp_16937
    tmp_16938 = alloc 4
    tmp_16939 = 1
    store tmp_16938+0, tmp_16939 as i32
    !tmp_16939
    tmp_16940 = call @sla__messages_write_TestDamageMessage(m1, tmp_16938)
    !tmp_16938
    m2 = tmp_16940
    tmp_16941 = call @sla__messages_update_TestDamageMessage(m2)
    m3 = tmp_16941
    tmp_16942 = alloc 4
    tmp_16943 = 2
    store tmp_16942+0, tmp_16943 as i32
    !tmp_16943
    tmp_16944 = call @sla__messages_write_TestDamageMessage(m3, tmp_16942)
    !tmp_16942
    m4 = tmp_16944
    tmp_16945 = alloc 4
    tmp_16946 = 3
    store tmp_16945+0, tmp_16946 as i32
    !tmp_16946
    tmp_16947 = call @sla__messages_write_TestDamageMessage(m4, tmp_16945)
    !tmp_16945
    m5 = tmp_16947
    tmp_16948 = call @sla__test_damage_default()
    tmp_16949 = call @sla__messages_update_drain_TestDamageMessage(m5, tmp_16948)
    !tmp_16948
    d1 = tmp_16949
    tmp_16950 = load d1+8 as i64
