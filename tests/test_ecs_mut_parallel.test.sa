@test "bundle registry registers and retrieves bundles"():
L_TEST_ENTRY_4188:
    tmp_17968 = call @sla__bundle_registry_new()
    r0 = tmp_17968
    EXPAND VEC_NEW tmp_17969
    c1 = tmp_17969
    tmp_17970 = 10
    EXPAND VEC_PUSH c1, tmp_17970, 8
    !tmp_17970
    tmp_17971 = 20
    EXPAND VEC_PUSH c1, tmp_17971, 8
    !tmp_17971
    @const SLA_STR_8 = utf8:"Bundle1"
    tmp_17972 = 7
    tmp_17973 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_17973, &SLA_STR_8, tmp_17972
    !tmp_17972
    EXPAND STRING_BUF_FROM_UTF8_UNCHECKED tmp_17974, tmp_17973
