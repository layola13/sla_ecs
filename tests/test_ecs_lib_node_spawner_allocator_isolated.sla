// Integration test for lib/schedule_node.sla + lib/bundle_spawner.sla + lib/remote_allocator.sla
@import "lib/schedule_node.sla"
@import "lib/bundle_spawner.sla"
@import "lib/remote_allocator.sla"

// === schedule_node tests ===

@test "node id system"() {
    let n = ecs_node_id_system(5);
    if ecs_node_id_kind(n) != ECS_NODE_SYSTEM { panic(34001); };
    if ecs_node_id_is_system(n) != true { panic(34002); };
    if ecs_node_id_is_set(n) != false { panic(34003); };
}

@test "node id set"() {
    let n = ecs_node_id_set(3);
    if ecs_node_id_kind(n) != ECS_NODE_SET { panic(34004); };
    if ecs_node_id_is_set(n) != true { panic(34005); };
}

@test "node id eq"() {
    let a = ecs_node_id_system(5);
    let b = ecs_node_id_system(5);
    let c = ecs_node_id_system(6);
    if ecs_node_id_eq(a, b) != true { panic(34006); };
    if ecs_node_id_eq(a, c) != false { panic(34007); };
}

@test "system with access new"() {
    let s = ecs_system_with_access_new(10, 42);
    if ecs_system_with_access_id(s) != 10 { panic(34008); };
    if ecs_system_with_access_name(s) != 42 { panic(34009); };
}

@test "system with access set_exclusive"() {
    let s = ecs_system_with_access_set_exclusive(ecs_system_with_access_new(1, 1));
    if ecs_system_with_access_is_exclusive(s) != true { panic(34010); };
}

@test "systems insert and get"() {
    let r = ecs_systems_insert(ecs_systems_new(), ecs_system_with_access_new(1, 42));
    let g = ecs_systems_get(r.0, r.1);
    if g.0 != true { panic(34011); };
    if ecs_system_with_access_name(g.1) != 42 { panic(34012); };
}

@test "systems len"() {
    let r = ecs_systems_insert(ecs_systems_insert(ecs_systems_new(), ecs_system_with_access_new(1, 1)).0, ecs_system_with_access_new(2, 2));
    if ecs_systems_len(r.0) != 2 { panic(34013); };
}

@test "systems is_empty"() {
    if ecs_systems_is_empty(ecs_systems_new()) != true { panic(34014); };
}

@test "systems add condition"() {
    let r = ecs_systems_insert(ecs_systems_new(), ecs_system_with_access_new(1, 1));
    let s = ecs_systems_add_condition(r.0, r.1, ecs_condition_with_access_new(10, 100));
    if ecs_systems_has_conditions(s, r.1) != true { panic(34015); };
    if ecs_systems_condition_count(s, r.1) != 1 { panic(34016); };
}

@test "systems has_conditions false"() {
    let r = ecs_systems_insert(ecs_systems_new(), ecs_system_with_access_new(1, 1));
    if ecs_systems_has_conditions(r.0, r.1) != false { panic(34017); };
}

@test "compact node dir"() {
    let c = ecs_compact_node_dir_new(ecs_node_id_system(5), ECS_DIRECTION_OUTGOING);
    if ecs_node_id_is_system(ecs_compact_node_dir_node(c)) != true { panic(34018); };
    if ecs_compact_node_dir_direction(c) != ECS_DIRECTION_OUTGOING { panic(34019); };
}

@test "compact node pair"() {
    let p = ecs_compact_node_pair_new(ecs_node_id_system(1), ecs_node_id_set(2));
    if ecs_node_id_is_system(ecs_compact_node_pair_a(p)) != true { panic(34020); };
    if ecs_node_id_is_set(ecs_compact_node_pair_b(p)) != true { panic(34021); };
}

// === bundle_spawner tests ===

@test "bundle spawner new"() {
    let s = ecs_bundle_spawner_new(100, 5);
    if ecs_bundle_spawner_world_id(s) != 100 { panic(34022); };
    if ecs_bundle_spawner_change_tick(s) != 5 { panic(34023); };
    if ecs_bundle_spawner_is_empty(s) != true { panic(34024); };
}

@test "bundle spawner spawn"() {
    let s = ecs_bundle_spawner_spawn(ecs_bundle_spawner_new(1, 1), 42);
    if ecs_bundle_spawner_len(s) != 1 { panic(34025); };
    if ecs_bundle_spawner_get_spawned(s, 0) != 42 { panic(34026); };
}

@test "bundle spawner spawn_batch"() {
    let entities: Vec<i64> = Vec::new();
    entities.push(10);
    entities.push(20);
    entities.push(30);
    let s = ecs_bundle_spawner_spawn_batch(ecs_bundle_spawner_new(1, 1), entities);
    if ecs_bundle_spawner_len(s) != 3 { panic(34027); };
}

@test "bundle spawner reserve_storage"() {
    let s = ecs_bundle_spawner_reserve_storage(ecs_bundle_spawner_new(1, 1), 16);
    if ecs_bundle_spawner_reserved(s) != 16 { panic(34028); };
}

@test "insert bundle target"() {
    let ib = ecs_insert_bundle_target(ecs_insert_bundle_new(1, 1, 5), 42);
    if ecs_insert_bundle_len(ib) != 1 { panic(34029); };
}

@test "insert bundle type"() {
    let ib = ecs_insert_bundle_new(1, 1, 77);
    if ecs_insert_bundle_bundle_type(ib) != 77 { panic(34030); };
}

@test "bundle inserter insert"() {
    let bi = ecs_bundle_inserter_insert(ecs_bundle_inserter_new(1, 1, 5));
    if ecs_bundle_inserter_count(bi) != 1 { panic(34031); };
}

@test "bundle inserter insert_batch"() {
    let bi = ecs_bundle_inserter_insert_batch(ecs_bundle_inserter_new(1, 1, 5), 10);
    if ecs_bundle_inserter_count(bi) != 10 { panic(34032); };
}

@test "bundle remover remove"() {
    let br = ecs_bundle_remover_remove(ecs_bundle_remover_new(1, 1, 5));
    if ecs_bundle_remover_count(br) != 1 { panic(34033); };
}

// === remote_allocator tests ===

@test "remote allocator alloc"() {
    let r = ecs_remote_allocator_alloc(ecs_remote_allocator_new());
    if r.0 != 1 { panic(34034); };
    let r2 = ecs_remote_allocator_alloc(r.1);
    if r2.0 != 2 { panic(34035); };
}

@test "remote allocator alloc_batch"() {
    let r = ecs_remote_allocator_alloc_batch(ecs_remote_allocator_new(), 3);
    if len(r.0) as i64 != 3 { panic(34036); };
    if r.0[0] != 1 { panic(34037); };
    if r.0[2] != 3 { panic(34038); };
}

@test "remote allocator close"() {
    let a = ecs_remote_allocator_close(ecs_remote_allocator_new());
    if ecs_remote_allocator_is_closed(a) != true { panic(34039); };
    let r = ecs_remote_allocator_alloc(a);
    if r.0 != -1 { panic(34040); };
}

@test "remote allocator allocated_count"() {
    let r = ecs_remote_allocator_alloc(ecs_remote_allocator_alloc(ecs_remote_allocator_new()).1);
    if ecs_remote_allocator_allocated_count(r.1) != 2 { panic(34041); };
}

@test "remote allocator next_entity"() {
    let r = ecs_remote_allocator_alloc(ecs_remote_allocator_new());
    if ecs_remote_allocator_next_entity(r.1) != 2 { panic(34042); };
}

@test "remote allocator contains"() {
    let r = ecs_remote_allocator_alloc(ecs_remote_allocator_new());
    if ecs_remote_allocator_contains(r.1, 1) != true { panic(34043); };
    if ecs_remote_allocator_contains(r.1, 99) != false { panic(34044); };
}

@test "remote allocator not closed by default"() {
    if ecs_remote_allocator_is_closed(ecs_remote_allocator_new()) != false { panic(34045); };
}
