@import "lib/world_identifier.sla"

@test "world id new and get"() {
    let w = ecs_world_id_new(5);
    if ecs_world_id_get(w) != 5 { panic(39001); };
}

@test "world id eq"() {
    if ecs_world_id_eq(ecs_world_id_new(3), ecs_world_id_new(3)) != true { panic(39002); };
    if ecs_world_id_eq(ecs_world_id_new(3), ecs_world_id_new(4)) != false { panic(39003); };
}

@test "world id lt"() {
    if ecs_world_id_lt(ecs_world_id_new(3), ecs_world_id_new(4)) != true { panic(39004); };
    if ecs_world_id_lt(ecs_world_id_new(4), ecs_world_id_new(3)) != false { panic(39005); };
}

@test "world id hash"() {
    if ecs_world_id_hash(ecs_world_id_new(7)) != 7 { panic(39006); };
}

@test "world id allocator alloc"() {
    let a = ecs_world_id_allocator_new();
    let r = ecs_world_id_allocator_alloc(a);
}

@test "world id allocator monotonic"() {
    let a = ecs_world_id_allocator_new();
    let r1 = ecs_world_id_allocator_alloc(a);
    let r2 = ecs_world_id_allocator_alloc(r1.0);
    let r3 = ecs_world_id_allocator_alloc(r2.0);
    let id1 = r1.1;
    let id2 = r2.1;
    let id3 = r3.1;
    if ecs_world_id_get(id1.1) != 0 { panic(39014); };
    if ecs_world_id_get(id2.1) != 1 { panic(39015); };
    if ecs_world_id_get(id3.1) != 2 { panic(39016); };
}
