@import "lib/system_adapter.sla"

@test "run system error ok and is_ok"() {
    let e = ecs_run_system_ok();
    if ecs_run_system_is_ok(e) != true { panic(42001); };
}

@test "run system error err and payload"() {
    let e = ecs_run_system_err(5, 99);
    if ecs_run_system_is_ok(e) != false { panic(42002); };
    if ecs_run_system_payload(e) != 99 { panic(42003); };
}

@test "not adapter inverts true"() {
    let m = ecs_not_marker_new();
    let r = ecs_not_adapt(m, true, ecs_run_system_ok());
    if ecs_run_system_is_ok(r.0) != true { panic(42004); };
    if r.1 != false { panic(42005); };
}

@test "not adapter inverts false"() {
    let m = ecs_not_marker_new();
    let r = ecs_not_adapt(m, false, ecs_run_system_ok());
    if r.1 != true { panic(42006); };
}

@test "not adapter propagates error"() {
    let m = ecs_not_marker_new();
    let err = ecs_run_system_err(7, 0);
    let r = ecs_not_adapt(m, true, err);
    if ecs_run_system_is_ok(r.0) != false { panic(42007); };
    if r.1 != false { panic(42008); };
}

@test "adapter system not kind run"() {
    let s = ecs_adapter_system_new(0, 1, 100);
    if ecs_adapter_system_kind(s) != 0 { panic(42009); };
    if ecs_adapter_system_name(s) != 100 { panic(42010); };
    let r = ecs_adapter_system_run(s, 0);
    if r.1 != 0 { panic(42011); };
}

@test "adapter system map kind run"() {
    let s = ecs_adapter_system_new(1, 10, 100);
    let r = ecs_adapter_system_run(s, 5);
    if r.1 != 15 { panic(42012); };
}

@test "adapter system chain kind run"() {
    let s = ecs_adapter_system_new(2, 20, 100);
    let r = ecs_adapter_system_run(s, 3);
    if r.1 != 23 { panic(42013); };
}

@test "into adapter system into"() {
    let i = ecs_into_adapter_system_new(1, 7);
    let s = ecs_into_adapter_system_into(i, 50);
    if ecs_adapter_system_name(s) != 50 { panic(42014); };
    if ecs_adapter_system_kind(s) != 1 { panic(42015); };
}

@test "map adapter adapt"() {
    let m = ecs_map_adapter_new(100);
    let r = ecs_map_adapt(m, 5, ecs_run_system_ok());
    if r.1 != 105 { panic(42016); };
}

@test "map adapter propagates error"() {
    let m = ecs_map_adapter_new(100);
    let r = ecs_map_adapt(m, 5, ecs_run_system_err(3, 0));
    if ecs_run_system_is_ok(r.0) != false { panic(42017); };
}

@test "chain adapter adapt"() {
    let c = ecs_chain_adapter_new(50);
    let r = ecs_chain_adapt(c, 10, ecs_run_system_ok());
    if r.1 != 60 { panic(42018); };
}

@test "chain adapter propagates error"() {
    let c = ecs_chain_adapter_new(50);
    let r = ecs_chain_adapt(c, 10, ecs_run_system_err(2, 0));
    if ecs_run_system_is_ok(r.0) != false { panic(42019); };
}

@test "is adapter system marker"() {
    let m = ecs_is_adapter_system_marker_new();
    if ecs_run_system_is_ok(ecs_run_system_ok()) != true { panic(42020); };
}
