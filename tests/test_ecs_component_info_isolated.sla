// ComponentInfo + ComponentDescriptor + EntityDisabling + BundleInfo completeness.
// Bevy component/info.rs: ComponentInfo (id, name, mutable, clone_behavior, type_id,
// layout, drop, storage_type, is_send_and_sync, hooks, required_components).
// Bevy entity_disabling.rs: Disabled, DefaultQueryFilters, register_disabling_component.
// Bevy bundle/info.rs: BundleInfo (explicit/required/contributed, len, is_empty, iter, get).

// --- ComponentDescriptor (Bevy ComponentDescriptor) ---
struct EcsComponentDescriptor {
    name: Vec<i32>,         // component name as char codes
    storage_type: i32,      // 0 = Table, 1 = SparseSet
    is_mutable: bool,
    is_send_and_sync: bool,
    type_id: i32,
}

fn descriptor_new(name: Vec<i32>, storage_type: i32, is_mutable: bool, type_id: i32) -> EcsComponentDescriptor {
    return EcsComponentDescriptor {
        name: name,
        storage_type: storage_type,
        is_mutable: is_mutable,
        is_send_and_sync: true,
        type_id: type_id,
    };
}

fn descriptor_storage_type(d: EcsComponentDescriptor) -> i32 { return d.storage_type; }
fn descriptor_mutable(d: EcsComponentDescriptor) -> bool { return d.is_mutable; }
fn descriptor_type_id(d: EcsComponentDescriptor) -> i32 { return d.type_id; }
fn descriptor_is_send_and_sync(d: EcsComponentDescriptor) -> bool { return d.is_send_and_sync; }
fn descriptor_name_len(d: EcsComponentDescriptor) -> i64 { return len(d.name) as i64; }

// --- ComponentInfo (Bevy ComponentInfo) ---
struct EcsComponentInfo {
    id: i32,
    descriptor: EcsComponentDescriptor,
    has_hooks: bool,
    has_required: bool,
    is_relationship: bool,
}

fn component_info_new(id: i32, descriptor: EcsComponentDescriptor) -> EcsComponentInfo {
    return EcsComponentInfo {
        id: id,
        descriptor: descriptor,
        has_hooks: false,
        has_required: false,
        is_relationship: false,
    };
}

fn component_info_id(info: EcsComponentInfo) -> i32 { return info.id; }
fn component_info_name(info: EcsComponentInfo) -> Vec<i32> { return info.descriptor.name; }
fn component_info_mutable(info: EcsComponentInfo) -> bool { return info.descriptor.is_mutable; }
fn component_info_storage_type(info: EcsComponentInfo) -> i32 { return info.descriptor.storage_type; }
fn component_info_type_id(info: EcsComponentInfo) -> i32 { return info.descriptor.type_id; }
fn component_info_is_send_and_sync(info: EcsComponentInfo) -> bool { return info.descriptor.is_send_and_sync; }
fn component_info_has_hooks(info: EcsComponentInfo) -> bool { return info.has_hooks; }
fn component_info_has_required(info: EcsComponentInfo) -> bool { return info.has_required; }
fn component_info_is_relationship(info: EcsComponentInfo) -> bool { return info.is_relationship; }

fn component_info_set_hooks(info: EcsComponentInfo) -> EcsComponentInfo {
    info.has_hooks = true;
    return info;
}

fn component_info_set_required(info: EcsComponentInfo) -> EcsComponentInfo {
    info.has_required = true;
    return info;
}

fn component_info_set_relationship(info: EcsComponentInfo) -> EcsComponentInfo {
    info.is_relationship = true;
    return info;
}

// --- Components registry (Bevy Components) ---
struct EcsComponents {
    infos: Vec<EcsComponentInfo>,
}

fn components_new() -> EcsComponents {
    let infos: Vec<EcsComponentInfo> = Vec::new();
    return EcsComponents { infos: infos };
}

fn components_register(comps: EcsComponents, id: i32, descriptor: EcsComponentDescriptor) -> (EcsComponents, EcsComponentInfo) {
    let info = component_info_new(id, descriptor);
    comps.infos.push(info);
    return (comps, info);
}

fn components_get(comps: EcsComponents, id: i32) -> EcsComponentInfo {
    let i: i64 = 0;
    let cnt = len(comps.infos) as i64;
    while i < cnt {
        if comps.infos[i].id == id { return comps.infos[i]; };
        i = i + 1;
    }
    return component_info_new(-1, descriptor_new(Vec::new(), 0, false, -1));
}

fn components_len(comps: EcsComponents) -> i64 { return len(comps.infos) as i64; }

fn components_get_id(comps: EcsComponents, type_id: i32) -> i32 {
    let i: i64 = 0;
    let cnt = len(comps.infos) as i64;
    while i < cnt {
        if comps.infos[i].descriptor.type_id == type_id { return comps.infos[i].id; };
        i = i + 1;
    }
    return -1;
}

// --- EntityDisabling (Bevy entity_disabling.rs) ---
struct EcsDefaultQueryFilters {
    disabling_ids: Vec<i32>,
}

fn default_query_filters_empty() -> EcsDefaultQueryFilters {
    let disabling_ids: Vec<i32> = Vec::new();
    return EcsDefaultQueryFilters { disabling_ids: disabling_ids };
}

fn default_query_filters_register_disabling(filters: EcsDefaultQueryFilters, component_id: i32) -> EcsDefaultQueryFilters {
    filters.disabling_ids.push(component_id);
    return filters;
}

fn default_query_filters_is_disabled(filters: EcsDefaultQueryFilters, component_ids: Vec<i32>) -> bool {
    let i: i64 = 0;
    let dcnt = len(filters.disabling_ids) as i64;
    while i < dcnt {
        let did = filters.disabling_ids[i];
        let j: i64 = 0;
        let ccnt = len(component_ids) as i64;
        while j < ccnt {
            if component_ids[j] == did { return true; };
            j = j + 1;
        }
        i = i + 1;
    }
    return false;
}

fn default_query_filters_disabling_count(filters: EcsDefaultQueryFilters) -> i64 {
    return len(filters.disabling_ids) as i64;
}

// Disabled marker component id (Bevy Disabled struct)
const DISABLED_ID: i32 = 10001;

// --- BundleInfo (Bevy bundle/info.rs) ---
struct EcsBundleInfo {
    id: i32,
    explicit_component_ids: Vec<i32>,
    required_component_ids: Vec<i32>,
}

fn bundle_info_new(id: i32, explicit: Vec<i32>) -> EcsBundleInfo {
    return EcsBundleInfo { id: id, explicit_component_ids: explicit, required_component_ids: Vec::new() };
}

fn bundle_info_new_with_required(id: i32, explicit: Vec<i32>, required: Vec<i32>) -> EcsBundleInfo {
    return EcsBundleInfo { id: id, explicit_component_ids: explicit, required_component_ids: required };
}

fn bundle_info_explicit_components(info: EcsBundleInfo) -> Vec<i32> { return info.explicit_component_ids; }
fn bundle_info_required_components(info: EcsBundleInfo) -> Vec<i32> { return info.required_component_ids; }

fn bundle_info_contributed_components(info: EcsBundleInfo) -> Vec<i32> {
    let result: Vec<i32> = Vec::new();
    let i: i64 = 0;
    let ecnt = len(info.explicit_component_ids) as i64;
    while i < ecnt {
        result.push(info.explicit_component_ids[i]);
        i = i + 1;
    }
    let j: i64 = 0;
    let rcnt = len(info.required_component_ids) as i64;
    while j < rcnt {
        result.push(info.required_component_ids[j]);
        j = j + 1;
    }
    return result;
}

fn bundle_info_explicit_count(info: EcsBundleInfo) -> i64 { return len(info.explicit_component_ids) as i64; }
fn bundle_info_required_count(info: EcsBundleInfo) -> i64 { return len(info.required_component_ids) as i64; }
fn bundle_info_contributed_count(info: EcsBundleInfo) -> i64 { return bundle_info_explicit_count(info) + bundle_info_required_count(info); }
fn bundle_info_has_required(info: EcsBundleInfo) -> bool { return len(info.required_component_ids) > 0; }
fn bundle_info_is_empty(info: EcsBundleInfo) -> bool { return bundle_info_contributed_count(info) == 0; }

// --- Bundles registry (Bevy Bundles) ---
struct EcsBundles {
    infos: Vec<EcsBundleInfo>,
}

fn bundles_new() -> EcsBundles {
    let infos: Vec<EcsBundleInfo> = Vec::new();
    return EcsBundles { infos: infos };
}

fn bundles_register(bundles: EcsBundles, info: EcsBundleInfo) -> EcsBundles {
    bundles.infos.push(info);
    return bundles;
}

fn bundles_len(bundles: EcsBundles) -> i64 { return len(bundles.infos) as i64; }

fn bundles_get(bundles: EcsBundles, id: i32) -> EcsBundleInfo {
    let i: i64 = 0;
    let cnt = len(bundles.infos) as i64;
    while i < cnt {
        if bundles.infos[i].id == id { return bundles.infos[i]; };
        i = i + 1;
    }
    return bundle_info_new(-1, Vec::new());
}

fn bundles_get_id(bundles: EcsBundles, type_id: i32) -> i32 {
    // In our model, bundle id == type_id
    let i: i64 = 0;
    let cnt = len(bundles.infos) as i64;
    while i < cnt {
        if bundles.infos[i].id == type_id { return bundles.infos[i].id; };
        i = i + 1;
    }
    return -1;
}

// --- Tests ---

@test "descriptor storage type"() {
    let name: Vec<i32> = Vec::new();
    name.push(80);  // 'P'
    name.push(111); // 'o'
    name.push(115); // 's'
    let d = descriptor_new(name, 0, true, 100);
    if descriptor_storage_type(d) != 0 { panic(10001); };
}

@test "descriptor mutable and type_id"() {
    let d = descriptor_new(Vec::new(), 1, false, 200);
    if descriptor_mutable(d) { panic(10002); };
    if descriptor_type_id(d) != 200 { panic(10003); };
}

@test "descriptor is_send_and_sync"() {
    let d = descriptor_new(Vec::new(), 0, true, 300);
    if descriptor_is_send_and_sync(d) != true { panic(10004); };
}

@test "component_info id and name"() {
    let name: Vec<i32> = Vec::new();
    name.push(86); // 'V'
    let d = descriptor_new(name, 0, true, 400);
    let info = component_info_new(42, d);
    if component_info_id(info) != 42 { panic(10005); };
    if descriptor_name_len(info.descriptor) != 1 { panic(10006); };
}

@test "component_info storage and mutable"() {
    let d = descriptor_new(Vec::new(), 1, true, 500);
    let info = component_info_new(10, d);
    if component_info_storage_type(info) != 1 { panic(10007); };
    if component_info_mutable(info) != true { panic(10008); };
}

@test "component_info hooks and required"() {
    let d = descriptor_new(Vec::new(), 0, true, 600);
    let info = component_info_new(1, d);
    let info2 = component_info_set_hooks(info);
    if component_info_has_hooks(info2) != true { panic(10009); };
    let info3 = component_info_set_required(info2);
    if component_info_has_required(info3) != true { panic(10010); };
}

@test "component_info relationship marker"() {
    let d = descriptor_new(Vec::new(), 0, true, 700);
    let info = component_info_new(1, d);
    let info2 = component_info_set_relationship(info);
    if component_info_is_relationship(info2) != true { panic(10011); };
}

@test "components register and get"() {
    let comps = components_new();
    let d = descriptor_new(Vec::new(), 0, true, 800);
    let (comps2, _info) = components_register(comps, 5, d);
    let info = components_get(comps2, 5);
    if info.id != 5 { panic(10012); };
}

@test "components len increments"() {
    let comps = components_new();
    let d = descriptor_new(Vec::new(), 0, true, 900);
    let (comps2, _info1) = components_register(comps, 1, d);
    let (comps3, _info2) = components_register(comps2, 2, d);
    if components_len(comps3) != 2 { panic(10013); };
}

@test "components get_id by type_id"() {
    let comps = components_new();
    let d = descriptor_new(Vec::new(), 0, true, 1000);
    let (comps2, _info3) = components_register(comps, 7, d);
    if components_get_id(comps2, 1000) != 7 { panic(10014); };
}

@test "entity disabling registers component"() {
    let filters = default_query_filters_empty();
    let filters2 = default_query_filters_register_disabling(filters, DISABLED_ID);
    if default_query_filters_disabling_count(filters2) != 1 { panic(10015); };
}

@test "entity disabling detects disabled entity"() {
    let filters = default_query_filters_empty();
    let filters2 = default_query_filters_register_disabling(filters, DISABLED_ID);
    let components: Vec<i32> = Vec::new();
    components.push(100);
    components.push(DISABLED_ID);
    if default_query_filters_is_disabled(filters2, components) != true { panic(10016); };
}

@test "entity disabling passes non-disabled entity"() {
    let filters = default_query_filters_empty();
    let filters2 = default_query_filters_register_disabling(filters, DISABLED_ID);
    let components: Vec<i32> = Vec::new();
    components.push(100);
    components.push(200);
    if default_query_filters_is_disabled(filters2, components) { panic(10017); };
}

@test "bundle_info explicit components"() {
    let explicit: Vec<i32> = Vec::new();
    explicit.push(1);
    explicit.push(2);
    let info = bundle_info_new(0, explicit);
    if bundle_info_explicit_count(info) != 2 { panic(10018); };
}

@test "bundle_info with required"() {
    let explicit: Vec<i32> = Vec::new();
    explicit.push(1);
    let required: Vec<i32> = Vec::new();
    required.push(2);
    required.push(3);
    let info = bundle_info_new_with_required(0, explicit, required);
    if bundle_info_required_count(info) != 2 { panic(10019); };
    if bundle_info_has_required(info) != true { panic(10020); };
}

@test "bundle_info contributed = explicit + required"() {
    let explicit: Vec<i32> = Vec::new();
    explicit.push(1);
    explicit.push(2);
    let required: Vec<i32> = Vec::new();
    required.push(3);
    let info = bundle_info_new_with_required(0, explicit, required);
    let contributed = bundle_info_contributed_components(info);
    if len(contributed) != 3 { panic(10021); };
    if contributed[0] != 1 { panic(10022); };
    if contributed[2] != 3 { panic(10023); };
}

@test "bundle_info is_empty"() {
    let info = bundle_info_new(0, Vec::new());
    if bundle_info_is_empty(info) != true { panic(10024); };
    let explicit: Vec<i32> = Vec::new();
    explicit.push(1);
    let info2 = bundle_info_new(0, explicit);
    if bundle_info_is_empty(info2) { panic(10025); };
}

@test "bundles register and get"() {
    let bundles = bundles_new();
    let explicit: Vec<i32> = Vec::new();
    explicit.push(1);
    let info = bundle_info_new(42, explicit);
    let bundles2 = bundles_register(bundles, info);
    if bundles_len(bundles2) != 1 { panic(10026); };
    let retrieved = bundles_get(bundles2, 42);
    if retrieved.id != 42 { panic(10027); };
}

@test "bundles get_id returns -1 for unregistered"() {
    let bundles = bundles_new();
    if bundles_get_id(bundles, 999) != -1 { panic(10028); };
}
