@import "lib/observer_system_param.sla"
@import "lib/query_access_iter.sla"

@test "on trigger new and accessors"() {
    let o = ecs_on_new(10, 20, 1, 100, 200, 300);
    if ecs_on_event_key(o) != 10 { panic(45001); };
    if ecs_on_event(o) != 20 { panic(45002); };
    if ecs_on_trigger_kind(o) != 1 { panic(45003); };
    if ecs_on_observer(o) != 100 { panic(45004); };
    if ecs_on_caller(o) != 200 { panic(45005); };
    if ecs_on_original_event_target(o) != 300 { panic(45006); };
}

@test "on trigger event_mut"() {
    let o = ecs_on_new(10, 20, 1, 100, 200, 300);
    let o2 = ecs_on_event_mut(o, 99);
    if ecs_on_event(o2) != 99 { panic(45007); };
}

@test "on trigger propagate"() {
    let o = ecs_on_new(10, 20, 1, 100, 200, 300);
    if ecs_on_get_propagate(o) != false { panic(45008); };
    let o2 = ecs_on_propagate(o, true);
    if ecs_on_get_propagate(o2) != true { panic(45009); };
}

@test "trigger context new and target"() {
    let c = ecs_trigger_context_new(42);
    if ecs_trigger_context_target(c) != 42 { panic(45010); };
    if ecs_trigger_context_get_propagate(c) != false { panic(45011); };
}

@test "trigger context set propagate"() {
    let c = ecs_trigger_context_new(42);
    let c2 = ecs_trigger_context_set_propagate(c, true);
    if ecs_trigger_context_get_propagate(c2) != true { panic(45012); };
}

@test "access type compatible archetypal"() {
    if ecs_access_type_is_compatible(ECS_AT_ARCHETYPAL, ECS_AT_WRITE) != true { panic(45013); };
    if ecs_access_type_is_compatible(ECS_AT_READ, ECS_AT_ARCHETYPAL) != true { panic(45014); };
}

@test "access type compatible two reads"() {
    if ecs_access_type_is_compatible(ECS_AT_READ, ECS_AT_READ) != true { panic(45015); };
}

@test "access type incompatible write read"() {
    if ecs_access_type_is_compatible(ECS_AT_WRITE, ECS_AT_READ) != false { panic(45016); };
}

@test "access type incompatible two writes"() {
    if ecs_access_type_is_compatible(ECS_AT_WRITE, ECS_AT_WRITE) != false { panic(45017); };
}

@test "access conflict error new"() {
    let e = ecs_access_conflict_new(ECS_AT_WRITE, ECS_AT_READ, 7);
    if ecs_access_conflict_a(e) != ECS_AT_WRITE { panic(45018); };
    if ecs_access_conflict_b(e) != ECS_AT_READ { panic(45019); };
    if ecs_access_conflict_component(e) != 7 { panic(45020); };
}

@test "query has conflicts none"() {
    let ids: Vec<i32> = Vec::new();
    ids.push(1);
    ids.push(2);
    let levels: Vec<i32> = Vec::new();
    levels.push(ECS_AT_READ);
    levels.push(ECS_AT_READ);
    if ecs_query_has_conflicts(ids, levels) != -1 { panic(45021); };
}

@test "query has conflicts found"() {
    let ids: Vec<i32> = Vec::new();
    ids.push(1);
    ids.push(1);
    let levels: Vec<i32> = Vec::new();
    levels.push(ECS_AT_READ);
    levels.push(ECS_AT_WRITE);
    if ecs_query_has_conflicts(ids, levels) != 1 { panic(45022); };
}

@test "query classify conflict write write"() {
    if ecs_query_classify_conflict(ECS_AT_WRITE, ECS_AT_WRITE) != ECS_QAE_MUTATING_WRITE { panic(45023); };
}

@test "query classify conflict write read"() {
    if ecs_query_classify_conflict(ECS_AT_WRITE, ECS_AT_READ) != ECS_QAE_WRITE_READ { panic(45024); };
}

@test "query classify conflict read write"() {
    if ecs_query_classify_conflict(ECS_AT_READ, ECS_AT_WRITE) != ECS_QAE_MUTATING_READ { panic(45025); };
}

@test "query classify no conflict"() {
    if ecs_query_classify_conflict(ECS_AT_READ, ECS_AT_READ) != ECS_QAE_NO_CONFLICT { panic(45026); };
}
