@import "lib/world_error.sla"

// === TryRunScheduleError ===

@test "try run schedule error ok"() {
    let e = ecs_try_run_schedule_error_ok();
    if ecs_try_run_schedule_error_is_ok(e) != true { panic(74001); };
}

@test "try run schedule error not found"() {
    let e = ecs_try_run_schedule_error_not_found(5);
    if ecs_try_run_schedule_error_is_ok(e) != false { panic(74010); };
    if ecs_try_run_schedule_error_label(e) != 5 { panic(74011); };
    if ecs_try_run_schedule_error_code(e) != 1 { panic(74012); };
}

// === TryInsertBatchError ===

@test "try insert batch error"() {
    let entities = Vec::new();
    entities.push(1);
    entities.push(2);
    let e = ecs_try_insert_batch_error_new(42, entities);
    if ecs_try_insert_batch_error_bundle_type(e) != 42 { panic(74020); };
    if ecs_try_insert_batch_error_entity_count(e) != 2 { panic(74021); };
    if ecs_try_insert_batch_error_has_entities(e) != true { panic(74022); };
}

@test "try insert batch error empty"() {
    let entities = Vec::new();
    let e = ecs_try_insert_batch_error_new(0, entities);
    if ecs_try_insert_batch_error_has_entities(e) != false { panic(74030); };
}

// === EntityDespawnError ===

@test "entity despawn error"() {
    let e = ecs_entity_despawn_error_not_spawned(99);
    if ecs_entity_despawn_error_is_ok(e) != false { panic(74040); };
    if ecs_entity_despawn_error_entity(e) != 99 { panic(74041); };
    if ecs_entity_despawn_error_code(e) != 2 { panic(74042); };
}

// === EntityComponentError ===

@test "entity component error ok"() {
    let e = ecs_entity_component_error_ok();
    if ecs_entity_component_error_is_ok(e) != true { panic(74050); };
}

@test "entity component error missing"() {
    let e = ecs_entity_component_error_missing_component(5);
    if ecs_entity_component_error_is_missing(e) != true { panic(74060); };
    if ecs_entity_component_error_is_aliased(e) != false { panic(74061); };
    if ecs_entity_component_error_component_id(e) != 5 { panic(74062); };
    if ecs_entity_component_error_code(e) != 3 { panic(74063); };
}

@test "entity component error aliased"() {
    let e = ecs_entity_component_error_aliased_mutability(7);
    if ecs_entity_component_error_is_aliased(e) != true { panic(74070); };
    if ecs_entity_component_error_is_missing(e) != false { panic(74071); };
    if ecs_entity_component_error_component_id(e) != 7 { panic(74072); };
    if ecs_entity_component_error_code(e) != 4 { panic(74073); };
}

// === EntityMutableFetchError ===

@test "entity mutable fetch error ok"() {
    let e = ecs_entity_mutable_fetch_error_ok();
    if ecs_entity_mutable_fetch_error_is_ok(e) != true { panic(74080); };
}

@test "entity mutable fetch error not spawned"() {
    let e = ecs_entity_mutable_fetch_error_not_spawned(42);
    if ecs_entity_mutable_fetch_error_is_not_spawned(e) != true { panic(74090); };
    if ecs_entity_mutable_fetch_error_entity(e) != 42 { panic(74091); };
    if ecs_entity_mutable_fetch_error_code(e) != 5 { panic(74092); };
}

@test "entity mutable fetch error aliased"() {
    let e = ecs_entity_mutable_fetch_error_aliased(10);
    if ecs_entity_mutable_fetch_error_is_aliased(e) != true { panic(74100); };
    if ecs_entity_mutable_fetch_error_entity(e) != 10 { panic(74101); };
    if ecs_entity_mutable_fetch_error_code(e) != 6 { panic(74102); };
}

// === ResourceFetchError ===

@test "resource fetch error ok"() {
    let e = ecs_resource_fetch_error_ok();
    if ecs_resource_fetch_error_is_ok(e) != true { panic(74110); };
}

@test "resource fetch error not registered"() {
    let e = ecs_resource_fetch_error_not_registered();
    if ecs_resource_fetch_error_is_not_registered(e) != true { panic(74120); };
    if ecs_resource_fetch_error_code(e) != 7 { panic(74121); };
}

@test "resource fetch error does not exist"() {
    let e = ecs_resource_fetch_error_does_not_exist(100);
    if ecs_resource_fetch_error_is_does_not_exist(e) != true { panic(74130); };
    if ecs_resource_fetch_error_component_id(e) != 100 { panic(74131); };
    if ecs_resource_fetch_error_code(e) != 8 { panic(74132); };
}

@test "resource fetch error no access"() {
    let e = ecs_resource_fetch_error_no_access(200);
    if ecs_resource_fetch_error_is_no_access(e) != true { panic(74140); };
    if ecs_resource_fetch_error_component_id(e) != 200 { panic(74141); };
    if ecs_resource_fetch_error_code(e) != 9 { panic(74142); };
}

@test "resource fetch error immutable"() {
    let e = ecs_resource_fetch_error_immutable(300);
    if ecs_resource_fetch_error_is_immutable(e) != true { panic(74150); };
    if ecs_resource_fetch_error_component_id(e) != 300 { panic(74151); };
    if ecs_resource_fetch_error_code(e) != 10 { panic(74152); };
}

// === Mutual exclusivity checks ===

@test "resource fetch error mutual exclusivity"() {
    let e = ecs_resource_fetch_error_not_registered();
    if ecs_resource_fetch_error_is_does_not_exist(e) != false { panic(74160); };
    if ecs_resource_fetch_error_is_no_access(e) != false { panic(74161); };
    if ecs_resource_fetch_error_is_immutable(e) != false { panic(74162); };
}

@test "entity component error mutual exclusivity"() {
    let e = ecs_entity_component_error_missing_component(1);
    if ecs_entity_component_error_is_ok(e) != false { panic(74170); };
    if ecs_entity_component_error_is_aliased(e) != false { panic(74171); };
}
