@import "lib/reflect_type_data.sla"

// Isolated tests for lib/reflect_type_data.sla — ReflectFromWorld + ReflectEvent + ReflectMapEntities + ReflectCommand
// Bevy reference: bevy_ecs/src/reflect/{from_world,event,map_entities,entity_commands}.rs

@test "reflect_from_world_fns_new"() {
    let fns = ecs_reflect_from_world_fns_new(42);
    let r = ecs_reflect_from_world_new(fns);
    if ecs_reflect_from_world_from_world(r) != 42 { panic(83300); };
}

@test "reflect_from_world_fn_pointers"() {
    let fns = ecs_reflect_from_world_fns_new(99);
    let r = ecs_reflect_from_world_new(fns);
    let fns2 = ecs_reflect_from_world_fn_pointers(r);
    if fns2.from_world_fn != 99 { panic(83301); };
}

@test "reflect_event_fns_new"() {
    let fns = ecs_reflect_event_fns_new(10, 20, 30);
    let r = ecs_reflect_event_new(fns);
    if ecs_reflect_event_trigger(r) != 10 { panic(83302); };
    if ecs_reflect_event_create_observer(r) != 20 { panic(83303); };
    if ecs_reflect_event_register_event_key(r) != 30 { panic(83304); };
}

@test "reflect_event_fn_pointers"() {
    let fns = ecs_reflect_event_fns_new(10, 20, 30);
    let r = ecs_reflect_event_new(fns);
    let fns2 = ecs_reflect_event_fn_pointers(r);
    if fns2.trigger_fn != 10 { panic(83305); };
    if fns2.create_observer_fn != 20 { panic(83306); };
    if fns2.register_event_key_fn != 30 { panic(83307); };
}

@test "reflect_map_entities_new"() {
    let r = ecs_reflect_map_entities_new(42);
    if ecs_reflect_map_entities_call(r) != 42 { panic(83308); };
}

@test "reflect_command_insert"() {
    let c = ecs_reflect_command_insert(100, 200);
    if ecs_reflect_command_is_insert(c) != true { panic(83309); };
    if ecs_reflect_command_is_remove(c) != false { panic(83310); };
    if ecs_reflect_command_type_path(c) != 100 { panic(83311); };
    if ecs_reflect_command_component(c) != 200 { panic(83312); };
}

@test "reflect_command_remove"() {
    let c = ecs_reflect_command_remove(100);
    if ecs_reflect_command_is_remove(c) != true { panic(83313); };
    if ecs_reflect_command_is_insert(c) != false { panic(83314); };
    if ecs_reflect_command_type_path(c) != 100 { panic(83315); };
}

@test "reflect_command_take"() {
    let c = ecs_reflect_command_take(100);
    if ecs_reflect_command_is_take(c) != true { panic(83316); };
    if ecs_reflect_command_is_remove(c) != false { panic(83317); };
    if ecs_reflect_command_type_path(c) != 100 { panic(83318); };
}

@test "reflect_command_kind"() {
    let c1 = ecs_reflect_command_insert(0, 0);
    if ecs_reflect_command_kind(c1) != 0 { panic(83319); };
    let c2 = ecs_reflect_command_remove(0);
    if ecs_reflect_command_kind(c2) != 1 { panic(83320); };
    let c3 = ecs_reflect_command_take(0);
    if ecs_reflect_command_kind(c3) != 2 { panic(83321); };
}

@test "reflect_command_constants"() {
    if ECS_REFLECT_CMD_INSERT != 0 { panic(83322); };
    if ECS_REFLECT_CMD_REMOVE != 1 { panic(83323); };
    if ECS_REFLECT_CMD_TAKE != 2 { panic(83324); };
}
