@import "lib/query_iter.sla"
@import "lib/unsafe_world_cell.sla"

// === query_iter tests ===

@test "query iter next"() {
    let ents: Vec<i64> = Vec::new();
    ents.push(1);
    ents.push(2);
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    vals.push(20);
    let it = ecs_query_iter_new(ents, vals);
    let r1 = ecs_query_iter_next(it);
    if r1.0 != true { panic(36001); };
    if r1.1 != 1 { panic(36002); };
    if r1.2 != 10 { panic(36003); };
}

@test "query iter exhausts"() {
    let ents: Vec<i64> = Vec::new();
    ents.push(1);
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    let it = ecs_query_iter_new(ents, vals);
    let r1 = ecs_query_iter_next(it);
    let r2 = ecs_query_iter_next(r1.3);
    if r2.0 != false { panic(36004); };
}

@test "query iter remaining"() {
    let ents: Vec<i64> = Vec::new();
    ents.push(1);
    ents.push(2);
    ents.push(3);
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    vals.push(20);
    vals.push(30);
    let it = ecs_query_iter_new(ents, vals);
    let r1 = ecs_query_iter_next(it);
    if ecs_query_iter_remaining(r1.3) != 2 { panic(36005); };
}

@test "query iter len"() {
    let ents: Vec<i64> = Vec::new();
    ents.push(1);
    ents.push(2);
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    vals.push(20);
    let it = ecs_query_iter_new(ents, vals);
    if ecs_query_iter_len(it) != 2 { panic(36006); };
}

@test "query iter is_empty"() {
    let it = ecs_query_iter_new(Vec::new(), Vec::new());
    if ecs_query_iter_is_empty(it) != true { panic(36007); };
}

@test "query iter last"() {
    let ents: Vec<i64> = Vec::new();
    ents.push(1);
    ents.push(2);
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    vals.push(20);
    let it = ecs_query_iter_new(ents, vals);
    let r = ecs_query_iter_last(it);
    if r.0 != true { panic(36008); };
    if r.1 != 2 { panic(36009); };
    if r.2 != 20 { panic(36010); };
}

@test "query iter nth"() {
    let ents: Vec<i64> = Vec::new();
    ents.push(1);
    ents.push(2);
    ents.push(3);
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    vals.push(20);
    vals.push(30);
    let it = ecs_query_iter_new(ents, vals);
    let r = ecs_query_iter_nth(it, 1);
    if r.0 != true { panic(36011); };
    if r.1 != 2 { panic(36012); };
    if r.2 != 20 { panic(36013); };
}

@test "query par iter for_each"() {
    let ents: Vec<i64> = Vec::new();
    ents.push(1);
    ents.push(2);
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    vals.push(20);
    let pi = ecs_query_par_iter_new(ents, vals);
    let r = ecs_query_par_iter_for_each(pi, Vec::new());
    if len(r.0) as i64 != 2 { panic(36014); };
}

@test "query par iter len"() {
    let ents: Vec<i64> = Vec::new();
    ents.push(1);
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    let pi = ecs_query_par_iter_new(ents, vals);
    if ecs_query_par_iter_len(pi) != 1 { panic(36015); };
}

@test "query many iter next"() {
    let targets: Vec<i64> = Vec::new();
    targets.push(10);
    targets.push(20);
    let it = ecs_query_many_iter_new(targets);
    let r = ecs_query_many_iter_next(it);
    if r.0 != true { panic(36016); };
    if r.1 != 10 { panic(36017); };
}

@test "query many iter set found"() {
    let targets: Vec<i64> = Vec::new();
    targets.push(10);
    let it = ecs_query_many_iter_new(targets);
    let it2 = ecs_query_many_iter_set_found(it, 0, 42);
    let r = ecs_query_many_iter_next(it2);
    if r.2 != 42 { panic(36018); };
    if r.3 != true { panic(36019); };
}

@test "query contiguous iter next"() {
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    vals.push(20);
    let it = ecs_query_contiguous_iter_new(vals);
    let r = ecs_query_contiguous_iter_next(it);
    if r.0 != true { panic(36020); };
    if r.1 != 10 { panic(36021); };
}

@test "query contiguous iter remaining"() {
    let vals: Vec<i32> = Vec::new();
    vals.push(10);
    vals.push(20);
    let it = ecs_query_contiguous_iter_new(vals);
    let r = ecs_query_contiguous_iter_next(it);
    if ecs_query_contiguous_iter_remaining(r.2) != 1 { panic(36022); };
}

