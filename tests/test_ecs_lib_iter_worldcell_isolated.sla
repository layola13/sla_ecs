@test "access conflict error"() {
    let e = ecs_access_conflict_error_new(5, 10);
    if ecs_access_conflict_error_a(e) != 5 { panic(36027); };
    if ecs_access_conflict_error_b(e) != 10 { panic(36028); };
}

// === unsafe_world_cell tests ===

@test "unsafe world cell new"() {
    let c = ecs_unsafe_world_cell_new(100);
    if ecs_unsafe_world_cell_id(c) != 100 { panic(36029); };
    if ecs_unsafe_world_cell_change_tick(c) != 0 { panic(36030); };
}

@test "unsafe world cell increment change tick"() {
    let c = ecs_unsafe_world_cell_new(1);
    let r = ecs_unsafe_world_cell_increment_change_tick(c);
    if r.0 != 1 { panic(36031); };
    if ecs_unsafe_world_cell_change_tick(r.1) != 1 { panic(36032); };
}

@test "unsafe world cell get entity spawned"() {
    let c = ecs_unsafe_world_cell_set_entity_count(ecs_unsafe_world_cell_new(1), 5);
    let r = ecs_unsafe_world_cell_get_entity(c, 3);
    if r.kind != ECS_ENTITY_SPAWNED { panic(36033); };
}

@test "unsafe world cell get entity not spawned"() {
    let c = ecs_unsafe_world_cell_set_entity_count(ecs_unsafe_world_cell_new(1), 5);
    let r = ecs_unsafe_world_cell_get_entity(c, 10);
    if r.kind != ECS_ENTITY_NOT_SPAWNED { panic(36034); };
}

@test "entity mutable fetch error not spawned"() {
    let e = ecs_entity_mutable_fetch_error_not_spawned(42);
    if ecs_entity_mutable_fetch_error_is_not_spawned(e) != true { panic(36035); };
}

@test "entity mutable fetch error aliased"() {
    let e = ecs_entity_mutable_fetch_error_aliased(42);
    if ecs_entity_mutable_fetch_error_is_aliased(e) != true { panic(36036); };
}

@test "entity component error missing"() {
    let e = ecs_entity_component_error_missing(5);
    if ecs_entity_component_error_is_missing(e) != true { panic(36037); };
}

@test "resource fetch error not registered"() {
    let e = ecs_resource_fetch_error_not_registered();
    if ecs_resource_fetch_error_is_not_registered(e) != true { panic(36038); };
}

@test "try run schedule error"() {
    let e = ecs_try_run_schedule_error_new(42);
    if ecs_try_run_schedule_error_label(e) != 42 { panic(36039); };
}

@test "try insert batch error"() {
    let e = ecs_try_insert_batch_error_new(10);
    if ecs_try_insert_batch_error_entity(e) != 10 { panic(36040); };
}

@test "entity despawn error"() {
    let e = ecs_entity_despawn_error_new(5);
    if ecs_entity_despawn_error_entity(e) != 5 { panic(36041); };
}
