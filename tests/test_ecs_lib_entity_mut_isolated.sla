@import "lib/entity_mut.sla"

// === EcsEntityMut ===

@test "entity mut new and id"() {
    let m = ecs_entity_mut_new(42);
    if ecs_entity_mut_id(m) != 42 { panic(66001); };
}

@test "entity mut location and archetype"() {
    let m = ecs_entity_mut_new(7);
    if ecs_entity_mut_archetype(m) != 0 { panic(66002); };
    let loc = ecs_entity_mut_location(m);
    if loc.0 != 0 { panic(66003); };
    if loc.1 != 0 { panic(66004); };
    let m2 = ecs_entity_mut_set_archetype(m, 3, 10);
    if ecs_entity_mut_archetype(m2) != 3 { panic(66005); };
    let loc2 = ecs_entity_mut_location(m2);
    if loc2.0 != 3 { panic(66006); };
    if loc2.1 != 10 { panic(66007); };
}

@test "entity mut contains"() {
    let m = ecs_entity_mut_new(1);
    if ecs_entity_mut_contains(m, 5) != false { panic(66010); };
    let m2 = ecs_entity_mut_insert(m, 5, 100);
    if ecs_entity_mut_contains(m2, 5) != true { panic(66011); };
    if ecs_entity_mut_contains_id(m2, 5) != true { panic(66012); };
    if ecs_entity_mut_contains_type_id(m2, 5) != true { panic(66013); };
}

@test "entity mut get and get_ref"() {
    let m = ecs_entity_mut_new(1);
    let g0 = ecs_entity_mut_get(m, 3);
    if g0.0 != false { panic(66020); };
    let m2 = ecs_entity_mut_insert(m, 3, 77);
    let g1 = ecs_entity_mut_get(m2, 3);
    if g1.0 != true { panic(66021); };
    if g1.1 != 77 { panic(66022); };
    let gr = ecs_entity_mut_get_ref(m2, 3);
    if gr.0 != true { panic(66023); };
    if gr.1 != 77 { panic(66024); };
}

@test "entity mut get_mut"() {
    let m = ecs_entity_mut_new(1);
    let m2 = ecs_entity_mut_insert(m, 4, 50);
    let gm = ecs_entity_mut_get_mut(m2, 4);
    if gm.0 != true { panic(66030); };
    if gm.1 != 50 { panic(66031); };
}

@test "entity mut insert overwrite"() {
    let m = ecs_entity_mut_new(1);
    let m2 = ecs_entity_mut_insert(m, 2, 10);
    let m3 = ecs_entity_mut_insert(m2, 2, 20);
    if ecs_entity_mut_contains(m3, 2) != true { panic(66040); };
    let g = ecs_entity_mut_get(m3, 2);
    if g.0 != true { panic(66041); };
    if g.1 != 20 { panic(66042); };
}

@test "entity mut insert multiple"() {
    let m = ecs_entity_mut_new(1);
    let m2 = ecs_entity_mut_insert(m, 1, 10);
    let m3 = ecs_entity_mut_insert(m2, 2, 20);
    let m4 = ecs_entity_mut_insert(m3, 3, 30);
    if ecs_entity_mut_component_count(m4) != 3 { panic(66050); };
}

@test "entity mut remove"() {
    let m = ecs_entity_mut_new(1);
    let m2 = ecs_entity_mut_insert(m, 1, 10);
    let m3 = ecs_entity_mut_insert(m2, 2, 20);
    let r = ecs_entity_mut_remove(m3, 1);
    let m4 = r.0;
    if r.1 != true { panic(66060); };
    if ecs_entity_mut_contains(m4, 1) != false { panic(66061); };
    if ecs_entity_mut_contains(m4, 2) != true { panic(66062); };
    if ecs_entity_mut_component_count(m4) != 1 { panic(66063); };
}

@test "entity mut remove nonexistent"() {
    let m = ecs_entity_mut_new(1);
    let m2 = ecs_entity_mut_insert(m, 1, 10);
    let r = ecs_entity_mut_remove(m2, 99);
    if r.1 != false { panic(66070); };
}

@test "entity mut remove swap last"() {
    let m = ecs_entity_mut_new(1);
    let m2 = ecs_entity_mut_insert(m, 1, 10);
    let m3 = ecs_entity_mut_insert(m2, 2, 20);
    let m4 = ecs_entity_mut_insert(m3, 3, 30);
    let r = ecs_entity_mut_remove(m4, 1);
    let m5 = r.0;
    if r.1 != true { panic(66080); };
    if ecs_entity_mut_component_count(m5) != 2 { panic(66081); };
    if ecs_entity_mut_contains(m5, 1) != false { panic(66082); };
    if ecs_entity_mut_contains(m5, 2) != true { panic(66083); };
    if ecs_entity_mut_contains(m5, 3) != true { panic(66084); };
}

@test "entity mut components list"() {
    let m = ecs_entity_mut_new(1);
    let m2 = ecs_entity_mut_insert(m, 10, 100);
    let m3 = ecs_entity_mut_insert(m2, 20, 200);
    let comps = ecs_entity_mut_components(m3);
    if len(comps) as i64 != 2 { panic(66090); };
}

@test "entity mut get change ticks by id"() {
    let m = ecs_entity_mut_new(1);
    let m2 = ecs_entity_mut_insert(m, 5, 42);
    let t = ecs_entity_mut_get_change_ticks_by_id(m2, 5);
    if t.0 != true { panic(66100); };
    if t.1 != 42 { panic(66101); };
    let t2 = ecs_entity_mut_get_change_ticks_by_id(m2, 99);
    if t2.0 != false { panic(66102); };
}

@test "entity mut reborrow and readonly"() {
    let m = ecs_entity_mut_new(5);
    let rb = ecs_entity_mut_reborrow(m);
    if ecs_entity_mut_id(rb) != 5 { panic(66110); };
    if ecs_entity_mut_into_readonly(m) != 5 { panic(66111); };
    if ecs_entity_mut_as_readonly(m) != 5 { panic(66112); };
}

// === EcsFilteredEntityMut ===

@test "filtered entity mut new and id"() {
    let f = ecs_filtered_entity_mut_new(9);
    if ecs_filtered_entity_mut_id(f) != 9 { panic(66120); };
    if ecs_filtered_entity_mut_allowed_count(f) != 0 { panic(66121); };
}

@test "filtered entity mut allow and is_allowed"() {
    let f = ecs_filtered_entity_mut_new(1);
    let f2 = ecs_filtered_entity_mut_allow(f, 5);
    if ecs_filtered_entity_mut_is_allowed(f2, 5) != true { panic(66130); };
    if ecs_filtered_entity_mut_is_allowed(f2, 6) != false { panic(66131); };
    if ecs_filtered_entity_mut_allowed_count(f2) != 1 { panic(66132); };
}

@test "filtered entity mut get allowed"() {
    let m = ecs_entity_mut_new(1);
    let m2 = ecs_entity_mut_insert(m, 3, 300);
    let m3 = ecs_entity_mut_insert(m2, 5, 500);
    let m4 = ecs_entity_mut_insert(m3, 7, 700);
    let f = ecs_filtered_entity_mut_from_inner(m4);
    let f2 = ecs_filtered_entity_mut_allow(f, 3);
    let f3 = ecs_filtered_entity_mut_allow(f2, 5);
    let f4 = ecs_filtered_entity_mut_allow(f3, 7);
    let g = ecs_filtered_entity_mut_get(f4, 3);
    if g.0 != true { panic(66140); };
    if g.1 != 300 { panic(66141); };
}

@test "filtered entity mut get not allowed"() {
    let f = ecs_filtered_entity_mut_new(1);
    let f2 = ecs_filtered_entity_mut_allow(f, 3);
    let g = ecs_filtered_entity_mut_get(f2, 5);
    if g.0 != false { panic(66150); };
}

@test "filtered entity mut get allowed but absent"() {
    let f = ecs_filtered_entity_mut_new(1);
    let f2 = ecs_filtered_entity_mut_allow(f, 3);
    let g = ecs_filtered_entity_mut_get(f2, 3);
    if g.0 != false { panic(66160); };
}

@test "entity mut into filtered"() {
    let m = ecs_entity_mut_new(42);
    let f = ecs_entity_mut_into_filtered(m);
    if ecs_filtered_entity_mut_id(f) != 42 { panic(66170); };
    if ecs_filtered_entity_mut_allowed_count(f) != 0 { panic(66171); };
}
