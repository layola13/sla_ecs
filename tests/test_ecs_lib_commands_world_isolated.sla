@import "lib/commands_world.sla"

// === spawn_empty ===

@test "commands spawn_empty"() {
    let c = ecs_commands_new();
    let result = ecs_commands_spawn_empty(c);
    let c2 = result.0;
    let e = result.1;
    if e != 0 { panic(72001); };
    if ecs_commands_entity_count(c2) != 1 { panic(72002); };
}

@test "commands spawn_empty multiple"() {
    let c = ecs_commands_new();
    let r1 = ecs_commands_spawn_empty(c);
    let r2 = ecs_commands_spawn_empty(r1.0);
    let r3 = ecs_commands_spawn_empty(r2.0);
    if ecs_commands_entity_count(r3.0) != 3 { panic(72010); };
    if r1.1 != 0 { panic(72011); };
    if r2.1 != 1 { panic(72012); };
    if r3.1 != 2 { panic(72013); };
}

// === spawn ===

@test "commands spawn with component"() {
    let c = ecs_commands_new();
    let result = ecs_commands_spawn(c, 5, 50);
    let c2 = result.0;
    let e = result.1;
    if ecs_commands_entity_count(c2) != 1 { panic(72020); };
    let g = ecs_commands_get_component(c2, e, 5);
    if g.0 != true { panic(72021); };
    if g.1 != 50 { panic(72022); };
}

// === entity / get_entity ===

@test "commands entity found"() {
    let c = ecs_commands_new();
    let r = ecs_commands_spawn_empty(c);
    let c2 = r.0;
    let e = r.1;
    let idx = ecs_commands_entity(c2, e);
    if idx != 0 { panic(72030); };
    let ge = ecs_commands_get_entity(c2, e);
    if ge.0 != true { panic(72031); };
}

@test "commands entity not found"() {
    let c = ecs_commands_new();
    let idx = ecs_commands_entity(c, 99);
    if idx != -1 { panic(72040); };
    let ge = ecs_commands_get_entity(c, 99);
    if ge.0 != false { panic(72041); };
}

// === insert_entity ===

@test "commands insert_entity new"() {
    let c = ecs_commands_new();
    let r = ecs_commands_spawn_empty(c);
    let c2 = r.0;
    let e = r.1;
    let c3 = ecs_commands_insert_entity(c2, e, 3, 30);
    let g = ecs_commands_get_component(c3, e, 3);
    if g.0 != true { panic(72050); };
    if g.1 != 30 { panic(72051); };
}

@test "commands insert_entity overwrite"() {
    let c = ecs_commands_new();
    let r = ecs_commands_spawn(c, 3, 30);
    let c2 = r.0;
    let e = r.1;
    let c3 = ecs_commands_insert_entity(c2, e, 3, 99);
    let g = ecs_commands_get_component(c3, e, 3);
    if g.1 != 99 { panic(72060); };
}

@test "commands insert_entity multiple components"() {
    let c = ecs_commands_new();
    let r = ecs_commands_spawn_empty(c);
    let c2 = r.0;
    let e = r.1;
    let c3 = ecs_commands_insert_entity(c2, e, 1, 10);
    let c4 = ecs_commands_insert_entity(c3, e, 2, 20);
    let g1 = ecs_commands_get_component(c4, e, 1);
    let g2 = ecs_commands_get_component(c4, e, 2);
    if g1.1 != 10 { panic(72070); };
    if g2.1 != 20 { panic(72071); };
}

// === insert_batch ===

@test "commands insert_batch replace"() {
    let c = ecs_commands_new();
    let r1 = ecs_commands_spawn_empty(c);
    let r2 = ecs_commands_spawn_empty(r1.0);
    let c2 = r2.0;
    let e1 = r1.1;
    let e2 = r2.1;
    let entities = Vec::new();
    entities.push(e1);
    entities.push(e2);
    let comp_ids = Vec::new();
    comp_ids.push(5);
    comp_ids.push(6);
    let values = Vec::new();
    values.push(50);
    values.push(60);
    let c3 = ecs_commands_insert_batch(c2, entities, comp_ids, values, 0);
    let g1 = ecs_commands_get_component(c3, e1, 5);
    let g2 = ecs_commands_get_component(c3, e2, 6);
    if g1.1 != 50 { panic(72080); };
    if g2.1 != 60 { panic(72081); };
}

@test "commands insert_batch keep mode"() {
    let c = ecs_commands_new();
    let r = ecs_commands_spawn(c, 5, 50);
    let c2 = r.0;
    let e = r.1;
    let entities = Vec::new();
    entities.push(e);
    let comp_ids = Vec::new();
    comp_ids.push(5);
    let values = Vec::new();
    values.push(99);
    // Keep mode: should not overwrite existing
    let c3 = ecs_commands_insert_batch(c2, entities, comp_ids, values, 1);
    let g = ecs_commands_get_component(c3, e, 5);
    if g.1 != 50 { panic(72090); };
}

// === spawn_batch ===

@test "commands spawn_batch"() {
    let c = ecs_commands_new();
    let comp_ids = Vec::new();
    comp_ids.push(1);
    comp_ids.push(2);
    let values = Vec::new();
    values.push(10);
    values.push(20);
    let c2 = ecs_commands_spawn_batch(c, comp_ids, values);
    if ecs_commands_entity_count(c2) != 2 { panic(72100); };
    if ecs_commands_component_count(c2) != 2 { panic(72101); };
}

// === Resources ===

@test "commands insert_resource"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_insert_resource(c, 100, 1000);
    let g = ecs_commands_get_resource(c2, 100);
    if g.0 != true { panic(72110); };
    if g.1 != 1000 { panic(72111); };
}

@test "commands insert_resource overwrite"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_insert_resource(c, 100, 500);
    let c3 = ecs_commands_insert_resource(c2, 100, 600);
    let g = ecs_commands_get_resource(c3, 100);
    if g.1 != 600 { panic(72120); };
    if ecs_commands_resource_count(c3) != 1 { panic(72121); };
}

@test "commands init_resource new"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_init_resource(c, 200);
    let g = ecs_commands_get_resource(c2, 200);
    if g.0 != true { panic(72130); };
    if g.1 != 0 { panic(72131); };
}

@test "commands init_resource existing noop"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_insert_resource(c, 200, 999);
    let c3 = ecs_commands_init_resource(c2, 200);
    let g = ecs_commands_get_resource(c3, 200);
    if g.1 != 999 { panic(72140); };
}

@test "commands insert_resource_if_neq different"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_insert_resource(c, 100, 500);
    let c3 = ecs_commands_insert_resource_if_neq(c2, 100, 600);
    let g = ecs_commands_get_resource(c3, 100);
    if g.1 != 600 { panic(72150); };
}

@test "commands insert_resource_if_neq same noop"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_insert_resource(c, 100, 500);
    let c3 = ecs_commands_insert_resource_if_neq(c2, 100, 500);
    let g = ecs_commands_get_resource(c3, 100);
    if g.1 != 500 { panic(72160); };
}

@test "commands remove_resource"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_insert_resource(c, 100, 500);
    let c3 = ecs_commands_insert_resource(c2, 200, 600);
    let c4 = ecs_commands_remove_resource(c3, 100);
    if ecs_commands_resource_count(c4) != 1 { panic(72170); };
    let g = ecs_commands_get_resource(c4, 100);
    if g.0 != false { panic(72171); };
    let g2 = ecs_commands_get_resource(c4, 200);
    if g2.0 != true { panic(72172); };
}

@test "commands remove_resource nonexistent"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_remove_resource(c, 99);
    if ecs_commands_resource_count(c2) != 0 { panic(72180); };
}

// === System registration ===

@test "commands register_system"() {
    let c = ecs_commands_new();
    let r1 = ecs_commands_register_system(c);
    let r2 = ecs_commands_register_system(r1.0);
    if r1.1 != 1 { panic(72190); };
    if r2.1 != 2 { panic(72191); };
    if ecs_commands_system_count(r2.0) != 2 { panic(72192); };
}

@test "commands unregister_system"() {
    let c = ecs_commands_new();
    let r1 = ecs_commands_register_system(c);
    let r2 = ecs_commands_register_system(r1.0);
    let r3 = ecs_commands_unregister_system(r2.0, r1.1);
    if r3.1 != true { panic(72200); };
    if ecs_commands_system_count(r3.0) != 1 { panic(72201); };
}

@test "commands unregister_system not found"() {
    let c = ecs_commands_new();
    let r = ecs_commands_unregister_system(c, 99);
    if r.1 != false { panic(72210); };
}

@test "commands run_system registered"() {
    let c = ecs_commands_new();
    let r = ecs_commands_register_system(c);
    let r2 = ecs_commands_run_system(r.0, r.1);
    if r2.1 != true { panic(72220); };
}

@test "commands run_system not registered"() {
    let c = ecs_commands_new();
    let r = ecs_commands_run_system(c, 99);
    if r.1 != false { panic(72230); };
}

// === run_schedule ===

@test "commands run_schedule"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_run_schedule(c, 5);
    let c3 = ecs_commands_run_schedule(c2, 10);
    if ecs_commands_schedule_count(c3) != 2 { panic(72240); };
}

// === queue ===

@test "commands queue"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_queue(c);
    let c3 = ecs_commands_queue(c2);
    if ecs_commands_queue_len(c3) != 2 { panic(72250); };
}

@test "commands queue_handled and queue_silenced"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_queue_handled(c);
    let c3 = ecs_commands_queue_silenced(c2);
    if ecs_commands_queue_len(c3) != 2 { panic(72260); };
}

// === append ===

@test "commands append"() {
    let c = ecs_commands_new();
    let other = Vec::new();
    other.push(0);
    other.push(1);
    other.push(2);
    let c2 = ecs_commands_append(c, other);
    if ecs_commands_queue_len(c2) != 3 { panic(72270); };
}

// === write_message ===

@test "commands write_message"() {
    let c = ecs_commands_new();
    let c2 = ecs_commands_write_message(c, 42);
    if ecs_commands_queue_len(c2) != 1 { panic(72280); };
}

// === has_component ===

@test "commands has_component"() {
    let c = ecs_commands_new();
    let r = ecs_commands_spawn(c, 5, 50);
    if ecs_commands_has_component(r.0, r.1, 5) != true { panic(72290); };
    if ecs_commands_has_component(r.0, r.1, 6) != false { panic(72291); };
}

// === get_component nonexistent ===

@test "commands get_component nonexistent"() {
    let c = ecs_commands_new();
    let r = ecs_commands_spawn_empty(c);
    let g = ecs_commands_get_component(r.0, r.1, 99);
    if g.0 != false { panic(72300); };
}

// === component_count ===

@test "commands component_count"() {
    let c = ecs_commands_new();
    let r = ecs_commands_spawn(c, 1, 10);
    let c2 = ecs_commands_insert_entity(r.0, r.1, 2, 20);
    if ecs_commands_component_count(c2) != 2 { panic(72310); };
}
