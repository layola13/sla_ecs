@import "lib/observer_entity_cloning.sla"

// Isolated tests for lib/observer_entity_cloning.sla — ObserverCloneState
// Bevy reference: bevy_ecs/src/observer/entity_cloning.rs

@test "clone_state_new"() {
    let s = ecs_observer_clone_state_new();
    if ecs_observer_clone_state_add_observers(s) != false { panic(83600); };
    if ecs_observer_clone_state_clone_count(s) != 0 { panic(83601); };
}

@test "clone_state_set_add_observers"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_set_add_observers(s, true);
    if ecs_observer_clone_state_add_observers(s2) != true { panic(83602); };
}

@test "clone_state_register_clone"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_register_clone(s, 10, 20);
    if ecs_observer_clone_state_clone_count(s2) != 1 { panic(83603); };
}

@test "clone_state_register_multiple"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_register_clone(s, 10, 20);
    let s3 = ecs_observer_clone_state_register_clone(s2, 30, 40);
    if ecs_observer_clone_state_clone_count(s3) != 2 { panic(83604); };
}

@test "clone_state_get_source"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_register_clone(s, 10, 20);
    let r = ecs_observer_clone_state_get_source(s2, 20);
    if r.0 != true { panic(83605); };
    if r.1 != 10 { panic(83606); };
}

@test "clone_state_get_source_not_found"() {
    let s = ecs_observer_clone_state_new();
    let r = ecs_observer_clone_state_get_source(s, 99);
    if r.0 != false { panic(83607); };
}

@test "clone_state_get_target"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_register_clone(s, 10, 20);
    let r = ecs_observer_clone_state_get_target(s2, 10);
    if r.0 != true { panic(83608); };
    if r.1 != 20 { panic(83609); };
}

@test "clone_state_get_target_not_found"() {
    let s = ecs_observer_clone_state_new();
    let r = ecs_observer_clone_state_get_target(s, 99);
    if r.0 != false { panic(83610); };
}

@test "clone_state_queue_observer"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_queue_observer(s, 100);
    if ecs_observer_clone_state_queued_observer_count(s2) != 1 { panic(83611); };
    if ecs_observer_clone_state_has_queued_observer(s2, 100) != true { panic(83612); };
}

@test "clone_state_queue_observer_multiple"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_queue_observer(s, 100);
    let s3 = ecs_observer_clone_state_queue_observer(s2, 200);
    if ecs_observer_clone_state_queued_observer_count(s3) != 2 { panic(83613); };
}

@test "clone_state_has_queued_observer_false"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_queue_observer(s, 100);
    if ecs_observer_clone_state_has_queued_observer(s2, 999) != false { panic(83614); };
}

@test "clone_state_queue_event_key"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_queue_event_key(s, 5);
    let s3 = ecs_observer_clone_state_queue_event_key(s2, 6);
    if ecs_observer_clone_state_event_key_count(s3) != 2 { panic(83615); };
}

@test "clone_state_queue_component"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_queue_component(s, 10);
    let s3 = ecs_observer_clone_state_queue_component(s2, 20);
    if ecs_observer_clone_state_component_count(s3) != 2 { panic(83616); };
}

@test "clone_state_clear"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_register_clone(s, 10, 20);
    let s3 = ecs_observer_clone_state_queue_observer(s2, 100);
    let s4 = ecs_observer_clone_state_clear(s3);
    if ecs_observer_clone_state_clone_count(s4) != 0 { panic(83617); };
    if ecs_observer_clone_state_queued_observer_count(s4) != 0 { panic(83618); };
}

@test "clone_state_full_workflow"() {
    let s = ecs_observer_clone_state_new();
    let s2 = ecs_observer_clone_state_set_add_observers(s, true);
    let s3 = ecs_observer_clone_state_register_clone(s2, 10, 20);
    let s4 = ecs_observer_clone_state_queue_observer(s3, 100);
    let s5 = ecs_observer_clone_state_queue_event_key(s4, 5);
    let s6 = ecs_observer_clone_state_queue_component(s5, 10);
    if ecs_observer_clone_state_add_observers(s6) != true { panic(83619); };
    if ecs_observer_clone_state_clone_count(s6) != 1 { panic(83620); };
    if ecs_observer_clone_state_queued_observer_count(s6) != 1 { panic(83621); };
    if ecs_observer_clone_state_event_key_count(s6) != 1 { panic(83622); };
    if ecs_observer_clone_state_component_count(s6) != 1 { panic(83623); };
}
