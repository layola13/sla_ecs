// Verification tests for transitive RequiredComponents expansion (Bevy 0.15+).
@import "../lib/ecs_world.sla"

struct RcA { a: i32 }
struct RcB { b: i32 }
struct RcC { c: i32 }
fn drop_rc_a(x: RcA) {}
fn drop_rc_b(x: RcB) {}
fn drop_rc_c(x: RcC) {}

const RCA_ID: i32 = 2601;
const RCB_ID: i32 = 2602;
const RCC_ID: i32 = 2603;

fn make_rc_a() -> ErasedComponentValue { return registry_erased_value_new<RcA>(RCA_ID, RcA { a: 1 }); }
fn make_rc_b() -> ErasedComponentValue { return registry_erased_value_new<RcB>(RCB_ID, RcB { b: 2 }); }
fn make_rc_c() -> ErasedComponentValue { return registry_erased_value_new<RcC>(RCC_ID, RcC { c: 3 }); }

@test "transitive required components expand recursively"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<RcA, i32, i32>(w0, RCA_ID, 0);
    let w2 = ecs_world_register<RcB, i32, i32>(w1, RCB_ID, 0);
    let w3 = ecs_world_register<RcC, i32, i32>(w2, RCC_ID, 0);
    let (w4, e) = ecs_world_spawn<i32, i32>(w3);
    let w5 = ecs_world_insert<RcA, i32, i32>(w4, e, RCA_ID, RcA { a: 99 });
    let req = ecs_required_components_new();
    let r1 = ecs_required_components_register(req, RCA_ID, RCB_ID, make_rc_b);
    let r2 = ecs_required_components_register(r1, RCB_ID, RCC_ID, make_rc_c);
    let w6 = ecs_world_apply_required<i32, i32>(w5, r2, e, RCA_ID);
    if ecs_world_has<i32, i32>(w6, e, RCB_ID) != true { panic(26001); };
    if ecs_world_has<i32, i32>(w6, e, RCC_ID) != true { panic(26002); };
}

@test "required components skip already present"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<RcA, i32, i32>(w0, RCA_ID, 0);
    let w2 = ecs_world_register<RcB, i32, i32>(w1, RCB_ID, 0);
    let (w3, e) = ecs_world_spawn<i32, i32>(w2);
    let w4 = ecs_world_insert<RcB, i32, i32>(w3, e, RCB_ID, RcB { b: 77 });
    let w5 = ecs_world_insert<RcA, i32, i32>(w4, e, RCA_ID, RcA { a: 99 });
    let req = ecs_required_components_new();
    let r1 = ecs_required_components_register(req, RCA_ID, RCB_ID, make_rc_b);
    let w6 = ecs_world_apply_required<i32, i32>(w5, r1, e, RCA_ID);
    let got = ecs_world_get<RcB, i32, i32>(w6, e, RCB_ID);
    if got.b != 77 { panic(26003); };
}
