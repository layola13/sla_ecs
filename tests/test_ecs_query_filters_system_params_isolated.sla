// Isolated test: Bevy ECS Query Filters + Fetch types + SystemParam types parity.
// Mirrors src/query/filter.rs + src/query/fetch.rs + src/system/system_param.rs

// === Query Filters (src/query/filter.rs) ===
// With<T>: entity must have component T
struct WithFilter { component_id: i32 }
fn with_new(cid: i32) -> WithFilter { return WithFilter { component_id: cid }; }
fn with_matches(wf: WithFilter, components: Vec<i32>) -> bool {
    let i: i64 = 0;
    let cnt = len(components) as i64;
    while i < cnt { if components[i] == wf.component_id { return true; }; i = i + 1; }
    return false;
}

// Without<T>: entity must NOT have component T
struct WithoutFilter { component_id: i32 }
fn without_new(cid: i32) -> WithoutFilter { return WithoutFilter { component_id: cid }; }
fn without_matches(wf: WithoutFilter, components: Vec<i32>) -> bool {
    let i: i64 = 0;
    let cnt = len(components) as i64;
    while i < cnt { if components[i] == wf.component_id { return false; }; i = i + 1; }
    return true;
}

// Or<A,B>: either A or B must match
struct OrFilter { a: i32, b: i32 }
fn or_new(a: i32, b: i32) -> OrFilter { return OrFilter { a: a, b: b }; }
fn or_matches(of: OrFilter, components: Vec<i32>) -> bool {
    let i: i64 = 0;
    let cnt = len(components) as i64;
    while i < cnt {
        if components[i] == of.a { return true; };
        if components[i] == of.b { return true; };
        i = i + 1;
    }
    return false;
}

// Added<T>: component was added since last tick
struct AddedFilter { component_id: i32 }
fn added_new(cid: i32) -> AddedFilter { return AddedFilter { component_id: cid }; }
fn added_matches(af: AddedFilter, added_components: Vec<i32>) -> bool {
    let i: i64 = 0;
    let cnt = len(added_components) as i64;
    while i < cnt { if added_components[i] == af.component_id { return true; }; i = i + 1; }
    return false;
}

// Changed<T>: component was changed since last tick
struct ChangedFilter { component_id: i32 }
fn changed_new(cid: i32) -> ChangedFilter { return ChangedFilter { component_id: cid }; }
fn changed_matches(cf: ChangedFilter, changed_components: Vec<i32>) -> bool {
    let i: i64 = 0;
    let cnt = len(changed_components) as i64;
    while i < cnt { if changed_components[i] == cf.component_id { return true; }; i = i + 1; }
    return false;
}

// Allow<T>: allow entities with disabling component T (bypasses default filter)
struct AllowFilter { component_id: i32 }
fn allow_new(cid: i32) -> AllowFilter { return AllowFilter { component_id: cid }; }
fn allow_component(af: AllowFilter) -> i32 { return af.component_id; }

// Spawned: entity was spawned this tick
fn spawned_matches(spawned_this_tick: bool) -> bool { return spawned_this_tick; }

// === Query Fetch types (src/query/fetch.rs) ===
// Has<T>: returns bool whether entity has component
fn has_check(components: Vec<i32>, cid: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(components) as i64;
    while i < cnt { if components[i] == cid { return true; }; i = i + 1; }
    return false;
}

// AnyOf<(A,B)>: returns Option tuple
fn any_of_check(components: Vec<i32>, a: i32, b: i32) -> (bool, bool) {
    let has_a = has_check(components, a);
    let has_b = has_check(components, b);
    return (has_a, has_b);
}

// Option<T>: returns Option<component>
fn option_check(components: Vec<i32>, cid: i32) -> (bool, i32) {
    if has_check(components, cid) { return (true, cid); };
    return (false, 0);
}

// Read<T>: read access to component
fn read_get(components: Vec<i32>, cid: i32) -> (bool, i32) {
    return option_check(components, cid);
}

// Write<T>: write access to component (same lookup, mutable)
fn write_get(components: Vec<i32>, cid: i32) -> (bool, i32) {
    return option_check(components, cid);
}

// === SystemParam types (src/system/system_param.rs) ===
// ParamSet: access multiple params by index
struct ParamSet {
    params: Vec<i32>,
}

fn pset_new() -> ParamSet { return ParamSet { params: Vec::new() }; }
fn pset_add(ps: ParamSet, val: i32) -> ParamSet { ps.params.push(val); return ps; }
fn pset_get_mut(ps: ParamSet, idx: i64) -> i32 { return ps.params[idx]; }
fn pset_len(ps: ParamSet) -> i64 { return len(ps.params) as i64; }
fn pset_for_each(ps: ParamSet, collected: Vec<i32>) -> Vec<i32> {
    let i: i64 = 0;
    let cnt = len(ps.params) as i64;
    while i < cnt { collected.push(ps.params[i]); i = i + 1; }
    return collected;
}

// Local<T>: per-system mutable state
struct Local {
    value: i32,
}

fn local_new(val: i32) -> Local { return Local { value: val }; }
fn local_get(l: Local) -> i32 { return l.value; }
fn local_set(l: Local, val: i32) -> Local { l.value = val; return l; }

// Deferred<T>: deferred buffer for commands
struct Deferred {
    commands: Vec<i32>,
}

fn deferred_new() -> Deferred { return Deferred { commands: Vec::new() }; }
fn deferred_push(d: Deferred, cmd: i32) -> Deferred { d.commands.push(cmd); return d; }
fn deferred_reborrow(d: Deferred) -> Deferred { return d; }
fn deferred_len(d: Deferred) -> i64 { return len(d.commands) as i64; }

// If<T>: conditional param wrapper
struct IfParam {
    value: i32,
    is_present: bool,
}

fn if_new(val: i32) -> IfParam { return IfParam { value: val, is_present: true }; }
fn if_into_inner(i: IfParam) -> i32 { return i.value; }
fn if_is_present(i: IfParam) -> bool { return i.is_present; }

// SystemChangeTick: tracks this_run and last_run ticks
struct SystemChangeTick {
    this_run: i64,
    last_run: i64,
}

fn sct_new(this_run: i64, last_run: i64) -> SystemChangeTick {
    return SystemChangeTick { this_run: this_run, last_run: last_run };
}

fn sct_this_run(sct: SystemChangeTick) -> i64 { return sct.this_run; }
fn sct_last_run(sct: SystemChangeTick) -> i64 { return sct.last_run; }

// StaticSystemParam: statically known param
struct StaticSystemParam {
    value: i32,
}

fn ssp_new(val: i32) -> StaticSystemParam { return StaticSystemParam { value: val }; }
fn ssp_get(ssp: StaticSystemParam) -> i32 { return ssp.value; }

// === Tests ===

@test "with filter matches present"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(5);
    comps.push(10);
    if with_matches(with_new(5), comps) != true { panic(29001); };
}

@test "with filter no match absent"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(10);
    if with_matches(with_new(5), comps) != false { panic(29002); };
}

@test "without filter matches absent"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(10);
    if without_matches(without_new(5), comps) != true { panic(29003); };
}

@test "without filter no match present"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(5);
    if without_matches(without_new(5), comps) != false { panic(29004); };
}

@test "or filter matches first"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(5);
    if or_matches(or_new(5, 10), comps) != true { panic(29005); };
}

@test "or filter matches second"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(10);
    if or_matches(or_new(5, 10), comps) != true { panic(29006); };
}

@test "or filter no match"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(20);
    if or_matches(or_new(5, 10), comps) != false { panic(29007); };
}

@test "added filter matches"() {
    let added: Vec<i32> = Vec::new();
    added.push(5);
    if added_matches(added_new(5), added) != true { panic(29008); };
}

@test "added filter no match"() {
    let added: Vec<i32> = Vec::new();
    added.push(10);
    if added_matches(added_new(5), added) != false { panic(29009); };
}

@test "changed filter matches"() {
    let changed: Vec<i32> = Vec::new();
    changed.push(5);
    if changed_matches(changed_new(5), changed) != true { panic(29010); };
}

@test "changed filter no match"() {
    let changed: Vec<i32> = Vec::new();
    if changed_matches(changed_new(5), changed) != false { panic(29011); };
}

@test "allow filter component"() {
    if allow_component(allow_new(42)) != 42 { panic(29012); };
}

@test "spawned filter true"() {
    if spawned_matches(true) != true { panic(29013); };
}

@test "spawned filter false"() {
    if spawned_matches(false) != false { panic(29014); };
}

@test "has check present"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(5);
    if has_check(comps, 5) != true { panic(29015); };
}

@test "has check absent"() {
    let comps: Vec<i32> = Vec::new();
    if has_check(comps, 5) != false { panic(29016); };
}

@test "any of both present"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(5);
    comps.push(10);
    let r = any_of_check(comps, 5, 10);
    if r.0 != true { panic(29017); };
    if r.1 != true { panic(29018); };
}

@test "any of one present"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(5);
    let r = any_of_check(comps, 5, 10);
    if r.0 != true { panic(29019); };
    if r.1 != false { panic(29020); };
}

@test "any of none present"() {
    let comps: Vec<i32> = Vec::new();
    let r = any_of_check(comps, 5, 10);
    if r.0 != false { panic(29021); };
    if r.1 != false { panic(29022); };
}

@test "option check present"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(42);
    let r = option_check(comps, 42);
    if r.0 != true { panic(29023); };
    if r.1 != 42 { panic(29024); };
}

@test "option check absent"() {
    let comps: Vec<i32> = Vec::new();
    let r = option_check(comps, 42);
    if r.0 != false { panic(29025); };
}

@test "read get present"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(42);
    let r = read_get(comps, 42);
    if r.0 != true { panic(29026); };
}

@test "write get present"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(42);
    let r = write_get(comps, 42);
    if r.0 != true { panic(29027); };
}

@test "param set add and get"() {
    let ps = pset_add(pset_add(pset_new(), 10), 20);
    if pset_get_mut(ps, 0) != 10 { panic(29028); };
    if pset_get_mut(ps, 1) != 20 { panic(29029); };
}

@test "param set len"() {
    let ps = pset_add(pset_add(pset_new(), 10), 20);
    if pset_len(ps) != 2 { panic(29030); };
}

@test "param set for_each"() {
    let ps = pset_add(pset_add(pset_new(), 10), 20);
    let collected = pset_for_each(ps, Vec::new());
    if len(collected) as i64 != 2 { panic(29031); };
    if collected[0] != 10 { panic(29032); };
}

@test "local get and set"() {
    let l = local_set(local_new(0), 42);
    if local_get(l) != 42 { panic(29033); };
}

@test "deferred push and len"() {
    let d = deferred_push(deferred_push(deferred_new(), 1), 2);
    if deferred_len(d) != 2 { panic(29034); };
}

@test "deferred reborrow"() {
    let d = deferred_push(deferred_new(), 1);
    let d2 = deferred_reborrow(d);
    if deferred_len(d2) != 1 { panic(29035); };
}

@test "if param into_inner"() {
    if if_into_inner(if_new(42)) != 42 { panic(29036); };
}

@test "if param is_present"() {
    if if_is_present(if_new(42)) != true { panic(29037); };
}

@test "system change tick this_run"() {
    let sct = sct_new(100, 90);
    if sct_this_run(sct) != 100 { panic(29038); };
}

@test "system change tick last_run"() {
    let sct = sct_new(100, 90);
    if sct_last_run(sct) != 90 { panic(29039); };
}

@test "static system param get"() {
    if ssp_get(ssp_new(42)) != 42 { panic(29040); };
}
