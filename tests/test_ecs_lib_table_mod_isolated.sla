@import "lib/table_mod.sla"

// Isolated tests for lib/table_mod.sla — Table + TableId + TableRow + Tables
// Bevy reference: bevy_ecs/src/storage/table/mod.rs

@test "table_id_new"() {
    let id = ecs_table_id_new(5);
    if ecs_table_id_value(id) != 5 { panic(83400); };
    if ecs_table_id_index(id) != 5 { panic(83401); };
}

@test "table_row_new"() {
    let r = ecs_table_row_new(10);
    if ecs_table_row_value(r) != 10 { panic(83402); };
    if ecs_table_row_index(r) != 10 { panic(83403); };
}

@test "table_new"() {
    let t = ecs_table_new(1, 100);
    if ecs_table_id(t) != 1 { panic(83404); };
    if ecs_table_entity_count(t) != 0 { panic(83405); };
    if ecs_table_entity_capacity(t) != 100 { panic(83406); };
    if ecs_table_component_count(t) != 0 { panic(83407); };
    if ecs_table_is_empty(t) != true { panic(83408); };
}

@test "table_add_column"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    if ecs_table_component_count(t2) != 1 { panic(83409); };
    if ecs_table_has_column(t2, 5) != true { panic(83410); };
}

@test "table_add_multiple_columns"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let t3 = ecs_table_add_column(t2, 6);
    let t4 = ecs_table_add_column(t3, 7);
    if ecs_table_component_count(t4) != 3 { panic(83411); };
}

@test "table_has_column_false"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    if ecs_table_has_column(t2, 99) != false { panic(83412); };
}

@test "table_get_column_index"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let t3 = ecs_table_add_column(t2, 6);
    if ecs_table_get_column_index(t3, 5) != 0 { panic(83413); };
    if ecs_table_get_column_index(t3, 6) != 1 { panic(83414); };
    if ecs_table_get_column_index(t3, 99) != -1 { panic(83415); };
}

@test "table_allocate"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let r = ecs_table_allocate(t2, 42, 10);
    let t3 = r.0;
    let row = r.1;
    if ecs_table_entity_count(t3) != 1 { panic(83416); };
    if row != 0 { panic(83417); };
}

@test "table_allocate_multiple"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let r1 = ecs_table_allocate(t2, 10, 1);
    let r2 = ecs_table_allocate(r1.0, 20, 2);
    let r3 = ecs_table_allocate(r2.0, 30, 3);
    if ecs_table_entity_count(r3.0) != 3 { panic(83418); };
    if r3.1 != 2 { panic(83419); };
}

@test "table_get_set"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let r = ecs_table_allocate(t2, 42, 10);
    let t3 = r.0;
    let row = r.1;
    let sr = ecs_table_set(t3, 5, row, 99, 20);
    let t4 = sr.0;
    if sr.1 != true { panic(83420); };
    let gr = ecs_table_get(t4, 5, row);
    if gr.0 != true { panic(83421); };
    if gr.1 != 99 { panic(83422); };
}

@test "table_get_nonexistent_column"() {
    let t = ecs_table_new(1, 100);
    let gr = ecs_table_get(t, 99, 0);
    if gr.0 != false { panic(83423); };
}

@test "table_get_added_tick"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let r = ecs_table_allocate(t2, 42, 10);
    let t3 = r.0;
    let at = ecs_table_get_added_tick(t3, 5, r.1);
    if at.0 != true { panic(83424); };
    if at.1 != 10 { panic(83425); };
}

@test "table_get_changed_tick"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let r = ecs_table_allocate(t2, 42, 10);
    let sr = ecs_table_set(r.0, 5, r.1, 99, 20);
    let ct = ecs_table_get_changed_tick(sr.0, 5, r.1);
    if ct.0 != true { panic(83426); };
    if ct.1 != 20 { panic(83427); };
}

@test "table_get_drop_for"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    if ecs_table_get_drop_for(t2, 5) != true { panic(83428); };
    if ecs_table_get_drop_for(t2, 99) != false { panic(83429); };
}

@test "table_swap_remove"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let r1 = ecs_table_allocate(t2, 10, 1);
    let r2 = ecs_table_allocate(r1.0, 20, 2);
    let r3 = ecs_table_allocate(r2.0, 30, 3);
    let sr = ecs_table_swap_remove(r3.0, 0);
    if sr.1 != true { panic(83430); };
    if ecs_table_entity_count(sr.0) != 2 { panic(83431); };
    let er = ecs_table_get_entity_at_row(sr.0, 0);
    if er.1 != 30 { panic(83432); };
}

@test "table_swap_remove_last"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let r1 = ecs_table_allocate(t2, 10, 1);
    let r2 = ecs_table_allocate(r1.0, 20, 2);
    let sr = ecs_table_swap_remove(r2.0, 1);
    if sr.1 != true { panic(83433); };
    if ecs_table_entity_count(sr.0) != 1 { panic(83434); };
    let er = ecs_table_get_entity_at_row(sr.0, 0);
    if er.1 != 10 { panic(83435); };
}

@test "table_swap_remove_out_of_range"() {
    let t = ecs_table_new(1, 100);
    let sr = ecs_table_swap_remove(t, 0);
    if sr.1 != false { panic(83436); };
}

@test "table_get_entity_at_row"() {
    let t = ecs_table_new(1, 100);
    let t2 = ecs_table_add_column(t, 5);
    let r1 = ecs_table_allocate(t2, 10, 1);
    let r2 = ecs_table_allocate(r1.0, 20, 2);
    let er0 = ecs_table_get_entity_at_row(r2.0, 0);
    if er0.1 != 10 { panic(83437); };
    let er1 = ecs_table_get_entity_at_row(r2.0, 1);
    if er1.1 != 20 { panic(83438); };
    let er2 = ecs_table_get_entity_at_row(r2.0, 2);
    if er2.0 != false { panic(83439); };
}

@test "tables_new"() {
    let ts = ecs_tables_new();
    if ecs_tables_len(ts) != 0 { panic(83440); };
    if ecs_tables_is_empty(ts) != true { panic(83441); };
}

@test "tables_create"() {
    let ts = ecs_tables_new();
    let r = ecs_tables_create(ts, 100);
    let ts2 = r.0;
    let id = r.1;
    if ecs_tables_count(ts2) != 1 { panic(83442); };
    if id != 0 { panic(83443); };
}

@test "tables_create_multiple"() {
    let ts = ecs_tables_new();
    let r1 = ecs_tables_create(ts, 100);
    let r2 = ecs_tables_create(r1.0, 200);
    if ecs_tables_count(r2.0) != 2 { panic(83444); };
    if r2.1 != 1 { panic(83445); };
}

@test "tables_get"() {
    let ts = ecs_tables_new();
    let r = ecs_tables_create(ts, 100);
    let ts2 = r.0;
    let id = r.1;
    let gr = ecs_tables_get(ts2, id);
    if gr.0 != true { panic(83446); };
    if ecs_table_id(gr.1) != id { panic(83447); };
}

@test "tables_get_not_found"() {
    let ts = ecs_tables_new();
    let gr = ecs_tables_get(ts, 99);
    if gr.0 != false { panic(83448); };
}
