@import "lib/system_name.sla"
@import "lib/world_entity_fetch.sla"
@import "lib/exclusive_function_system.sla"

@test "debug name new and accessors"() {
    let d = ecs_debug_name_new(5, 2);
    if ecs_debug_name_name(d) != 5 { panic(43001); };
    if ecs_debug_name_crate(d) != 2 { panic(43002); };
}

@test "debug name eq"() {
    if ecs_debug_name_eq(ecs_debug_name_new(5, 2), ecs_debug_name_new(5, 9)) != true { panic(43003); };
    if ecs_debug_name_eq(ecs_debug_name_new(5, 2), ecs_debug_name_new(6, 2)) != false { panic(43004); };
}

@test "system name new and id"() {
    let s = ecs_system_name_new(42, 1);
    if ecs_system_name_id(s) != 42 { panic(43005); };
}

@test "system name eq"() {
    let a = ecs_system_name_new(7, 1);
    let b = ecs_system_name_new(7, 1);
    if ecs_system_name_eq(a, b) != true { panic(43006); };
}

@test "system name with_name"() {
    let s = ecs_system_name_new(7, 1);
    let s2 = ecs_system_name_with_name(s, 99);
    if ecs_system_name_id(s2) != 99 { panic(43007); };
}

@test "entity fetcher new and count"() {
    let f = ecs_entity_fetcher_new(1, 10);
    if ecs_entity_fetcher_world_id(f) != 1 { panic(43008); };
    if ecs_entity_fetcher_count(f) != 10 { panic(43009); };
}

@test "entity fetcher get found"() {
    let f = ecs_entity_fetcher_new(1, 10);
    let r = ecs_entity_fetcher_get(f, 5);
    if r.0 != true { panic(43010); };
    if r.1 != 5 { panic(43011); };
}

@test "entity fetcher get out of range"() {
    let f = ecs_entity_fetcher_new(1, 10);
    let r = ecs_entity_fetcher_get(f, 20);
    if r.0 != false { panic(43012); };
}

@test "entity fetcher get negative"() {
    let f = ecs_entity_fetcher_new(1, 10);
    let r = ecs_entity_fetcher_get(f, -1);
    if r.0 != false { panic(43013); };
}

@test "entity fetcher get_mut"() {
    let f = ecs_entity_fetcher_new(1, 10);
    let r = ecs_entity_fetcher_get_mut(f, 3);
    if r.0 != true { panic(43014); };
    if r.1 != 3 { panic(43015); };
}

@test "world entity fetch batch"() {
    let f = ecs_entity_fetcher_new(1, 10);
    if ecs_world_entity_fetch_batch(f, 0, 5) != 5 { panic(43016); };
    if ecs_world_entity_fetch_batch(f, 8, 5) != 2 { panic(43017); };
}

@test "exclusive function system new"() {
    let s = ecs_exclusive_function_system_new(42, true);
    if ecs_exclusive_function_system_name(s) != 42 { panic(43018); };
    if ecs_exclusive_function_system_has_input(s) != true { panic(43019); };
    if ecs_exclusive_function_system_is_initialized(s) != false { panic(43020); };
}

@test "exclusive function system initialize"() {
    let s = ecs_exclusive_function_system_new(42, false);
    let s2 = ecs_exclusive_function_system_initialize(s);
    if ecs_exclusive_function_system_is_initialized(s2) != true { panic(43021); };
}

@test "exclusive function system run"() {
    let s = ecs_exclusive_function_system_new(42, false);
    let r = ecs_exclusive_function_system_run(s, 99);
    if r.1 != 99 { panic(43022); };
    if ecs_exclusive_function_system_last_run(r.0) != 99 { panic(43023); };
}

@test "exclusive function system with_name"() {
    let s = ecs_exclusive_function_system_new(42, false);
    let s2 = ecs_exclusive_function_system_with_name(s, 77);
    if ecs_exclusive_function_system_name(s2) != 77 { panic(43024); };
}

@test "exclusive function system apply_deferred"() {
    let s = ecs_exclusive_function_system_new(42, false);
    let s2 = ecs_exclusive_function_system_apply_deferred(s);
    if ecs_exclusive_function_system_name(s2) != 42 { panic(43025); };
}
