@import "lib/thin_array_ptr.sla"

// Isolated tests for lib/thin_array_ptr.sla — ThinArrayPtr
// Bevy reference: bevy_ecs/src/storage/thin_array_ptr.rs

@test "thin_array_with_capacity"() {
    let a = ecs_thin_array_with_capacity(10);
    if ecs_thin_array_capacity(a) != 10 { panic(82700); };
    if ecs_thin_array_len(a) != 0 { panic(82701); };
    if ecs_thin_array_is_empty(a) != true { panic(82702); };
}

@test "thin_array_empty"() {
    let a = ecs_thin_array_empty();
    if ecs_thin_array_capacity(a) != 0 { panic(82703); };
    if ecs_thin_array_len(a) != 0 { panic(82704); };
}

@test "thin_array_alloc"() {
    let a = ecs_thin_array_empty();
    let a2 = ecs_thin_array_alloc(a, 50);
    if ecs_thin_array_capacity(a2) != 50 { panic(82705); };
}

@test "thin_array_realloc"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_realloc(a, 10, 20);
    if ecs_thin_array_capacity(a2) != 20 { panic(82706); };
}

@test "thin_array_initialize"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_initialize(a, 0, 42);
    if ecs_thin_array_len(a2) != 1 { panic(82707); };
    let g = ecs_thin_array_get(a2, 0);
    if g.0 != true { panic(82708); };
    if g.1 != 42 { panic(82709); };
}

@test "thin_array_initialize_multiple"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_initialize(a, 0, 10);
    let a3 = ecs_thin_array_initialize(a2, 1, 20);
    let a4 = ecs_thin_array_initialize(a3, 2, 30);
    if ecs_thin_array_len(a4) != 3 { panic(82710); };
    let g0 = ecs_thin_array_get(a4, 0);
    if g0.1 != 10 { panic(82711); };
    let g1 = ecs_thin_array_get(a4, 1);
    if g1.1 != 20 { panic(82712); };
    let g2 = ecs_thin_array_get(a4, 2);
    if g2.1 != 30 { panic(82713); };
}

@test "thin_array_get_out_of_range"() {
    let a = ecs_thin_array_with_capacity(10);
    let g = ecs_thin_array_get(a, 0);
    if g.0 != false { panic(82714); };
}

@test "thin_array_swap_remove"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_initialize(a, 0, 10);
    let a3 = ecs_thin_array_initialize(a2, 1, 20);
    let a4 = ecs_thin_array_initialize(a3, 2, 30);
    let a5 = ecs_thin_array_swap_remove(a4, 0);
    if ecs_thin_array_len(a5) != 2 { panic(82715); };
    let g0 = ecs_thin_array_get(a5, 0);
    if g0.1 != 30 { panic(82716); };
}

@test "thin_array_swap_remove_last"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_initialize(a, 0, 10);
    let a3 = ecs_thin_array_initialize(a2, 1, 20);
    let a4 = ecs_thin_array_swap_remove(a3, 1);
    if ecs_thin_array_len(a4) != 1 { panic(82717); };
    let g0 = ecs_thin_array_get(a4, 0);
    if g0.1 != 10 { panic(82718); };
}

@test "thin_array_swap_remove_nonoverlapping"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_initialize(a, 0, 10);
    let a3 = ecs_thin_array_initialize(a2, 1, 20);
    let a4 = ecs_thin_array_initialize(a3, 2, 30);
    let a5 = ecs_thin_array_swap_remove_nonoverlapping(a4, 1);
    if ecs_thin_array_len(a5) != 2 { panic(82719); };
}

@test "thin_array_clear_elements"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_initialize(a, 0, 10);
    let a3 = ecs_thin_array_initialize(a2, 1, 20);
    let a4 = ecs_thin_array_clear_elements(a3, 2);
    if ecs_thin_array_len(a4) != 0 { panic(82720); };
    if ecs_thin_array_is_empty(a4) != true { panic(82721); };
}

@test "thin_array_drop"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_initialize(a, 0, 10);
    let a3 = ecs_thin_array_initialize(a2, 1, 20);
    let a4 = ecs_thin_array_drop(a3, 10, 2);
    if ecs_thin_array_len(a4) != 0 { panic(82722); };
    if ecs_thin_array_capacity(a4) != 0 { panic(82723); };
}

@test "thin_array_as_slice"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_initialize(a, 0, 10);
    let a3 = ecs_thin_array_initialize(a2, 1, 20);
    let a4 = ecs_thin_array_initialize(a3, 2, 30);
    let s = ecs_thin_array_as_slice(a4, 2);
    if len(s) != 2 { panic(82724); };
    if s[0] != 10 { panic(82725); };
    if s[1] != 20 { panic(82726); };
}

@test "thin_array_as_slice_exceeds"() {
    let a = ecs_thin_array_with_capacity(10);
    let a2 = ecs_thin_array_initialize(a, 0, 10);
    let s = ecs_thin_array_as_slice(a2, 5);
    if len(s) != 1 { panic(82727); };
}

@test "thin_array_as_slice_empty"() {
    let a = ecs_thin_array_with_capacity(10);
    let s = ecs_thin_array_as_slice(a, 3);
    if len(s) != 0 { panic(82728); };
}
