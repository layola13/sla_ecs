@import "lib/entry.sla"

// === ComponentEntry basics ===

@test "entry occupied construct"() {
    let e = ecs_entry_occupied(5, 42, 1);
    if ecs_entry_is_occupied(e) != true { panic(67001); };
    if ecs_entry_is_vacant(e) != false { panic(67002); };
    if ecs_entry_component_id(e) != 5 { panic(67003); };
    if ecs_entry_value(e) != 42 { panic(67004); };
    if ecs_entry_entity(e) != 1 { panic(67005); };
}

@test "entry vacant construct"() {
    let e = ecs_entry_vacant(7, 2);
    if ecs_entry_is_occupied(e) != false { panic(67010); };
    if ecs_entry_is_vacant(e) != true { panic(67011); };
    if ecs_entry_component_id(e) != 7 { panic(67012); };
    if ecs_entry_entity(e) != 2 { panic(67013); };
}

@test "entry from state occupied"() {
    let e = ecs_entry_from_state(3, 1, true, 99);
    if ecs_entry_is_occupied(e) != true { panic(67020); };
    if ecs_entry_value(e) != 99 { panic(67021); };
}

@test "entry from state vacant"() {
    let e = ecs_entry_from_state(3, 1, false, 0);
    if ecs_entry_is_vacant(e) != true { panic(67030); };
}

// === and_modify ===

@test "entry and_modify occupied"() {
    let e = ecs_entry_occupied(5, 10, 1);
    let e2 = ecs_entry_and_modify(e, 5);
    if ecs_entry_value(e2) != 15 { panic(67040); };
}

@test "entry and_modify vacant noop"() {
    let e = ecs_entry_vacant(5, 1);
    let e2 = ecs_entry_and_modify(e, 5);
    if ecs_entry_is_vacant(e2) != true { panic(67050); };
}

// === insert_entry ===

@test "entry insert_entry occupied"() {
    let e = ecs_entry_occupied(5, 10, 1);
    let o = ecs_entry_insert_entry(e, 20);
    if ecs_occupied_entry_get(o) != 20 { panic(67060); };
}

@test "entry insert_entry vacant"() {
    let e = ecs_entry_vacant(5, 1);
    let o = ecs_entry_insert_entry(e, 30);
    if ecs_occupied_entry_get(o) != 30 { panic(67070); };
}

// === or_insert ===

@test "entry or_insert occupied keeps"() {
    let e = ecs_entry_occupied(5, 10, 1);
    let o = ecs_entry_or_insert(e, 99);
    if ecs_occupied_entry_get(o) != 10 { panic(67080); };
}

@test "entry or_insert vacant inserts"() {
    let e = ecs_entry_vacant(5, 1);
    let o = ecs_entry_or_insert(e, 99);
    if ecs_occupied_entry_get(o) != 99 { panic(67090); };
}

// === or_insert_with ===

@test "entry or_insert_with vacant"() {
    let e = ecs_entry_vacant(5, 1);
    let o = ecs_entry_or_insert_with(e, 42);
    if ecs_occupied_entry_get(o) != 42 { panic(67100); };
}

// === or_default ===

@test "entry or_default vacant"() {
    let e = ecs_entry_vacant(5, 1);
    let o = ecs_entry_or_default(e);
    if ecs_occupied_entry_get(o) != 0 { panic(67110); };
}

@test "entry or_default occupied"() {
    let e = ecs_entry_occupied(5, 7, 1);
    let o = ecs_entry_or_default(e);
    if ecs_occupied_entry_get(o) != 7 { panic(67120); };
}

// === OccupiedComponentEntry ===

@test "occupied entry new and get"() {
    let o = ecs_occupied_entry_new(5, 100, 1);
    if ecs_occupied_entry_get(o) != 100 { panic(67130); };
    if ecs_occupied_entry_component_id(o) != 5 { panic(67131); };
    if ecs_occupied_entry_entity(o) != 1 { panic(67132); };
}

@test "occupied entry insert"() {
    let o = ecs_occupied_entry_new(5, 10, 1);
    let o2 = ecs_occupied_entry_insert(o, 20);
    if ecs_occupied_entry_get(o2) != 20 { panic(67140); };
}

@test "occupied entry take"() {
    let o = ecs_occupied_entry_new(5, 77, 1);
    if ecs_occupied_entry_take(o) != 77 { panic(67150); };
}

@test "occupied entry get_mut"() {
    let o = ecs_occupied_entry_new(5, 50, 1);
    if ecs_occupied_entry_get_mut(o) != 50 { panic(67160); };
}

@test "occupied entry into_mut"() {
    let o = ecs_occupied_entry_new(5, 33, 1);
    if ecs_occupied_entry_into_mut(o) != 33 { panic(67170); };
}

// === VacantComponentEntry ===

@test "vacant entry new and insert"() {
    let v = ecs_vacant_entry_new(8, 3);
    if ecs_vacant_entry_component_id(v) != 8 { panic(67180); };
    if ecs_vacant_entry_entity(v) != 3 { panic(67181); };
    let o = ecs_vacant_entry_insert(v, 42);
    if ecs_occupied_entry_get(o) != 42 { panic(67182); };
    if ecs_occupied_entry_component_id(o) != 8 { panic(67183); };
}

// === Chained operations (matching Bevy examples) ===

@test "entry chain or_insert then modify"() {
    // entity.spawn_empty(); entity.entry().or_insert(Comp(4));
    let e = ecs_entry_vacant(5, 1);
    let o = ecs_entry_or_insert(e, 4);
    // .into_mut().0 *= 2
    let val = ecs_occupied_entry_into_mut(o);
    if val != 4 { panic(67190); };
    // now modify: get_mut and double
    let o2 = ecs_occupied_entry_new(5, 4, 1);
    let mut_val = ecs_occupied_entry_get_mut(o2);
    let doubled = mut_val * 2;
    if doubled != 8 { panic(67191); };
}

@test "entry chain and_modify then insert_entry"() {
    // entity.spawn(Comp(0)); entity.entry().and_modify(|c| c.0 += 1)
    let e = ecs_entry_occupied(5, 0, 1);
    let e2 = ecs_entry_and_modify(e, 1);
    if ecs_entry_value(e2) != 1 { panic(67200); };
    // .insert_entry(Comp(4))
    let o = ecs_entry_insert_entry(e2, 4);
    if ecs_occupied_entry_get(o) != 4 { panic(67201); };
}
