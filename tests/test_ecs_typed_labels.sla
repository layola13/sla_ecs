// Verification tests for typed ScheduleLabel / SystemSet traits.
@import "../lib/label.sla"

struct UpdateLabel { n: i32 }
impl EcsScheduleLabelTrait for UpdateLabel {
    fn label_id(&self) -> i32 { return 5001; }
}

struct PhysicsLabel { n: i32 }
impl EcsScheduleLabelTrait for PhysicsLabel {
    fn label_id(&self) -> i32 { return 5002; }
}

struct PhysicsSet { n: i32 }
impl EcsSystemSetTrait for PhysicsSet {
    fn set_id(&self) -> i32 { return 6001; }
}

@test "typed schedule label gives stable id"() {
    let label = UpdateLabel { n: 1 };
    if ecs_typed_schedule_label_id<UpdateLabel>(label) != 5001 { panic(21001); };
}

@test "same label type compares equal regardless of field"() {
    let a = UpdateLabel { n: 1 };
    let b = UpdateLabel { n: 99 };
    if ecs_typed_schedule_label_equals<UpdateLabel, UpdateLabel>(a, b) != true { panic(21002); };
}

@test "different label types are not equal"() {
    let a = UpdateLabel { n: 1 };
    let b = PhysicsLabel { n: 1 };
    if ecs_typed_schedule_label_equals<UpdateLabel, PhysicsLabel>(a, b) != false { panic(21003); };
}

@test "typed system set gives stable id"() {
    let set = PhysicsSet { n: 1 };
    if ecs_typed_system_set_id<PhysicsSet>(set) != 6001 { panic(21004); };
}
