// Isolated test: Bevy ECS Template engine parity.
// Mirrors src/template.rs: Template trait, TemplateContext, SceneEntityReferences,
// FromTemplate, EntityTemplate, FnTemplate, OptionTemplate, VecTemplate.

// SceneEntityReference: a reference to an entity within a scene/template
struct InnerSceneEntityReference {
    index: i32,
    generation: i32,
}

fn iser_new(index: i32, generation: i32) -> InnerSceneEntityReference {
    return InnerSceneEntityReference { index: index, generation: generation };
}

fn iser_eq(a: InnerSceneEntityReference, b: InnerSceneEntityReference) -> bool {
    return a.index == b.index && a.generation == b.generation;
}

struct SceneEntityReference {
    inner: InnerSceneEntityReference,
}

fn ser_new(index: i32, generation: i32) -> SceneEntityReference {
    return SceneEntityReference { inner: iser_new(index, generation) };
}

fn ser_inner(s: SceneEntityReference) -> InnerSceneEntityReference { return s.inner; }

// SceneEntityReferences: maps references to actual entities
struct SceneEntityReferences {
    refs: Vec<InnerSceneEntityReference>,
    entities: Vec<i64>,
}

fn sers_new() -> SceneEntityReferences {
    return SceneEntityReferences { refs: Vec::new(), entities: Vec::new() };
}

fn sers_set(sers: SceneEntityReferences, ref_: SceneEntityReference, entity: i64) -> SceneEntityReferences {
    sers.refs.push(ref_.inner);
    sers.entities.push(entity);
    return sers;
}

fn sers_get(sers: SceneEntityReferences, ref_: SceneEntityReference) -> i64 {
    let i: i64 = 0;
    let cnt = len(sers.refs) as i64;
    while i < cnt {
        if iser_eq(sers.refs[i], ref_.inner) { return sers.entities[i]; };
        i = i + 1;
    }
    return -1;
}

fn sers_len(sers: SceneEntityReferences) -> i64 { return len(sers.refs) as i64; }

// TemplateContext: provides access to world resources and entity references during template instantiation
struct TemplateContext {
    references: SceneEntityReferences,
    resource_values: Vec<i32>,
    resource_ids: Vec<i32>,
}

fn tc_new() -> TemplateContext {
    return TemplateContext { references: sers_new(), resource_values: Vec::new(), resource_ids: Vec::new() };
}

fn tc_get_entity(tc: TemplateContext, ref_: SceneEntityReference) -> i64 {
    return sers_get(tc.references, ref_);
}

fn tc_set_entity(tc: TemplateContext, ref_: SceneEntityReference, entity: i64) -> TemplateContext {
    tc.references = sers_set(tc.references, ref_, entity);
    return tc;
}

fn tc_resource(tc: TemplateContext, rid: i32) -> (bool, i32) {
    let i: i64 = 0;
    let cnt = len(tc.resource_ids) as i64;
    while i < cnt {
        if tc.resource_ids[i] == rid { return (true, tc.resource_values[i]); };
        i = i + 1;
    }
    return (false, 0);
}

fn tc_insert_resource(tc: TemplateContext, rid: i32, rval: i32) -> TemplateContext {
    tc.resource_ids.push(rid);
    tc.resource_values.push(rval);
    return tc;
}

fn tc_resource_entity(tc: TemplateContext, rid: i32) -> i64 {
    let r = tc_resource(tc, rid);
    if r.0 { return rid; };
    return -1;
}

// EntityTemplate: enum of reference or fn-based template
const TEMPLATE_REF: i32 = 0;
const TEMPLATE_FN: i32 = 1;

struct EntityTemplate {
    kind: i32,
    ref_index: i32,
    fn_id: i32,
}

fn et_from_reference(ref_index: i32) -> EntityTemplate {
    return EntityTemplate { kind: TEMPLATE_REF, ref_index: ref_index, fn_id: 0 };
}

fn et_from_fn(fn_id: i32) -> EntityTemplate {
    return EntityTemplate { kind: TEMPLATE_FN, ref_index: 0, fn_id: fn_id };
}

fn et_kind(et: EntityTemplate) -> i32 { return et.kind; }
fn et_ref_index(et: EntityTemplate) -> i32 { return et.ref_index; }
fn et_fn_id(et: EntityTemplate) -> i32 { return et.fn_id; }

// FnTemplate: closure-based template
struct FnTemplate {
    fn_id: i32,
}

fn fn_template(fn_id: i32) -> FnTemplate { return FnTemplate { fn_id: fn_id }; }
fn fnt_id(ft: FnTemplate) -> i32 { return ft.fn_id; }

// OptionTemplate: optional template
const OPT_SOME: i32 = 0;
const OPT_NONE: i32 = 1;

struct OptionTemplate {
    kind: i32,
    inner: EntityTemplate,
}

fn ot_some(et: EntityTemplate) -> OptionTemplate { return OptionTemplate { kind: OPT_SOME, inner: et }; }
fn ot_none() -> OptionTemplate { return OptionTemplate { kind: OPT_NONE, inner: et_from_reference(0) }; }
fn ot_is_some(ot: OptionTemplate) -> bool { return ot.kind == OPT_SOME; }
fn ot_is_none(ot: OptionTemplate) -> bool { return ot.kind == OPT_NONE; }

// VecTemplate: collection of templates
struct VecTemplate {
    templates: Vec<EntityTemplate>,
}

fn vt_new() -> VecTemplate { return VecTemplate { templates: Vec::new() }; }
fn vt_push(vt: VecTemplate, et: EntityTemplate) -> VecTemplate { vt.templates.push(et); return vt; }
fn vt_len(vt: VecTemplate) -> i64 { return len(vt.templates) as i64; }
fn vt_get(vt: VecTemplate, idx: i64) -> EntityTemplate { return vt.templates[idx]; }

// === Tests ===

@test "inner scene entity reference eq"() {
    let a = iser_new(1, 2);
    let b = iser_new(1, 2);
    let c = iser_new(1, 3);
    if iser_eq(a, b) != true { panic(30001); };
    if iser_eq(a, c) != false { panic(30002); };
}

@test "scene entity reference inner"() {
    let s = ser_new(5, 10);
    let inner = ser_inner(s);
    if inner.index != 5 { panic(30003); };
    if inner.generation != 10 { panic(30004); };
}

@test "scene entity references set and get"() {
    let sers = sers_set(sers_new(), ser_new(1, 0), 100);
    if sers_get(sers, ser_new(1, 0)) != 100 { panic(30005); };
}

@test "scene entity references get miss"() {
    if sers_get(sers_new(), ser_new(1, 0)) != -1 { panic(30006); };
}

@test "scene entity references len"() {
    let sers = sers_set(sers_set(sers_new(), ser_new(1, 0), 100), ser_new(2, 0), 200);
    if sers_len(sers) != 2 { panic(30007); };
}

@test "template context get_entity"() {
    let tc = tc_set_entity(tc_new(), ser_new(1, 0), 42);
    if tc_get_entity(tc, ser_new(1, 0)) != 42 { panic(30008); };
}

@test "template context get_entity miss"() {
    if tc_get_entity(tc_new(), ser_new(1, 0)) != -1 { panic(30009); };
}

@test "template context resource"() {
    let tc = tc_insert_resource(tc_new(), 5, 99);
    let r = tc_resource(tc, 5);
    if r.0 != true { panic(30010); };
    if r.1 != 99 { panic(30011); };
}

@test "template context resource miss"() {
    let r = tc_resource(tc_new(), 5);
    if r.0 != false { panic(30012); };
}

@test "template context resource_entity"() {
    let tc = tc_insert_resource(tc_new(), 5, 99);
    if tc_resource_entity(tc, 5) != 5 { panic(30013); };
}

@test "template context resource_entity miss"() {
    if tc_resource_entity(tc_new(), 5) != -1 { panic(30014); };
}

@test "entity template from_reference"() {
    let et = et_from_reference(3);
    if et_kind(et) != TEMPLATE_REF { panic(30015); };
    if et_ref_index(et) != 3 { panic(30016); };
}

@test "entity template from_fn"() {
    let et = et_from_fn(7);
    if et_kind(et) != TEMPLATE_FN { panic(30017); };
    if et_fn_id(et) != 7 { panic(30018); };
}

@test "fn template id"() {
    if fnt_id(fn_template(42)) != 42 { panic(30019); };
}

@test "option template some"() {
    let ot = ot_some(et_from_reference(1));
    if ot_is_some(ot) != true { panic(30020); };
    if ot_is_none(ot) != false { panic(30021); };
}

@test "option template none"() {
    let ot = ot_none();
    if ot_is_none(ot) != true { panic(30022); };
    if ot_is_some(ot) != false { panic(30023); };
}

@test "vec template push and len"() {
    let vt = vt_push(vt_push(vt_new(), et_from_reference(1)), et_from_fn(2));
    if vt_len(vt) != 2 { panic(30024); };
}

@test "vec template get"() {
    let vt = vt_push(vt_push(vt_new(), et_from_reference(1)), et_from_fn(2));
    let et = vt_get(vt, 0);
    if et_kind(et) != TEMPLATE_REF { panic(30025); };
    let et2 = vt_get(vt, 1);
    if et_kind(et2) != TEMPLATE_FN { panic(30026); };
}

@test "vec template empty"() {
    if vt_len(vt_new()) != 0 { panic(30027); };
}
