@import "lib/system_input.sla"
@import "lib/command_queue.sla"
@import "lib/observer_storage.sla"

@test "system input unit"() {
    let i = ecs_system_input_unit();
    if ecs_system_input_is_input(i) != false { panic(51001); };
}

@test "system input in"() {
    let i = ecs_system_input_in(42);
    if ecs_system_input_is_input(i) != true { panic(51002); };
    if ecs_system_input_value(i) != 42 { panic(51003); };
}

@test "system input in ref and in mut"() {
    let r = ecs_system_input_in_ref(5);
    if ecs_system_input_kind(r) != ECS_INPUT_IN_REF { panic(51004); };
    let m = ecs_system_input_in_mut(6);
    if ecs_system_input_kind(m) != ECS_INPUT_IN_MUT { panic(51005); };
}

@test "in new and value"() {
    let i = ecs_in_new(99);
    if ecs_in_value(i) != 99 { panic(51006); };
}

@test "in mut set"() {
    let m = ecs_in_mut_new(1);
    let m2 = ecs_in_mut_set(m, 77);
    if ecs_in_mut_value(m2) != 77 { panic(51007); };
}

@test "static system input"() {
    let s = ecs_static_system_input_new(ECS_INPUT_IN, 5);
    if ecs_static_system_input_kind(s) != ECS_INPUT_IN { panic(51008); };
    if ecs_static_system_input_value(s) != 5 { panic(51009); };
}

@test "from input"() {
    let i = ecs_from_input(42);
    if ecs_system_input_kind(i) != ECS_INPUT_IN { panic(51010); };
}

@test "command queue new and push"() {
    let q = ecs_command_queue_new();
    q = ecs_command_queue_push(q, 1);
    q = ecs_command_queue_push(q, 2);
    if ecs_command_queue_len(q) != 2 { panic(51011); };
    if ecs_command_queue_is_empty(q) != false { panic(51012); };
}

@test "command queue apply"() {
    let q = ecs_command_queue_new();
    q = ecs_command_queue_push(q, 1);
    q = ecs_command_queue_push(q, 2);
    let r = ecs_command_queue_apply(q);
    if r.1 != 2 { panic(51013); };
    if ecs_command_queue_is_empty(r.0) != true { panic(51014); };
    if ecs_command_queue_applied_count(r.0) != 2 { panic(51015); };
}

@test "command queue append"() {
    let q = ecs_command_queue_new();
    q = ecs_command_queue_push(q, 1);
    let other = ecs_command_queue_new();
    other = ecs_command_queue_push(other, 2);
    other = ecs_command_queue_push(other, 3);
    q = ecs_command_queue_append(q, other);
    if ecs_command_queue_len(q) != 3 { panic(51016); };
}

@test "command queue silent and silence drop warning"() {
    let q = ecs_command_queue_silent();
    if ecs_command_queue_is_silenced(q) != true { panic(51017); };
    let q2 = ecs_command_queue_new();
    let q3 = ecs_command_queue_silence_drop_warning(q2);
    if ecs_command_queue_is_silenced(q3) != true { panic(51018); };
}

@test "cached observers add global"() {
    let c = ecs_cached_observers_new();
    c = ecs_cached_observers_add_global(c, 100);
    if ecs_cached_observers_global(c) != 1 { panic(51019); };
}

@test "cached observers add component"() {
    let c = ecs_cached_observers_new();
    c = ecs_cached_observers_add_component(c, 5, 100);
    c = ecs_cached_observers_add_component(c, 5, 101);
    c = ecs_cached_observers_add_component(c, 6, 102);
    if ecs_cached_observers_component_count(c) != 2 { panic(51020); };
    let runners = ecs_cached_observers_component_runners(c, 5);
    if len(runners) as i64 != 2 { panic(51021); };
}

@test "cached observers add entity"() {
    let c = ecs_cached_observers_new();
    c = ecs_cached_observers_add_entity(c, 1, 100);
    c = ecs_cached_observers_add_entity(c, 2, 101);
    if ecs_cached_observers_entity_count(c) != 2 { panic(51022); };
    let runners = ecs_cached_observers_entity_runners(c, 1);
    if len(runners) as i64 != 1 { panic(51023); };
}

@test "observers catalog add global"() {
    let s = ecs_observers_catalog_new();
    s = ecs_observers_catalog_add_global(s, 10, 200);
    s = ecs_observers_catalog_add_global(s, 10, 201);
    s = ecs_observers_catalog_add_global(s, 20, 202);
    if ecs_observers_catalog_event_count(s) != 2 { panic(51024); };
}

@test "observer node new and entity"() {
    let n = ecs_observer_node_new(5, 100);
    if ecs_observer_node_entity(n) != 5 { panic(51025); };
    if ecs_observer_node_runner(n) != 100 { panic(51026); };
}

@test "observer node watch entity and component"() {
    let n = ecs_observer_node_new(5, 100);
    n = ecs_observer_node_watch_entity(n, 7);
    n = ecs_observer_node_with_component(n, 3);
    if ecs_observer_node_entity_watch_count(n) != 1 { panic(51027); };
    if ecs_observer_node_component_count(n) != 1 { panic(51028); };
}

@test "observer node run if and error handler"() {
    let n = ecs_observer_node_new(5, 100);
    n = ecs_observer_node_run_if(n, 9);
    n = ecs_observer_node_with_error_handler(n, 2);
    if ecs_observer_node_condition(n) != 9 { panic(51029); };
}

@test "observer descriptor"() {
    let d = ecs_observer_descriptor_new(3);
    let comps: Vec<i32> = Vec::new();
    comps.push(1);
    comps.push(2);
    d = ecs_observer_descriptor_with_components(d, comps);
    if ecs_observer_descriptor_component_count(d) != 2 { panic(51030); };
    if ecs_observer_descriptor_event_kind(d) != 3 { panic(51031); };
}
