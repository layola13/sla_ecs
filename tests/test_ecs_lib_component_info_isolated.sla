@import "lib/component_info.sla"

@test "component id new and index"() {
    let id = ecs_component_id_new(5);
    if ecs_component_id_index(id) != 5 { panic(63001); };
}

@test "component id eq"() {
    if ecs_component_id_eq(ecs_component_id_new(5), ecs_component_id_new(5)) != true { panic(63002); };
    if ecs_component_id_eq(ecs_component_id_new(5), ecs_component_id_new(6)) != false { panic(63003); };
}

@test "component info new and id"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    if ecs_component_id_index(ecs_component_info_id(c)) != 3 { panic(63004); };
    if ecs_component_info_name(c) != 100 { panic(63005); };
}

@test "component info mutable"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    if ecs_component_info_mutable(c) != true { panic(63006); };
    let c2 = ecs_component_info_set_mutable(c, false);
    if ecs_component_info_mutable(c2) != false { panic(63007); };
}

@test "component info type id"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    let t = ecs_component_info_type_id(c);
    if t.0 != false { panic(63008); };
    let c2 = ecs_component_info_set_type_id(c, 42);
    let t2 = ecs_component_info_type_id(c2);
    if t2.0 != true { panic(63009); };
    if t2.1 != 42 { panic(63010); };
}

@test "component info layout"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    let c2 = ecs_component_info_set_layout(c, 16, 8);
    let l = ecs_component_info_layout(c2);
    if l.0 != 16 { panic(63011); };
    if l.1 != 8 { panic(63012); };
}

@test "component info storage type"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    if ecs_component_info_storage_type(c) != ECS_STORAGE_TABLE { panic(63013); };
    let c2 = ecs_component_info_set_storage_type(c, ECS_STORAGE_SPARSE_SET);
    if ecs_component_info_storage_type(c2) != ECS_STORAGE_SPARSE_SET { panic(63014); };
}

@test "component info send and sync"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    if ecs_component_info_is_send_and_sync(c) != true { panic(63015); };
    let c2 = ecs_component_info_set_non_send(c);
    if ecs_component_info_is_send_and_sync(c2) != false { panic(63016); };
}

@test "component info drop"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    if ecs_component_info_drop(c) != false { panic(63017); };
    let c2 = ecs_component_info_set_drop(c);
    if ecs_component_info_drop(c2) != true { panic(63018); };
}

@test "component info clone behavior"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    let c2 = ecs_component_info_set_clone_behavior(c, 1);
    if ecs_component_info_clone_behavior(c2) != 1 { panic(63019); };
}

@test "component info hooks"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    if ecs_component_info_has_hooks(c) != false { panic(63020); };
    let c2 = ecs_component_info_set_has_hooks(c);
    if ecs_component_info_has_hooks(c2) != true { panic(63021); };
}

@test "component info required count"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    let c2 = ecs_component_info_set_required_count(c, 5);
    if ecs_component_info_required_components_count(c2) != 5 { panic(63022); };
}

@test "component info relationship accessor"() {
    let c = ecs_component_info_new(ecs_component_id_new(3), 100);
    let c2 = ecs_component_info_set_relationship_accessor(c, 2);
    if ecs_component_info_relationship_accessor(c2) != 2 { panic(63023); };
}

@test "component descriptor new"() {
    let d = ecs_component_descriptor_new();
    if ecs_component_descriptor_storage_type(d) != ECS_STORAGE_TABLE { panic(63024); };
    if ecs_component_descriptor_is_resource(d) != false { panic(63025); };
}

@test "component descriptor new resource"() {
    let d = ecs_component_descriptor_new_resource();
    if ecs_component_descriptor_is_resource(d) != true { panic(63026); };
    if ecs_component_descriptor_storage_type(d) != ECS_STORAGE_SPARSE_SET { panic(63027); };
}

@test "component descriptor type id"() {
    let d = ecs_component_descriptor_new();
    let d2 = ecs_component_descriptor_set_type_id(d, 99);
    let t = ecs_component_descriptor_type_id(d2);
    if t.0 != true { panic(63028); };
    if t.1 != 99 { panic(63029); };
}

@test "component descriptor layout"() {
    let d = ecs_component_descriptor_new();
    let d2 = ecs_component_descriptor_set_layout(d, 32, 16);
    let l = ecs_component_descriptor_layout(d2);
    if l.0 != 32 { panic(63030); };
    if l.1 != 16 { panic(63031); };
}

@test "component constants"() {
    if ECS_CONST_ADD != 0 { panic(63032); };
    if ECS_CONST_INSERT != 1 { panic(63033); };
    if ECS_CONST_DISCARD != 2 { panic(63034); };
    if ECS_CONST_REMOVE != 3 { panic(63035); };
    if ECS_CONST_DESPAWN != 4 { panic(63036); };
    if ECS_CONST_IS_RESOURCE != 5 { panic(63037); };
}
