@import "lib/unique_slice.sla"

// Isolated tests for lib/unique_slice.sla — UniqueEntityEquivalentSlice
// Bevy reference: bevy_ecs/src/entity/unique_slice.rs

fn make_slice_3() -> EcsUniqueEntitySlice {
    let items = Vec::new();
    items.push(30);
    items.push(10);
    items.push(20);
    return ecs_unique_slice_new(items);
}

@test "unique_slice_new_empty"() {
    let s = ecs_unique_slice_empty();
    if ecs_unique_slice_len(s) != 0 { panic(82200); };
    if ecs_unique_slice_is_empty(s) != true { panic(82201); };
}

@test "unique_slice_new_with_items"() {
    let s = make_slice_3();
    if ecs_unique_slice_len(s) != 3 { panic(82202); };
}

@test "unique_slice_get"() {
    let s = make_slice_3();
    let g0 = ecs_unique_slice_get(s, 0);
    if g0.0 != true { panic(82203); };
    if g0.1 != 30 { panic(82204); };
    let g2 = ecs_unique_slice_get(s, 2);
    if g2.0 != true { panic(82205); };
    if g2.1 != 20 { panic(82206); };
    let g3 = ecs_unique_slice_get(s, 3);
    if g3.0 != false { panic(82207); };
}

@test "unique_slice_first_last"() {
    let s = make_slice_3();
    let f = ecs_unique_slice_first(s);
    if f.0 != true { panic(82208); };
    if f.1 != 30 { panic(82209); };
    let l = ecs_unique_slice_last(s);
    if l.0 != true { panic(82210); };
    if l.1 != 20 { panic(82211); };
}

@test "unique_slice_first_empty"() {
    let s = ecs_unique_slice_empty();
    let f = ecs_unique_slice_first(s);
    if f.0 != false { panic(82212); };
    let l = ecs_unique_slice_last(s);
    if l.0 != false { panic(82213); };
}

@test "unique_slice_contains"() {
    let s = make_slice_3();
    if ecs_unique_slice_contains(s, 10) != true { panic(82214); };
    if ecs_unique_slice_contains(s, 20) != true { panic(82215); };
    if ecs_unique_slice_contains(s, 30) != true { panic(82216); };
    if ecs_unique_slice_contains(s, 40) != false { panic(82217); };
}

@test "unique_slice_index_of"() {
    let s = make_slice_3();
    if ecs_unique_slice_index_of(s, 30) != 0 { panic(82218); };
    if ecs_unique_slice_index_of(s, 10) != 1 { panic(82219); };
    if ecs_unique_slice_index_of(s, 20) != 2 { panic(82220); };
    if ecs_unique_slice_index_of(s, 99) != -1 { panic(82221); };
}

@test "unique_slice_rindex_of"() {
    let s = make_slice_3();
    if ecs_unique_slice_rindex_of(s, 20) != 2 { panic(82222); };
    if ecs_unique_slice_rindex_of(s, 30) != 0 { panic(82223); };
    if ecs_unique_slice_rindex_of(s, 99) != -1 { panic(82224); };
}

@test "unique_slice_swap"() {
    let s = make_slice_3();
    let s2 = ecs_unique_slice_swap(s, 0, 2);
    let g0 = ecs_unique_slice_get(s2, 0);
    if g0.1 != 20 { panic(82225); };
    let g2 = ecs_unique_slice_get(s2, 2);
    if g2.1 != 30 { panic(82226); };
}

@test "unique_slice_swap_out_of_range"() {
    let s = make_slice_3();
    let s2 = ecs_unique_slice_swap(s, 0, 99);
    let g0 = ecs_unique_slice_get(s2, 0);
    if g0.1 != 30 { panic(82227); };
}

@test "unique_slice_reverse"() {
    let s = make_slice_3();
    let s2 = ecs_unique_slice_reverse(s);
    let g0 = ecs_unique_slice_get(s2, 0);
    if g0.1 != 20 { panic(82228); };
    let g1 = ecs_unique_slice_get(s2, 1);
    if g1.1 != 10 { panic(82229); };
    let g2 = ecs_unique_slice_get(s2, 2);
    if g2.1 != 30 { panic(82230); };
}

@test "unique_slice_rotate_left"() {
    let s = make_slice_3();
    let s2 = ecs_unique_slice_rotate_left(s, 1);
    let g0 = ecs_unique_slice_get(s2, 0);
    if g0.1 != 10 { panic(82231); };
    let g1 = ecs_unique_slice_get(s2, 1);
    if g1.1 != 20 { panic(82232); };
    let g2 = ecs_unique_slice_get(s2, 2);
    if g2.1 != 30 { panic(82233); };
}

@test "unique_slice_rotate_right"() {
    let s = make_slice_3();
    let s2 = ecs_unique_slice_rotate_right(s, 1);
    let g0 = ecs_unique_slice_get(s2, 0);
    if g0.1 != 20 { panic(82234); };
    let g1 = ecs_unique_slice_get(s2, 1);
    if g1.1 != 30 { panic(82235); };
    let g2 = ecs_unique_slice_get(s2, 2);
    if g2.1 != 10 { panic(82236); };
}

@test "unique_slice_rotate_zero"() {
    let s = make_slice_3();
    let s2 = ecs_unique_slice_rotate_left(s, 0);
    let g0 = ecs_unique_slice_get(s2, 0);
    if g0.1 != 30 { panic(82237); };
}

@test "unique_slice_sort"() {
    let s = make_slice_3();
    let s2 = ecs_unique_slice_sort(s);
    let g0 = ecs_unique_slice_get(s2, 0);
    if g0.1 != 10 { panic(82238); };
    let g1 = ecs_unique_slice_get(s2, 1);
    if g1.1 != 20 { panic(82239); };
    let g2 = ecs_unique_slice_get(s2, 2);
    if g2.1 != 30 { panic(82240); };
}

@test "unique_slice_get_sub_slice"() {
    let s = make_slice_3();
    let res = ecs_unique_slice_get_sub_slice(s, 1, 3);
    if res.0 != true { panic(82241); };
    let sub = res.1;
    if ecs_unique_slice_len(sub) != 2 { panic(82242); };
    let g0 = ecs_unique_slice_get(sub, 0);
    if g0.1 != 10 { panic(82243); };
    let g1 = ecs_unique_slice_get(sub, 1);
    if g1.1 != 20 { panic(82244); };
}

@test "unique_slice_starts_with"() {
    let s = make_slice_3();
    let prefix = Vec::new();
    prefix.push(30);
    prefix.push(10);
    if ecs_unique_slice_starts_with(s, prefix) != true { panic(82245); };
    let prefix2 = Vec::new();
    prefix2.push(30);
    prefix2.push(20);
    if ecs_unique_slice_starts_with(s, prefix2) != false { panic(82246); };
}

@test "unique_slice_ends_with"() {
    let s = make_slice_3();
    let suffix = Vec::new();
    suffix.push(20);
    if ecs_unique_slice_ends_with(s, suffix) != true { panic(82247); };
    let suffix2 = Vec::new();
    suffix2.push(30);
    if ecs_unique_slice_ends_with(s, suffix2) != false { panic(82248); };
}

@test "unique_slice_to_vec"() {
    let s = make_slice_3();
    let v = ecs_unique_slice_to_vec(s);
    if len(v) != 3 { panic(82249); };
    if v[0] != 30 { panic(82250); };
    if v[1] != 10 { panic(82251); };
    if v[2] != 20 { panic(82252); };
}

@test "unique_slice_eq"() {
    let s1 = make_slice_3();
    let s2 = make_slice_3();
    if ecs_unique_slice_eq(s1, s2) != true { panic(82253); };
    let s3 = ecs_unique_slice_empty();
    if ecs_unique_slice_eq(s1, s3) != false { panic(82254); };
}

@test "unique_slice_count_greater_than"() {
    let s = make_slice_3();
    if ecs_unique_slice_count_greater_than(s, 15) != 2 { panic(82255); };
    if ecs_unique_slice_count_greater_than(s, 0) != 3 { panic(82256); };
}

@test "unique_slice_min_max"() {
    let s = make_slice_3();
    let mn = ecs_unique_slice_min(s);
    if mn.0 != true { panic(82257); };
    if mn.1 != 10 { panic(82258); };
    let mx = ecs_unique_slice_max(s);
    if mx.0 != true { panic(82259); };
    if mx.1 != 30 { panic(82260); };
}

@test "unique_slice_min_empty"() {
    let s = ecs_unique_slice_empty();
    let mn = ecs_unique_slice_min(s);
    if mn.0 != false { panic(82261); };
    let mx = ecs_unique_slice_max(s);
    if mx.0 != false { panic(82262); };
}

@test "unique_slice_into_inner"() {
    let s = make_slice_3();
    let inner = ecs_unique_slice_into_inner(s);
    if len(inner) != 3 { panic(82263); };
    if inner[0] != 30 { panic(82264); };
}
