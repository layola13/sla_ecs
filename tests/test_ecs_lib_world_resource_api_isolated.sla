@import "lib/world_resource_api.sla"

// === Basic ===

@test "resource new empty"() {
    let w = ecs_world_resource_new();
    if ecs_world_resource_count(w) != 0 { panic(73001); };
    if ecs_world_resource_current_tick(w) != 0 { panic(73002); };
}

@test "resource tick"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_tick(w);
    if ecs_world_resource_current_tick(w2) != 1 { panic(73010); };
    let w3 = ecs_world_resource_tick(w2);
    if ecs_world_resource_current_tick(w3) != 2 { panic(73011); };
}

// === insert_resource ===

@test "resource insert new"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 100, 1000);
    if ecs_world_resource_count(w2) != 1 { panic(73020); };
    if ecs_world_resource_contains(w2, 100) != true { panic(73021); };
}

@test "resource insert overwrite"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 100, 500);
    let w3 = ecs_world_resource_insert(w2, 100, 600);
    if ecs_world_resource_count(w3) != 1 { panic(73030); };
    let g = ecs_world_resource_get(w3, 100);
    if g.1 != 600 { panic(73031); };
}

// === init_resource ===

@test "resource init new"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_init(w, 200);
    let g = ecs_world_resource_get(w2, 200);
    if g.0 != true { panic(73040); };
    if g.1 != 0 { panic(73041); };
}

@test "resource init existing noop"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 200, 999);
    let w3 = ecs_world_resource_init(w2, 200);
    let g = ecs_world_resource_get(w3, 200);
    if g.1 != 999 { panic(73050); };
}

// === get_resource_or_insert_with ===

@test "resource get_or_insert_with new"() {
    let w = ecs_world_resource_new();
    let result = ecs_world_resource_get_or_insert_with(w, 100, 42);
    if result.1 != 42 { panic(73060); };
    let g = ecs_world_resource_get(result.0, 100);
    if g.1 != 42 { panic(73061); };
}

@test "resource get_or_insert_with existing"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 100, 50);
    let result = ecs_world_resource_get_or_insert_with(w2, 100, 99);
    if result.1 != 50 { panic(73070); };
}

// === remove_resource ===

@test "resource remove"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 100, 500);
    let w3 = ecs_world_resource_insert(w2, 200, 600);
    let result = ecs_world_resource_remove(w3, 100);
    if result.1 != true { panic(73080); };
    if result.2 != 500 { panic(73081); };
    if ecs_world_resource_contains(result.0, 100) != false { panic(73082); };
    if ecs_world_resource_contains(result.0, 200) != true { panic(73083); };
}

@test "resource remove nonexistent"() {
    let w = ecs_world_resource_new();
    let result = ecs_world_resource_remove(w, 99);
    if result.1 != false { panic(73090); };
}

// === contains & get ===

@test "resource contains"() {
    let w = ecs_world_resource_new();
    if ecs_world_resource_contains(w, 100) != false { panic(73100); };
    let w2 = ecs_world_resource_insert(w, 100, 500);
    if ecs_world_resource_contains(w2, 100) != true { panic(73101); };
}

@test "resource get"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 100, 500);
    let g = ecs_world_resource_get(w2, 100);
    if g.0 != true { panic(73110); };
    if g.1 != 500 { panic(73111); };
    let g2 = ecs_world_resource_get(w2, 99);
    if g2.0 != false { panic(73112); };
}

@test "resource value"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 100, 777);
    if ecs_world_resource_value(w2, 100) != 777 { panic(73120); };
    if ecs_world_resource_value(w2, 99) != 0 { panic(73121); };
}

// === Change detection ===

@test "resource is_added"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_tick(w);
    let w3 = ecs_world_resource_insert(w2, 100, 500);
    // Added at tick 1, so is_added since tick 0
    if ecs_world_resource_is_added(w3, 100, 0) != true { panic(73130); };
    // Not added since tick 1
    if ecs_world_resource_is_added(w3, 100, 1) != false { panic(73131); };
}

@test "resource is_changed"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_tick(w);
    let w3 = ecs_world_resource_insert(w2, 100, 500);
    let w4 = ecs_world_resource_tick(w3);
    let w5 = ecs_world_resource_insert(w4, 100, 600);
    // Changed at tick 2
    if ecs_world_resource_is_changed(w5, 100, 1) != true { panic(73140); };
    if ecs_world_resource_is_changed(w5, 100, 2) != false { panic(73141); };
}

@test "resource get_change_ticks"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_tick(w);
    let w3 = ecs_world_resource_insert(w2, 100, 500);
    let t = ecs_world_resource_get_change_ticks(w3, 100);
    if t.0 != true { panic(73150); };
    if t.1 != 1 { panic(73151); };
    if t.2 != 1 { panic(73152); };
}

@test "resource get_change_ticks nonexistent"() {
    let w = ecs_world_resource_new();
    let t = ecs_world_resource_get_change_ticks(w, 99);
    if t.0 != false { panic(73160); };
}

// === modify_resource ===

@test "resource modify"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 100, 50);
    let result = ecs_world_resource_modify(w2, 100, 10);
    if result.1 != true { panic(73170); };
    if result.2 != 60 { panic(73171); };
    let g = ecs_world_resource_get(result.0, 100);
    if g.1 != 60 { panic(73172); };
}

@test "resource modify nonexistent"() {
    let w = ecs_world_resource_new();
    let result = ecs_world_resource_modify(w, 99, 10);
    if result.1 != false { panic(73180); };
}

// === Non-send resources ===

@test "non_send init"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_init_non_send(w, 300);
    if ecs_world_resource_contains_non_send(w2, 300) != true { panic(73190); };
    let g = ecs_world_resource_get_non_send(w2, 300);
    if g.1 != 0 { panic(73191); };
}

@test "non_send insert"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert_non_send(w, 300, 999);
    let g = ecs_world_resource_get_non_send(w2, 300);
    if g.1 != 999 { panic(73200); };
}

@test "non_send insert overwrite"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert_non_send(w, 300, 999);
    let w3 = ecs_world_resource_insert_non_send(w2, 300, 888);
    let g = ecs_world_resource_get_non_send(w3, 300);
    if g.1 != 888 { panic(73210); };
    if ecs_world_resource_non_send_count(w3) != 1 { panic(73211); };
}

@test "non_send remove"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert_non_send(w, 300, 999);
    let result = ecs_world_resource_remove_non_send(w2, 300);
    if result.1 != true { panic(73220); };
    if ecs_world_resource_contains_non_send(result.0, 300) != false { panic(73221); };
}

@test "non_send remove nonexistent"() {
    let w = ecs_world_resource_new();
    let result = ecs_world_resource_remove_non_send(w, 99);
    if result.1 != false { panic(73230); };
}

@test "non_send contains"() {
    let w = ecs_world_resource_new();
    if ecs_world_resource_contains_non_send(w, 300) != false { panic(73240); };
    let w2 = ecs_world_resource_insert_non_send(w, 300, 999);
    if ecs_world_resource_contains_non_send(w2, 300) != true { panic(73241); };
}

@test "non_send count"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert_non_send(w, 1, 10);
    let w3 = ecs_world_resource_insert_non_send(w2, 2, 20);
    if ecs_world_resource_non_send_count(w3) != 2 { panic(73250); };
}

// === resource_scope ===

@test "resource scope"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 100, 500);
    let result = ecs_world_resource_scope(w2, 100);
    if result.1 != true { panic(73260); };
    if result.2 != 500 { panic(73261); };
    if ecs_world_resource_contains(result.0, 100) != false { panic(73262); };
}

// === Multiple resources ===

@test "resource multiple"() {
    let w = ecs_world_resource_new();
    let w2 = ecs_world_resource_insert(w, 1, 10);
    let w3 = ecs_world_resource_insert(w2, 2, 20);
    let w4 = ecs_world_resource_insert(w3, 3, 30);
    if ecs_world_resource_count(w4) != 3 { panic(73270); };
    if ecs_world_resource_value(w4, 1) != 10 { panic(73271); };
    if ecs_world_resource_value(w4, 2) != 20 { panic(73272); };
    if ecs_world_resource_value(w4, 3) != 30 { panic(73273); };
}
