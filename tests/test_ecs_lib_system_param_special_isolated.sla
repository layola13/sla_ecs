// === RemovedComponents ===

@test "removed components new"() {
    let r = ecs_removed_components_new();
    if ecs_removed_components_len(r) != 0 { panic(78100); };
    if ecs_removed_components_is_empty(r) != true { panic(78101); };
}

@test "removed components add"() {
    let r = ecs_removed_components_new();
    let r2 = ecs_removed_components_add(r, 1);
    let r3 = ecs_removed_components_add(r2, 2);
    if ecs_removed_components_len(r3) != 2 { panic(78110); };
    if ecs_removed_components_is_empty(r3) != false { panic(78111); };
}

@test "removed components next"() {
    let r = ecs_removed_components_new();
    let r2 = ecs_removed_components_add(r, 10);
    let r3 = ecs_removed_components_add(r2, 20);
    let n1 = ecs_removed_components_next(r3);
    if n1.1 != true { panic(78120); };
    if n1.2 != 10 { panic(78121); };
    let n2 = ecs_removed_components_next(n1.0);
    if n2.1 != true { panic(78122); };
    if n2.2 != 20 { panic(78123); };
    let n3 = ecs_removed_components_next(n2.0);
    if n3.1 != false { panic(78124); };
}

@test "removed components is_empty after read"() {
    let r = ecs_removed_components_new();
    let r2 = ecs_removed_components_add(r, 1);
    let n = ecs_removed_components_next(r2);
    if ecs_removed_components_is_empty(n.0) != true { panic(78130); };
}

@test "removed components clear"() {
    let r = ecs_removed_components_new();
    let r2 = ecs_removed_components_add(r, 1);
    let r3 = ecs_removed_components_add(r2, 2);
    let r4 = ecs_removed_components_clear(r3);
    if ecs_removed_components_len(r4) != 0 { panic(78140); };
    if ecs_removed_components_is_empty(r4) != true { panic(78141); };
}

// === RunSystemOnce ===

@test "run system once ok"() {
    let r = ecs_run_system_once_result_ok(42);
    if ecs_run_system_once_is_ok(r) != true { panic(78150); };
    if ecs_run_system_once_output(r) != 42 { panic(78151); };
}

@test "run system once err"() {
    let r = ecs_run_system_once_result_err();
    if ecs_run_system_once_is_ok(r) != false { panic(78160); };
}

// === SystemParamValidationError ===

@test "param validation ok"() {
    let e = ecs_system_param_validation_ok();
    if ecs_system_param_validation_is_ok(e) != true { panic(78170); };
    if ecs_system_param_validation_is_skipped(e) != false { panic(78171); };
}

@test "param validation skipped"() {
    let e = ecs_system_param_validation_skipped();
    if ecs_system_param_validation_is_skipped(e) != true { panic(78180); };
    if ecs_system_param_validation_is_ok(e) != false { panic(78181); };
}
