@import "lib/system_param_special.sla"

// === SystemBuffer ===

@test "system buffer new"() {
    let b = ecs_system_buffer_new();
    if ecs_system_buffer_len(b) != 0 { panic(78001); };
    if ecs_system_buffer_is_applied(b) != false { panic(78002); };
}

@test "system buffer push"() {
    let b = ecs_system_buffer_new();
    let b2 = ecs_system_buffer_push(b, 10);
    let b3 = ecs_system_buffer_push(b2, 20);
    if ecs_system_buffer_len(b3) != 2 { panic(78010); };
    if ecs_system_buffer_get(b3, 0) != 10 { panic(78011); };
    if ecs_system_buffer_get(b3, 1) != 20 { panic(78012); };
}

@test "system buffer apply"() {
    let b = ecs_system_buffer_new();
    let b2 = ecs_system_buffer_apply(b);
    if ecs_system_buffer_is_applied(b2) != true { panic(78020); };
}

@test "system buffer queue"() {
    let b = ecs_system_buffer_new();
    let b2 = ecs_system_buffer_queue(b, 42);
    if ecs_system_buffer_len(b2) != 1 { panic(78030); };
}

@test "system buffer clear"() {
    let b = ecs_system_buffer_new();
    let b2 = ecs_system_buffer_push(b, 10);
    let b3 = ecs_system_buffer_clear(b2);
    if ecs_system_buffer_len(b3) != 0 { panic(78040); };
}

// === Deferred ===

@test "deferred new"() {
    let d = ecs_deferred_new();
    if ecs_deferred_len(d) != 0 { panic(78050); };
    if ecs_deferred_has_deferred(d) != true { panic(78051); };
}

@test "deferred push"() {
    let d = ecs_deferred_new();
    let d2 = ecs_deferred_push(d, 5);
    let d3 = ecs_deferred_push(d2, 10);
    if ecs_deferred_len(d3) != 2 { panic(78060); };
}

@test "deferred apply"() {
    let d = ecs_deferred_new();
    let d2 = ecs_deferred_push(d, 5);
    let d3 = ecs_deferred_apply(d2);
    if ecs_deferred_is_applied(d3) != true { panic(78070); };
}

@test "deferred reborrow"() {
    let d = ecs_deferred_new();
    let rb = ecs_deferred_reborrow(d);
    if ecs_deferred_has_deferred(rb) != true { panic(78080); };
}

@test "deferred clear"() {
    let d = ecs_deferred_new();
    let d2 = ecs_deferred_push(d, 5);
    let d3 = ecs_deferred_clear(d2);
    if ecs_deferred_len(d3) != 0 { panic(78090); };
}

