@import "lib/reflect_component.sla"
@import "lib/reflect_bundle.sla"
@import "lib/reflect_misc.sla"
@import "lib/world_reflect.sla"

@test "reflect component insert and get"() {
    let r = ecs_reflect_component_new(5);
    r = ecs_reflect_component_insert(r, 1, 100);
    r = ecs_reflect_component_insert(r, 2, 200);
    let g = ecs_reflect_component_reflect(r, 1);
    if g.0 != true { panic(56001); };
    if g.1 != 100 { panic(56002); };
}

@test "reflect component contains"() {
    let r = ecs_reflect_component_new(5);
    r = ecs_reflect_component_insert(r, 1, 100);
    if ecs_reflect_component_contains(r, 1) != true { panic(56003); };
    if ecs_reflect_component_contains(r, 2) != false { panic(56004); };
}

@test "reflect component remove"() {
    let r = ecs_reflect_component_new(5);
    r = ecs_reflect_component_insert(r, 1, 100);
    let r2 = ecs_reflect_component_remove(r, 1);
    if r2.1 != true { panic(56005); };
    if ecs_reflect_component_contains(r2.0, 1) != false { panic(56006); };
}

@test "reflect component take"() {
    let r = ecs_reflect_component_new(5);
    r = ecs_reflect_component_insert(r, 1, 100);
    let t = ecs_reflect_component_take(r, 1);
    if t.1 != true { panic(56007); };
    if t.2 != 100 { panic(56008); };
}

@test "reflect component copy"() {
    let r = ecs_reflect_component_new(5);
    r = ecs_reflect_component_insert(r, 1, 100);
    r = ecs_reflect_component_copy(r, 1, 2);
    let g = ecs_reflect_component_reflect(r, 2);
    if g.1 != 100 { panic(56009); };
}

@test "reflect bundle add component"() {
    let b = ecs_reflect_bundle_new(3);
    b = ecs_reflect_bundle_add_component(b, 1);
    b = ecs_reflect_bundle_add_component(b, 2);
    if ecs_reflect_bundle_component_count(b) != 2 { panic(56010); };
    if ecs_reflect_bundle_component_at(b, 1) != 2 { panic(56011); };
}

@test "reflect bundle insert"() {
    let b = ecs_reflect_bundle_new(3);
    b = ecs_reflect_bundle_add_component(b, 1);
    b = ecs_reflect_bundle_add_component(b, 2);
    if ecs_reflect_bundle_insert(b, 5) != 2 { panic(56012); };
}

@test "reflect event trigger"() {
    let e = ecs_reflect_event_new(7);
    e = ecs_reflect_event_trigger(e);
    e = ecs_reflect_event_trigger(e);
    if ecs_reflect_event_trigger_count(e) != 2 { panic(56013); };
}

@test "reflect message send"() {
    let m = ecs_reflect_message_new(9);
    m = ecs_reflect_message_send(m);
    if ecs_reflect_message_sent_count(m) != 1 { panic(56014); };
}

@test "from world"() {
    let f = ecs_from_world_from_world(1, 42);
    if ecs_from_world_value(f) != 42 { panic(56015); };
    if ecs_from_world_world_id(f) != 1 { panic(56016); };
}

@test "reflect map entities remap"() {
    let m = ecs_reflect_map_entities_new();
    m = ecs_reflect_map_entities_remap(m, 3);
    if ecs_reflect_map_entities_count(m) != 3 { panic(56017); };
}

@test "reflect entity commands push"() {
    let c = ecs_reflect_entity_commands_new();
    c = ecs_reflect_entity_commands_push(c, 1);
    c = ecs_reflect_entity_commands_push(c, 2);
    if ecs_reflect_entity_commands_count(c) != 2 { panic(56018); };
    if ecs_reflect_entity_commands_at(c, 0) != 1 { panic(56019); };
}

@test "reflect world register"() {
    let w = ecs_reflect_world_new(1);
    w = ecs_reflect_world_register_component(w);
    w = ecs_reflect_world_register_resource(w);
    w = ecs_reflect_world_register_resource(w);
    if ecs_reflect_world_component_count(w) != 1 { panic(56020); };
    if ecs_reflect_world_resource_count(w) != 2 { panic(56021); };
}

@test "short type name"() {
    if ecs_short_type_name(42) != 42 { panic(56022); };
}
