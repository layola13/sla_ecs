@import "lib/non_send_storage.sla"

// Isolated tests for lib/non_send_storage.sla — NonSendData + NonSends
// Bevy reference: bevy_ecs/src/storage/non_send.rs

@test "non_send_data_new"() {
    let d = ecs_non_send_data_new(5);
    if ecs_non_send_data_component_id(d) != 5 { panic(83500); };
    if ecs_non_send_data_is_present(d) != false { panic(83501); };
}

@test "non_send_data_insert"() {
    let d = ecs_non_send_data_new(5);
    let d2 = ecs_non_send_data_insert(d, 42, 10);
    if ecs_non_send_data_is_present(d2) != true { panic(83502); };
    let g = ecs_non_send_data_get_data(d2);
    if g.0 != true { panic(83503); };
    if g.1 != 42 { panic(83504); };
}

@test "non_send_data_remove"() {
    let d = ecs_non_send_data_new(5);
    let d2 = ecs_non_send_data_insert(d, 42, 10);
    let d3 = ecs_non_send_data_remove(d2);
    if ecs_non_send_data_is_present(d3) != false { panic(83505); };
    let g = ecs_non_send_data_get_data(d3);
    if g.0 != false { panic(83506); };
}

@test "non_send_data_get_ticks"() {
    let d = ecs_non_send_data_new(5);
    let d2 = ecs_non_send_data_insert(d, 42, 10);
    let t = ecs_non_send_data_get_ticks(d2);
    if t.0 != true { panic(83507); };
    if t.1 != 10 { panic(83508); };
    if t.2 != 10 { panic(83509); };
}

@test "non_send_data_get_ticks_not_present"() {
    let d = ecs_non_send_data_new(5);
    let t = ecs_non_send_data_get_ticks(d);
    if t.0 != false { panic(83510); };
}

@test "non_send_data_get_added_tick"() {
    let d = ecs_non_send_data_new(5);
    let d2 = ecs_non_send_data_insert(d, 42, 10);
    let at = ecs_non_send_data_get_added_tick(d2);
    if at.0 != true { panic(83511); };
    if at.1 != 10 { panic(83512); };
}

@test "non_send_data_get_changed_tick"() {
    let d = ecs_non_send_data_new(5);
    let d2 = ecs_non_send_data_insert(d, 42, 10);
    let d3 = ecs_non_send_data_set_changed(d2, 20, 99);
    let ct = ecs_non_send_data_get_changed_tick(d3);
    if ct.0 != true { panic(83513); };
    if ct.1 != 20 { panic(83514); };
}

@test "non_send_data_get_changed_by"() {
    let d = ecs_non_send_data_new(5);
    let d2 = ecs_non_send_data_insert(d, 42, 10);
    let d3 = ecs_non_send_data_set_changed(d2, 20, 99);
    let cb = ecs_non_send_data_get_changed_by(d3);
    if cb.0 != true { panic(83515); };
    if cb.1 != 99 { panic(83516); };
}

@test "non_sends_new"() {
    let s = ecs_non_sends_new();
    if ecs_non_sends_len(s) != 0 { panic(83517); };
    if ecs_non_sends_is_empty(s) != true { panic(83518); };
}

@test "non_sends_insert"() {
    let s = ecs_non_sends_new();
    let s2 = ecs_non_sends_insert(s, 5, 42, 10);
    if ecs_non_sends_len(s2) != 1 { panic(83519); };
    if ecs_non_sends_contains(s2, 5) != true { panic(83520); };
}

@test "non_sends_insert_multiple"() {
    let s = ecs_non_sends_new();
    let s2 = ecs_non_sends_insert(s, 5, 42, 10);
    let s3 = ecs_non_sends_insert(s2, 6, 99, 20);
    if ecs_non_sends_len(s3) != 2 { panic(83521); };
}

@test "non_sends_insert_existing"() {
    let s = ecs_non_sends_new();
    let s2 = ecs_non_sends_insert(s, 5, 42, 10);
    let s3 = ecs_non_sends_insert(s2, 5, 99, 20);
    if ecs_non_sends_len(s3) != 1 { panic(83522); };
    let gr = ecs_non_sends_get(s3, 5);
    if gr.0 != true { panic(83523); };
    let g = ecs_non_send_data_get_data(gr.1);
    if g.1 != 99 { panic(83524); };
}

@test "non_sends_get"() {
    let s = ecs_non_sends_new();
    let s2 = ecs_non_sends_insert(s, 5, 42, 10);
    let gr = ecs_non_sends_get(s2, 5);
    if gr.0 != true { panic(83525); };
    if ecs_non_send_data_is_present(gr.1) != true { panic(83526); };
}

@test "non_sends_get_not_found"() {
    let s = ecs_non_sends_new();
    let gr = ecs_non_sends_get(s, 99);
    if gr.0 != false { panic(83527); };
}

@test "non_sends_remove"() {
    let s = ecs_non_sends_new();
    let s2 = ecs_non_sends_insert(s, 5, 42, 10);
    let r = ecs_non_sends_remove(s2, 5);
    if r.1 != true { panic(83528); };
    if ecs_non_sends_contains(r.0, 5) != false { panic(83529); };
}

@test "non_sends_remove_not_found"() {
    let s = ecs_non_sends_new();
    let r = ecs_non_sends_remove(s, 99);
    if r.1 != false { panic(83530); };
}

@test "non_sends_clear"() {
    let s = ecs_non_sends_new();
    let s2 = ecs_non_sends_insert(s, 5, 42, 10);
    let s3 = ecs_non_sends_insert(s2, 6, 99, 20);
    let s4 = ecs_non_sends_clear(s3);
    if ecs_non_sends_len(s4) != 0 { panic(83531); };
    if ecs_non_sends_is_empty(s4) != true { panic(83532); };
}

@test "non_sends_count_present"() {
    let s = ecs_non_sends_new();
    let s2 = ecs_non_sends_insert(s, 5, 42, 10);
    let s3 = ecs_non_sends_insert(s2, 6, 99, 20);
    if ecs_non_sends_count_present(s3) != 2 { panic(83533); };
    let s4 = ecs_non_sends_remove(s3, 5);
    if ecs_non_sends_count_present(s4.0) != 1 { panic(83534); };
}

@test "non_sends_contains_false"() {
    let s = ecs_non_sends_new();
    if ecs_non_sends_contains(s, 5) != false { panic(83535); };
}
