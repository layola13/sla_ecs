// Isolated test: verifies the standalone lib modules (error, stepping, query_access,
// query_filters, batching, template) work correctly when imported.
@import "lib/error.sla"
@import "lib/stepping.sla"
@import "lib/query_access.sla"
@import "lib/query_filters.sla"
@import "lib/batching.sla"
@import "lib/template.sla"

@test "lib error: bevy error severity"() {
    let e = ecs_bevy_error_warn(42);
    if ecs_bevy_error_severity(e) != ECS_SEVERITY_WARNING { panic(31001); };
    if ecs_bevy_error_message(e) != 42 { panic(31002); };
}

@test "lib error: with_severity"() {
    let e = ecs_bevy_error_with_severity(ecs_bevy_error_ignore(1), ECS_SEVERITY_ERROR);
    if ecs_bevy_error_severity(e) != ECS_SEVERITY_ERROR { panic(31003); };
}

@test "lib error: with_context"() {
    let e = ecs_bevy_error_with_context(ecs_bevy_error_warn(1), 99);
    if ecs_bevy_error_context_len(e) != 1 { panic(31004); };
}

@test "lib error: error context system"() {
    let ctx = ecs_error_context_system(100, 5);
    if ecs_error_context_kind(ctx) != ECS_ERR_CTX_SYSTEM { panic(31005); };
    if ecs_error_context_name(ctx) != 100 { panic(31006); };
}

@test "lib error: error context command"() {
    let ctx = ecs_error_context_command(400);
    if ecs_error_context_is_command(ctx) != true { panic(31007); };
}

@test "lib error: command result ok"() {
    let r = ecs_command_result_ok();
    if ecs_command_result_is_ok(r) != true { panic(31008); };
    let res = ecs_command_result_to_err(r);
    if res.0 != false { panic(31009); };
}

@test "lib error: command result err"() {
    let r = ecs_command_result_err(ecs_bevy_error_warn(1));
    let res = ecs_command_result_to_err(r);
    if res.0 != true { panic(31010); };
}

@test "lib error: fallback handler default"() {
    let feh = ecs_fallback_error_handler_default();
    if ecs_fallback_error_handler_handler(feh) != ECS_HANDLER_PANIC { panic(31011); };
}

@test "lib error: severity to handler"() {
    if ecs_severity_to_handler(ECS_SEVERITY_PANIC) != ECS_HANDLER_PANIC { panic(31012); };
    if ecs_severity_to_handler(ECS_SEVERITY_IGNORE) != ECS_HANDLER_IGNORE { panic(31013); };
}

@test "lib stepping: enable disable"() {
    let s = ecs_stepping_enable(ecs_stepping_new());
    if ecs_stepping_is_enabled(s) != true { panic(31014); };
    let s2 = ecs_stepping_disable(s);
    if ecs_stepping_is_enabled(s2) != false { panic(31015); };
}

@test "lib stepping: add remove schedule"() {
    let s = ecs_stepping_add_schedule(ecs_stepping_new(), 100);
    if ecs_stepping_schedule_count(s) != 1 { panic(31016); };
    let s2 = ecs_stepping_remove_schedule(s, 100);
    if ecs_stepping_schedule_count(s2) != 0 { panic(31017); };
}

@test "lib stepping: step and continue"() {
    let s = ecs_stepping_step_frame(ecs_stepping_step_frame(ecs_stepping_new()));
    if ecs_stepping_step_count(s) != 2 { panic(31018); };
}

@test "lib stepping: breakpoint"() {
    let s = ecs_stepping_set_breakpoint(ecs_stepping_new(), 42);
    if ecs_stepping_has_breakpoint(s, 42) != true { panic(31019); };
    let s2 = ecs_stepping_clear_breakpoint(s, 42);
    if ecs_stepping_has_breakpoint(s2, 42) != false { panic(31020); };
}

@test "lib stepping: always/never run"() {
    let s = ecs_stepping_always_run_node(ecs_stepping_new(), 7);
    if ecs_stepping_is_always_run(s, 7) != true { panic(31021); };
    let s2 = ecs_stepping_never_run_node(s, 8);
    if ecs_stepping_is_never_run(s2, 8) != true { panic(31022); };
}

@test "lib access: add read write"() {
    let a = ecs_access_add_write(ecs_access_add_read(ecs_access_new(), 5), 10);
    if ecs_access_has_read(a, 5) != true { panic(31023); };
    if ecs_access_has_write(a, 10) != true { panic(31024); };
}

@test "lib access: is_compatible"() {
    let a = ecs_access_add_write(ecs_access_new(), 1);
    let b = ecs_access_add_read(ecs_access_new(), 1);
    if ecs_access_is_compatible(a, b) != false { panic(31025); };
}

@test "lib access: is_subset"() {
    let a = ecs_access_add_read(ecs_access_new(), 1);
    let b = ecs_access_add_read(ecs_access_add_read(ecs_access_new(), 1), 2);
    if ecs_access_is_subset(a, b) != true { panic(31026); };
}

@test "lib access: read_all"() {
    let a = ecs_access_read_all(ecs_access_new());
    if ecs_access_has_read_all(a) != true { panic(31027); };
    if ecs_access_has_read(a, 42) != true { panic(31028); };
}

@test "lib access: clear"() {
    let a = ecs_access_clear(ecs_access_add_write(ecs_access_new(), 5));
    if ecs_access_has_any_read(a) != false { panic(31029); };
}

@test "lib filters: with matches"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(5);
    if ecs_with_filter_matches(ecs_with_filter_new(5), comps) != true { panic(31030); };
}

@test "lib filters: without matches"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(10);
    if ecs_without_filter_matches(ecs_without_filter_new(5), comps) != true { panic(31031); };
}

@test "lib filters: or matches"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(5);
    if ecs_or_filter_matches(ecs_or_filter_new(5, 10), comps) != true { panic(31032); };
}

@test "lib filters: added matches"() {
    let added: Vec<i32> = Vec::new();
    added.push(5);
    if ecs_added_filter_matches(ecs_added_filter_new(5), added) != true { panic(31033); };
}

@test "lib filters: has fetch"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(42);
    if ecs_has_fetch(comps, 42) != true { panic(31034); };
}

@test "lib filters: any of"() {
    let comps: Vec<i32> = Vec::new();
    comps.push(5);
    let r = ecs_any_of_fetch(comps, 5, 10);
    if r.has_a != true { panic(31035); };
    if r.has_b != false { panic(31036); };
}

@test "lib batching: calc_batch_size"() {
    let bs = ecs_batching_strategy_new();
    let sz = ecs_batching_strategy_calc_batch_size(bs, 100, 4);
    if sz != 25 { panic(31037); };
}

@test "lib batching: fixed"() {
    let bs = ecs_batching_strategy_fixed(32);
    let sz = ecs_batching_strategy_calc_batch_size(bs, 1000, 8);
    if sz != 32 { panic(31038); };
}

@test "lib batching: clamp min"() {
    let bs = ecs_batching_strategy_min_batch(ecs_batching_strategy_new(), 50);
    let sz = ecs_batching_strategy_calc_batch_size(bs, 100, 4);
    if sz != 50 { panic(31039); };
}

@test "lib template: scene entity references"() {
    let sers = ecs_sers_set(ecs_sers_new(), ecs_ser_new(1, 0), 100);
    if ecs_sers_get(sers, ecs_ser_new(1, 0)) != 100 { panic(31040); };
}

@test "lib template: context get entity"() {
    let tc = ecs_template_context_set_entity(ecs_template_context_new(), ecs_ser_new(1, 0), 42);
    if ecs_template_context_get_entity(tc, ecs_ser_new(1, 0)) != 42 { panic(31041); };
}

@test "lib template: context resource"() {
    let tc = ecs_template_context_resource_mut(ecs_template_context_new(), 5, 99);
    let r = ecs_template_context_resource(tc, 5);
    if r.0 != true { panic(31042); };
    if r.1 != 99 { panic(31043); };
}

@test "lib template: entity template from fn"() {
    let et = ecs_entity_template_from_fn(7);
    if ecs_entity_template_kind(et) != ECS_TEMPLATE_FN { panic(31044); };
}

@test "lib template: option some"() {
    let ot = ecs_option_template_some(ecs_entity_template_from_reference(1));
    if ecs_option_template_is_some(ot) != true { panic(31045); };
}

@test "lib template: vec push len"() {
    let vt = ecs_vec_template_push(ecs_vec_template_push(ecs_vec_template_new(), ecs_entity_template_from_reference(1)), ecs_entity_template_from_fn(2));
    if ecs_vec_template_len(vt) != 2 { panic(31046); };
}
