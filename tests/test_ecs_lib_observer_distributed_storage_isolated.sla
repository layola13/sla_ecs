@import "lib/observer_distributed_storage.sla"

// Isolated tests for lib/observer_distributed_storage.sla — Observer + ObservedBy
// Bevy reference: bevy_ecs/src/observer/distributed_storage.rs

@test "observer_new"() {
    let o = ecs_observer_new(10, 42);
    if ecs_observer_entity(o) != 10 { panic(83000); };
    if ecs_observer_runner(o) != 42 { panic(83001); };
    if ecs_observer_is_dynamic(o) != false { panic(83002); };
    if ecs_observer_component_count(o) != 0 { panic(83003); };
}

@test "observer_with_dynamic_runner"() {
    let o = ecs_observer_with_dynamic_runner(99);
    if ecs_observer_is_dynamic(o) != true { panic(83004); };
    if ecs_observer_runner(o) != 99 { panic(83005); };
}

@test "observer_with_entity"() {
    let o = ecs_observer_new(0, 42);
    let o2 = ecs_observer_with_entity(o, 10);
    if ecs_observer_entity(o2) != 10 { panic(83006); };
}

@test "observer_watch_entity"() {
    let o = ecs_observer_new(10, 42);
    let o2 = ecs_observer_watch_entity(o, 20);
    if ecs_observer_entity_count(o2) != 1 { panic(83007); };
    if ecs_observer_watches_entity(o2, 20) != true { panic(83008); };
}

@test "observer_watch_entities"() {
    let o = ecs_observer_new(10, 42);
    let entities = Vec::new();
    entities.push(20);
    entities.push(30);
    let o2 = ecs_observer_watch_entities(o, entities);
    if ecs_observer_entity_count(o2) != 2 { panic(83009); };
}

@test "observer_with_component"() {
    let o = ecs_observer_new(10, 42);
    let o2 = ecs_observer_with_component(o, 5);
    if ecs_observer_component_count(o2) != 1 { panic(83010); };
    if ecs_observer_watches_component(o2, 5) != true { panic(83011); };
}

@test "observer_with_components"() {
    let o = ecs_observer_new(10, 42);
    let cids = Vec::new();
    cids.push(5);
    cids.push(6);
    let o2 = ecs_observer_with_components(o, cids);
    if ecs_observer_component_count(o2) != 2 { panic(83012); };
}

@test "observer_with_event_key"() {
    let o = ecs_observer_new(10, 42);
    let o2 = ecs_observer_with_event_key(o, 100);
    if ecs_observer_event_key_count(o2) != 1 { panic(83013); };
}

@test "observer_with_error_handler"() {
    let o = ecs_observer_new(10, 42);
    let o2 = ecs_observer_with_error_handler(o, 7);
    if ecs_observer_error_handler(o2) != 7 { panic(83014); };
}

@test "observer_run_if"() {
    let o = ecs_observer_new(10, 42);
    let o2 = ecs_observer_run_if(o, 3);
    if ecs_observer_condition(o2) != 3 { panic(83015); };
}

@test "observer_set_name"() {
    let o = ecs_observer_new(10, 42);
    let o2 = ecs_observer_set_name(o, 999);
    if ecs_observer_name(o2) != 999 { panic(83016); };
}

@test "observer_watches_entity_false"() {
    let o = ecs_observer_new(10, 42);
    let o2 = ecs_observer_watch_entity(o, 20);
    if ecs_observer_watches_entity(o2, 99) != false { panic(83017); };
}

@test "observer_watches_component_false"() {
    let o = ecs_observer_new(10, 42);
    if ecs_observer_watches_component(o, 5) != false { panic(83018); };
}

@test "observed_by_new"() {
    let ob = ecs_observed_by_new();
    if ecs_observed_by_len(ob) != 0 { panic(83019); };
}

@test "observed_by_add"() {
    let ob = ecs_observed_by_new();
    let ob2 = ecs_observed_by_add(ob, 10, 20);
    if ecs_observed_by_len(ob2) != 1 { panic(83020); };
    if ecs_observed_by_count(ob2, 10) != 1 { panic(83021); };
}

@test "observed_by_get"() {
    let ob = ecs_observed_by_new();
    let ob2 = ecs_observed_by_add(ob, 10, 20);
    let ob3 = ecs_observed_by_add(ob2, 10, 30);
    let obs = ecs_observed_by_get(ob3, 10);
    if len(obs) != 2 { panic(83022); };
    if obs[0] != 20 { panic(83023); };
    if obs[1] != 30 { panic(83024); };
}

@test "observed_by_count"() {
    let ob = ecs_observed_by_new();
    let ob2 = ecs_observed_by_add(ob, 10, 20);
    let ob3 = ecs_observed_by_add(ob2, 10, 30);
    let ob4 = ecs_observed_by_add(ob3, 20, 40);
    if ecs_observed_by_count(ob4, 10) != 2 { panic(83025); };
    if ecs_observed_by_count(ob4, 20) != 1 { panic(83026); };
    if ecs_observed_by_count(ob4, 99) != 0 { panic(83027); };
}

@test "observed_by_remove"() {
    let ob = ecs_observed_by_new();
    let ob2 = ecs_observed_by_add(ob, 10, 20);
    let ob3 = ecs_observed_by_add(ob2, 10, 30);
    let ob4 = ecs_observed_by_remove(ob3, 10, 20);
    if ecs_observed_by_count(ob4, 10) != 1 { panic(83028); };
    let obs = ecs_observed_by_get(ob4, 10);
    if obs[0] != 30 { panic(83029); };
}

@test "observed_by_remove_all"() {
    let ob = ecs_observed_by_new();
    let ob2 = ecs_observed_by_add(ob, 10, 20);
    let ob3 = ecs_observed_by_remove(ob2, 10, 20);
    if ecs_observed_by_count(ob3, 10) != 0 { panic(83030); };
}

@test "observed_by_remove_different_target"() {
    let ob = ecs_observed_by_new();
    let ob2 = ecs_observed_by_add(ob, 10, 20);
    let ob3 = ecs_observed_by_add(ob2, 20, 30);
    // Remove observer for target 10, should not affect target 20
    let ob4 = ecs_observed_by_remove(ob3, 10, 20);
    if ecs_observed_by_count(ob4, 10) != 0 { panic(83031); };
    if ecs_observed_by_count(ob4, 20) != 1 { panic(83032); };
}
