@import "lib/message_cursor.sla"
@import "lib/message_mutator.sla"
@import "lib/message_registry_update.sla"

@test "message cursor new and len"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 5);
    if ecs_message_cursor_len(c) != 5 { panic(65001); };
    if ecs_message_cursor_is_empty(c) != false { panic(65002); };
}

@test "message cursor read"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 3);
    let r1 = ecs_message_cursor_read(c);
    if r1.1 != true { panic(65003); };
    if r1.2 != 0 { panic(65004); };
    let r2 = ecs_message_cursor_read(r1.0);
    if r2.2 != 1 { panic(65005); };
}

@test "message cursor read exhausted"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 1);
    let r1 = ecs_message_cursor_read(c);
    let r2 = ecs_message_cursor_read(r1.0);
    if r2.1 != false { panic(65006); };
}

@test "message cursor len after reads"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 5);
    let r = ecs_message_cursor_read(c);
    if ecs_message_cursor_len(r.0) != 4 { panic(65007); };
}

@test "message cursor clear"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 5);
    c = ecs_message_cursor_clear(c);
    if ecs_message_cursor_len(c) != 0 { panic(65008); };
}

@test "message cursor missed"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_missed(c, 3);
    if ecs_message_cursor_missed_messages(c) != 3 { panic(65009); };
}

@test "message cursor read with id"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 2);
    let r = ecs_message_cursor_read_with_id(c);
    if r.1 != true { panic(65010); };
    if r.2 != 0 { panic(65011); };
    if r.3 != 0 { panic(65012); };
}

@test "message mutator write"() {
    let m = ecs_message_mutator_new();
    let r = ecs_message_mutator_write(m, 100);
    if r.1 != 0 { panic(65013); };
    if ecs_message_mutator_written_count(r.0) != 1 { panic(65014); };
    if ecs_message_mutator_total(r.0) != 1 { panic(65015); };
}

@test "message mutator write batch"() {
    let m = ecs_message_mutator_new();
    let values: Vec<i64> = Vec::new();
    values.push(1);
    values.push(2);
    values.push(3);
    let r = ecs_message_mutator_write_batch(m, values);
    if r.1 != 3 { panic(65016); };
    if ecs_message_mutator_total(r.0) != 3 { panic(65017); };
}

@test "message mutator write default"() {
    let m = ecs_message_mutator_new();
    let r = ecs_message_mutator_write_default(m);
    if r.1 != 0 { panic(65018); };
}

@test "message mutator read"() {
    let m = ecs_message_mutator_new();
    m = ecs_message_mutator_write(m, 100).0;
    m = ecs_message_mutator_write(m, 200).0;
    let r = ecs_message_mutator_read(m);
    if r.1 != true { panic(65019); };
    if r.2 != 100 { panic(65020); };
}

@test "message mutator len and clear"() {
    let m = ecs_message_mutator_new();
    m = ecs_message_mutator_write(m, 100).0;
    m = ecs_message_mutator_write(m, 200).0;
    if ecs_message_mutator_len(m) != 2 { panic(65021); };
    m = ecs_message_mutator_clear(m);
    if ecs_message_mutator_is_empty(m) != true { panic(65022); };
}

@test "message registry register and count"() {
    let r = ecs_message_registry_new();
    r = ecs_message_registry_register(r, 1);
    r = ecs_message_registry_register(r, 2);
    if ecs_message_registry_count(r) != 2 { panic(65023); };
}

@test "message registry register dedup"() {
    let r = ecs_message_registry_new();
    r = ecs_message_registry_register(r, 1);
    r = ecs_message_registry_register(r, 1);
    if ecs_message_registry_count(r) != 1 { panic(65024); };
}

@test "message registry is registered"() {
    let r = ecs_message_registry_new();
    r = ecs_message_registry_register(r, 5);
    if ecs_message_registry_is_registered(r, 5) != true { panic(65025); };
    if ecs_message_registry_is_registered(r, 6) != false { panic(65026); };
}

@test "message registry deregister"() {
    let r = ecs_message_registry_new();
    r = ecs_message_registry_register(r, 1);
    r = ecs_message_registry_register(r, 2);
    let r2 = ecs_message_registry_deregister(r, 1);
    if r2.1 != true { panic(65027); };
    if ecs_message_registry_count(r2.0) != 1 { panic(65028); };
}

@test "message registry signal and should update"() {
    let r = ecs_message_registry_new();
    if ecs_message_registry_should_update(r) != ECS_SUM_NO { panic(65029); };
    r = ecs_message_registry_signal(r, true);
    if ecs_message_registry_should_update(r) != ECS_SUM_YES { panic(65030); };
}

@test "message registry run updates"() {
    let r = ecs_message_registry_new();
    r = ecs_message_registry_signal(r, true);
    r = ecs_message_registry_run_updates(r, 10);
    if ecs_message_registry_last_change_tick(r) != 10 { panic(65031); };
    if ecs_message_registry_update_count(r) != 1 { panic(65032); };
    if ecs_message_registry_has_signal(r) != false { panic(65033); };
}

@test "message mut iterator"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 5);
    let it = ecs_message_mut_iterator_new(c);
    if ecs_message_mut_iterator_len(it) != 5 { panic(65039); };
    if ecs_message_mut_iterator_is_empty(it) != false { panic(65040); };
}

@test "message mut par iter batching"() {
    let p = ecs_message_mut_par_iter_new(100);
    let p2 = ecs_message_mut_par_iter_batching_strategy(p, 30);
    if ecs_message_mut_par_iter_batch_count(p2) != 4 { panic(65041); };
}

@test "message mut par iter for each"() {
    let p = ecs_message_mut_par_iter_new(100);
    if ecs_message_mut_par_iter_for_each(p) != 100 { panic(65042); };
}
