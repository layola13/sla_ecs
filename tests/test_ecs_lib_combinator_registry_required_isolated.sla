@import "lib/system_combinator.sla"
@import "lib/system_registry.sla"
@import "lib/component_required.sla"

@test "combinator system pipe combine"() {
    let c = ecs_combinator_system_new(ECS_COMBINE_PIPE, 10, 20, 1);
    if ecs_combinator_system_combine(c) != 20 { panic(64001); };
}

@test "combinator system and combine"() {
    let c1 = ecs_combinator_system_new(ECS_COMBINE_AND, 1, 1, 1);
    if ecs_combinator_system_combine(c1) != 1 { panic(64002); };
    let c2 = ecs_combinator_system_new(ECS_COMBINE_AND, 1, 0, 1);
    if ecs_combinator_system_combine(c2) != 0 { panic(64003); };
}

@test "combinator system or combine"() {
    let c1 = ecs_combinator_system_new(ECS_COMBINE_OR, 0, 0, 1);
    if ecs_combinator_system_combine(c1) != 0 { panic(64004); };
    let c2 = ecs_combinator_system_new(ECS_COMBINE_OR, 0, 1, 1);
    if ecs_combinator_system_combine(c2) != 1 { panic(64005); };
}

@test "combinator system map combine"() {
    let c = ecs_combinator_system_new(ECS_COMBINE_MAP, 42, 0, 1);
    if ecs_combinator_system_combine(c) != 42 { panic(64006); };
}

@test "combinator system kind and name"() {
    let c = ecs_combinator_system_new(ECS_COMBINE_PIPE, 1, 2, 99);
    if ecs_combinator_system_kind(c) != ECS_COMBINE_PIPE { panic(64007); };
    if ecs_combinator_system_name(c) != 99 { panic(64008); };
}

@test "pipe system new and a output"() {
    let p = ecs_pipe_system_new(10, 1);
    if ecs_pipe_system_a_output(p) != 10 { panic(64009); };
    if ecs_pipe_system_b_input(p) != 10 { panic(64010); };
}

@test "pipe system run b and output"() {
    let p = ecs_pipe_system_new(10, 1);
    let p2 = ecs_pipe_system_run_b(p, 99);
    if ecs_pipe_system_output(p2) != 99 { panic(64011); };
}

@test "into pipe system into"() {
    let i = ecs_into_pipe_system_new(50);
    let p = ecs_into_pipe_system_into(i, 7);
    if ecs_pipe_system_name(p) != 7 { panic(64012); };
    if ecs_pipe_system_a_output(p) != 50 { panic(64013); };
}

@test "xor combine"() {
    if ecs_xor_combine(true, false) != true { panic(64014); };
    if ecs_xor_combine(true, true) != false { panic(64015); };
    if ecs_xor_combine(false, false) != false { panic(64016); };
    if ecs_xor_combine(false, true) != true { panic(64017); };
}

@test "system id new and entity"() {
    let id = ecs_system_id_new(42);
    if ecs_system_id_entity(id) != 42 { panic(64018); };
}

@test "system id eq"() {
    if ecs_system_id_eq(ecs_system_id_new(5), ecs_system_id_new(5)) != true { panic(64019); };
    if ecs_system_id_eq(ecs_system_id_new(5), ecs_system_id_new(6)) != false { panic(64020); };
}

@test "registered system new and initialize"() {
    let r = ecs_registered_system_new(ecs_system_id_new(1), 100);
    if ecs_registered_system_is_initialized(r) != false { panic(64021); };
    let r2 = ecs_registered_system_initialize(r);
    if ecs_registered_system_is_initialized(r2) != true { panic(64022); };
}

@test "registered system run"() {
    let r = ecs_registered_system_new(ecs_system_id_new(1), 100);
    let r2 = ecs_registered_system_run(r, 77);
    if r2.1 != 77 { panic(64023); };
    if ecs_registered_system_run_count(r2.0) != 1 { panic(64024); };
}

@test "removed system"() {
    let r = ecs_removed_system_new(100, true);
    if ecs_removed_system_initialized(r) != true { panic(64025); };
    if ecs_removed_system_system(r) != 100 { panic(64026); };
}

@test "system handle strong and weak"() {
    let s = ecs_system_handle_strong(5);
    if ecs_system_handle_is_strong(s) != true { panic(64027); };
    let w = ecs_system_handle_weak(6);
    if ecs_system_handle_is_weak(w) != true { panic(64028); };
    if ecs_system_handle_entity(w) != 6 { panic(64029); };
}

@test "strong system handle"() {
    let h = ecs_strong_system_handle_new(9);
    if ecs_strong_system_handle_entity(h) != 9 { panic(64030); };
}

@test "despawn unused registered systems"() {
    let used: Vec<i64> = Vec::new();
    used.push(1);
    used.push(2);
    let all: Vec<i64> = Vec::new();
    all.push(1);
    all.push(2);
    all.push(3);
    all.push(4);
    if ecs_despawn_unused_registered_systems(used, all) != 2 { panic(64031); };
}

@test "required component new"() {
    let r = ecs_required_component_new(5, 10, 1);
    if ecs_required_component_id(r) != 5 { panic(64032); };
    if ecs_required_component_constructor(r) != 10 { panic(64033); };
    if ecs_required_component_depth(r) != 1 { panic(64034); };
}

@test "required components register and len"() {
    let r = ecs_required_components_new();
    r = ecs_required_components_register(r, 1, 10, 1);
    r = ecs_required_components_register(r, 2, 20, 1);
    if ecs_required_components_len(r) != 2 { panic(64035); };
}

@test "required components register shallowest wins"() {
    let r = ecs_required_components_new();
    r = ecs_required_components_register(r, 1, 10, 3);
    r = ecs_required_components_register(r, 1, 20, 1);
    let d = ecs_required_components_depth_of(r, 1);
    if d.1 != 1 { panic(64036); };
    let c = ecs_required_components_constructor_of(r, 1);
    if c.1 != 20 { panic(64037); };
}

@test "required components register deeper ignored"() {
    let r = ecs_required_components_new();
    r = ecs_required_components_register(r, 1, 10, 1);
    r = ecs_required_components_register(r, 1, 20, 3);
    let c = ecs_required_components_constructor_of(r, 1);
    if c.1 != 10 { panic(64038); };
}

@test "required components contains"() {
    let r = ecs_required_components_new();
    r = ecs_required_components_register(r, 1, 10, 1);
    if ecs_required_components_contains(r, 1) != true { panic(64039); };
    if ecs_required_components_contains(r, 2) != false { panic(64040); };
}

@test "required components iter ids"() {
    let r = ecs_required_components_new();
    r = ecs_required_components_register(r, 1, 10, 1);
    r = ecs_required_components_register(r, 2, 20, 1);
    let ids = ecs_required_components_iter_ids(r);
    if len(ids) as i64 != 2 { panic(64041); };
}

@test "required components registrator"() {
    let reg = ecs_required_components_registrator_new(99);
    if ecs_required_components_registrator_target(reg) != 99 { panic(64042); };
    let reg2 = ecs_required_components_registrator_register_required(reg, 1, 10);
    if ecs_required_components_registrator_count(reg2) != 1 { panic(64043); };
}

@test "required components registrator recursive"() {
    let reg = ecs_required_components_registrator_new(99);
    let reg2 = ecs_required_components_registrator_register_required_recursive(reg, 1, 10, 2);
    let d = ecs_required_components_depth_of(ecs_required_components_registrator_required(reg2), 1);
    if d.1 != 2 { panic(64044); };
}
