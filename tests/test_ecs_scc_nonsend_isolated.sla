// Full Tarjan SCC + NonSend storage (NonSendData/NonSends).
// State threaded as tuple returns since SLA passes by value.

struct EcsEdge2 { from: i32, to: i32 }

struct EcsTarjanState {
    index: i32,
    indices: Vec<i32>,
    lowlinks: Vec<i32>,
    on_stack: Vec<bool>,
    stack: Vec<i32>,
    node_count: i32,
}

fn tarjan_state_new(node_count: i32) -> EcsTarjanState {
    let indices: Vec<i32> = Vec::new();
    let lowlinks: Vec<i32> = Vec::new();
    let on_stack: Vec<bool> = Vec::new();
    let i: i32 = 0;
    while i < node_count {
        indices.push(-1);
        lowlinks.push(-1);
        on_stack.push(false);
        i = i + 1;
    }
    return EcsTarjanState { index: 0, indices: indices, lowlinks: lowlinks, on_stack: on_stack, stack: Vec::new(), node_count: node_count };
}

fn tarjan_compute(node_count: i32, edges: Vec<EcsEdge2>) -> Vec<Vec<i32>> {
    let state = tarjan_state_new(node_count);
    let r = tarjan_next(node_count, edges, state, Vec::new(), 0);
    return r.1;
}

fn tarjan_strongconnect(nc: i32, edges: Vec<EcsEdge2>, state: EcsTarjanState, sccs: Vec<Vec<i32>>, v: i32) -> (EcsTarjanState, Vec<Vec<i32>>) {
    state.indices[v] = state.index;
    state.lowlinks[v] = state.index;
    state.index = state.index + 1;
    state.stack.push(v);
    state.on_stack[v] = true;
    let r1 = tarjan_succ(nc, edges, state, sccs, v, 0);
    let s2 = r1.0;
    let sccs2 = r1.1;
    if s2.lowlinks[v] == s2.indices[v] {
        return tarjan_pop_scc(nc, s2, sccs2, Vec::new(), v);
    };
    return tarjan_next(nc, edges, s2, sccs2, v + 1);
}

fn tarjan_succ(nc: i32, edges: Vec<EcsEdge2>, state: EcsTarjanState, sccs: Vec<Vec<i32>>, v: i32, ei: i64) -> (EcsTarjanState, Vec<Vec<i32>>) {
    if ei >= (len(edges) as i64) { return (state, sccs); };
    let edge = edges[ei];
    if edge.from != v { return tarjan_succ(nc, edges, state, sccs, v, ei + 1); };
    let w = edge.to;
    if state.indices[w] == -1 {
        let r = tarjan_strongconnect(nc, edges, state, sccs, w);
        let s2 = r.0;
        let sccs2 = r.1;
        if s2.lowlinks[w] < s2.lowlinks[v] { s2.lowlinks[v] = s2.lowlinks[w]; };
        return tarjan_succ(nc, edges, s2, sccs2, v, ei + 1);
    };
    if state.on_stack[w] {
        if state.indices[w] < state.lowlinks[v] { state.lowlinks[v] = state.indices[w]; };
    };
    return tarjan_succ(nc, edges, state, sccs, v, ei + 1);
}

fn tarjan_pop_scc(nc: i32, state: EcsTarjanState, sccs: Vec<Vec<i32>>, scc: Vec<i32>, root: i32) -> (EcsTarjanState, Vec<Vec<i32>>) {
    let w = state.stack[len(state.stack) - 1];
    state.stack.pop();
    state.on_stack[w] = false;
    scc.push(w);
    if w != root { return tarjan_pop_scc(nc, state, sccs, scc, root); };
    sccs.push(scc);
    return tarjan_next(nc, Vec::new(), state, sccs, root + 1);
}

fn tarjan_next(nc: i32, edges: Vec<EcsEdge2>, state: EcsTarjanState, sccs: Vec<Vec<i32>>, v: i32) -> (EcsTarjanState, Vec<Vec<i32>>) {
    if v >= nc { return (state, sccs); };
    if state.indices[v] != -1 { return tarjan_next(nc, edges, state, sccs, v + 1); };
    return tarjan_strongconnect(nc, edges, state, sccs, v);
}

fn scc_count(sccs: Vec<Vec<i32>>) -> i64 { return len(sccs) as i64; }

struct EcsNonSendData { is_present: bool, value: i32, added_tick: i32, changed_tick: i32, thread_id: i32 }

fn nsd_new(tid: i32) -> EcsNonSendData { return EcsNonSendData { is_present: false, value: 0, added_tick: 0, changed_tick: 0, thread_id: tid }; }
fn nsd_insert(d: EcsNonSendData, v: i32, t: i32) -> EcsNonSendData { d.is_present = true; d.value = v; d.added_tick = t; d.changed_tick = t; return d; }
fn nsd_remove(d: EcsNonSendData) -> EcsNonSendData { d.is_present = false; d.value = 0; return d; }
fn nsd_is_present(d: EcsNonSendData) -> bool { return d.is_present; }
fn nsd_get(d: EcsNonSendData) -> i32 { return d.value; }
fn nsd_added(d: EcsNonSendData) -> i32 { return d.added_tick; }
fn nsd_changed(d: EcsNonSendData) -> i32 { return d.changed_tick; }
fn nsd_thread(d: EcsNonSendData) -> i32 { return d.thread_id; }

struct EcsNonSendEntry { cid: i32, data: EcsNonSendData }
struct EcsNonSends { entries: Vec<EcsNonSendEntry> }

fn ns_new() -> EcsNonSends { return EcsNonSends { entries: Vec::new() }; }
fn ns_len(ns: EcsNonSends) -> i64 { return len(ns.entries) as i64; }
fn ns_is_empty(ns: EcsNonSends) -> bool { return len(ns.entries) == 0; }

fn ns_insert(ns: EcsNonSends, cid: i32, v: i32, t: i32, tid: i32) -> EcsNonSends {
    let i: i64 = 0;
    let cnt = len(ns.entries) as i64;
    while i < cnt {
        if ns.entries[i].cid == cid {
            ns.entries[i].data = nsd_insert(ns.entries[i].data, v, t);
            return ns;
        };
        i = i + 1;
    }
    ns.entries.push(EcsNonSendEntry { cid: cid, data: nsd_insert(nsd_new(tid), v, t) });
    return ns;
}

fn ns_get(ns: EcsNonSends, cid: i32) -> EcsNonSendData {
    let i: i64 = 0;
    let cnt = len(ns.entries) as i64;
    while i < cnt { if ns.entries[i].cid == cid { return ns.entries[i].data; }; i = i + 1; }
    return nsd_new(0);
}

fn ns_clear(ns: EcsNonSends) -> EcsNonSends { ns.entries = Vec::new(); return ns; }

const NS_COMP: i32 = 21001;

@test "tarjan SCC single node"() {
    let sccs = tarjan_compute(1, Vec::new());
    if scc_count(sccs) != 1 { panic(21001); };
}

@test "tarjan SCC two disconnected"() {
    let sccs = tarjan_compute(2, Vec::new());
    if scc_count(sccs) != 2 { panic(21002); };
}

@test "tarjan SCC linear chain"() {
    let edges: Vec<EcsEdge2> = Vec::new();
    edges.push(EcsEdge2 { from: 0, to: 1 });
    edges.push(EcsEdge2 { from: 1, to: 2 });
    let sccs = tarjan_compute(3, edges);
    if scc_count(sccs) != 3 { panic(21003); };
}

@test "tarjan SCC self-loop"() {
    let edges: Vec<EcsEdge2> = Vec::new();
    edges.push(EcsEdge2 { from: 0, to: 0 });
    let sccs = tarjan_compute(1, edges);
    if scc_count(sccs) != 1 { panic(21004); };
}

@test "tarjan SCC two-node cycle"() {
    let edges: Vec<EcsEdge2> = Vec::new();
    edges.push(EcsEdge2 { from: 0, to: 1 });
    edges.push(EcsEdge2 { from: 1, to: 0 });
    let sccs = tarjan_compute(2, edges);
    if scc_count(sccs) != 1 { panic(21017); };
    if len(sccs[0]) != 2 { panic(21018); };
}

@test "tarjan SCC three-node cycle"() {
    let edges: Vec<EcsEdge2> = Vec::new();
    edges.push(EcsEdge2 { from: 0, to: 1 });
    edges.push(EcsEdge2 { from: 1, to: 2 });
    edges.push(EcsEdge2 { from: 2, to: 0 });
    let sccs = tarjan_compute(3, edges);
    if scc_count(sccs) != 1 { panic(21019); };
}

@test "tarjan SCC mixed cycle and singleton"() {
    let edges: Vec<EcsEdge2> = Vec::new();
    edges.push(EcsEdge2 { from: 0, to: 1 });
    edges.push(EcsEdge2 { from: 1, to: 0 });
    edges.push(EcsEdge2 { from: 2, to: 3 });
    let sccs = tarjan_compute(4, edges);
    if scc_count(sccs) != 3 { panic(21020); };
}

@test "nonsend_data insert"() {
    let d = nsd_insert(nsd_new(1), 42, 5);
    if nsd_is_present(d) != true { panic(21005); };
    if nsd_get(d) != 42 { panic(21006); };
}

@test "nonsend_data remove"() {
    let d = nsd_remove(nsd_insert(nsd_new(1), 42, 5));
    if nsd_is_present(d) { panic(21007); };
}

@test "nonsend_data ticks"() {
    let d = nsd_insert(nsd_new(1), 42, 7);
    if nsd_added(d) != 7 { panic(21008); };
    if nsd_changed(d) != 7 { panic(21009); };
}

@test "nonsend_data thread"() {
    if nsd_thread(nsd_new(42)) != 42 { panic(21010); };
}

@test "nonsends insert and len"() {
    let ns = ns_insert(ns_new(), NS_COMP, 100, 1, 0);
    if ns_len(ns) != 1 { panic(21011); };
}

@test "nonsends get"() {
    let ns = ns_insert(ns_new(), NS_COMP, 100, 1, 0);
    if nsd_get(ns_get(ns, NS_COMP)) != 100 { panic(21012); };
}

@test "nonsends is_empty"() {
    if ns_is_empty(ns_new()) != true { panic(21013); };
}

@test "nonsends clear"() {
    let ns = ns_clear(ns_insert(ns_new(), NS_COMP, 100, 1, 0));
    if ns_is_empty(ns) != true { panic(21014); };
}

@test "nonsends insert twice updates"() {
    let ns = ns_insert(ns_insert(ns_new(), NS_COMP, 100, 1, 0), NS_COMP, 200, 2, 0);
    if ns_len(ns) != 1 { panic(21015); };
    if nsd_get(ns_get(ns, NS_COMP)) != 200 { panic(21016); };
}
