// Integration test for lib/schedule_error.sla + lib/query_error.sla +
// lib/auto_insert_apply_deferred.sla + lib/parallel_scope.sla
@import "lib/schedule_error.sla"
@import "lib/query_error.sla"
@import "lib/auto_insert_apply_deferred.sla"
@import "lib/parallel_scope.sla"

// === schedule_error tests ===

@test "schedule build error new"() {
    let e = ecs_schedule_build_error_new(ECS_SCHED_ERR_AMBIGUITY, 42);
    if ecs_schedule_build_error_kind(e) != ECS_SCHED_ERR_AMBIGUITY { panic(35001); };
    if ecs_schedule_build_error_is_ambiguity(e) != true { panic(35002); };
}

@test "schedule build error hierarchy sort"() {
    let e = ecs_schedule_build_error_new(ECS_SCHED_ERR_HIERARCHY_SORT, 1);
    if ecs_schedule_build_error_is_hierarchy_sort(e) != true { panic(35003); };
}

@test "schedule build warning ambiguous"() {
    let w = ecs_schedule_build_warning_ambiguous(1, 2);
    if ecs_schedule_build_warning_is_ambiguous(w) != true { panic(35004); };
    if ecs_schedule_build_warning_kind(w) != ECS_SCHED_WARN_AMBIGUOUS { panic(35005); };
}

@test "schedule build warning redundant"() {
    let w = ecs_schedule_build_warning_redundant(3, 4);
    if ecs_schedule_build_warning_is_redundant(w) != true { panic(35006); };
}

@test "schedule error build"() {
    let e = ecs_schedule_error_build(ecs_schedule_build_error_new(ECS_SCHED_ERR_AMBIGUITY, 1));
    if ecs_schedule_error_is_build(e) != true { panic(35007); };
}

@test "schedule error system"() {
    let e = ecs_schedule_error_system(99);
    if ecs_schedule_error_is_system(e) != true { panic(35008); };
}

@test "schedule build settings default"() {
    let s = ecs_schedule_build_settings_default();
    if ecs_schedule_build_settings_auto_insert(s) != true { panic(35009); };
    if ecs_schedule_build_settings_ambiguity_detection(s) != false { panic(35010); };
}

@test "schedule build settings set"() {
    let s = ecs_schedule_build_settings_set_ambiguity_detection(ecs_schedule_build_settings_default(), true);
    if ecs_schedule_build_settings_ambiguity_detection(s) != true { panic(35011); };
    let s2 = ecs_schedule_build_settings_set_auto_insert(s, false);
    if ecs_schedule_build_settings_auto_insert(s2) != false { panic(35012); };
}

// === query_error tests ===

@test "query entity error not found"() {
    let e = ecs_query_entity_error_not_found(42);
    if ecs_query_entity_error_is_not_found(e) != true { panic(35013); };
    if ecs_query_entity_error_entity(e) != 42 { panic(35014); };
}

@test "query entity error does not match"() {
    let e = ecs_query_entity_error_does_not_match(10);
    if ecs_query_entity_error_is_does_not_match(e) != true { panic(35015); };
}

@test "query entity error alien"() {
    let e = ecs_query_entity_error_alien(5);
    if ecs_query_entity_error_is_alien(e) != true { panic(35016); };
}

@test "query single error no entities"() {
    let e = ecs_query_single_error_no_entities();
    if ecs_query_single_error_is_no_entities(e) != true { panic(35017); };
}

@test "query single error multiple"() {
    let e = ecs_query_single_error_multiple_entities(3);
    if ecs_query_single_error_is_multiple(e) != true { panic(35018); };
    if ecs_query_single_error_count(e) != 3 { panic(35019); };
}

@test "query not dense error"() {
    let e = ecs_query_not_dense_error_new(42);
    if ecs_query_not_dense_error_name(e) != 42 { panic(35020); };
}

@test "access conflicts add and len"() {
    let c = ecs_access_conflicts_add(ecs_access_conflicts_add(ecs_access_conflicts_new(), 5), 10);
    if ecs_access_conflicts_len(c) != 2 { panic(35021); };
    if ecs_access_conflicts_get(c, 0) != 5 { panic(35022); };
}

@test "access conflicts empty"() {
    if ecs_access_conflicts_is_empty(ecs_access_conflicts_new()) != true { panic(35023); };
}

// === auto_insert_apply_deferred tests ===

@test "auto insert no sync edge"() {
    let p = ecs_auto_insert_add_no_sync_edge(ecs_auto_insert_apply_deferred_new(), 1, 2);
    if ecs_auto_insert_is_no_sync(p, 1, 2) != true { panic(35024); };
    if ecs_auto_insert_is_no_sync(p, 3, 4) != false { panic(35025); };
}

@test "auto insert get sync point new"() {
    let r = ecs_auto_insert_get_sync_point(ecs_auto_insert_apply_deferred_new(), 5);
    if r.0 != 0 { panic(35026); };
    if ecs_auto_insert_sync_point_count(r.1) != 1 { panic(35027); };
}

@test "auto insert get sync point cached"() {
    let r1 = ecs_auto_insert_get_sync_point(ecs_auto_insert_apply_deferred_new(), 5);
    let r2 = ecs_auto_insert_get_sync_point(r1.1, 5);
    if r2.0 != 0 { panic(35028); };
    if ecs_auto_insert_sync_point_count(r2.1) != 1 { panic(35029); };
}

@test "auto insert get sync point different distances"() {
    let r1 = ecs_auto_insert_get_sync_point(ecs_auto_insert_apply_deferred_new(), 5);
    let r2 = ecs_auto_insert_get_sync_point(r1.1, 10);
    if r2.0 != 1 { panic(35030); };
    if ecs_auto_insert_sync_point_count(r2.1) != 2 { panic(35031); };
}

@test "is apply deferred"() {
    if ecs_is_apply_deferred(ECS_APPLY_DEFERRED) != true { panic(35032); };
    if ecs_is_apply_deferred(5) != false { panic(35033); };
}

@test "apply deferred marker"() {
    if ecs_apply_deferred_marker() != ECS_APPLY_DEFERRED { panic(35034); };
}

// === parallel_scope tests ===

@test "parallel commands new"() {
    let pc = ecs_parallel_commands_new(100);
    if ecs_parallel_commands_world_id(pc) != 100 { panic(35035); };
    if ecs_parallel_commands_total_commands(pc) != 0 { panic(35036); };
}

@test "parallel commands command scope"() {
    let r = ecs_parallel_commands_command_scope(ecs_parallel_commands_new(1), 5);
    if r.0 != 1 { panic(35037); };
    if ecs_parallel_commands_total_commands(r.1) != 5 { panic(35038); };
}

@test "parallel commands multiple scopes"() {
    let r1 = ecs_parallel_commands_command_scope(ecs_parallel_commands_new(1), 3);
    let r2 = ecs_parallel_commands_command_scope(r1.1, 7);
    if ecs_parallel_commands_scope_count(r2.1) != 2 { panic(35039); };
    if ecs_parallel_commands_total_commands(r2.1) != 10 { panic(35040); };
}
