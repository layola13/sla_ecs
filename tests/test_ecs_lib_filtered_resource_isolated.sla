@import "lib/filtered_resource.sla"

@test "resource access add read and has"() {
    let a = ecs_resource_access_new();
    a = ecs_resource_access_add_read(a, 1);
    if ecs_resource_access_has_read(a, 1) != true { panic(46001); };
    if ecs_resource_access_has_read(a, 2) != false { panic(46002); };
}

@test "resource access add write and has"() {
    let a = ecs_resource_access_new();
    a = ecs_resource_access_add_write(a, 5);
    if ecs_resource_access_has_write(a, 5) != true { panic(46003); };
    if ecs_resource_access_has_write(a, 6) != false { panic(46004); };
}

@test "resource access counts"() {
    let a = ecs_resource_access_new();
    a = ecs_resource_access_add_read(a, 1);
    a = ecs_resource_access_add_read(a, 2);
    a = ecs_resource_access_add_write(a, 3);
    if ecs_resource_access_read_count(a) != 2 { panic(46005); };
    if ecs_resource_access_write_count(a) != 1 { panic(46006); };
}

@test "filtered resources has read"() {
    let f = ecs_filtered_resources_new();
    f = ecs_filtered_resources_add_read(f, 1);
    if ecs_filtered_resources_has_read(f, 1) != true { panic(46007); };
    if ecs_filtered_resources_has_read(f, 2) != false { panic(46008); };
}

@test "filtered resources get not registered"() {
    let f = ecs_filtered_resources_new();
    let r = ecs_filtered_resources_get(f, 1);
    if r.0 != false { panic(46009); };
    if r.1 != ECS_RFE_NOT_REGISTERED { panic(46010); };
}

@test "filtered resources get does not exist"() {
    let f = ecs_filtered_resources_new();
    f = ecs_filtered_resources_add_read(f, 1);
    let r = ecs_filtered_resources_get(f, 1);
    if r.0 != false { panic(46011); };
    if r.1 != ECS_RFE_DOES_NOT_EXIST { panic(46012); };
}

@test "filtered resources get found"() {
    let f = ecs_filtered_resources_new();
    f = ecs_filtered_resources_add_read(f, 1);
    f = ecs_filtered_resources_set(f, 1, 99);
    let r = ecs_filtered_resources_get(f, 1);
    if r.0 != true { panic(46013); };
    if r.1 != 99 { panic(46014); };
}

@test "filtered resources mut add read and write"() {
    let f = ecs_filtered_resources_mut_new();
    f = ecs_filtered_resources_mut_add_read(f, 1);
    f = ecs_filtered_resources_mut_add_write(f, 2);
    if ecs_filtered_resources_mut_has_read(f, 1) != true { panic(46015); };
    if ecs_filtered_resources_mut_has_write(f, 2) != true { panic(46016); };
}

@test "filtered resources mut get"() {
    let f = ecs_filtered_resources_mut_new();
    f = ecs_filtered_resources_mut_set(f, 1, 50);
    let r = ecs_filtered_resources_mut_get(f, 1);
    if r.0 != true { panic(46017); };
    if r.1 != 50 { panic(46018); };
}

@test "filtered resources mut get_mut no write"() {
    let f = ecs_filtered_resources_mut_new();
    f = ecs_filtered_resources_mut_set(f, 1, 50);
    let r = ecs_filtered_resources_mut_get_mut(f, 1);
    if r.0 != false { panic(46019); };
    if r.1 != ECS_RFE_CONFLICT { panic(46020); };
}

@test "filtered resources mut get_mut with write"() {
    let f = ecs_filtered_resources_mut_new();
    f = ecs_filtered_resources_mut_add_write(f, 1);
    f = ecs_filtered_resources_mut_set(f, 1, 50);
    let r = ecs_filtered_resources_mut_get_mut(f, 1);
    if r.0 != true { panic(46021); };
    if r.1 != 50 { panic(46022); };
}

@test "filtered resources mut as readonly"() {
    let f = ecs_filtered_resources_mut_new();
    f = ecs_filtered_resources_mut_add_read(f, 1);
    f = ecs_filtered_resources_mut_set(f, 1, 77);
    let r = ecs_filtered_resources_mut_as_readonly(f);
    let g = ecs_filtered_resources_get(r, 1);
    if g.0 != true { panic(46023); };
    if g.1 != 77 { panic(46024); };
}

@test "filtered resources mut reborrow"() {
    let f = ecs_filtered_resources_mut_new();
    f = ecs_filtered_resources_mut_add_write(f, 1);
    let f2 = ecs_filtered_resources_mut_reborrow(f);
    if ecs_filtered_resources_mut_has_write(f2, 1) != true { panic(46025); };
}
