// Verification tests for the Result<T> try_* facades added to lib/ecs_world.sla.
@import "../lib/ecs_world.sla"

struct ResultCompA { v: i32 }
struct ResultCompB { v: i32 }

fn drop_result_comp_a(x: ResultCompA) {}
fn drop_result_comp_b(x: ResultCompB) {}

const RCA_TYPE_ID: i32 = 1701;
const RCB_TYPE_ID: i32 = 1702;

@test "ecs_world_try_get returns ok for present component"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<ResultCompA, i32, i32>(w0, RCA_TYPE_ID, 0);
    let (w2, e) = ecs_world_spawn<i32, i32>(w1);
    let w3 = ecs_world_insert<ResultCompA, i32, i32>(w2, e, RCA_TYPE_ID, ResultCompA { v: 11 });
    let r = ecs_world_try_get<ResultCompA, i32, i32>(w3, e, RCA_TYPE_ID, ResultCompA { v: -1 });
    if result_is_ok<ResultCompA>(r) != true { panic(17001); };
    let got = result_unwrap<ResultCompA>(r);
    if got.v != 11 { panic(17002); };
}

@test "ecs_world_try_get returns err for missing component"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<ResultCompB, i32, i32>(w0, RCB_TYPE_ID, 0);
    let (w2, e) = ecs_world_spawn<i32, i32>(w1);
    let r = ecs_world_try_get<ResultCompB, i32, i32>(w2, e, RCB_TYPE_ID, ResultCompB { v: -1 });
    if result_is_err<ResultCompB>(r) != true { panic(17003); };
    if result_error_code<ResultCompB>(r) != ERR_COMPONENT_NOT_FOUND() { panic(17004); };
}

@test "ecs_world_try_get_resource returns ok then err"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_insert_resource<i32, i32>(w0, 4242);
    let r1 = ecs_world_try_get_resource<i32, i32>(w1, -1);
    if result_is_ok<i32>(r1) != true { panic(17005); };
    if result_unwrap<i32>(r1) != 4242 { panic(17006); };
    let w2 = ecs_world_remove_resource<i32, i32>(w1);
    let r2 = ecs_world_try_get_resource<i32, i32>(w2, -1);
    if result_is_err<i32>(r2) != true { panic(17007); };
    if result_error_code<i32>(r2) != ERR_RESOURCE_NOT_FOUND() { panic(17008); };
}
