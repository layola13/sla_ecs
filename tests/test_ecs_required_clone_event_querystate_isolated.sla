// Isolated test: Bevy ECS RequiredComponents + ComponentCloneBehavior +
// Event/EntityEvent/EventKey + QueryState + Entity unique collections parity.
// Mirrors src/component/required.rs + clone.rs + src/event/mod.rs + src/query/state.rs + src/entity/unique_*.rs

// === RequiredComponents (src/component/required.rs) ===
struct RequiredComponent {
    component_id: i32,
    constructor_id: i32,
}

struct RequiredComponents {
    required: Vec<RequiredComponent>,
}

fn rc_new() -> RequiredComponents { return RequiredComponents { required: Vec::new() }; }

fn rc_register(rc: RequiredComponents, component_id: i32, constructor_id: i32) -> RequiredComponents {
    let i: i64 = 0;
    let cnt = len(rc.required) as i64;
    while i < cnt {
        if rc.required[i].component_id == component_id { return rc; };
        i = i + 1;
    }
    rc.required.push(RequiredComponent { component_id: component_id, constructor_id: constructor_id });
    return rc;
}

fn rc_iter_ids(rc: RequiredComponents) -> Vec<i32> {
    let ids: Vec<i32> = Vec::new();
    let i: i64 = 0;
    let cnt = len(rc.required) as i64;
    while i < cnt { ids.push(rc.required[i].component_id); i = i + 1; }
    return ids;
}

fn rc_contains(rc: RequiredComponents, cid: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(rc.required) as i64;
    while i < cnt { if rc.required[i].component_id == cid { return true; }; i = i + 1; }
    return false;
}

fn rc_len(rc: RequiredComponents) -> i64 { return len(rc.required) as i64; }

fn rc_get_constructor(rc: RequiredComponents, cid: i32) -> i32 {
    let i: i64 = 0;
    let cnt = len(rc.required) as i64;
    while i < cnt { if rc.required[i].component_id == cid { return rc.required[i].constructor_id; }; i = i + 1; }
    return -1;
}

// === ComponentCloneBehavior (src/component/clone.rs) ===
const CLONE_BEHAVIOR_CLONE: i32 = 0;
const CLONE_BEHAVIOR_REFLECT: i32 = 1;
const CLONE_BEHAVIOR_IGNORE: i32 = 2;
const CLONE_BEHAVIOR_CUSTOM: i32 = 3;

struct ComponentCloneBehavior {
    behavior: i32,
    custom_fn_id: i32,
}

fn ccb_clone() -> ComponentCloneBehavior { return ComponentCloneBehavior { behavior: CLONE_BEHAVIOR_CLONE, custom_fn_id: 0 }; }
fn ccb_reflect() -> ComponentCloneBehavior { return ComponentCloneBehavior { behavior: CLONE_BEHAVIOR_REFLECT, custom_fn_id: 0 }; }
fn ccb_ignore() -> ComponentCloneBehavior { return ComponentCloneBehavior { behavior: CLONE_BEHAVIOR_IGNORE, custom_fn_id: 0 }; }
fn ccb_custom(fn_id: i32) -> ComponentCloneBehavior { return ComponentCloneBehavior { behavior: CLONE_BEHAVIOR_CUSTOM, custom_fn_id: fn_id }; }

fn ccb_resolve(b: ComponentCloneBehavior, default_fn: i32) -> i32 {
    if b.behavior == CLONE_BEHAVIOR_CUSTOM { return b.custom_fn_id; };
    if b.behavior == CLONE_BEHAVIOR_IGNORE { return 0; };
    if b.behavior == CLONE_BEHAVIOR_REFLECT { return default_fn; };
    return default_fn;
}

fn ccb_behavior(b: ComponentCloneBehavior) -> i32 { return b.behavior; }

// === Event / EntityEvent / EventKey (src/event/mod.rs) ===
struct EventRegistry {
    next_key: i32,
    keys: Vec<i32>,
}

fn er_new() -> EventRegistry { return EventRegistry { next_key: 0, keys: Vec::new() }; }

fn er_register_event_key(er: EventRegistry) -> (EventRegistry, i32) {
    let key = er.next_key;
    er.keys.push(key);
    er.next_key = key + 1;
    return (er, key);
}

fn er_event_key(er: EventRegistry, key: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(er.keys) as i64;
    while i < cnt { if er.keys[i] == key { return true; }; i = i + 1; }
    return false;
}

fn er_count(er: EventRegistry) -> i64 { return len(er.keys) as i64; }

// EntityEvent target: entity the event is sent to
struct EntityEventTarget {
    event_key: i32,
    target_entity: i64,
    is_global: bool,
}

fn eet_entity(key: i32, entity: i64) -> EntityEventTarget {
    return EntityEventTarget { event_key: key, target_entity: entity, is_global: false };
}

fn eet_global(key: i32) -> EntityEventTarget {
    return EntityEventTarget { event_key: key, target_entity: 0, is_global: true };
}

fn eet_is_global(t: EntityEventTarget) -> bool { return t.is_global; }
fn eet_target(t: EntityEventTarget) -> i64 { return t.target_entity; }
fn eet_key(t: EntityEventTarget) -> i32 { return t.event_key; }

// === QueryState (src/query/state.rs) ===
struct QueryState {
    component_access_reads: Vec<i32>,
    component_access_writes: Vec<i32>,
    world_id: i64,
    matched_table_count: i64,
    matched_archetype_count: i64,
    is_initialized: bool,
}

fn qs_new(world_id: i64) -> QueryState {
    return QueryState { component_access_reads: Vec::new(), component_access_writes: Vec::new(), world_id: world_id, matched_table_count: 0, matched_archetype_count: 0, is_initialized: false };
}

fn qs_init_access(qs: QueryState) -> QueryState { qs.is_initialized = true; return qs; }

fn qs_add_read(qs: QueryState, cid: i32) -> QueryState { qs.component_access_reads.push(cid); return qs; }
fn qs_add_write(qs: QueryState, cid: i32) -> QueryState { qs.component_access_writes.push(cid); return qs; }

fn qs_component_access_reads(qs: QueryState) -> i64 { return len(qs.component_access_reads) as i64; }
fn qs_component_access_writes(qs: QueryState) -> i64 { return len(qs.component_access_writes) as i64; }

fn qs_validate_world(qs: QueryState, world_id: i64) -> bool { return qs.world_id == world_id; }

fn qs_is_empty(qs: QueryState) -> bool { return qs.matched_table_count == 0; }

fn qs_set_matched(qs: QueryState, tables: i64, archetypes: i64) -> QueryState {
    qs.matched_table_count = tables;
    qs.matched_archetype_count = archetypes;
    return qs;
}

fn qs_matched_tables(qs: QueryState) -> i64 { return qs.matched_table_count; }
fn qs_matched_archetypes(qs: QueryState) -> i64 { return qs.matched_archetype_count; }

// transmute: create new query state with different access but same world
fn qs_transmute(qs: QueryState, new_reads: Vec<i32>) -> QueryState {
    return QueryState { component_access_reads: new_reads, component_access_writes: Vec::new(), world_id: qs.world_id, matched_table_count: qs.matched_table_count, matched_archetype_count: qs.matched_archetype_count, is_initialized: qs.is_initialized };
}

// join: merge access from another query state
fn qs_join(qs: QueryState, other: QueryState) -> QueryState {
    let i: i64 = 0;
    let cnt = len(other.component_access_reads) as i64;
    while i < cnt { qs.component_access_reads.push(other.component_access_reads[i]); i = i + 1; }
    return qs;
}

// === Entity Unique Collections (src/entity/unique_vec.rs) ===
struct UniqueVec {
    items: Vec<i64>,
}

fn uv_new() -> UniqueVec { return UniqueVec { items: Vec::new() }; }
fn uv_with_capacity(cap: i64) -> UniqueVec {
    let v: Vec<i64> = Vec::new();
    return UniqueVec { items: v };
}
fn uv_push(uv: UniqueVec, item: i64) -> UniqueVec { uv.items.push(item); return uv; }
fn uv_len(uv: UniqueVec) -> i64 { return len(uv.items) as i64; }
fn uv_is_empty(uv: UniqueVec) -> bool { return len(uv.items) == 0; }
fn uv_pop(uv: UniqueVec) -> (bool, i64, UniqueVec) {
    let cnt = len(uv.items) as i64;
    if cnt == 0 { return (false, 0, uv); };
    let val = uv.items[cnt - 1];
    uv.items.pop();
    return (true, val, uv);
}
fn uv_swap_remove(uv: UniqueVec, idx: i64) -> (i64, UniqueVec) {
    let val = uv.items[idx];
    let cnt = len(uv.items) as i64;
    uv.items[idx] = uv.items[cnt - 1];
    uv.items.pop();
    return (val, uv);
}
fn uv_get(uv: UniqueVec, idx: i64) -> i64 { return uv.items[idx]; }
fn uv_truncate(uv: UniqueVec, new_len: i64) -> UniqueVec {
    let cnt = len(uv.items) as i64;
    while cnt > new_len { uv.items.pop(); cnt = cnt - 1; }
    return uv;
}
fn uv_clear(uv: UniqueVec) -> UniqueVec { uv.items = Vec::new(); return uv; }

// === Tests ===

@test "required components register"() {
    let rc = rc_register(rc_new(), 5, 10);
    if rc_len(rc) != 1 { panic(26001); };
    if rc_contains(rc, 5) != true { panic(26002); };
}

@test "required components register dedup"() {
    let rc = rc_register(rc_register(rc_new(), 5, 10), 5, 20);
    if rc_len(rc) != 1 { panic(26003); };
}

@test "required components iter_ids"() {
    let rc = rc_register(rc_register(rc_new(), 1, 10), 2, 20);
    let ids = rc_iter_ids(rc);
    if len(ids) as i64 != 2 { panic(26004); };
    if ids[0] != 1 { panic(26005); };
}

@test "required components get_constructor"() {
    let rc = rc_register(rc_new(), 5, 42);
    if rc_get_constructor(rc, 5) != 42 { panic(26006); };
    if rc_get_constructor(rc, 99) != -1 { panic(26007); };
}

@test "required components contains absent"() {
    if rc_contains(rc_new(), 5) != false { panic(26008); };
}

@test "clone behavior clone"() {
    let b = ccb_clone();
    if ccb_behavior(b) != CLONE_BEHAVIOR_CLONE { panic(26009); };
}

@test "clone behavior reflect"() {
    let b = ccb_reflect();
    if ccb_behavior(b) != CLONE_BEHAVIOR_REFLECT { panic(26010); };
}

@test "clone behavior ignore"() {
    let b = ccb_ignore();
    if ccb_behavior(b) != CLONE_BEHAVIOR_IGNORE { panic(26011); };
}

@test "clone behavior custom"() {
    let b = ccb_custom(77);
    if ccb_behavior(b) != CLONE_BEHAVIOR_CUSTOM { panic(26012); };
}

@test "clone behavior resolve custom"() {
    let b = ccb_custom(77);
    if ccb_resolve(b, 99) != 77 { panic(26013); };
}

@test "clone behavior resolve reflect uses default"() {
    let b = ccb_reflect();
    if ccb_resolve(b, 99) != 99 { panic(26014); };
}

@test "clone behavior resolve ignore returns zero"() {
    let b = ccb_ignore();
    if ccb_resolve(b, 99) != 0 { panic(26015); };
}

@test "event registry register key"() {
    let r = er_register_event_key(er_new());
    if er_count(r.0) != 1 { panic(26016); };
    if r.1 != 0 { panic(26017); };
}

@test "event registry register multiple"() {
    let r1 = er_register_event_key(er_new());
    let r2 = er_register_event_key(r1.0);
    if r2.1 != 1 { panic(26018); };
    if er_count(r2.0) != 2 { panic(26019); };
}

@test "event registry event_key lookup"() {
    let r = er_register_event_key(er_new());
    if er_event_key(r.0, r.1) != true { panic(26020); };
    if er_event_key(r.0, 999) != false { panic(26021); };
}

@test "entity event target entity"() {
    let t = eet_entity(5, 42);
    if eet_is_global(t) != false { panic(26022); };
    if eet_target(t) != 42 { panic(26023); };
    if eet_key(t) != 5 { panic(26024); };
}

@test "entity event target global"() {
    let t = eet_global(5);
    if eet_is_global(t) != true { panic(26025); };
}

@test "query state new"() {
    let qs = qs_new(100);
    if qs_is_empty(qs) != true { panic(26026); };
    if qs_validate_world(qs, 100) != true { panic(26027); };
}

@test "query state init access"() {
    let qs = qs_init_access(qs_new(1));
    if qs.is_initialized != true { panic(26028); };
}

@test "query state add read write"() {
    let qs = qs_add_write(qs_add_read(qs_new(1), 5), 10);
    if qs_component_access_reads(qs) != 1 { panic(26029); };
    if qs_component_access_writes(qs) != 1 { panic(26030); };
}

@test "query state validate world mismatch"() {
    let qs = qs_new(100);
    if qs_validate_world(qs, 200) != false { panic(26031); };
}

@test "query state matched tables"() {
    let qs = qs_set_matched(qs_new(1), 5, 3);
    if qs_matched_tables(qs) != 5 { panic(26032); };
    if qs_matched_archetypes(qs) != 3 { panic(26033); };
    if qs_is_empty(qs) != false { panic(26034); };
}

@test "query state transmute"() {
    let qs = qs_set_matched(qs_new(1), 5, 3);
    let reads: Vec<i32> = Vec::new();
    reads.push(42);
    let qs2 = qs_transmute(qs, reads);
    if qs_validate_world(qs2, 1) != true { panic(26035); };
    if qs_matched_tables(qs2) != 5 { panic(26036); };
}

@test "query state join"() {
    let qs1 = qs_add_read(qs_new(1), 5);
    let qs2 = qs_add_read(qs_new(1), 10);
    let joined = qs_join(qs1, qs2);
    if qs_component_access_reads(joined) != 2 { panic(26037); };
}

@test "unique vec push and len"() {
    let uv = uv_push(uv_push(uv_new(), 10), 20);
    if uv_len(uv) != 2 { panic(26038); };
}

@test "unique vec is_empty"() {
    if uv_is_empty(uv_new()) != true { panic(26039); };
}

@test "unique vec pop"() {
    let uv = uv_push(uv_new(), 10);
    let r = uv_pop(uv);
    if r.0 != true { panic(26040); };
    if r.1 != 10 { panic(26041); };
    if uv_len(r.2) != 0 { panic(26042); };
}

@test "unique vec pop empty"() {
    let r = uv_pop(uv_new());
    if r.0 != false { panic(26043); };
}

@test "unique vec swap_remove"() {
    let uv = uv_push(uv_push(uv_push(uv_new(), 10), 20), 30);
    let r = uv_swap_remove(uv, 0);
    if r.0 != 10 { panic(26044); };
    if uv_len(r.1) != 2 { panic(26045); };
}

@test "unique vec get"() {
    let uv = uv_push(uv_push(uv_new(), 10), 20);
    if uv_get(uv, 0) != 10 { panic(26046); };
    if uv_get(uv, 1) != 20 { panic(26047); };
}

@test "unique vec truncate"() {
    let uv = uv_push(uv_push(uv_push(uv_new(), 10), 20), 30);
    let uv2 = uv_truncate(uv, 1);
    if uv_len(uv2) != 1 { panic(26048); };
}

@test "unique vec clear"() {
    let uv = uv_clear(uv_push(uv_new(), 10));
    if uv_is_empty(uv) != true { panic(26049); };
}

@test "unique vec with_capacity"() {
    let uv = uv_with_capacity(16);
    if uv_is_empty(uv) != true { panic(26050); };
}
