@import "lib/observer_centralized_storage.sla"

// Isolated tests for lib/observer_centralized_storage.sla — Observers + CachedObservers
// Bevy reference: bevy_ecs/src/observer/centralized_storage.rs

@test "cached_observers_new"() {
    let c = ecs_cached_observers_new();
    if ecs_cached_observers_is_empty(c) != true { panic(83200); };
    if ecs_cached_observers_global_count(c) != 0 { panic(83201); };
}

@test "cached_observers_add_global"() {
    let c = ecs_cached_observers_new();
    let c2 = ecs_cached_observers_add_global(c, 42);
    if ecs_cached_observers_global_count(c2) != 1 { panic(83202); };
    if ecs_cached_observers_is_empty(c2) != false { panic(83203); };
}

@test "cached_observers_add_component"() {
    let c = ecs_cached_observers_new();
    let c2 = ecs_cached_observers_add_component(c, 5, 42);
    if ecs_cached_observers_component_count(c2) != 1 { panic(83204); };
    let runners = ecs_cached_observers_get_component_runners(c2, 5);
    if len(runners) != 1 { panic(83205); };
    if runners[0] != 42 { panic(83206); };
}

@test "cached_observers_add_component_multiple_runners"() {
    let c = ecs_cached_observers_new();
    let c2 = ecs_cached_observers_add_component(c, 5, 10);
    let c3 = ecs_cached_observers_add_component(c2, 5, 20);
    if ecs_cached_observers_component_count(c3) != 1 { panic(83207); };
    let runners = ecs_cached_observers_get_component_runners(c3, 5);
    if len(runners) != 2 { panic(83208); };
}

@test "cached_observers_add_entity"() {
    let c = ecs_cached_observers_new();
    let c2 = ecs_cached_observers_add_entity(c, 100, 42);
    if ecs_cached_observers_entity_count(c2) != 1 { panic(83209); };
    let runners = ecs_cached_observers_get_entity_runners(c2, 100);
    if len(runners) != 1 { panic(83210); };
    if runners[0] != 42 { panic(83211); };
}

@test "cached_observers_get_component_not_found"() {
    let c = ecs_cached_observers_new();
    let runners = ecs_cached_observers_get_component_runners(c, 99);
    if len(runners) != 0 { panic(83212); };
}

@test "cached_observers_get_entity_not_found"() {
    let c = ecs_cached_observers_new();
    let runners = ecs_cached_observers_get_entity_runners(c, 999);
    if len(runners) != 0 { panic(83213); };
}

@test "observers_new"() {
    let o = ecs_observers_new();
    let r = ecs_observers_get(o, ECS_OBS_EVENT_ADD);
    if r.0 != true { panic(83214); };
    if ecs_cached_observers_is_empty(r.1) != true { panic(83215); };
}

@test "observers_get_lifecycle_add"() {
    let o = ecs_observers_new();
    let r = ecs_observers_get(o, ECS_OBS_EVENT_ADD);
    if r.0 != true { panic(83216); };
}

@test "observers_get_lifecycle_insert"() {
    let o = ecs_observers_new();
    let r = ecs_observers_get(o, ECS_OBS_EVENT_INSERT);
    if r.0 != true { panic(83217); };
}

@test "observers_get_not_found"() {
    let o = ecs_observers_new();
    let r = ecs_observers_get(o, 999);
    if r.0 != false { panic(83218); };
}

@test "observers_add_global_add"() {
    let o = ecs_observers_new();
    let o2 = ecs_observers_add_global(o, ECS_OBS_EVENT_ADD, 42);
    let r = ecs_observers_get(o2, ECS_OBS_EVENT_ADD);
    if ecs_cached_observers_global_count(r.1) != 1 { panic(83219); };
}

@test "observers_add_global_remove"() {
    let o = ecs_observers_new();
    let o2 = ecs_observers_add_global(o, ECS_OBS_EVENT_REMOVE, 99);
    let r = ecs_observers_get(o2, ECS_OBS_EVENT_REMOVE);
    if ecs_cached_observers_global_count(r.1) != 1 { panic(83220); };
}

@test "observers_add_global_extra"() {
    let o = ecs_observers_new();
    let o2 = ecs_observers_add_global(o, 100, 42);
    let r = ecs_observers_get(o2, 100);
    if r.0 != true { panic(83221); };
    if ecs_cached_observers_global_count(r.1) != 1 { panic(83222); };
}

@test "is_archetype_cached_add"() {
    if ecs_observers_is_archetype_cached(ECS_OBS_EVENT_ADD) != ECS_ARCHETYPE_FLAG_ON_ADD { panic(83223); };
}

@test "is_archetype_cached_insert"() {
    if ecs_observers_is_archetype_cached(ECS_OBS_EVENT_INSERT) != ECS_ARCHETYPE_FLAG_ON_INSERT { panic(83224); };
}

@test "is_archetype_cached_remove"() {
    if ecs_observers_is_archetype_cached(ECS_OBS_EVENT_REMOVE) != ECS_ARCHETYPE_FLAG_ON_REMOVE { panic(83225); };
}

@test "is_archetype_cached_despawn"() {
    if ecs_observers_is_archetype_cached(ECS_OBS_EVENT_DESPAWN) != ECS_ARCHETYPE_FLAG_ON_DESPAWN { panic(83226); };
}

@test "is_archetype_cached_not_cached"() {
    if ecs_observers_is_archetype_cached(999) != 0 { panic(83227); };
}

@test "observers_get_or_create_new"() {
    let o = ecs_observers_new();
    let r = ecs_observers_get_or_create(o, 200);
    let o2 = r.0;
    let cached = r.1;
    if ecs_cached_observers_is_empty(cached) != true { panic(83228); };
    // Should now be retrievable
    let r2 = ecs_observers_get(o2, 200);
    if r2.0 != true { panic(83229); };
}

@test "cached_component_observers_count"() {
    let c = ecs_cached_component_observers_new();
    let c2 = ecs_cached_component_observers_add(c, 1, 10);
    let c3 = ecs_cached_component_observers_add(c2, 2, 20);
    if ecs_cached_component_observers_count(c3) != 2 { panic(83230); };
}
