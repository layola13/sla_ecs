// Integration test for lib/schedule_graph.sla + lib/entity_access.sla
@import "lib/schedule_graph.sla"
@import "lib/entity_access.sla"

// === schedule_graph tests ===

@test "digraph add node"() {
    let g = ecs_digraph_add_node(ecs_digraph_new(), 5);
    if ecs_digraph_node_count(g) != 1 { panic(32001); };
    if ecs_digraph_contains_node(g, 5) != true { panic(32002); };
}

@test "digraph add edge"() {
    let g = ecs_digraph_add_edge(ecs_digraph_add_edge(ecs_digraph_new(), 0, 1), 1, 2);
    if ecs_digraph_edge_count(g) != 2 { panic(32003); };
    if ecs_digraph_contains_edge(g, 0, 1) != true { panic(32004); };
}

@test "digraph remove edge"() {
    let g = ecs_digraph_add_edge(ecs_digraph_new(), 0, 1);
    let r = ecs_digraph_remove_edge(g, 0, 1);
    if r.0 != true { panic(32005); };
    if ecs_digraph_edge_count(r.1) != 0 { panic(32006); };
}

@test "digraph neighbors"() {
    let g = ecs_digraph_add_edge(ecs_digraph_add_edge(ecs_digraph_new(), 0, 1), 0, 2);
    let n = ecs_digraph_neighbors(g, 0);
    if len(n) as i64 != 2 { panic(32007); };
}

@test "digraph toposort linear"() {
    let g = ecs_digraph_add_edge(ecs_digraph_add_edge(ecs_digraph_new(), 0, 1), 1, 2);
    let r = ecs_digraph_toposort(g);
    if r.0 != true { panic(32008); };
    if len(r.1) as i64 != 3 { panic(32009); };
    if r.1[0] != 0 { panic(32010); };
}

@test "digraph toposort cycle"() {
    let g = ecs_digraph_add_edge(ecs_digraph_add_edge(ecs_digraph_new(), 0, 1), 1, 0);
    let r = ecs_digraph_toposort(g);
    if r.0 != false { panic(32011); };
}

@test "digraph toposort diamond"() {
    let g = ecs_digraph_add_edge(ecs_digraph_add_edge(ecs_digraph_add_edge(ecs_digraph_add_edge(ecs_digraph_new(), 0, 1), 0, 2), 1, 3), 2, 3);
    let r = ecs_digraph_toposort(g);
    if r.0 != true { panic(32012); };
    if r.1[0] != 0 { panic(32013); };
    if r.1[3] != 3 { panic(32014); };
}

@test "dag new dirty"() {
    let d = ecs_dag_new();
    if ecs_dag_is_dirty(d) != false { panic(32015); };
    if ecs_dag_is_toposorted(d) != false { panic(32016); };
}

@test "dag add edge marks dirty"() {
    let d = ecs_dag_add_edge(ecs_dag_new(), 0, 1);
    if ecs_dag_is_dirty(d) != true { panic(32017); };
}

@test "dag toposort clears dirty"() {
    let d = ecs_dag_add_edge(ecs_dag_new(), 0, 1);
    let r = ecs_dag_toposort(d);
    if ecs_dag_is_dirty(r.1) != false { panic(32018); };
    if ecs_dag_is_toposorted(r.1) != true { panic(32019); };
}

@test "dag get_toposort cached"() {
    let d = ecs_dag_add_edge(ecs_dag_new(), 0, 1);
    let r = ecs_dag_toposort(d);
    let cached = ecs_dag_get_toposort(r.1);
    if len(cached) as i64 != 2 { panic(32020); };
}

@test "dag contains edge"() {
    let d = ecs_dag_add_edge(ecs_dag_new(), 0, 1);
    if ecs_dag_contains_edge(d, 0, 1) != true { panic(32021); };
    if ecs_dag_contains_edge(d, 1, 0) != false { panic(32022); };
}

@test "tarjan scc single node"() {
    let sccs = ecs_tarjan_compute(1, Vec::new());
    if ecs_tarjan_scc_count(sccs) != 1 { panic(32023); };
}

@test "tarjan scc cycle"() {
    let edges: Vec<EcsGraphEdge> = Vec::new();
    edges.push(ecs_graph_edge_new(0, 1));
    edges.push(ecs_graph_edge_new(1, 0));
    let sccs = ecs_tarjan_compute(2, edges);
    if ecs_tarjan_scc_count(sccs) != 1 { panic(32024); };
}

@test "tarjan scc disconnected"() {
    let sccs = ecs_tarjan_compute(3, Vec::new());
    if ecs_tarjan_scc_count(sccs) != 3 { panic(32025); };
}

// === entity_access tests ===

@test "entity ref contains"() {
    let r = ecs_entity_ref_add(ecs_entity_ref_new(1), 5, 42);
    if ecs_entity_ref_contains(r, 5) != true { panic(32026); };
    if ecs_entity_ref_contains(r, 99) != false { panic(32027); };
}

@test "entity ref get"() {
    let r = ecs_entity_ref_add(ecs_entity_ref_new(1), 5, 42);
    let g = ecs_entity_ref_get(r, 5);
    if g.0 != true { panic(32028); };
    if g.1 != 42 { panic(32029); };
}

@test "entity ref id"() {
    if ecs_entity_ref_id(ecs_entity_ref_new(77)) != 77 { panic(32030); };
}

@test "entity ref component count"() {
    let r = ecs_entity_ref_add(ecs_entity_ref_add(ecs_entity_ref_new(1), 5, 42), 6, 99);
    if ecs_entity_ref_component_count(r) != 2 { panic(32031); };
}

@test "entity world mut insert new"() {
    let m = ecs_entity_world_mut_insert(ecs_entity_world_mut_new(1), 5, 42);
    if ecs_entity_world_mut_contains(m, 5) != true { panic(32032); };
}

@test "entity world mut insert update"() {
    let m = ecs_entity_world_mut_insert(ecs_entity_world_mut_insert(ecs_entity_world_mut_new(1), 5, 42), 5, 99);
    let g = ecs_entity_world_mut_get(m, 5);
    if g.1 != 99 { panic(32033); };
}

@test "entity world mut remove"() {
    let m = ecs_entity_world_mut_remove(ecs_entity_world_mut_insert(ecs_entity_world_mut_new(1), 5, 42), 5);
    if ecs_entity_world_mut_contains(m, 5) != false { panic(32034); };
}

@test "entry occupied"() {
    let r = ecs_entity_ref_add(ecs_entity_ref_new(1), 5, 42);
    let e = ecs_entity_ref_entry(r, 5);
    if ecs_entry_is_occupied(e) != true { panic(32035); };
    if ecs_entry_get(e) != 42 { panic(32036); };
}

@test "entry vacant"() {
    let r = ecs_entity_ref_new(1);
    let e = ecs_entity_ref_entry(r, 5);
    if ecs_entry_is_occupied(e) != false { panic(32037); };
}

@test "entry or_insert vacant"() {
    let e = ecs_entry_or_insert(ecs_entry_vacant(5), 42);
    if ecs_entry_is_occupied(e) != true { panic(32038); };
    if ecs_entry_get(e) != 42 { panic(32039); };
}

@test "entry or_insert occupied keeps"() {
    let e = ecs_entry_or_insert(ecs_entry_occupied(5, 99), 42);
    if ecs_entry_get(e) != 99 { panic(32040); };
}

@test "filtered entity ref allow"() {
    let f = ecs_filtered_entity_ref_allow(ecs_filtered_entity_ref_new(1), 5);
    if ecs_filtered_entity_ref_is_allowed(f, 5) != true { panic(32041); };
    if ecs_filtered_entity_ref_is_allowed(f, 6) != false { panic(32042); };
}
