@import "lib/schedule_auto_insert_deferred.sla"

// === Basic ===

@test "auto insert pass new"() {
    let p = ecs_auto_insert_pass_new();
    if ecs_auto_insert_sync_point_count(p) != 0 { panic(76001); };
    if ecs_auto_insert_no_sync_edge_count(p) != 0 { panic(76002); };
}

// === edge_key ===

@test "edge_key encoding"() {
    if ecs_auto_insert_edge_key(1, 2) != 10002 { panic(76010); };
    if ecs_auto_insert_edge_key(3, 4) != 30004 { panic(76011); };
}

// === add_dependency with ignore ===

@test "add_dependency ignore"() {
    let p = ecs_auto_insert_pass_new();
    let p2 = ecs_auto_insert_add_dependency(p, 1, 2, true);
    if ecs_auto_insert_no_sync_edge_count(p2) != 1 { panic(76020); };
    if ecs_auto_insert_is_no_sync(p2, 1, 2) != true { panic(76021); };
}

@test "add_dependency normal"() {
    let p = ecs_auto_insert_pass_new();
    let p2 = ecs_auto_insert_add_dependency(p, 1, 2, false);
    if ecs_auto_insert_no_sync_edge_count(p2) != 0 { panic(76030); };
    if ecs_auto_insert_is_no_sync(p2, 1, 2) != false { panic(76031); };
}

// === should_insert_sync ===

@test "should_insert true"() {
    let p = ecs_auto_insert_pass_new();
    if ecs_auto_insert_should_insert_sync(p, 1, 2, true) != true { panic(76040); };
}

@test "should_insert false no deferred"() {
    let p = ecs_auto_insert_pass_new();
    if ecs_auto_insert_should_insert_sync(p, 1, 2, false) != false { panic(76050); };
}

@test "should_insert false no_sync"() {
    let p = ecs_auto_insert_pass_new();
    let p2 = ecs_auto_insert_add_dependency(p, 1, 2, true);
    if ecs_auto_insert_should_insert_sync(p2, 1, 2, true) != false { panic(76060); };
}

// === get_sync_point ===

@test "get_sync_point creates new"() {
    let p = ecs_auto_insert_pass_new();
    let r = ecs_auto_insert_get_sync_point(p, 5);
    if r.1 != 0 { panic(76070); };
    if ecs_auto_insert_sync_point_count(r.0) != 1 { panic(76071); };
}

@test "get_sync_point reuses existing"() {
    let p = ecs_auto_insert_pass_new();
    let r1 = ecs_auto_insert_get_sync_point(p, 5);
    let r2 = ecs_auto_insert_get_sync_point(r1.0, 5);
    if r2.1 != 0 { panic(76080); };
    if ecs_auto_insert_sync_point_count(r2.0) != 1 { panic(76081); };
}

@test "get_sync_point different distances"() {
    let p = ecs_auto_insert_pass_new();
    let r1 = ecs_auto_insert_get_sync_point(p, 5);
    let r2 = ecs_auto_insert_get_sync_point(r1.0, 10);
    if r2.1 != 1 { panic(76090); };
    if ecs_auto_insert_sync_point_count(r2.0) != 2 { panic(76091); };
}

// === add_auto_sync ===

@test "add_auto_sync"() {
    let p = ecs_auto_insert_pass_new();
    let r1 = ecs_auto_insert_add_auto_sync(p);
    let r2 = ecs_auto_insert_add_auto_sync(r1.0);
    if r1.1 != 0 { panic(76100); };
    if r2.1 != 1 { panic(76101); };
}

// === build ===

@test "build with deferred"() {
    let p = ecs_auto_insert_pass_new();
    let edges_from = Vec::new();
    edges_from.push(1);
    edges_from.push(2);
    let edges_to = Vec::new();
    edges_to.push(3);
    edges_to.push(4);
    let flags = Vec::new();
    flags.push(true);
    flags.push(true);
    let result = ecs_auto_insert_build(p, edges_from, edges_to, flags);
    // Each edge with deferred gets 3 entries (from, sync, to) = 6 total
    if len(result.1) as i64 != 6 { panic(76110); };
}

@test "build without deferred"() {
    let p = ecs_auto_insert_pass_new();
    let edges_from = Vec::new();
    edges_from.push(1);
    let edges_to = Vec::new();
    edges_to.push(2);
    let flags = Vec::new();
    flags.push(false);
    let result = ecs_auto_insert_build(p, edges_from, edges_to, flags);
    // No deferred: direct edge = 2 entries
    if len(result.1) as i64 != 2 { panic(76120); };
}

@test "build mixed"() {
    let p = ecs_auto_insert_pass_new();
    let edges_from = Vec::new();
    edges_from.push(1);
    edges_from.push(2);
    let edges_to = Vec::new();
    edges_to.push(3);
    edges_to.push(4);
    let flags = Vec::new();
    flags.push(true);
    flags.push(false);
    let result = ecs_auto_insert_build(p, edges_from, edges_to, flags);
    // First edge deferred: 3 entries; second not: 2 entries = 5 total
    if len(result.1) as i64 != 5 { panic(76130); };
}

@test "build with ignore_deferred edge"() {
    let p = ecs_auto_insert_pass_new();
    let p2 = ecs_auto_insert_add_dependency(p, 1, 3, true);
    let edges_from = Vec::new();
    edges_from.push(1);
    let edges_to = Vec::new();
    edges_to.push(3);
    let flags = Vec::new();
    flags.push(true);
    let result = ecs_auto_insert_build(p2, edges_from, edges_to, flags);
    // Edge is no_sync: direct edge = 2 entries
    if len(result.1) as i64 != 2 { panic(76140); };
}

// === build reuses sync points ===

@test "build reuses sync points"() {
    let p = ecs_auto_insert_pass_new();
    let edges_from = Vec::new();
    edges_from.push(1);
    edges_from.push(2);
    let edges_to = Vec::new();
    edges_to.push(3);
    edges_to.push(4);
    let flags = Vec::new();
    flags.push(true);
    flags.push(true);
    let result = ecs_auto_insert_build(p, edges_from, edges_to, flags);
    // Both edges deferred, same distance=0: 1 sync point reused
    if ecs_auto_insert_sync_point_count(result.0) != 1 { panic(76150); };
}
