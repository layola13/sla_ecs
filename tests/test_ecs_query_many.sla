// Verification tests for multi-entity fetch facades (get_many / iter_many).
@import "../lib/ecs_world.sla"

struct QmComp { v: i32 }
fn drop_qm_comp(x: QmComp) {}

const QM_ID: i32 = 2001;

// get_many (Bevy Query::get_many): all input entities must match, else panic.
// Returns items in input order.
@test "get_many returns all matching in input order"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<QmComp, i32, i32>(w0, QM_ID, 0);
    let (w2, e1) = ecs_world_spawn<i32, i32>(w1);
    let w3 = ecs_world_insert<QmComp, i32, i32>(w2, e1, QM_ID, QmComp { v: 10 });
    let (w4, e2) = ecs_world_spawn<i32, i32>(w3);
    let w5 = ecs_world_insert<QmComp, i32, i32>(w4, e2, QM_ID, QmComp { v: 20 });
    let entities: Vec<Entity> = Vec::new();
    entities.push(e2);
    entities.push(e1);
    let q = ecs_world_get_many<QmComp, i32, i32>(w5, entities, QM_ID);
    if len(q.items) != 2 { panic(20001); };
    if q.items[0].value.v != 20 { panic(20002); };
    if q.items[1].value.v != 10 { panic(20003); };
}

// iter_many (Bevy Query::iter_many): iterates, skipping non-matching entities,
// and allows duplicate inputs to produce duplicate outputs.
@test "iter_many skips non matching and allows duplicates"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<QmComp, i32, i32>(w0, QM_ID, 0);
    let (w2, e1) = ecs_world_spawn<i32, i32>(w1);
    let w3 = ecs_world_insert<QmComp, i32, i32>(w2, e1, QM_ID, QmComp { v: 7 });
    let (w4, e2) = ecs_world_spawn<i32, i32>(w3);
    // e2 has no component
    let entities: Vec<Entity> = Vec::new();
    entities.push(e2);
    entities.push(e1);
    entities.push(e1);
    let q = ecs_world_iter_many<QmComp, i32, i32>(w4, entities, QM_ID);
    // e2 skipped; e1 appears twice
    if len(q.items) != 2 { panic(20004); };
    if q.items[0].value.v != 7 { panic(20005); };
    if q.items[1].value.v != 7 { panic(20006); };
}
