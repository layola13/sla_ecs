@import "lib/query_state.sla"
@import "lib/query_world_query.sla"
@import "lib/query_par_iter.sla"

@test "query state add read and write"() {
    let s = ecs_query_state_new();
    s = ecs_query_state_add_read(s, 1);
    s = ecs_query_state_add_write(s, 2);
    if len(s.component_reads) as i64 != 1 { panic(57001); };
    if len(s.component_writes) as i64 != 1 { panic(57002); };
}

@test "query state matched tables and archetypes"() {
    let s = ecs_query_state_new();
    s = ecs_query_state_add_matched_table(s, 10);
    s = ecs_query_state_add_matched_archetype(s, 20);
    if ecs_query_state_matched_table_count(s) != 1 { panic(57003); };
    if ecs_query_state_matched_archetype_count(s) != 1 { panic(57004); };
}

@test "query state init access"() {
    let s = ecs_query_state_new();
    let s2 = ecs_query_state_init_access(s);
    if ecs_query_state_is_initialized(s2) != true { panic(57005); };
}

@test "query state as readonly"() {
    let s = ecs_query_state_new();
    s = ecs_query_state_add_write(s, 2);
    let ro = ecs_query_state_as_readonly(s);
    if len(ro.component_writes) as i64 != 0 { panic(57006); };
    if len(ro.component_reads) as i64 != 1 { panic(57007); };
}

@test "query state update archetypes"() {
    let s = ecs_query_state_new();
    let s2 = ecs_query_state_update_archetypes(s, 5);
    if ecs_query_state_generation(s2) != 5 { panic(57008); };
}

@test "query state is empty"() {
    let s = ecs_query_state_new();
    if ecs_query_state_is_empty(s) != true { panic(57009); };
    let s2 = ecs_query_state_add_matched_table(s, 1);
    if ecs_query_state_is_empty(s2) != false { panic(57010); };
}

@test "query state contains"() {
    let s = ecs_query_state_new();
    s = ecs_query_state_add_matched_archetype(s, 20);
    if ecs_query_state_contains(s, 20) != true { panic(57011); };
    if ecs_query_state_contains(s, 99) != false { panic(57012); };
}

@test "query state from builder"() {
    let reads: Vec<i32> = Vec::new();
    reads.push(1);
    let writes: Vec<i32> = Vec::new();
    writes.push(2);
    let s = ecs_query_state_from_builder(reads, writes);
    if len(s.component_reads) as i64 != 1 { panic(57013); };
    if len(s.component_writes) as i64 != 1 { panic(57014); };
}

@test "world query read"() {
    let q = ecs_world_query_read(5);
    if ecs_world_query_kind(q) != ECS_WQ_READ { panic(57015); };
    if ecs_world_query_is_read_only(q) != true { panic(57016); };
}

@test "world query write"() {
    let q = ecs_world_query_write(5);
    if ecs_world_query_is_write(q) != true { panic(57017); };
    if ecs_world_query_is_read_only(q) != false { panic(57018); };
}

@test "world query filter and has"() {
    let f = ecs_world_query_filter(5);
    if ecs_world_query_is_filter(f) != true { panic(57019); };
    let h = ecs_world_query_has(5);
    if ecs_world_query_is_filter(h) != true { panic(57020); };
}

@test "world query fetch"() {
    let q = ecs_world_query_read(5);
    let f = ecs_world_query_fetch_new(q, 99);
    if ecs_world_query_fetch_value(f) != 99 { panic(57021); };
    if ecs_world_query_fetch_kind(f) != ECS_WQ_READ { panic(57022); };
}

@test "par iter new and len"() {
    let p = ecs_query_par_iter_new(100);
    if ecs_query_par_iter_len(p) != 100 { panic(57023); };
    if ecs_query_par_iter_is_empty(p) != false { panic(57024); };
}

@test "par iter batching strategy"() {
    let p = ecs_query_par_iter_new(100);
    let p2 = ecs_query_par_iter_batching_strategy(p, 50);
    if ecs_query_par_iter_batch_size(p2) != 50 { panic(57025); };
}

@test "par iter for each"() {
    let p = ecs_query_par_iter_new(100);
    if ecs_query_par_iter_for_each(p) != 100 { panic(57026); };
}

@test "par iter batch count"() {
    let p = ecs_query_par_iter_new(100);
    let p2 = ecs_query_par_iter_batching_strategy(p, 30);
    if ecs_query_par_iter_batch_count(p2) != 4 { panic(57027); };
}

@test "par iter batch count exact"() {
    let p = ecs_query_par_iter_new(100);
    let p2 = ecs_query_par_iter_batching_strategy(p, 25);
    if ecs_query_par_iter_batch_count(p2) != 4 { panic(57028); };
}
