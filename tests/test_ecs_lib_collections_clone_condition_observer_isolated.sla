// Integration test for lib/entity_collections.sla + lib/component_clone.sla +
// lib/schedule_condition.sla + lib/observer_runner.sla
@import "lib/entity_collections.sla"
@import "lib/component_clone.sla"
@import "lib/schedule_condition.sla"
@import "lib/observer_runner.sla"

// === entity_collections tests ===

@test "entity hash map insert and get"() {
    let m = ecs_entity_hash_map_insert(ecs_entity_hash_map_new(), 10, 42);
    let r = ecs_entity_hash_map_get(m, 10);
    if r.0 != true { panic(33001); };
    if r.1 != 42 { panic(33002); };
}

@test "entity hash map insert update"() {
    let m = ecs_entity_hash_map_insert(ecs_entity_hash_map_insert(ecs_entity_hash_map_new(), 10, 42), 10, 99);
    let r = ecs_entity_hash_map_get(m, 10);
    if r.1 != 99 { panic(33003); };
    if ecs_entity_hash_map_len(m) != 1 { panic(33004); };
}

@test "entity hash map remove"() {
    let m = ecs_entity_hash_map_insert(ecs_entity_hash_map_new(), 10, 42);
    let r = ecs_entity_hash_map_remove(m, 10);
    if r.0 != true { panic(33005); };
    if ecs_entity_hash_map_len(r.2) != 0 { panic(33006); };
}

@test "entity hash map contains_key"() {
    let m = ecs_entity_hash_map_insert(ecs_entity_hash_map_new(), 10, 42);
    if ecs_entity_hash_map_contains_key(m, 10) != true { panic(33007); };
    if ecs_entity_hash_map_contains_key(m, 99) != false { panic(33008); };
}

@test "entity hash map keys"() {
    let m = ecs_entity_hash_map_insert(ecs_entity_hash_map_insert(ecs_entity_hash_map_new(), 10, 42), 20, 99);
    let keys = ecs_entity_hash_map_keys(m);
    if len(keys) as i64 != 2 { panic(33009); };
}

@test "entity index map insert and get"() {
    let m = ecs_entity_index_map_insert(ecs_entity_index_map_new(), 10, 42);
    let r = ecs_entity_index_map_get(m, 10);
    if r.0 != true { panic(33010); };
    if r.1 != 42 { panic(33011); };
}

@test "entity index map get_index_of"() {
    let m = ecs_entity_index_map_insert(ecs_entity_index_map_insert(ecs_entity_index_map_new(), 10, 42), 20, 99);
    if ecs_entity_index_map_get_index_of(m, 20) != 1 { panic(33012); };
    if ecs_entity_index_map_get_index_of(m, 99) != -1 { panic(33013); };
}

@test "entity index map get_by_index"() {
    let m = ecs_entity_index_map_insert(ecs_entity_index_map_insert(ecs_entity_index_map_new(), 10, 42), 20, 99);
    let r = ecs_entity_index_map_get_by_index(m, 0);
    if r.0 != 10 { panic(33014); };
    if r.1 != 42 { panic(33015); };
}

@test "entity index map shift_remove preserves order"() {
    let m = ecs_entity_index_map_insert(ecs_entity_index_map_insert(ecs_entity_index_map_insert(ecs_entity_index_map_new(), 10, 1), 20, 2), 30, 3);
    let r = ecs_entity_index_map_shift_remove(m, 20);
    if r.0 != true { panic(33016); };
    let r2 = ecs_entity_index_map_get_by_index(r.2, 1);
    if r2.0 != 30 { panic(33017); };
}

@test "entity index set insert dedup"() {
    let r1 = ecs_entity_index_set_insert(ecs_entity_index_set_new(), 10);
    let r2 = ecs_entity_index_set_insert(r1.1, 10);
    if r2.0 != false { panic(33018); };
    if ecs_entity_index_set_len(r2.1) != 1 { panic(33019); };
}

@test "entity index set contains"() {
    let r = ecs_entity_index_set_insert(ecs_entity_index_set_new(), 10);
    if ecs_entity_index_set_contains(r.1, 10) != true { panic(33020); };
    if ecs_entity_index_set_contains(r.1, 99) != false { panic(33021); };
}

@test "entity index set shift_remove"() {
    let r = ecs_entity_index_set_insert(ecs_entity_index_set_insert(ecs_entity_index_set_new(), 10).1, 20);
    let r2 = ecs_entity_index_set_shift_remove(r.1, 10);
    if r2.0 != true { panic(33022); };
    if ecs_entity_index_set_len(r2.1) != 1 { panic(33023); };
}

@test "entity index set get_index"() {
    let r = ecs_entity_index_set_insert(ecs_entity_index_set_insert(ecs_entity_index_set_new(), 10).1, 20);
    if ecs_entity_index_set_get_index(r.1, 20) != 1 { panic(33024); };
}

// === component_clone tests ===

@test "source component read"() {
    let sc = ecs_source_component_new(5, 42);
    let r = ecs_source_component_read(sc);
    if r.0 != true { panic(33025); };
    if r.1 != 42 { panic(33026); };
}

@test "entity mapper get_or_insert"() {
    let r = ecs_entity_mapper_get_or_insert(ecs_entity_mapper_new(), 10, 100);
    if r.0 != 100 { panic(33027); };
    let r2 = ecs_entity_mapper_get(r.1, 10);
    if r2.0 != true { panic(33028); };
    if r2.1 != 100 { panic(33029); };
}

@test "entity mapper len"() {
    let r = ecs_entity_mapper_get_or_insert(ecs_entity_mapper_get_or_insert(ecs_entity_mapper_new(), 10, 100).1, 20, 200);
    if ecs_entity_mapper_len(r.1) != 2 { panic(33030); };
}

@test "component clone ctx new"() {
    let ctx = ecs_component_clone_ctx_new(10, 20, 5, 42);
    if ecs_component_clone_ctx_source(ctx) != 10 { panic(33031); };
    if ecs_component_clone_ctx_target(ctx) != 20 { panic(33032); };
    if ecs_component_clone_ctx_component_id(ctx) != 5 { panic(33033); };
}

@test "component clone ctx write target"() {
    let ctx = ecs_component_clone_ctx_write_target_component(ecs_component_clone_ctx_new(10, 20, 5, 0), 99);
    if ecs_component_clone_ctx_target_component_written(ctx) != true { panic(33034); };
}

@test "component clone behavior resolve custom"() {
    let b = ecs_component_clone_behavior_custom(77);
    if ecs_component_clone_behavior_resolve(b, 99) != 77 { panic(33035); };
}

@test "component clone behavior resolve ignore"() {
    let b = ecs_component_clone_behavior_ignore();
    if ecs_component_clone_behavior_resolve(b, 99) != 0 { panic(33036); };
}

@test "component clone via clone"() {
    let sc = ecs_source_component_new(5, 42);
    let ctx = ecs_component_clone_via_clone(sc, ecs_component_clone_ctx_new(10, 20, 5, 0));
    if ecs_component_clone_ctx_target_component_written(ctx) != true { panic(33037); };
}

// === schedule_condition tests ===

@test "run_once first run"() {
    let r = ecs_run_once(ecs_run_once_state_new());
    if r.0 != true { panic(33038); };
}

@test "run_once second run"() {
    let r1 = ecs_run_once(ecs_run_once_state_new());
    let r2 = ecs_run_once(r1.1);
    if r2.0 != false { panic(33039); };
}

@test "condition resource_exists"() {
    if ecs_condition_resource_exists(true) != true { panic(33040); };
    if ecs_condition_resource_exists(false) != false { panic(33041); };
}

@test "condition resource_changed"() {
    if ecs_condition_resource_changed(true) != true { panic(33042); };
}

@test "condition resource_removed"() {
    if ecs_condition_resource_removed(false, true) != true { panic(33043); };
    if ecs_condition_resource_removed(true, true) != false { panic(33044); };
}

@test "condition not"() {
    if ecs_condition_not(true) != false { panic(33045); };
    if ecs_condition_not(false) != true { panic(33046); };
}

@test "condition and"() {
    if ecs_condition_and(true, true) != true { panic(33047); };
    if ecs_condition_and(true, false) != false { panic(33048); };
}

@test "condition or"() {
    if ecs_condition_or(false, true) != true { panic(33049); };
    if ecs_condition_or(false, false) != false { panic(33050); };
}

@test "condition on_message"() {
    if ecs_condition_on_message(5) != true { panic(33051); };
    if ecs_condition_on_message(0) != false { panic(33052); };
}

@test "condition any_with_component"() {
    if ecs_condition_any_with_component(3) != true { panic(33053); };
    if ecs_condition_any_with_component(0) != false { panic(33054); };
}

// === observer_runner tests ===

@test "trigger global"() {
    let t = ecs_trigger_global(5);
    if ecs_trigger_kind(t) != ECS_TRIGGER_GLOBAL { panic(33055); };
    if ecs_trigger_event_key(t) != 5 { panic(33056); };
}

@test "trigger entity"() {
    let t = ecs_trigger_entity(5, 42);
    if ecs_trigger_kind(t) != ECS_TRIGGER_ENTITY { panic(33057); };
    if ecs_trigger_target(t) != 42 { panic(33058); };
}

@test "trigger propagate"() {
    let t = ecs_trigger_propagate(5, 42, true);
    if ecs_trigger_get_propagate(t) != true { panic(33059); };
    let t2 = ecs_trigger_set_propagate(t, false);
    if ecs_trigger_get_propagate(t2) != false { panic(33060); };
}

@test "on event access"() {
    let o = ecs_on_new(42, 5, ecs_trigger_entity(5, 10));
    if ecs_on_event(o) != 42 { panic(33061); };
    if ecs_on_event_key(o) != 5 { panic(33062); };
}

@test "on propagate"() {
    let o = ecs_on_new(42, 5, ecs_trigger_propagate(5, 10, true));
    if ecs_on_propagate(o) != true { panic(33063); };
    let o2 = ecs_on_set_propagate(o, false);
    if ecs_on_propagate(o2) != false { panic(33064); };
}

@test "observer registry add"() {
    let r = ecs_observer_registry_add(ecs_observer_registry_new(), 5, 0);
    if ecs_observer_registry_count(r.0) != 1 { panic(33065); };
    if r.1 != 0 { panic(33066); };
}

@test "observer registry trigger"() {
    let r = ecs_observer_registry_add(ecs_observer_registry_new(), 5, 0);
    let reg = ecs_observer_registry_trigger(r.0, ecs_trigger_global(5));
    if ecs_observer_run_count(reg, r.1) != 1 { panic(33067); };
}

@test "observer registry deactivate"() {
    let r = ecs_observer_registry_add(ecs_observer_registry_new(), 5, 0);
    let reg = ecs_observer_registry_deactivate(r.0, r.1);
    let reg2 = ecs_observer_registry_trigger(reg, ecs_trigger_global(5));
    if ecs_observer_run_count(reg2, r.1) != 0 { panic(33068); };
}

@test "observer with condition"() {
    let owc = ecs_observer_with_condition_new(0);
    if ecs_observer_with_condition_should_run(owc) != true { panic(33069); };
    let owc2 = ecs_observer_with_condition_run_if(owc, false);
    if ecs_observer_with_condition_should_run(owc2) != false { panic(33070); };
}
