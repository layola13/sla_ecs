// Verification tests for Reflect trait + full ReflectComponent fn-pointer table.
@import "../lib/reflect.sla"
@import "../lib/world_registry_erased.sla"
@import "../lib/box_drop.sla"

struct ReflectPos { x: i32, y: i32 }

impl EcsReflect for ReflectPos {
    fn reflect_type_id(&self) -> i32 { return 7701; }
}

fn reflect_pos_insert(type_id: i32) -> ErasedComponentValue {
    return registry_erased_value_new<ReflectPos>(type_id, ReflectPos { x: 0, y: 0 });
}

fn reflect_pos_apply(target: ErasedComponentValue, source: ErasedComponentValue) -> ErasedComponentValue {
    let src = registry_erased_value_read<ReflectPos>(source, 7701);
    return registry_erased_value_new<ReflectPos>(7701, ReflectPos { x: src.x, y: src.y });
}

fn reflect_pos_remove(entity_row: i32) -> i32 {
    return 7701;
}

fn reflect_pos_take(entity_row: i32) -> ErasedComponentValue {
    return registry_erased_value_new<ReflectPos>(7701, ReflectPos { x: 0, y: 0 });
}

fn reflect_pos_contains(row: i32) -> bool {
    return row >= 0;
}

fn reflect_pos_reflect(row: i32) -> ErasedComponentValue {
    return registry_erased_value_new<ReflectPos>(7701, ReflectPos { x: row, y: row });
}

fn reflect_pos_copy(source_value: ErasedComponentValue) -> ErasedComponentValue {
    let src = registry_erased_value_read<ReflectPos>(source_value, 7701);
    return registry_erased_value_new<ReflectPos>(7701, ReflectPos { x: src.x, y: src.y });
}

fn reflect_pos_register() -> i32 {
    return 7701;
}

fn make_reflect_pos_fns() -> EcsReflectComponentFns {
    return EcsReflectComponentFns {
        insert: reflect_pos_insert,
        apply: reflect_pos_apply,
        remove: reflect_pos_remove,
        take: reflect_pos_take,
        contains: reflect_pos_contains,
        reflect: reflect_pos_reflect,
        copy: reflect_pos_copy,
        register_component: reflect_pos_register,
    };
}

@test "reflect trait exposes type id"() {
    let p = ReflectPos { x: 1, y: 2 };
    if p.reflect_type_id() != 7701 { panic(22001); };
}

@test "reflect component stores type id"() {
    let rc = ecs_reflect_component_new(7701, make_reflect_pos_fns());
    if ecs_reflect_component_type_id(rc) != 7701 { panic(22002); };
}

@test "reflect component insert builds erased value"() {
    let rc = ecs_reflect_component_new(7701, make_reflect_pos_fns());
    let erased = ecs_reflect_component_insert(rc, 7701);
    let typed = registry_erased_value_read<ReflectPos>(erased, 7701);
    if typed.x != 0 { panic(22003); };
    if typed.y != 0 { panic(22004); };
}

@test "reflect component contains delegates to fn"() {
    let rc = ecs_reflect_component_new(7701, make_reflect_pos_fns());
    if ecs_reflect_component_contains(rc, 5) != true { panic(22005); };
    if ecs_reflect_component_contains(rc, -1) != false { panic(22006); };
}

@test "reflect component apply copies source fields"() {
    let rc = ecs_reflect_component_new(7701, make_reflect_pos_fns());
    let target = registry_erased_value_new<ReflectPos>(7701, ReflectPos { x: 0, y: 0 });
    let source = registry_erased_value_new<ReflectPos>(7701, ReflectPos { x: 9, y: 8 });
    let applied = ecs_reflect_component_apply(rc, target, source);
    let typed = registry_erased_value_read<ReflectPos>(applied, 7701);
    if typed.x != 9 { panic(22007); };
    if typed.y != 8 { panic(22008); };
}

@test "reflect component take returns erased value"() {
    let rc = ecs_reflect_component_new(7701, make_reflect_pos_fns());
    let taken = ecs_reflect_component_take(rc, 3);
    let typed = registry_erased_value_read<ReflectPos>(taken, 7701);
    if typed.x != 0 { panic(22009); };
}

@test "reflect component reflect reads value"() {
    let rc = ecs_reflect_component_new(7701, make_reflect_pos_fns());
    let reflected = ecs_reflect_component_reflect(rc, 7);
    let typed = registry_erased_value_read<ReflectPos>(reflected, 7701);
    if typed.x != 7 { panic(22010); };
}

@test "reflect component copy duplicates value"() {
    let rc = ecs_reflect_component_new(7701, make_reflect_pos_fns());
    let original = registry_erased_value_new<ReflectPos>(7701, ReflectPos { x: 5, y: 6 });
    let copied = ecs_reflect_component_copy(rc, original);
    let typed = registry_erased_value_read<ReflectPos>(copied, 7701);
    if typed.x != 5 { panic(22011); };
    if typed.y != 6 { panic(22012); };
}

@test "reflect component register returns component id"() {
    let rc = ecs_reflect_component_new(7701, make_reflect_pos_fns());
    if ecs_reflect_component_register(rc) != 7701 { panic(22013); };
}

@test "reflect component remove returns type id"() {
    let rc = ecs_reflect_component_new(7701, make_reflect_pos_fns());
    if ecs_reflect_component_remove(rc, 1) != 7701 { panic(22014); };
}
