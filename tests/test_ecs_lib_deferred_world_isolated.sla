@import "lib/deferred_world.sla"

@test "deferred world new and change tick"() {
    let d = ecs_deferred_world_new(10);
    if ecs_deferred_world_change_tick(d) != 10 { panic(40001); };
}

@test "deferred world commands queue"() {
    let d = ecs_deferred_world_new(5);
    d = ecs_deferred_world_commands(d, 1);
    d = ecs_deferred_world_commands(d, 2);
    if ecs_deferred_world_queued_len(d) != 2 { panic(40002); };
    if ecs_deferred_world_queued_at(d, 0) != 1 { panic(40003); };
    if ecs_deferred_world_queued_at(d, 1) != 2 { panic(40004); };
}

@test "deferred world entity mut"() {
    let d = ecs_deferred_world_new(5);
    d = ecs_deferred_world_entity_mut(d, 42);
    if ecs_deferred_world_queued_len(d) != 1 { panic(40005); };
    if ecs_deferred_world_queued_at(d, 0) != 42 { panic(40006); };
}

@test "deferred world entities and commands"() {
    let d = ecs_deferred_world_new(5);
    d = ecs_deferred_world_commands(d, 7);
    d = ecs_deferred_world_commands(d, 8);
    let r = ecs_deferred_world_entities_and_commands(d);
    if r.0 != 2 { panic(40007); };
}

@test "deferred world reborrow"() {
    let d = ecs_deferred_world_new(5);
    let d2 = ecs_deferred_world_reborrow(d);
    if ecs_deferred_world_change_tick(d2) != 5 { panic(40008); };
}

@test "deferred world write message"() {
    let d = ecs_deferred_world_new(5);
    d = ecs_deferred_world_write_message(d, 100);
    d = ecs_deferred_world_write_message(d, 200);
    if ecs_deferred_world_written_messages_len(d) != 2 { panic(40009); };
}

@test "deferred world write message default"() {
    let d = ecs_deferred_world_new(5);
    d = ecs_deferred_world_write_message_default(d);
    if ecs_deferred_world_written_messages_len(d) != 1 { panic(40010); };
}

@test "deferred world write message batch"() {
    let msgs: Vec<i64> = Vec::new();
    msgs.push(1);
    msgs.push(2);
    msgs.push(3);
    let d = ecs_deferred_world_new(5);
    d = ecs_deferred_world_write_message_batch(d, msgs);
    if ecs_deferred_world_written_messages_len(d) != 3 { panic(40011); };
}

@test "deferred world trigger"() {
    let d = ecs_deferred_world_new(5);
    d = ecs_deferred_world_trigger(d, 9);
    d = ecs_deferred_world_trigger(d, 10);
    if ecs_deferred_world_triggered_len(d) != 2 { panic(40012); };
    if ecs_deferred_world_triggered_at(d, 0) != 9 { panic(40013); };
    if ecs_deferred_world_triggered_at(d, 1) != 10 { panic(40014); };
}

@test "deferred world get resource mut"() {
    let d = ecs_deferred_world_new(5);
    let r = ecs_deferred_world_get_resource_mut(d, 1);
    if r.0 != true { panic(40015); };
}

@test "deferred world get non send mut"() {
    let d = ecs_deferred_world_new(5);
    let r = ecs_deferred_world_get_non_send_mut(d, 1);
    if r.0 != true { panic(40016); };
}

@test "deferred world get mut by id"() {
    let d = ecs_deferred_world_new(5);
    let r = ecs_deferred_world_get_mut_by_id(d, 1);
    if r.0 != true { panic(40017); };
}

@test "deferred world as unsafe world cell"() {
    let d = ecs_deferred_world_new(7);
    if ecs_deferred_world_as_unsafe_world_cell(d) != 7 { panic(40018); };
}
