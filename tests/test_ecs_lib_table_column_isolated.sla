@import "lib/table_column.sla"

// Isolated tests for lib/table_column.sla — Column
// Bevy reference: bevy_ecs/src/storage/table/column.rs

@test "column_with_capacity"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    if ecs_column_component_id(c) != 5 { panic(82500); };
    if ecs_column_component_size(c) != 16 { panic(82501); };
    if ecs_column_capacity(c) != 100 { panic(82502); };
    if ecs_column_has_drop(c) != true { panic(82503); };
    if ecs_column_len(c) != 0 { panic(82504); };
    if ecs_column_is_empty(c) != true { panic(82505); };
}

@test "column_initialize"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 42, 10);
    if ecs_column_len(c2) != 1 { panic(82506); };
    let d = ecs_column_get_data(c2, 0);
    if d.0 != true { panic(82507); };
    if d.1 != 42 { panic(82508); };
}

@test "column_initialize_multiple"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 10, 1);
    let c3 = ecs_column_initialize(c2, 1, 20, 2);
    let c4 = ecs_column_initialize(c3, 2, 30, 3);
    if ecs_column_len(c4) != 3 { panic(82509); };
    let d0 = ecs_column_get_data(c4, 0);
    if d0.1 != 10 { panic(82510); };
    let d1 = ecs_column_get_data(c4, 1);
    if d1.1 != 20 { panic(82511); };
    let d2 = ecs_column_get_data(c4, 2);
    if d2.1 != 30 { panic(82512); };
}

@test "column_get_added_tick"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 42, 10);
    let at = ecs_column_get_added_tick(c2, 0);
    if at.0 != true { panic(82513); };
    if at.1 != 10 { panic(82514); };
}

@test "column_get_changed_tick"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 42, 10);
    let ct = ecs_column_get_changed_tick(c2, 0);
    if ct.0 != true { panic(82515); };
    if ct.1 != 10 { panic(82516); };
}

@test "column_get_ticks"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 42, 10);
    let t = ecs_column_get_ticks(c2, 0);
    if t.0 != true { panic(82517); };
    if t.1 != 10 { panic(82518); };
    if t.2 != 10 { panic(82519); };
}

@test "column_get_ticks_out_of_range"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let t = ecs_column_get_ticks(c, 0);
    if t.0 != false { panic(82520); };
}

@test "column_replace"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 42, 10);
    let c3 = ecs_column_replace(c2, 0, 99, 20);
    let d = ecs_column_get_data(c3, 0);
    if d.1 != 99 { panic(82521); };
    let ct = ecs_column_get_changed_tick(c3, 0);
    if ct.1 != 20 { panic(82522); };
}

@test "column_replace_out_of_range"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_replace(c, 0, 99, 20);
    if ecs_column_len(c2) != 0 { panic(82523); };
}

@test "column_swap_remove"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 10, 1);
    let c3 = ecs_column_initialize(c2, 1, 20, 2);
    let c4 = ecs_column_initialize(c3, 2, 30, 3);
    // Remove row 0 (swap with last)
    let c5 = ecs_column_swap_remove(c4, 0);
    if ecs_column_len(c5) != 2 { panic(82524); };
    // Row 0 should now have the old last element (30)
    let d0 = ecs_column_get_data(c5, 0);
    if d0.1 != 30 { panic(82525); };
}

@test "column_swap_remove_last"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 10, 1);
    let c3 = ecs_column_initialize(c2, 1, 20, 2);
    let c4 = ecs_column_swap_remove(c3, 1);
    if ecs_column_len(c4) != 1 { panic(82526); };
    let d0 = ecs_column_get_data(c4, 0);
    if d0.1 != 10 { panic(82527); };
}

@test "column_clear"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 10, 1);
    let c3 = ecs_column_initialize(c2, 1, 20, 2);
    let c4 = ecs_column_clear(c3);
    if ecs_column_len(c4) != 0 { panic(82528); };
    if ecs_column_is_empty(c4) != true { panic(82529); };
}

@test "column_check_change_ticks"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 10, 100);
    let c3 = ecs_column_initialize(c2, 1, 20, 200);
    let c4 = ecs_column_check_change_ticks(c3, 150);
    let at0 = ecs_column_get_added_tick(c4, 0);
    if at0.1 != 100 { panic(82530); };
    let at1 = ecs_column_get_added_tick(c4, 1);
    if at1.1 != 150 { panic(82531); };
}

@test "column_realloc"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_realloc(c, 200);
    if ecs_column_capacity(c2) != 200 { panic(82532); };
}

@test "column_realloc_smaller"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_realloc(c, 50);
    if ecs_column_capacity(c2) != 100 { panic(82533); };
}

@test "column_drop_last"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 10, 1);
    let c3 = ecs_column_initialize(c2, 1, 20, 2);
    let c4 = ecs_column_drop_last(c3);
    if ecs_column_len(c4) != 1 { panic(82534); };
    let d0 = ecs_column_get_data(c4, 0);
    if d0.1 != 10 { panic(82535); };
}

@test "column_drop_last_empty"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_drop_last(c);
    if ecs_column_len(c2) != 0 { panic(82536); };
}

@test "column_get_drop"() {
    let c1 = ecs_column_with_capacity(5, 16, 100, true);
    if ecs_column_get_drop(c1) != true { panic(82537); };
    let c2 = ecs_column_with_capacity(5, 16, 100, false);
    if ecs_column_get_drop(c2) != false { panic(82538); };
}

@test "column_count_matching"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 42, 1);
    let c3 = ecs_column_initialize(c2, 1, 42, 2);
    let c4 = ecs_column_initialize(c3, 2, 99, 3);
    if ecs_column_count_matching(c4, 42) != 2 { panic(82539); };
    if ecs_column_count_matching(c4, 99) != 1 { panic(82540); };
    if ecs_column_count_matching(c4, 0) != 0 { panic(82541); };
}

@test "column_get_changed_by"() {
    let c = ecs_column_with_capacity(5, 16, 100, true);
    let c2 = ecs_column_initialize(c, 0, 42, 10);
    let cb = ecs_column_get_changed_by(c2, 0);
    if cb.0 != true { panic(82542); };
    if cb.1 != 0 { panic(82543); };
}
