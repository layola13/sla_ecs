@import "lib/intern.sla"
@import "lib/name_hashed.sla"
@import "lib/lifecycle_hooks.sla"
@import "lib/entity_disabling_filters.sla"

@test "interner intern new"() {
    let i = ecs_interner_new();
    let r = ecs_interner_intern(i, 42);
    if r.1 != 0 { panic(60001); };
    if ecs_interner_len(r.0) != 1 { panic(60002); };
}

@test "interner intern existing returns same id"() {
    let i = ecs_interner_new();
    let r1 = ecs_interner_intern(i, 42);
    let r2 = ecs_interner_intern(r1.0, 42);
    if r2.1 != 0 { panic(60003); };
    if ecs_interner_len(r2.0) != 1 { panic(60004); };
}

@test "interner intern different"() {
    let i = ecs_interner_new();
    let r1 = ecs_interner_intern(i, 42);
    let r2 = ecs_interner_intern(r1.0, 99);
    if r2.1 != 1 { panic(60005); };
    if ecs_interner_len(r2.0) != 2 { panic(60006); };
}

@test "interner resolve"() {
    let i = ecs_interner_new();
    let r = ecs_interner_intern(i, 42);
    let g = ecs_interner_resolve(r.0, 0);
    if g.0 != true { panic(60007); };
    if g.1 != 42 { panic(60008); };
    let g2 = ecs_interner_resolve(r.0, 99);
    if g2.0 != false { panic(60009); };
}

@test "interner contains"() {
    let i = ecs_interner_new();
    let r = ecs_interner_intern(i, 42);
    if ecs_interner_contains(r.0, 42) != true { panic(60010); };
    if ecs_interner_contains(r.0, 99) != false { panic(60011); };
}

@test "interned new and eq"() {
    let a = ecs_interned_new(5);
    let b = ecs_interned_new(5);
    let c = ecs_interned_new(6);
    if ecs_interned_eq(a, b) != true { panic(60012); };
    if ecs_interned_eq(a, c) != false { panic(60013); };
}

@test "hashed str new and value"() {
    let h = ecs_hashed_str_new(42);
    if ecs_hashed_str_value(h) != 42 { panic(60014); };
    if ecs_hashed_str_pre_hash(h) != 1302 { panic(60015); };
}

@test "hashed str set"() {
    let h = ecs_hashed_str_new(42);
    let h2 = ecs_hashed_str_set(h, 10);
    if ecs_hashed_str_value(h2) != 10 { panic(60016); };
    if ecs_hashed_str_pre_hash(h2) != 310 { panic(60017); };
}

@test "name new and as str"() {
    let n = ecs_name_new(5);
    if ecs_name_as_str(n) != 5 { panic(60018); };
    if ecs_name_pre_hash(n) != 155 { panic(60019); };
}

@test "name set"() {
    let n = ecs_name_new(5);
    let n2 = ecs_name_set(n, 10);
    if ecs_name_as_str(n2) != 10 { panic(60020); };
}

@test "name mutate"() {
    let n = ecs_name_new(5);
    let n2 = ecs_name_mutate(n, 3);
    if ecs_name_as_str(n2) != 8 { panic(60021); };
}

@test "name eq"() {
    if ecs_name_eq(ecs_name_new(5), ecs_name_new(5)) != true { panic(60022); };
    if ecs_name_eq(ecs_name_new(5), ecs_name_new(6)) != false { panic(60023); };
}

@test "name or entity name"() {
    let n = ecs_name_or_entity_name(5);
    if ecs_name_or_entity_is_name(n) != true { panic(60024); };
    if ecs_name_or_entity_value(n) != 5 { panic(60025); };
}

@test "name or entity entity"() {
    let e = ecs_name_or_entity_entity(42);
    if ecs_name_or_entity_is_entity(e) != true { panic(60026); };
    if ecs_name_or_entity_value(e) != 42 { panic(60027); };
}

@test "hook context new"() {
    let c = ecs_hook_context_new(1, 5, ECS_LIFECYCLE_ADD);
    if ecs_hook_context_entity(c) != 1 { panic(60028); };
    if ecs_hook_context_component_id(c) != 5 { panic(60029); };
    if ecs_hook_context_kind(c) != ECS_LIFECYCLE_ADD { panic(60030); };
}

@test "component hooks on add"() {
    let h = ecs_component_hooks_new();
    let h2 = ecs_component_hooks_on_add(h, 100);
    if ecs_component_hooks_has_add(h2) != true { panic(60031); };
    if ecs_component_hooks_get_add(h2) != 100 { panic(60032); };
}

@test "component hooks on remove"() {
    let h = ecs_component_hooks_new();
    let h2 = ecs_component_hooks_on_remove(h, 200);
    if ecs_component_hooks_has_remove(h2) != true { panic(60033); };
}

@test "component hooks try on add"() {
    let h = ecs_component_hooks_new();
    let r1 = ecs_component_hooks_try_on_add(h, 100);
    if r1.1 != true { panic(60034); };
    let r2 = ecs_component_hooks_try_on_add(r1.0, 200);
    if r2.1 != false { panic(60035); };
}

@test "component hooks count"() {
    let h = ecs_component_hooks_new();
    h = ecs_component_hooks_on_add(h, 1);
    h = ecs_component_hooks_on_remove(h, 2);
    if ecs_component_hooks_count(h) != 2 { panic(60036); };
}

@test "removed component new"() {
    let r = ecs_removed_component_new(5, 10);
    if ecs_removed_component_id(r) != 5 { panic(60037); };
    if ecs_removed_component_entity(r) != 10 { panic(60038); };
}

@test "disabled new"() {
    let d = ecs_disabled_new(5);
    if ecs_disabled_component_id(d) != 5 { panic(60039); };
}

@test "default query filters register and count"() {
    let f = ecs_default_query_filters_empty();
    f = ecs_default_query_filters_register(f, 1);
    f = ecs_default_query_filters_register(f, 2);
    if ecs_default_query_filters_disabling_count(f) != 2 { panic(60040); };
}

@test "default query filters is disabled"() {
    let f = ecs_default_query_filters_empty();
    f = ecs_default_query_filters_register(f, 1);
    if ecs_default_query_filters_is_disabled(f, 1) != true { panic(60041); };
    if ecs_default_query_filters_is_disabled(f, 3) != false { panic(60042); };
}

@test "default query filters is entity disabled"() {
    let f = ecs_default_query_filters_empty();
    f = ecs_default_query_filters_register(f, 2);
    let comps: Vec<i32> = Vec::new();
    comps.push(1);
    comps.push(2);
    if ecs_default_query_filters_is_entity_disabled(f, comps) != true { panic(60043); };
    let comps2: Vec<i32> = Vec::new();
    comps2.push(1);
    comps2.push(3);
    if ecs_default_query_filters_is_entity_disabled(f, comps2) != false { panic(60044); };
}
