// Verification tests for multi-component Query<(A,B)> and Query<(A,B,C)> facades.
@import "../lib/ecs_world.sla"

struct MQA { a: i32 }
struct MQB { b: i32 }
struct MQC { c: i32 }

struct MQD { d: i32 }

fn drop_mqa(x: MQA) {}
fn drop_mqb(x: MQB) {}
fn drop_mqc(x: MQC) {}
fn drop_mqd(x: MQD) {}

const MQA_ID: i32 = 1901;
const MQB_ID: i32 = 1902;
const MQC_ID: i32 = 1903;
const MQD_ID: i32 = 1904;

@test "query pair returns entities with both components"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<MQA, i32, i32>(w0, MQA_ID, 0);
    let w2 = ecs_world_register<MQB, i32, i32>(w1, MQB_ID, 0);
    let (w3, e1) = ecs_world_spawn<i32, i32>(w2);
    let w4 = ecs_world_insert<MQA, i32, i32>(w3, e1, MQA_ID, MQA { a: 1 });
    let w5 = ecs_world_insert<MQB, i32, i32>(w4, e1, MQB_ID, MQB { b: 10 });
    let (w6, e2) = ecs_world_spawn<i32, i32>(w5);
    let w7 = ecs_world_insert<MQA, i32, i32>(w6, e2, MQA_ID, MQA { a: 2 });
    // e2 has only A, not B
    let q = ecs_world_query_pair<MQA, MQB, i32, i32>(w7, MQA_ID, MQB_ID);
    if len(q.items) != 1 { panic(19001); };
    if q.items[0].first.a != 1 { panic(19002); };
    if q.items[0].second.b != 10 { panic(19003); };
}

@test "query pair count and is_empty and contains"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<MQA, i32, i32>(w0, MQA_ID, 0);
    let w2 = ecs_world_register<MQB, i32, i32>(w1, MQB_ID, 0);
    if ecs_world_query_pair_is_empty<i32, i32>(w2, MQA_ID, MQB_ID) != true { panic(19004); };
    let (w3, e1) = ecs_world_spawn<i32, i32>(w2);
    let w4 = ecs_world_insert<MQA, i32, i32>(w3, e1, MQA_ID, MQA { a: 5 });
    let w5 = ecs_world_insert<MQB, i32, i32>(w4, e1, MQB_ID, MQB { b: 50 });
    if ecs_world_query_pair_count<i32, i32>(w5, MQA_ID, MQB_ID) != 1 { panic(19005); };
    if ecs_world_query_pair_contains<i32, i32>(w5, e1, MQA_ID, MQB_ID) != true { panic(19006); };
}

@test "query triple returns entities with all three"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<MQA, i32, i32>(w0, MQA_ID, 0);
    let w2 = ecs_world_register<MQB, i32, i32>(w1, MQB_ID, 0);
    let w3 = ecs_world_register<MQC, i32, i32>(w2, MQC_ID, 0);
    let (w4, e1) = ecs_world_spawn<i32, i32>(w3);
    let w5 = ecs_world_insert<MQA, i32, i32>(w4, e1, MQA_ID, MQA { a: 1 });
    let w6 = ecs_world_insert<MQB, i32, i32>(w5, e1, MQB_ID, MQB { b: 2 });
    let w7 = ecs_world_insert<MQC, i32, i32>(w6, e1, MQC_ID, MQC { c: 3 });
    let (w8, e2) = ecs_world_spawn<i32, i32>(w7);
    let w9 = ecs_world_insert<MQA, i32, i32>(w8, e2, MQA_ID, MQA { a: 9 });
    let w10 = ecs_world_insert<MQB, i32, i32>(w9, e2, MQB_ID, MQB { b: 9 });
    // e2 has A and B but not C
    let q = ecs_world_query_triple<MQA, MQB, MQC, i32, i32>(w10, MQA_ID, MQB_ID, MQC_ID);
    if len(q.items) != 1 { panic(19007); };
    if q.items[0].first.a != 1 { panic(19008); };
    if q.items[0].second.b != 2 { panic(19009); };
    if q.items[0].third.c != 3 { panic(19010); };
}

@test "query quad returns entities with all four"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<MQA, i32, i32>(w0, MQA_ID, 0);
    let w2 = ecs_world_register<MQB, i32, i32>(w1, MQB_ID, 0);
    let w3 = ecs_world_register<MQC, i32, i32>(w2, MQC_ID, 0);
    let w4 = ecs_world_register<MQD, i32, i32>(w3, MQD_ID, 0);
    let (w5, e1) = ecs_world_spawn<i32, i32>(w4);
    let w6 = ecs_world_insert<MQA, i32, i32>(w5, e1, MQA_ID, MQA { a: 1 });
    let w7 = ecs_world_insert<MQB, i32, i32>(w6, e1, MQB_ID, MQB { b: 2 });
    let w8 = ecs_world_insert<MQC, i32, i32>(w7, e1, MQC_ID, MQC { c: 3 });
    let w9 = ecs_world_insert<MQD, i32, i32>(w8, e1, MQD_ID, MQD { d: 4 });
    let (w10, e2) = ecs_world_spawn<i32, i32>(w9);
    let w11 = ecs_world_insert<MQA, i32, i32>(w10, e2, MQA_ID, MQA { a: 10 });
    let w12 = ecs_world_insert<MQB, i32, i32>(w11, e2, MQB_ID, MQB { b: 20 });
    let w13 = ecs_world_insert<MQC, i32, i32>(w12, e2, MQC_ID, MQC { c: 30 });
    // e2 has A,B,C but not D
    let q = ecs_world_query_quad<MQA, MQB, MQC, MQD, i32, i32>(w13, MQA_ID, MQB_ID, MQC_ID, MQD_ID);
    if len(q.items) != 1 { panic(19011); };
    if q.items[0].first.a != 1 { panic(19012); };
    if q.items[0].second.b != 2 { panic(19013); };
    if q.items[0].third.c != 3 { panic(19014); };
    if q.items[0].fourth.d != 4 { panic(19015); };
}

@test "query pair mut writes back first component"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<MQA, i32, i32>(w0, MQA_ID, 0);
    let w2 = ecs_world_register<MQB, i32, i32>(w1, MQB_ID, 0);
    let (w3, e1) = ecs_world_spawn<i32, i32>(w2);
    let w4 = ecs_world_insert<MQA, i32, i32>(w3, e1, MQA_ID, MQA { a: 7 });
    let w5 = ecs_world_insert<MQB, i32, i32>(w4, e1, MQB_ID, MQB { b: 70 });
    let q = ecs_world_query_pair_mut<MQA, MQB, i32, i32>(w5, MQA_ID, MQB_ID);
    let updated = mq_double_first(q);
    let w6 = ecs_world_apply_pair_mut<MQA, MQB, i32, i32>(w5, updated);
    let got = ecs_world_get<MQA, i32, i32>(w6, e1, MQA_ID);
    if got.a != 14 { panic(19016); };
}

fn mq_double_first(query: Query<TableErasedPairMut<MQA, MQB>>) -> Query<TableErasedPairMut<MQA, MQB>> {
    let out = query_new<TableErasedPairMut<MQA, MQB>>();
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        let item = query.items[i];
        let first = item.first;
        let new_first = TableErasedMut<MQA> { entity: first.entity, component_id: first.component_id, type_id: first.type_id, archetype_id: first.archetype_id, row: first.row, value: MQA { a: first.value.a * 2 } };
        out.items.push(TableErasedPairMut<MQA, MQB> { first: new_first, second_component_id: item.second_component_id, second_type_id: item.second_type_id, second: item.second });
        i = i + 1;
    }
    return out;
}

struct MQE { e: i32 }
fn drop_mqe(x: MQE) {}
const MQE_ID: i32 = 1905;

@test "query quintuple returns entities with all five"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register<MQA, i32, i32>(w0, MQA_ID, 0);
    let w2 = ecs_world_register<MQB, i32, i32>(w1, MQB_ID, 0);
    let w3 = ecs_world_register<MQC, i32, i32>(w2, MQC_ID, 0);
    let w4 = ecs_world_register<MQD, i32, i32>(w3, MQD_ID, 0);
    let w5 = ecs_world_register<MQE, i32, i32>(w4, MQE_ID, 0);
    let (w6, e1) = ecs_world_spawn<i32, i32>(w5);
    let w7 = ecs_world_insert<MQA, i32, i32>(w6, e1, MQA_ID, MQA { a: 1 });
    let w8 = ecs_world_insert<MQB, i32, i32>(w7, e1, MQB_ID, MQB { b: 2 });
    let w9 = ecs_world_insert<MQC, i32, i32>(w8, e1, MQC_ID, MQC { c: 3 });
    let w10 = ecs_world_insert<MQD, i32, i32>(w9, e1, MQD_ID, MQD { d: 4 });
    let w11 = ecs_world_insert<MQE, i32, i32>(w10, e1, MQE_ID, MQE { e: 5 });
    let (w12, e2) = ecs_world_spawn<i32, i32>(w11);
    let w13 = ecs_world_insert<MQA, i32, i32>(w12, e2, MQA_ID, MQA { a: 10 });
    let w14 = ecs_world_insert<MQB, i32, i32>(w13, e2, MQB_ID, MQB { b: 20 });
    let w15 = ecs_world_insert<MQC, i32, i32>(w14, e2, MQC_ID, MQC { c: 30 });
    let w16 = ecs_world_insert<MQD, i32, i32>(w15, e2, MQD_ID, MQD { d: 40 });
    let q = ecs_world_query_quintuple<MQA, MQB, MQC, MQD, MQE, i32, i32>(w16, MQA_ID, MQB_ID, MQC_ID, MQD_ID, MQE_ID);
    if len(q.items) != 1 { panic(19016); };
    if q.items[0].first.a != 1 { panic(19017); };
    if q.items[0].fifth.e != 5 { panic(19018); };
}
