@import "lib/entity_command.sla"

@test "entity command insert"() {
    let c = ecs_entity_command_insert(5, ECS_INSERT_MODE_DEFAULT);
    if ecs_entity_command_kind(c) != 0 { panic(52001); };
    if ecs_entity_command_component_id(c) != 5 { panic(52002); };
}

@test "entity command remove"() {
    let c = ecs_entity_command_remove(7);
    if ecs_entity_command_kind(c) != 1 { panic(52003); };
    if ecs_entity_command_component_id(c) != 7 { panic(52004); };
}

@test "entity command clear"() {
    let c = ecs_entity_command_clear();
    if ecs_entity_command_kind(c) != 2 { panic(52005); };
}

@test "entity command despawn"() {
    let c = ecs_entity_command_despawn();
    if ecs_entity_command_kind(c) != 3 { panic(52006); };
}

@test "entity command clone with opt out"() {
    let c = ecs_entity_command_clone_with_opt_out(100);
    if ecs_entity_command_kind(c) != 4 { panic(52007); };
    if ecs_entity_command_target(c) != 100 { panic(52008); };
    if ecs_entity_command_mode(c) != ECS_INSERT_MODE_DEFAULT { panic(52009); };
}

@test "entity command clone with opt in"() {
    let c = ecs_entity_command_clone_with_opt_in(100);
    if ecs_entity_command_mode(c) != ECS_INSERT_MODE_KEEP_EXISTING { panic(52010); };
}

@test "entity command move components"() {
    let c = ecs_entity_command_move_components(200);
    if ecs_entity_command_kind(c) != 5 { panic(52011); };
    if ecs_entity_command_target(c) != 200 { panic(52012); };
}

@test "entity command log components"() {
    let c = ecs_entity_command_log_components();
    if ecs_entity_command_kind(c) != 6 { panic(52013); };
}

@test "entity command observe"() {
    let c = ecs_entity_command_observe(300);
    if ecs_entity_command_kind(c) != 7 { panic(52014); };
    if ecs_entity_command_target(c) != 300 { panic(52015); };
}

@test "entity command retain"() {
    let c = ecs_entity_command_retain(8);
    if ecs_entity_command_kind(c) != 9 { panic(52016); };
}

@test "entity command remove with requires"() {
    let c = ecs_entity_command_remove_with_requires(9);
    if ecs_entity_command_kind(c) != 10 { panic(52017); };
}

@test "entity command insert from world"() {
    let c = ecs_entity_command_insert_from_world(3, ECS_INSERT_MODE_KEEP_EXISTING);
    if ecs_entity_command_kind(c) != 8 { panic(52018); };
    if ecs_entity_command_mode(c) != ECS_INSERT_MODE_KEEP_EXISTING { panic(52019); };
}

@test "entity command apply despawn ok"() {
    let c = ecs_entity_command_despawn();
    let r = ecs_entity_command_apply(c, 5);
    if r.0 != ECS_EC_OK { panic(52020); };
    if r.1 != 1 { panic(52021); };
}

@test "entity command apply entity not found"() {
    let c = ecs_entity_command_insert(5, 0);
    let r = ecs_entity_command_apply(c, -1);
    if r.0 != ECS_EC_ENTITY_NOT_FOUND { panic(52022); };
}
