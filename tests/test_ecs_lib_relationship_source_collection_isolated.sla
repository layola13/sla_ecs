@import "lib/relationship_source_collection.sla"

@test "rsc new vec and len"() {
    let c = ecs_rsc_new(ECS_RSC_VEC);
    if ecs_rsc_kind(c) != ECS_RSC_VEC { panic(62001); };
    if ecs_rsc_len(c) != 0 { panic(62002); };
    if ecs_rsc_is_empty(c) != true { panic(62003); };
}

@test "rsc vec insert appends"() {
    let c = ecs_rsc_new(ECS_RSC_VEC);
    c = ecs_rsc_insert(c, 1);
    c = ecs_rsc_insert(c, 2);
    c = ecs_rsc_insert(c, 1);
    if ecs_rsc_len(c) != 3 { panic(62004); };
}

@test "rsc hashset insert dedup"() {
    let c = ecs_rsc_new(ECS_RSC_HASHSET);
    c = ecs_rsc_insert(c, 1);
    c = ecs_rsc_insert(c, 2);
    c = ecs_rsc_insert(c, 1);
    if ecs_rsc_len(c) != 2 { panic(62005); };
}

@test "rsc contains"() {
    let c = ecs_rsc_new(ECS_RSC_VEC);
    c = ecs_rsc_insert(c, 5);
    if ecs_rsc_contains(c, 5) != true { panic(62006); };
    if ecs_rsc_contains(c, 6) != false { panic(62007); };
}

@test "rsc remove"() {
    let c = ecs_rsc_new(ECS_RSC_VEC);
    c = ecs_rsc_insert(c, 1);
    c = ecs_rsc_insert(c, 2);
    let r = ecs_rsc_remove(c, 1);
    if r.1 != true { panic(62009); };
    if ecs_rsc_len(r.0) != 1 { panic(62010); };
}

@test "rsc remove missing"() {
    let c = ecs_rsc_new(ECS_RSC_VEC);
    c = ecs_rsc_insert(c, 1);
    let r = ecs_rsc_remove(c, 99);
    if r.1 != false { panic(62011); };
}

@test "rsc clear"() {
    let c = ecs_rsc_new(ECS_RSC_VEC);
    c = ecs_rsc_insert(c, 1);
    c = ecs_rsc_insert(c, 2);
    c = ecs_rsc_clear(c);
    if ecs_rsc_is_empty(c) != true { panic(62012); };
}

@test "rsc at"() {
    let c = ecs_rsc_new(ECS_RSC_VEC);
    c = ecs_rsc_insert(c, 10);
    c = ecs_rsc_insert(c, 20);
    if ecs_rsc_at(c, 0) != 10 { panic(62013); };
    if ecs_rsc_at(c, 1) != 20 { panic(62014); };
}

@test "rsc first and last"() {
    let c = ecs_rsc_new(ECS_RSC_VEC);
    c = ecs_rsc_insert(c, 10);
    c = ecs_rsc_insert(c, 20);
    c = ecs_rsc_insert(c, 30);
    if ecs_rsc_first(c) != 10 { panic(62015); };
    if ecs_rsc_last(c) != 30 { panic(62016); };
}

@test "rsc swap"() {
    let c = ecs_rsc_new(ECS_RSC_VEC);
    c = ecs_rsc_insert(c, 10);
    c = ecs_rsc_insert(c, 20);
    c = ecs_rsc_swap(c, 0, 1);
    if ecs_rsc_at(c, 0) != 20 { panic(62017); };
    if ecs_rsc_at(c, 1) != 10 { panic(62018); };
}

@test "relationship hook mode constants"() {
    if ecs_relationship_hook_mode_skip() != ECS_RHM_SKIP { panic(62019); };
    if ecs_relationship_hook_mode_run() != ECS_RHM_RUN { panic(62020); };
    if ecs_relationship_hook_mode_run_if_parent_exists() != ECS_RHM_RUN_IF_PARENT_EXISTS { panic(62021); };
}

@test "relationship clone behavior constants"() {
    if ecs_relationship_clone_behavior_clone() != ECS_RCB_CLONE { panic(62022); };
    if ecs_relationship_clone_behavior_ignore() != ECS_RCB_IGNORE { panic(62023); };
    if ecs_relationship_clone_behavior_default() != ECS_RCB_DEFAULT { panic(62024); };
    if ecs_relationship_clone_behavior_via_reflect() != ECS_RCB_VIA_REFLECT { panic(62025); };
}
