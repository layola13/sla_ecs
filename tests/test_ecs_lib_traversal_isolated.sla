@import "lib/traversal.sla"

@test "traversal none traverse"() {
    let t = ecs_traversal_none_new();
    let r = ecs_traversal_none_traverse(t, 0);
    if r.0 != false { panic(38001); };
}

@test "traversal relationship traverse"() {
    let t = ecs_traversal_relationship_new(42);
    if ecs_traversal_relationship_get(t) != 42 { panic(38002); };
    let r = ecs_traversal_relationship_traverse(t, 0);
    if r.0 != true { panic(38003); };
    if r.1 != 42 { panic(38004); };
}

@test "traversal path follow simple"() {
    let p = ecs_traversal_path_new();
    p = ecs_traversal_path_set_edge(p, 0, 1);
    p = ecs_traversal_path_set_edge(p, 1, 2);
    p = ecs_traversal_path_set_edge(p, 2, -1);
    let path = ecs_traversal_path_follow(p, 0, 10);
    if len(path) as i64 != 2 { panic(38005); };
    if path[0] != 1 { panic(38006); };
    if path[1] != 2 { panic(38007); };
}

@test "traversal path loop detection"() {
    let p = ecs_traversal_path_new();
    p = ecs_traversal_path_set_edge(p, 0, 1);
    p = ecs_traversal_path_set_edge(p, 1, 0);
    let path = ecs_traversal_path_follow(p, 0, 10);
    // 0 -> 1, then 1 -> 0 which is visited, so stop. path = [1]
    if len(path) as i64 != 1 { panic(38008); };
    if path[0] != 1 { panic(38009); };
}

@test "traversal path max depth"() {
    let p = ecs_traversal_path_new();
    p = ecs_traversal_path_set_edge(p, 0, 1);
    p = ecs_traversal_path_set_edge(p, 1, 2);
    p = ecs_traversal_path_set_edge(p, 2, 3);
    let path = ecs_traversal_path_follow(p, 0, 2);
    if len(path) as i64 != 2 { panic(38010); };
    if path[0] != 1 { panic(38011); };
    if path[1] != 2 { panic(38012); };
}

@test "propagate none"() {
    let p = ecs_propagate_none();
    if ecs_propagate_is_none(p) != true { panic(38013); };
    if ecs_propagate_is_traverse(p) != false { panic(38014); };
}

@test "propagate traverse"() {
    let p = ecs_propagate_traverse(7);
    if ecs_propagate_is_traverse(p) != true { panic(38015); };
    if ecs_propagate_target(p) != 7 { panic(38016); };
}

@test "propagate targets"() {
    let p = ecs_propagate_targets(9);
    if ecs_propagate_is_targets(p) != true { panic(38017); };
    if ecs_propagate_target(p) != 9 { panic(38018); };
}
