// Isolated clone_and_spawn verification (avoids facade_gaps large-file codegen).
@import "../lib/ecs_world.sla"

struct CPos { x: i32, y: i32 }
struct CVel { vx: i32, vy: i32 }
fn drop_cpos(x: CPos) {}
fn drop_cvel(x: CVel) {}

const CPOS_ID: i32 = 3101;
const CVEL_ID: i32 = 3102;

@test "clone and spawn copies components isolated"() {
    let world = ecs_world_new<i32, i32>(0, 0);
    let w1 = ecs_world_register_table<CPos, i32, i32>(world, CPOS_ID);
    let w2 = ecs_world_register_table<CVel, i32, i32>(w1, CVEL_ID);
    let (w3, e1) = ecs_world_spawn<i32, i32>(w2);
    let w4 = ecs_world_insert<CPos, i32, i32>(w3, e1, CPOS_ID, CPos { x: 5, y: 6 });
    let w5 = ecs_world_insert<CVel, i32, i32>(w4, e1, CVEL_ID, CVel { vx: 1, vy: 2 });
    let type_ids: Vec<i32> = Vec::new();
    type_ids.push(CPOS_ID);
    type_ids.push(CVEL_ID);
    let (w6, clone) = ecs_world_clone_and_spawn<i32, i32>(w5, e1, type_ids);
    let p = ecs_world_get<CPos, i32, i32>(w6, clone, CPOS_ID);
    if p.x != 5 { panic(31001); };
    let v = ecs_world_get<CVel, i32, i32>(w6, clone, CVEL_ID);
    if v.vx != 1 { panic(31002); };
}
