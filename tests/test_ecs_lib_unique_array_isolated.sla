@import "lib/unique_array.sla"

// Isolated tests for lib/unique_array.sla — UniqueEntityEquivalentArray
// Bevy reference: bevy_ecs/src/entity/unique_array.rs

@test "unique_array_new_empty"() {
    let a = ecs_unique_array_new(5);
    if ecs_unique_array_len(a) != 0 { panic(82300); };
    if ecs_unique_array_is_empty(a) != true { panic(82301); };
    if ecs_unique_array_capacity(a) != 5 { panic(82302); };
    if ecs_unique_array_is_full(a) != false { panic(82303); };
}

@test "unique_array_push"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    if r1.1 != true { panic(82304); };
    let r2 = ecs_unique_array_push(r1.0, 20);
    if r2.1 != true { panic(82305); };
    if ecs_unique_array_len(r2.0) != 2 { panic(82306); };
}

@test "unique_array_push_duplicate"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 10);
    if r2.1 != false { panic(82307); };
    if ecs_unique_array_len(r2.0) != 1 { panic(82308); };
}

@test "unique_array_push_full"() {
    let a = ecs_unique_array_new(2);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    let r3 = ecs_unique_array_push(r2.0, 30);
    if r3.1 != false { panic(82309); };
    if ecs_unique_array_is_full(r2.0) != true { panic(82310); };
}

@test "unique_array_get"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    let g0 = ecs_unique_array_get(r2.0, 0);
    if g0.0 != true { panic(82311); };
    if g0.1 != 10 { panic(82312); };
    let g1 = ecs_unique_array_get(r2.0, 1);
    if g1.1 != 20 { panic(82313); };
    let g2 = ecs_unique_array_get(r2.0, 2);
    if g2.0 != false { panic(82314); };
}

@test "unique_array_first_last"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    let r3 = ecs_unique_array_push(r2.0, 30);
    let f = ecs_unique_array_first(r3.0);
    if f.1 != 10 { panic(82315); };
    let l = ecs_unique_array_last(r3.0);
    if l.1 != 30 { panic(82316); };
}

@test "unique_array_first_empty"() {
    let a = ecs_unique_array_new(3);
    let f = ecs_unique_array_first(a);
    if f.0 != false { panic(82317); };
}

@test "unique_array_contains"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    if ecs_unique_array_contains(r2.0, 10) != true { panic(82318); };
    if ecs_unique_array_contains(r2.0, 20) != true { panic(82319); };
    if ecs_unique_array_contains(r2.0, 30) != false { panic(82320); };
}

@test "unique_array_index_of"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    if ecs_unique_array_index_of(r2.0, 10) != 0 { panic(82321); };
    if ecs_unique_array_index_of(r2.0, 20) != 1 { panic(82322); };
    if ecs_unique_array_index_of(r2.0, 99) != -1 { panic(82323); };
}

@test "unique_array_set"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    let r3 = ecs_unique_array_set(r2.0, 0, 30);
    if r3.1 != true { panic(82324); };
    let g0 = ecs_unique_array_get(r3.0, 0);
    if g0.1 != 30 { panic(82325); };
}

@test "unique_array_set_duplicate"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    // Setting index 0 to 20 (which is at index 1) should fail
    let r3 = ecs_unique_array_set(r2.0, 0, 20);
    if r3.1 != false { panic(82326); };
}

@test "unique_array_set_same_index"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    // Setting index 0 to 10 (same value at same index) should succeed
    let r2 = ecs_unique_array_set(r1.0, 0, 10);
    if r2.1 != true { panic(82327); };
}

@test "unique_array_swap"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    let r3 = ecs_unique_array_push(r2.0, 30);
    let s = ecs_unique_array_swap(r3.0, 0, 2);
    let g0 = ecs_unique_array_get(s, 0);
    if g0.1 != 30 { panic(82328); };
    let g2 = ecs_unique_array_get(s, 2);
    if g2.1 != 10 { panic(82329); };
}

@test "unique_array_reverse"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    let r3 = ecs_unique_array_push(r2.0, 30);
    let s = ecs_unique_array_reverse(r3.0);
    let g0 = ecs_unique_array_get(s, 0);
    if g0.1 != 30 { panic(82330); };
    let g2 = ecs_unique_array_get(s, 2);
    if g2.1 != 10 { panic(82331); };
}

@test "unique_array_eq"() {
    let a1 = ecs_unique_array_new(3);
    let r1a = ecs_unique_array_push(a1, 10);
    let r1b = ecs_unique_array_push(r1a.0, 20);
    let a2 = ecs_unique_array_new(3);
    let r2a = ecs_unique_array_push(a2, 10);
    let r2b = ecs_unique_array_push(r2a.0, 20);
    if ecs_unique_array_eq(r1b.0, r2b.0) != true { panic(82332); };
}

@test "unique_array_into_inner"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    let inner = ecs_unique_array_into_inner(r2.0);
    if len(inner) != 2 { panic(82333); };
    if inner[0] != 10 { panic(82334); };
    if inner[1] != 20 { panic(82335); };
}

@test "unique_array_sum"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    let r3 = ecs_unique_array_push(r2.0, 30);
    if ecs_unique_array_sum(r3.0) != 60 { panic(82336); };
}

@test "unique_array_map_doubled"() {
    let a = ecs_unique_array_new(3);
    let r1 = ecs_unique_array_push(a, 10);
    let r2 = ecs_unique_array_push(r1.0, 20);
    let result = ecs_unique_array_map_doubled(r2.0);
    if len(result) != 2 { panic(82337); };
    if result[0] != 20 { panic(82338); };
    if result[1] != 40 { panic(82339); };
}

@test "unique_array_from_array"() {
    let items = Vec::new();
    items.push(10);
    items.push(20);
    let a = ecs_unique_array_from_array(items, 3);
    if ecs_unique_array_len(a) != 2 { panic(82340); };
    if ecs_unique_array_capacity(a) != 3 { panic(82341); };
}
