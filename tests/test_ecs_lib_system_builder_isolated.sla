@import "lib/system_builder.sla"

@test "param builder of"() {
    let p = ecs_param_builder_of();
    if ecs_param_builder_kind(p) != ECS_PB_OF { panic(48001); };
}

@test "param builder resource"() {
    let p = ecs_param_builder_resource(5);
    if ecs_param_builder_kind(p) != ECS_PB_RESOURCE { panic(48002); };
    if ecs_param_builder_component_id(p) != 5 { panic(48003); };
}

@test "param builder resource mut"() {
    let p = ecs_param_builder_resource_mut(5);
    if ecs_param_builder_kind(p) != ECS_PB_RESOURCE_MUT { panic(48004); };
}

@test "param builder local"() {
    let p = ecs_param_builder_local(7);
    if ecs_param_builder_kind(p) != ECS_PB_LOCAL { panic(48005); };
    if ecs_param_builder_component_id(p) != 7 { panic(48006); };
}

@test "param builder query"() {
    let p = ecs_param_builder_query(3);
    if ecs_param_builder_kind(p) != ECS_PB_QUERY { panic(48007); };
}

@test "param builder query filtered"() {
    let p = ecs_param_builder_query_filtered(3, 4);
    if ecs_param_builder_kind(p) != ECS_PB_QUERY_FILTERED { panic(48008); };
    if ecs_param_builder_filter_id(p) != 4 { panic(48009); };
}

@test "into builder system new"() {
    let b = ecs_param_builder_query(3);
    let s = ecs_into_builder_system_new(b, 99);
    if ecs_into_builder_system_func(s) != 99 { panic(48010); };
}

@test "builder system new and initialize"() {
    let b = ecs_param_builder_query(3);
    let s = ecs_builder_system_new(b, 99);
    if ecs_builder_system_is_initialized(s) != false { panic(48011); };
    let s2 = ecs_builder_system_initialize(s);
    if ecs_builder_system_is_initialized(s2) != true { panic(48012); };
}

@test "builder system with name"() {
    let b = ecs_param_builder_query(3);
    let s = ecs_builder_system_new(b, 99);
    let s2 = ecs_builder_system_with_name(s, 42);
    if ecs_builder_system_name(s2) != 42 { panic(48013); };
}

@test "query param builder"() {
    let q = ecs_query_param_builder_new(7);
    if ecs_query_param_builder_func(q) != 7 { panic(48014); };
}

@test "param set builder add and len"() {
    let p = ecs_param_set_builder_new();
    p = ecs_param_set_builder_add(p, ecs_param_builder_resource(1));
    p = ecs_param_set_builder_add(p, ecs_param_builder_query(2));
    if ecs_param_set_builder_len(p) != 2 { panic(48015); };
}

@test "local builder"() {
    let l = ecs_local_builder_new(123);
    if ecs_local_builder_value(l) != 123 { panic(48016); };
}

@test "dyn param builder"() {
    let b = ecs_param_builder_resource(5);
    let d = ecs_dyn_param_builder_new(b);
    if ecs_param_builder_kind(ecs_dyn_param_builder_inner(d)) != ECS_PB_RESOURCE { panic(48017); };
}

@test "filtered resources param builder"() {
    let f = ecs_filtered_resources_param_builder_new();
    f = ecs_filtered_resources_param_builder_add_read(f, 1);
    f = ecs_filtered_resources_param_builder_add_write(f, 2);
    if ecs_filtered_resources_param_builder_read_count(f) != 1 { panic(48018); };
    if ecs_filtered_resources_param_builder_write_count(f) != 1 { panic(48019); };
}
