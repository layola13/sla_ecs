@import "lib/entities_collection.sla"

// Isolated tests for lib/entities_collection.sla — EcsEntities collection
// Bevy reference: bevy_ecs/src/entity/mod.rs — Entities struct

@test "entities_new_empty"() {
    let e = ecs_entities_new();
    if ecs_entities_len(e) != 0 { panic(82001); };
    if ecs_entities_is_empty(e) != true { panic(82002); };
    if ecs_entities_count_spawned(e) != 0 { panic(82003); };
    if ecs_entities_any_spawned(e) != false { panic(82004); };
}

@test "entities_alloc_new_slots"() {
    let e = ecs_entities_new();
    let r0 = ecs_entities_alloc(e);
    let e1 = r0.0;
    if r0.1 != 0 { panic(82005); };
    if r0.2 != 0 { panic(82006); };

    let r1 = ecs_entities_alloc(e1);
    if r1.1 != 1 { panic(82007); };
    if r1.2 != 0 { panic(82008); };

    if ecs_entities_len(r1.0) != 2 { panic(82009); };
    if ecs_entities_count_spawned(r1.0) != 2 { panic(82010); };
}

@test "entities_alloc_and_contains"() {
    let e = ecs_entities_new();
    let r = ecs_entities_alloc(e);
    let e1 = r.0;
    let idx = r.1;
    let gen = r.2;

    if ecs_entities_contains(e1, idx, gen) != true { panic(82011); };
    if ecs_entities_contains_spawned(e1, idx, gen) != true { panic(82012); };
    if ecs_entities_is_index_spawned(e1, idx) != true { panic(82013); };

    if ecs_entities_contains(e1, idx, gen + 1) != false { panic(82014); };
    if ecs_entities_contains_spawned(e1, idx, gen + 1) != false { panic(82015); };

    if ecs_entities_contains(e1, 999, 0) != false { panic(82016); };
    if ecs_entities_contains(e1, -1, 0) != false { panic(82017); };
}

@test "entities_free_and_reuse"() {
    let e = ecs_entities_new();
    let r0 = ecs_entities_alloc(e);
    let e1 = r0.0;
    let idx0 = r0.1;
    let gen0 = r0.2;

    let r1 = ecs_entities_alloc(e1);
    let e2 = r1.0;

    if ecs_entities_count_spawned(e2) != 2 { panic(82018); };

    let e3 = ecs_entities_free(e2, idx0, gen0);
    if ecs_entities_count_spawned(e3) != 1 { panic(82019); };
    if ecs_entities_contains_spawned(e3, idx0, gen0) != false { panic(82020); };
    if ecs_entities_is_index_spawned(e3, idx0) != false { panic(82021); };
    if ecs_entities_contains(e3, idx0, gen0) != true { panic(82022); };

    let r2 = ecs_entities_alloc(e3);
    let e4 = r2.0;
    if r2.1 != idx0 { panic(82023); };
    if r2.2 != gen0 + 1 { panic(82024); };
    if ecs_entities_count_spawned(e4) != 2 { panic(82025); };
    if ecs_entities_contains_spawned(e4, r2.1, r2.2) != true { panic(82026); };
}

@test "entities_free_nonexistent"() {
    let e = ecs_entities_new();
    let e1 = ecs_entities_free(e, 0, 0);
    if ecs_entities_count_spawned(e1) != 0 { panic(82027); };
}

@test "entities_free_wrong_gen"() {
    let e = ecs_entities_new();
    let r = ecs_entities_alloc(e);
    let e1 = r.0;
    let idx = r.1;
    let gen = r.2;

    let e2 = ecs_entities_free(e1, idx, gen + 100);
    if ecs_entities_count_spawned(e2) != 1 { panic(82028); };
    if ecs_entities_contains_spawned(e2, idx, gen) != true { panic(82029); };
}

@test "entities_free_many"() {
    let e = ecs_entities_new();
    let r0 = ecs_entities_alloc(e);
    let e1 = r0.0;
    let i0 = r0.1;
    let g0 = r0.2;
    let r1 = ecs_entities_alloc(e1);
    let e2 = r1.0;
    let i1 = r1.1;
    let g1 = r1.2;
    let r2 = ecs_entities_alloc(e2);
    let e3 = r2.0;
    let i2 = r2.1;
    let g2 = r2.2;

    let indices = Vec::new();
    indices.push(i0);
    indices.push(i1);
    indices.push(i2);
    let gens = Vec::new();
    gens.push(g0);
    gens.push(g1);
    gens.push(g2);

    let e4 = ecs_entities_free_many(e3, indices, gens);
    if ecs_entities_count_spawned(e4) != 0 { panic(82030); };
}

@test "entities_get_spawned_location"() {
    let e = ecs_entities_new();
    let r = ecs_entities_alloc(e);
    let e1 = r.0;
    let idx = r.1;
    let gen = r.2;

    let gr = ecs_entities_get_spawned(e1, idx, gen);
    if gr.0 != true { panic(82031); };
    let loc = gr.1;
    if ecs_entity_location_archetype(loc) != 0 { panic(82032); };
    if ecs_entity_location_table(loc) != 0 { panic(82033); };
    if ecs_entity_location_table_row(loc) != 0 { panic(82034); };

    let new_loc = ecs_entity_location_new(3, 7, 12);
    let e2 = ecs_entities_set_location(e1, idx, gen, new_loc);

    let gr2 = ecs_entities_get_spawned(e2, idx, gen);
    if gr2.0 != true { panic(82035); };
    let loc2 = gr2.1;
    if ecs_entity_location_archetype(loc2) != 3 { panic(82036); };
    if ecs_entity_location_table(loc2) != 7 { panic(82037); };
    if ecs_entity_location_table_row(loc2) != 12 { panic(82038); };
}

@test "entities_get_spawned_not_found"() {
    let e = ecs_entities_new();
    let gr = ecs_entities_get_spawned(e, 0, 0);
    if gr.0 != false { panic(82039); };
}

@test "entities_get"() {
    let e = ecs_entities_new();
    let r = ecs_entities_alloc(e);
    let e1 = r.0;
    let idx = r.1;
    let gen = r.2;

    let gr = ecs_entities_get(e1, idx, gen);
    if gr.0 != true { panic(82040); };
    if gr.1 != true { panic(82041); };

    let e2 = ecs_entities_free(e1, idx, gen);

    let gr2 = ecs_entities_get(e2, idx, gen);
    if gr2.0 != true { panic(82042); };
    if gr2.1 != false { panic(82043); };

    let gr3 = ecs_entities_get(e2, 999, 0);
    if gr3.0 != false { panic(82044); };
}

@test "entities_set_location_nonexistent"() {
    let e = ecs_entities_new();
    let loc = ecs_entity_location_new(1, 2, 3);
    let e1 = ecs_entities_set_location(e, 999, 0, loc);
    if ecs_entities_len(e1) != 0 { panic(82045); };
}

@test "entities_resolve_from_index"() {
    let e = ecs_entities_new();
    let r = ecs_entities_alloc(e);
    let e1 = r.0;
    let idx = r.1;
    let gen = r.2;

    let res = ecs_entities_resolve_from_index(e1, idx);
    if res.0 != idx { panic(82046); };
    if res.1 != gen { panic(82047); };

    let res2 = ecs_entities_resolve_from_index(e1, 999);
    if res2.0 != -1 { panic(82048); };

    let res3 = ecs_entities_resolve_from_index(e1, -1);
    if res3.0 != -1 { panic(82049); };
}

@test "entities_ticks"() {
    let e = ecs_entities_new();
    let e1 = ecs_entities_tick(e);
    if ecs_entities_current_tick(e1) != 1 { panic(82050); };

    let r = ecs_entities_alloc(e1);
    let e2 = r.0;
    let idx = r.1;
    let gen = r.2;

    let st = ecs_entities_get_spawn_tick(e2, idx, gen);
    if st.0 != true { panic(82051); };
    if st.1 != 1 { panic(82052); };

    let e3 = ecs_entities_free(e2, idx, gen);
    let dt = ecs_entities_get_despawn_tick(e3, idx, gen);
    if dt.0 != true { panic(82053); };
    if dt.1 != 1 { panic(82054); };

    let st2 = ecs_entities_get_spawn_tick(e3, 999, 0);
    if st2.0 != false { panic(82055); };
}

@test "entities_tick_increments"() {
    let e = ecs_entities_new();
    if ecs_entities_current_tick(e) != 0 { panic(82056); };
    let e1 = ecs_entities_tick(e);
    let e2 = ecs_entities_tick(e1);
    let e3 = ecs_entities_tick(e2);
    if ecs_entities_current_tick(e3) != 3 { panic(82057); };
}

@test "entities_clear"() {
    let e = ecs_entities_new();
    let r0 = ecs_entities_alloc(e);
    let e1 = r0.0;
    let i0 = r0.1;
    let g0 = r0.2;
    let r1 = ecs_entities_alloc(e1);
    let e2 = r1.0;

    let e3 = ecs_entities_free(e2, i0, g0);

    let e4 = ecs_entities_clear(e3);
    if ecs_entities_len(e4) != 0 { panic(82058); };
    if ecs_entities_is_empty(e4) != true { panic(82059); };
    if ecs_entities_count_spawned(e4) != 0 { panic(82060); };
}

@test "entity_location_eq"() {
    let a = ecs_entity_location_new(1, 2, 3);
    let b = ecs_entity_location_new(1, 2, 3);
    let c = ecs_entity_location_new(1, 2, 4);
    let d = ecs_entity_location_new(0, 2, 3);

    if ecs_entity_location_eq(a, b) != true { panic(82061); };
    if ecs_entity_location_eq(a, c) != false { panic(82062); };
    if ecs_entity_location_eq(a, d) != false { panic(82063); };
}

@test "entity_location_accessors"() {
    let loc = ecs_entity_location_new(5, 10, 15);
    if ecs_entity_location_archetype(loc) != 5 { panic(82064); };
    if ecs_entity_location_table(loc) != 10 { panic(82065); };
    if ecs_entity_location_table_row(loc) != 15 { panic(82066); };
}

@test "entities_multiple_alloc_free_cycle"() {
    let e = ecs_entities_new();

    let r0 = ecs_entities_alloc(e);
    let e1 = r0.0;
    let i0 = r0.1;
    let g0 = r0.2;
    let r1 = ecs_entities_alloc(e1);
    let e2 = r1.0;
    let i1 = r1.1;
    let g1 = r1.2;
    let r2 = ecs_entities_alloc(e2);
    let e3 = r2.0;
    let i2 = r2.1;
    let g2 = r2.2;

    if ecs_entities_count_spawned(e3) != 3 { panic(82067); };

    let e4 = ecs_entities_free(e3, i0, g0);
    let e5 = ecs_entities_free(e4, i1, g1);
    let e6 = ecs_entities_free(e5, i2, g2);

    if ecs_entities_count_spawned(e6) != 0 { panic(82068); };
    if ecs_entities_len(e6) != 3 { panic(82069); };

    let r3 = ecs_entities_alloc(e6);
    let e7 = r3.0;
    let r4 = ecs_entities_alloc(e7);
    let e8 = r4.0;

    if ecs_entities_count_spawned(e8) != 2 { panic(82070); };
    if r3.2 <= 0 { panic(82071); };
    if r4.2 <= 0 { panic(82072); };
}

@test "entities_free_already_freed"() {
    let e = ecs_entities_new();
    let r = ecs_entities_alloc(e);
    let e1 = r.0;
    let idx = r.1;
    let gen = r.2;

    let e2 = ecs_entities_free(e1, idx, gen);
    if ecs_entities_count_spawned(e2) != 0 { panic(82073); };

    let e3 = ecs_entities_free(e2, idx, gen);
    if ecs_entities_count_spawned(e3) != 0 { panic(82074); };
}
