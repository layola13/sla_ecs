// Verification tests for EntityMapper (Bevy EntityMapper trait parity).
@import "../lib/ecs_world.sla"

@test "get mapped returns identity for unknown source"() {
    let mapper = ecs_entity_mapper_new();
    let src = entity_new(10, 1);
    let got = ecs_entity_mapper_get_mapped(mapper, src);
    if got.id != 10 { panic(27001); };
}

@test "set mapped then get mapped returns target"() {
    let mapper = ecs_entity_mapper_new();
    let src = entity_new(10, 1);
    let tgt = entity_new(99, 1);
    let m1 = ecs_entity_mapper_set_mapped(mapper, src, tgt);
    let got = ecs_entity_mapper_get_mapped(m1, src);
    if got.id != 99 { panic(27002); };
}

@test "set mapped overwrites existing"() {
    let mapper = ecs_entity_mapper_new();
    let src = entity_new(10, 1);
    let m1 = ecs_entity_mapper_set_mapped(mapper, src, entity_new(50, 1));
    let m2 = ecs_entity_mapper_set_mapped(m1, src, entity_new(77, 1));
    let got = ecs_entity_mapper_get_mapped(m2, src);
    if got.id != 77 { panic(27003); };
}

@test "get or assign spawns new entity on miss"() {
    let w0 = ecs_world_new<i32, i32>(0, 0);
    let mapper = ecs_entity_mapper_new();
    let src = entity_new(42, 1);
    let (w1, m1, target) = ecs_entity_mapper_get_or_assign<i32, i32>(w0, mapper, src);
    if target.id == 42 { panic(27004); };
    if ecs_entity_mapper_len(m1) != 1 { panic(27005); };
    let (w2, m2, again) = ecs_entity_mapper_get_or_assign<i32, i32>(w1, m1, src);
    if again.id != target.id { panic(27006); };
    if ecs_entity_mapper_len(m2) != 1 { panic(27007); };
}

@test "contains reports mapping presence"() {
    let mapper = ecs_entity_mapper_new();
    let src = entity_new(10, 1);
    if ecs_entity_mapper_contains(mapper, src) != false { panic(27008); };
    let m1 = ecs_entity_mapper_set_mapped(mapper, src, entity_new(99, 1));
    if ecs_entity_mapper_contains(m1, src) != true { panic(27009); };
}
