@import "lib/schedule_build_settings.sla"

// === LogLevel ===

@test "log level ignore"() {
    if ecs_log_level_is_ignore(ecs_log_level_ignore()) != true { panic(77001); };
    if ecs_log_level_is_warn(ecs_log_level_ignore()) != false { panic(77002); };
}

@test "log level warn"() {
    if ecs_log_level_is_warn(ecs_log_level_warn()) != true { panic(77010); };
    if ecs_log_level_is_ignore(ecs_log_level_warn()) != false { panic(77011); };
}

@test "log level error"() {
    if ecs_log_level_is_error(ecs_log_level_error()) != true { panic(77020); };
    if ecs_log_level_is_warn(ecs_log_level_error()) != false { panic(77021); };
}

// === ScheduleBuildSettings defaults ===

@test "settings default"() {
    let s = ecs_schedule_build_settings2_default();
    if ecs_schedule_build_settings2_ambiguity_detection(s) != 0 { panic(77030); };
    if ecs_schedule_build_settings2_hierarchy_detection(s) != 1 { panic(77031); };
    if ecs_schedule_build_settings2_auto_insert(s) != true { panic(77032); };
    if ecs_schedule_build_settings2_use_shortnames(s) != true { panic(77033); };
    if ecs_schedule_build_settings2_report_sets(s) != true { panic(77034); };
}

// === ScheduleBuildSettings custom ===

@test "settings custom"() {
    let s = ecs_schedule_build_settings2_new(2, 2, false, false, false);
    if ecs_schedule_build_settings2_ambiguity_detection(s) != 2 { panic(77040); };
    if ecs_schedule_build_settings2_hierarchy_detection(s) != 2 { panic(77041); };
    if ecs_schedule_build_settings2_auto_insert(s) != false { panic(77042); };
    if ecs_schedule_build_settings2_use_shortnames(s) != false { panic(77043); };
    if ecs_schedule_build_settings2_report_sets(s) != false { panic(77044); };
}

// === Setters ===

@test "settings set ambiguity"() {
    let s = ecs_schedule_build_settings2_default();
    let s2 = ecs_schedule_build_settings2_set_ambiguity(s, 2);
    if ecs_schedule_build_settings2_ambiguity_detection(s2) != 2 { panic(77050); };
}

@test "settings set hierarchy"() {
    let s = ecs_schedule_build_settings2_default();
    let s2 = ecs_schedule_build_settings2_set_hierarchy(s, 0);
    if ecs_schedule_build_settings2_hierarchy_detection(s2) != 0 { panic(77060); };
}

@test "settings set auto_insert"() {
    let s = ecs_schedule_build_settings2_default();
    let s2 = ecs_schedule_build_settings2_set_auto_insert(s, false);
    if ecs_schedule_build_settings2_auto_insert(s2) != false { panic(77070); };
}

@test "settings set shortnames"() {
    let s = ecs_schedule_build_settings2_default();
    let s2 = ecs_schedule_build_settings2_set_shortnames(s, false);
    if ecs_schedule_build_settings2_use_shortnames(s2) != false { panic(77080); };
}

@test "settings set report_sets"() {
    let s = ecs_schedule_build_settings2_default();
    let s2 = ecs_schedule_build_settings2_set_report_sets(s, false);
    if ecs_schedule_build_settings2_report_sets(s2) != false { panic(77090); };
}

// === ScheduleBuildMetadata ===

@test "metadata new"() {
    let m = ecs_schedule_build_metadata_new();
    if ecs_schedule_build_metadata_warning_count(m) != 0 { panic(77100); };
    if ecs_schedule_build_metadata_edges_added(m) != 0 { panic(77101); };
}

@test "metadata add warning"() {
    let m = ecs_schedule_build_metadata_new();
    let m2 = ecs_schedule_build_metadata_add_warning(m);
    let m3 = ecs_schedule_build_metadata_add_warning(m2);
    if ecs_schedule_build_metadata_warning_count(m3) != 2 { panic(77110); };
}

@test "metadata add edge"() {
    let m = ecs_schedule_build_metadata_new();
    let m2 = ecs_schedule_build_metadata_add_edge(m);
    let m3 = ecs_schedule_build_metadata_add_edge(m2);
    let m4 = ecs_schedule_build_metadata_add_edge(m3);
    if ecs_schedule_build_metadata_edges_added(m4) != 3 { panic(77120); };
}

@test "metadata mixed"() {
    let m = ecs_schedule_build_metadata_new();
    let m2 = ecs_schedule_build_metadata_add_warning(m);
    let m3 = ecs_schedule_build_metadata_add_edge(m2);
    let m4 = ecs_schedule_build_metadata_add_warning(m3);
    if ecs_schedule_build_metadata_warning_count(m4) != 2 { panic(77130); };
    if ecs_schedule_build_metadata_edges_added(m4) != 1 { panic(77131); };
}
