@import "lib/parallel_scope.sla"

// Isolated tests for lib/parallel_scope.sla — ParallelCommands + ParallelCommandQueue
// Bevy reference: bevy_ecs/src/system/commands/parallel_scope.rs

@test "parallel_command_queue_new"() {
    let q = ecs_parallel_command_queue_new();
    if ecs_parallel_command_queue_len(q) != 0 { panic(83700); };
    if ecs_parallel_command_queue_is_empty(q) != true { panic(83701); };
}

@test "parallel_command_queue_command"() {
    let q = ecs_parallel_command_queue_new();
    let q2 = ecs_parallel_command_queue_command(q, 0, 42);
    if ecs_parallel_command_queue_len(q2) != 1 { panic(83702); };
}

@test "parallel_command_queue_multiple_threads"() {
    let q = ecs_parallel_command_queue_new();
    let q2 = ecs_parallel_command_queue_command(q, 0, 10);
    let q3 = ecs_parallel_command_queue_command(q2, 1, 20);
    let q4 = ecs_parallel_command_queue_command(q3, 0, 30);
    if ecs_parallel_command_queue_len(q4) != 3 { panic(83703); };
    if ecs_parallel_command_queue_count_for_thread(q4, 0) != 2 { panic(83704); };
    if ecs_parallel_command_queue_count_for_thread(q4, 1) != 1 { panic(83705); };
}

@test "parallel_command_queue_get_for_thread"() {
    let q = ecs_parallel_command_queue_new();
    let q2 = ecs_parallel_command_queue_command(q, 0, 10);
    let q3 = ecs_parallel_command_queue_command(q2, 1, 20);
    let q4 = ecs_parallel_command_queue_command(q3, 0, 30);
    let cmds = ecs_parallel_command_queue_get_commands_for_thread(q4, 0);
    if len(cmds) != 2 { panic(83706); };
    if cmds[0] != 10 { panic(83707); };
    if cmds[1] != 30 { panic(83708); };
}

@test "parallel_command_queue_get_all"() {
    let q = ecs_parallel_command_queue_new();
    let q2 = ecs_parallel_command_queue_command(q, 0, 10);
    let q3 = ecs_parallel_command_queue_command(q2, 1, 20);
    let all = ecs_parallel_command_queue_get_all_commands(q3);
    if len(all) != 2 { panic(83709); };
    if all[0] != 10 { panic(83710); };
    if all[1] != 20 { panic(83711); };
}

@test "parallel_command_queue_clear"() {
    let q = ecs_parallel_command_queue_new();
    let q2 = ecs_parallel_command_queue_command(q, 0, 10);
    let q3 = ecs_parallel_command_queue_clear(q2);
    if ecs_parallel_command_queue_len(q3) != 0 { panic(83712); };
}

@test "parallel_commands_new"() {
    let c = ecs_parallel_commands_new();
    if ecs_parallel_commands_total_commands(c) != 0 { panic(83713); };
    if ecs_parallel_commands_is_empty(c) != true { panic(83714); };
}

@test "parallel_commands_command_scope"() {
    let c = ecs_parallel_commands_new();
    let c2 = ecs_parallel_commands_command_scope(c, 0, 42);
    if ecs_parallel_commands_total_commands(c2) != 1 { panic(83715); };
}

@test "parallel_commands_multiple_scopes"() {
    let c = ecs_parallel_commands_new();
    let c2 = ecs_parallel_commands_command_scope(c, 0, 10);
    let c3 = ecs_parallel_commands_command_scope(c2, 1, 20);
    let c4 = ecs_parallel_commands_command_scope(c3, 0, 30);
    if ecs_parallel_commands_total_commands(c4) != 3 { panic(83716); };
    if ecs_parallel_commands_queue_count(c4) != 3 { panic(83717); };
}

@test "parallel_commands_clear"() {
    let c = ecs_parallel_commands_new();
    let c2 = ecs_parallel_commands_command_scope(c, 0, 10);
    let c3 = ecs_parallel_commands_clear(c2);
    if ecs_parallel_commands_total_commands(c3) != 0 { panic(83718); };
    if ecs_parallel_commands_is_empty(c3) != true { panic(83719); };
}

@test "parallel_command_queue_count_for_thread_none"() {
    let q = ecs_parallel_command_queue_new();
    if ecs_parallel_command_queue_count_for_thread(q, 99) != 0 { panic(83720); };
}
