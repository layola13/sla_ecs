// Verification tests for typed Bevy error enums (EntityComponentError etc.).
@import "../lib/ecs_world.sla"

@test "entity component error missing maps to component not found code"() {
    let err = EcsEntityComponentError::MissingComponent { component_id: 5 };
    let code = ecs_entity_component_error_code(err);
    if code != ERR_COMPONENT_NOT_FOUND() { panic(28001); };
}

@test "entity component error aliased maps to multiple match code"() {
    let err = EcsEntityComponentError::AliasedMutability { component_id: 7 };
    let code = ecs_entity_component_error_code(err);
    if code != ERR_QUERY_MULTIPLE_MATCH() { panic(28002); };
}

@test "resource fetch error not registered maps to resource not found"() {
    let err = EcsResourceFetchError::NotRegistered;
    let code = ecs_resource_fetch_error_code(err);
    if code != ERR_RESOURCE_NOT_FOUND() { panic(28003); };
}

@test "resource fetch error does not exist maps to resource not found"() {
    let err = EcsResourceFetchError::DoesNotExist { component_id: 9 };
    let code = ecs_resource_fetch_error_code(err);
    if code != ERR_RESOURCE_NOT_FOUND() { panic(28004); };
}

@test "query single error no entities maps to no match"() {
    let err = EcsQuerySingleError::NoEntities;
    let code = ecs_query_single_error_code(err);
    if code != ERR_QUERY_NO_MATCH() { panic(28005); };
}

@test "query single error multiple entities maps to multiple match"() {
    let err = EcsQuerySingleError::MultipleEntities;
    let code = ecs_query_single_error_code(err);
    if code != ERR_QUERY_MULTIPLE_MATCH() { panic(28006); };
}
