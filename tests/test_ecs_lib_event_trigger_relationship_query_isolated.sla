@import "lib/event_trigger.sla"
@import "lib/relationship_query_iter.sla"

@test "global trigger new"() {
    let g = ecs_global_trigger_new();
    if (1 == 1) != true { panic(61001); };
}

@test "entity trigger new and target"() {
    let t = ecs_entity_trigger_new(42);
    if ecs_entity_trigger_target(t) != 42 { panic(61002); };
}

@test "propagate entity trigger new"() {
    let t = ecs_propagate_entity_trigger_new(7, true);
    if ecs_propagate_entity_trigger_auto(t) != true { panic(61003); };
    if ecs_propagate_entity_trigger_event(t) != 7 { panic(61004); };
}

@test "propagate entity trigger set target"() {
    let t = ecs_propagate_entity_trigger_new(7, true);
    let t2 = ecs_propagate_entity_trigger_set_target(t, 99);
    if ecs_propagate_entity_trigger_target(t2) != 99 { panic(61005); };
}

@test "propagate entity trigger should propagate"() {
    let t = ecs_propagate_entity_trigger_new(7, false);
    if ecs_propagate_entity_trigger_should_propagate(t) != false { panic(61006); };
}

@test "entity components trigger add"() {
    let t = ecs_entity_components_trigger_new(5);
    t = ecs_entity_components_trigger_add(t, 1);
    t = ecs_entity_components_trigger_add(t, 2);
    if ecs_entity_components_trigger_target(t) != 5 { panic(61007); };
    if ecs_entity_components_trigger_component_count(t) != 2 { panic(61008); };
    if ecs_entity_components_trigger_component_at(t, 1) != 2 { panic(61009); };
}

@test "relationship query add child and related"() {
    let r = ecs_relationship_query_new();
    r = ecs_relationship_query_add_child(r, 1, 2);
    r = ecs_relationship_query_add_child(r, 1, 3);
    let rel = ecs_relationship_query_related(r, 1);
    if rel.0 != true { panic(61010); };
    if rel.1 != 2 { panic(61011); };
}

@test "relationship query related missing"() {
    let r = ecs_relationship_query_new();
    let rel = ecs_relationship_query_related(r, 99);
    if rel.0 != false { panic(61012); };
}

@test "relationship query sources"() {
    let r = ecs_relationship_query_new();
    r = ecs_relationship_query_add_child(r, 1, 2);
    r = ecs_relationship_query_add_child(r, 1, 3);
    let s = ecs_relationship_query_sources(r, 1);
    if len(s) as i64 != 2 { panic(61013); };
    if s[1] != 3 { panic(61014); };
}

@test "relationship query sources missing"() {
    let r = ecs_relationship_query_new();
    let s = ecs_relationship_query_sources(r, 99);
    if len(s) as i64 != 0 { panic(61015); };
}

@test "relationship query iter descendants"() {
    let r = ecs_relationship_query_new();
    r = ecs_relationship_query_add_child(r, 1, 2);
    r = ecs_relationship_query_add_child(r, 1, 3);
    r = ecs_relationship_query_add_child(r, 2, 4);
    r = ecs_relationship_query_add_child(r, 3, 5);
    let d = ecs_relationship_query_iter_descendants(r, 1);
    if len(d) as i64 != 4 { panic(61016); };
}

@test "relationship query iter siblings"() {
    let r = ecs_relationship_query_new();
    r = ecs_relationship_query_add_child(r, 1, 2);
    r = ecs_relationship_query_add_child(r, 1, 3);
    let sibs = ecs_relationship_query_iter_siblings(r, 1, 2);
    if len(sibs) as i64 != 1 { panic(61017); };
    if sibs[0] != 3 { panic(61018); };
}

@test "ancestor walker set parent and parent of"() {
    let w = ecs_ancestor_walker_new();
    w = ecs_ancestor_walker_set_parent(w, 2, 1);
    let p = ecs_ancestor_walker_parent_of(w, 2);
    if p.0 != true { panic(61019); };
    if p.1 != 1 { panic(61020); };
}

@test "ancestor walker root ancestor"() {
    let w = ecs_ancestor_walker_new();
    w = ecs_ancestor_walker_set_parent(w, 3, 2);
    w = ecs_ancestor_walker_set_parent(w, 2, 1);
    if ecs_ancestor_walker_root_ancestor(w, 3) != 1 { panic(61021); };
}

@test "ancestor walker root ancestor self"() {
    let w = ecs_ancestor_walker_new();
    if ecs_ancestor_walker_root_ancestor(w, 5) != 5 { panic(61022); };
}

@test "ancestor walker iter ancestors"() {
    let w = ecs_ancestor_walker_new();
    w = ecs_ancestor_walker_set_parent(w, 3, 2);
    w = ecs_ancestor_walker_set_parent(w, 2, 1);
    if ecs_ancestor_walker_iter_ancestors_count(w, 3) != 2 { panic(61023); };
}
