// RelationshipSourceCollection variants (Vec, EntityHashSet, EntityHashMap) +
// OrderedRelationshipSourceCollection (insert, remove_at, swap, sort) +
// ComponentsRegistrator (register, register_with_descriptor, queue, peek, next, len).
// Bevy relationship/relationship_source_collection.rs + component/register.rs.

// --- RelationshipSourceCollection: Vec-backed ---
struct EcsRelVecCollection {
    entities: Vec<i32>,
}

fn rel_vec_new() -> EcsRelVecCollection {
    return EcsRelVecCollection { entities: Vec::new() };
}

fn rel_vec_with_capacity(cap: i64) -> EcsRelVecCollection {
    return EcsRelVecCollection { entities: Vec::new() };
}

fn rel_vec_add(c: EcsRelVecCollection, entity: i32) -> (EcsRelVecCollection, bool) {
    c.entities.push(entity);
    return (c, true);
}

fn rel_vec_remove(c: EcsRelVecCollection, entity: i32) -> (EcsRelVecCollection, bool) {
    let i: i64 = 0;
    let cnt = len(c.entities) as i64;
    while i < cnt {
        if c.entities[i] == entity {
            c.entities.remove(i);
            return (c, true);
        };
        i = i + 1;
    }
    return (c, false);
}

fn rel_vec_len(c: EcsRelVecCollection) -> i64 { return len(c.entities) as i64; }
fn rel_vec_is_empty(c: EcsRelVecCollection) -> bool { return len(c.entities) == 0; }

fn rel_vec_clear(c: EcsRelVecCollection) -> EcsRelVecCollection {
    let empty: Vec<i32> = Vec::new();
    c.entities = empty;
    return c;
}

fn rel_vec_contains(c: EcsRelVecCollection, entity: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(c.entities) as i64;
    while i < cnt {
        if c.entities[i] == entity { return true; };
        i = i + 1;
    }
    return false;
}

fn rel_vec_get(c: EcsRelVecCollection, index: i64) -> i32 {
    if index < 0 || index >= (len(c.entities) as i64) { return -1; };
    return c.entities[index];
}

// --- OrderedRelationshipSourceCollection ---
fn rel_vec_insert(c: EcsRelVecCollection, index: i64, entity: i32) -> EcsRelVecCollection {
    if index >= (len(c.entities) as i64) {
        c.entities.push(entity);
        return c;
    };
    // Manual insert: push to end, then shift right
    c.entities.push(entity);
    let i = len(c.entities) as i64 - 1;
    return rel_vec_insert_shift(c, index, i, entity);
}

fn rel_vec_insert_shift(c: EcsRelVecCollection, target: i64, i: i64, entity: i32) -> EcsRelVecCollection {
    if i <= target {
        c.entities[target] = entity;
        return c;
    };
    c.entities[i] = c.entities[i - 1];
    return rel_vec_insert_shift(c, target, i - 1, entity);
}

fn rel_vec_remove_at(c: EcsRelVecCollection, index: i64) -> (EcsRelVecCollection, i32, bool) {
    if index < 0 || index >= (len(c.entities) as i64) {
        return (c, -1, false);
    };
    let entity = c.entities[index];
    c.entities.remove(index);
    return (c, entity, true);
}

fn rel_vec_swap(c: EcsRelVecCollection, a: i64, b: i64) -> EcsRelVecCollection {
    let tmp = c.entities[a];
    c.entities[a] = c.entities[b];
    c.entities[b] = tmp;
    return c;
}

// --- EntityHashSet-backed collection (dedup) ---
struct EcsRelHashSetCollection {
    entities: Vec<i32>,
}

fn rel_hashset_new() -> EcsRelHashSetCollection { return EcsRelHashSetCollection { entities: Vec::new() }; }

fn rel_hashset_add(c: EcsRelHashSetCollection, entity: i32) -> (EcsRelHashSetCollection, bool) {
    if rel_hashset_contains(c, entity) { return (c, false); };
    c.entities.push(entity);
    return (c, true);
}

fn rel_hashset_contains(c: EcsRelHashSetCollection, entity: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(c.entities) as i64;
    while i < cnt {
        if c.entities[i] == entity { return true; };
        i = i + 1;
    }
    return false;
}

fn rel_hashset_len(c: EcsRelHashSetCollection) -> i64 { return len(c.entities) as i64; }
fn rel_hashset_is_empty(c: EcsRelHashSetCollection) -> bool { return len(c.entities) == 0; }

// --- source_to_remove_before_add (one-to-one) ---
fn rel_vec_source_to_remove(c: EcsRelVecCollection) -> i32 {
    // For one-to-one: return the single entity if exactly one exists
    if len(c.entities) == 1 { return c.entities[0]; };
    return -1;
}

// --- extend_from_iter ---
fn rel_vec_extend(c: EcsRelVecCollection, entities: Vec<i32>) -> EcsRelVecCollection {
    return rel_vec_extend_rec(c, entities, 0);
}

fn rel_vec_extend_rec(c: EcsRelVecCollection, entities: Vec<i32>, i: i64) -> EcsRelVecCollection {
    if i >= (len(entities) as i64) { return c; };
    let (c2, _) = rel_vec_add(c, entities[i]);
    return rel_vec_extend_rec(c2, entities, i + 1);
}

// --- ComponentsRegistrator ---
struct EcsComponentIds {
    next_id: i32,
    count: i32,
}

fn component_ids_new() -> EcsComponentIds {
    return EcsComponentIds { next_id: 0, count: 0 };
}

fn component_ids_peek(ids: EcsComponentIds) -> i32 { return ids.next_id; }

fn component_ids_next(ids: EcsComponentIds) -> (EcsComponentIds, i32) {
    let id = ids.next_id;
    ids.next_id = id + 1;
    ids.count = ids.count + 1;
    return (ids, id);
}

fn component_ids_len(ids: EcsComponentIds) -> i32 { return ids.count; }
fn component_ids_is_empty(ids: EcsComponentIds) -> bool { return ids.count == 0; }

struct EcsComponentsRegistrator {
    ids: EcsComponentIds,
    registered: Vec<i32>,  // registered component type_ids
    queued: Vec<i32>,      // queued registrations
}

fn registrator_new() -> EcsComponentsRegistrator {
    return EcsComponentsRegistrator { ids: component_ids_new(), registered: Vec::new(), queued: Vec::new() };
}

fn registrator_register_component(reg: EcsComponentsRegistrator, type_id: i32) -> (EcsComponentsRegistrator, i32) {
    let (ids, component_id) = component_ids_next(reg.ids);
    reg.ids = ids;
    reg.registered.push(type_id);
    return (reg, component_id);
}

fn registrator_register_resource(reg: EcsComponentsRegistrator, type_id: i32) -> (EcsComponentsRegistrator, i32) {
    let (ids, component_id) = component_ids_next(reg.ids);
    reg.ids = ids;
    reg.registered.push(type_id);
    return (reg, component_id);
}

fn registrator_register_non_send(reg: EcsComponentsRegistrator, type_id: i32) -> (EcsComponentsRegistrator, i32) {
    let (ids, component_id) = component_ids_next(reg.ids);
    reg.ids = ids;
    reg.registered.push(type_id);
    return (reg, component_id);
}

fn registrator_queue_register(reg: EcsComponentsRegistrator, type_id: i32) -> EcsComponentsRegistrator {
    reg.queued.push(type_id);
    return reg;
}

fn registrator_apply_queued(reg: EcsComponentsRegistrator) -> EcsComponentsRegistrator {
    let reg2 = registrator_apply_queued_rec(reg, 0);
    let empty: Vec<i32> = Vec::new();
    reg2.queued = empty;
    return reg2;
}

fn registrator_apply_queued_rec(reg: EcsComponentsRegistrator, i: i64) -> EcsComponentsRegistrator {
    if i >= (len(reg.queued) as i64) { return reg; };
    let (reg2, _) = registrator_register_component(reg, reg.queued[i]);
    return registrator_apply_queued_rec(reg2, i + 1);
}

fn registrator_any_queued(reg: EcsComponentsRegistrator) -> bool { return len(reg.queued) > 0; }
fn registrator_num_queued(reg: EcsComponentsRegistrator) -> i64 { return len(reg.queued) as i64; }
fn registrator_registered_count(reg: EcsComponentsRegistrator) -> i64 { return len(reg.registered) as i64; }

fn registrator_contains(reg: EcsComponentsRegistrator, type_id: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(reg.registered) as i64;
    while i < cnt {
        if reg.registered[i] == type_id { return true; };
        i = i + 1;
    }
    return false;
}

@test "rel_vec add and len"() {
    let c = rel_vec_new();
    let (c2, added) = rel_vec_add(c, 1);
    if added != true { panic(17001); };
    if rel_vec_len(c2) != 1 { panic(17002); };
}

@test "rel_vec add duplicate returns true (Vec allows)"() {
    let c = rel_vec_new();
    let (c2, _) = rel_vec_add(c, 1);
    let (c3, added) = rel_vec_add(c2, 1);
    if added != true { panic(17003); };
    if rel_vec_len(c3) != 2 { panic(17004); };
}

@test "rel_vec remove"() {
    let c = rel_vec_new();
    let (c2, _) = rel_vec_add(c, 1);
    let (c3, removed) = rel_vec_remove(c2, 1);
    if removed != true { panic(17005); };
    if rel_vec_len(c3) != 0 { panic(17006); };
}

@test "rel_vec remove absent returns false"() {
    let c = rel_vec_new();
    let (_, removed) = rel_vec_remove(c, 999);
    if removed { panic(17007); };
}

@test "rel_vec is_empty"() {
    let c = rel_vec_new();
    if rel_vec_is_empty(c) != true { panic(17008); };
}

@test "rel_vec clear"() {
    let c = rel_vec_new();
    let (c2, _) = rel_vec_add(c, 1);
    let (c3, _) = rel_vec_add(c2, 2);
    let c4 = rel_vec_clear(c3);
    if rel_vec_is_empty(c4) != true { panic(17009); };
}

@test "rel_vec contains"() {
    let c = rel_vec_new();
    let (c2, _) = rel_vec_add(c, 42);
    if rel_vec_contains(c2, 42) != true { panic(17010); };
    if rel_vec_contains(c2, 99) { panic(17011); };
}

@test "rel_vec insert at index"() {
    let c = rel_vec_new();
    let (c2, _) = rel_vec_add(c, 1);
    let (c3, _) = rel_vec_add(c2, 3);
    let c4 = rel_vec_insert(c3, 1, 2);
    if rel_vec_get(c4, 0) != 1 { panic(17012); };
    if rel_vec_get(c4, 1) != 2 { panic(17013); };
    if rel_vec_get(c4, 2) != 3 { panic(17014); };
}

@test "rel_vec insert at end when index too large"() {
    let c = rel_vec_new();
    let (c2, _) = rel_vec_add(c, 1);
    let c3 = rel_vec_insert(c2, 99, 2);
    if rel_vec_get(c3, 1) != 2 { panic(17015); };
}

@test "rel_vec extend_from_iter"() {
    let c = rel_vec_new();
    let entities: Vec<i32> = Vec::new();
    entities.push(1);
    entities.push(2);
    entities.push(3);
    let c2 = rel_vec_extend(c, entities);
    if rel_vec_len(c2) != 3 { panic(17016); };
}

@test "rel_vec source_to_remove one-to-one"() {
    let c = rel_vec_new();
    let (c2, _) = rel_vec_add(c, 42);
    if rel_vec_source_to_remove(c2) != 42 { panic(17017); };
    let (c3, _) = rel_vec_add(c2, 99);
    if rel_vec_source_to_remove(c3) != -1 { panic(17018); };
}

@test "hashset add returns true for new"() {
    let c = rel_hashset_new();
    let (c2, added) = rel_hashset_add(c, 1);
    if added != true { panic(17019); };
}

@test "hashset add returns false for duplicate"() {
    let c = rel_hashset_new();
    let (c2, _) = rel_hashset_add(c, 1);
    let (c3, added) = rel_hashset_add(c2, 1);
    if added { panic(17020); };
    if rel_hashset_len(c3) != 1 { panic(17021); };
}

@test "hashset is_empty"() {
    let c = rel_hashset_new();
    if rel_hashset_is_empty(c) != true { panic(17022); };
}

@test "component_ids peek and next"() {
    let ids = component_ids_new();
    if component_ids_peek(ids) != 0 { panic(17023); };
    let (ids2, id) = component_ids_next(ids);
    if id != 0 { panic(17024); };
    if component_ids_peek(ids2) != 1 { panic(17025); };
}

@test "component_ids len and is_empty"() {
    let ids = component_ids_new();
    if component_ids_is_empty(ids) != true { panic(17026); };
    let (ids2, _) = component_ids_next(ids);
    if component_ids_len(ids2) != 1 { panic(17027); };
}

@test "registrator register_component returns id"() {
    let reg = registrator_new();
    let (reg2, id) = registrator_register_component(reg, 100);
    if id != 0 { panic(17028); };
    if registrator_registered_count(reg2) != 1 { panic(17029); };
    if registrator_contains(reg2, 100) != true { panic(17030); };
}

@test "registrator register_resource"() {
    let reg = registrator_new();
    let (reg2, id) = registrator_register_resource(reg, 200);
    if id != 0 { panic(17031); };
    if registrator_contains(reg2, 200) != true { panic(17032); };
}

@test "registrator register_non_send"() {
    let reg = registrator_new();
    let (reg2, id) = registrator_register_non_send(reg, 300);
    if id != 0 { panic(17033); };
}

@test "registrator queue and apply"() {
    let reg = registrator_new();
    let reg2 = registrator_queue_register(reg, 400);
    if registrator_any_queued(reg2) != true { panic(17034); };
    if registrator_num_queued(reg2) != 1 { panic(17035); };
    let reg3 = registrator_apply_queued(reg2);
    if registrator_any_queued(reg3) { panic(17036); };
    if registrator_registered_count(reg3) != 1 { panic(17037); };
    if registrator_contains(reg3, 400) != true { panic(17038); };
}

@test "registrator multiple registrations get sequential ids"() {
    let reg = registrator_new();
    let (reg2, id1) = registrator_register_component(reg, 1);
    let (reg3, id2) = registrator_register_component(reg2, 2);
    let (reg4, id3) = registrator_register_component(reg3, 3);
    if id1 != 0 { panic(17039); };
    if id2 != 1 { panic(17040); };
    if id3 != 2 { panic(17041); };
    if registrator_registered_count(reg4) != 3 { panic(17042); };
}

@test "registrator queue multiple then apply"() {
    let reg = registrator_new();
    let reg2 = registrator_queue_register(reg, 1);
    let reg3 = registrator_queue_register(reg2, 2);
    let reg4 = registrator_queue_register(reg3, 3);
    if registrator_num_queued(reg4) != 3 { panic(17043); };
    let reg5 = registrator_apply_queued(reg4);
    if registrator_registered_count(reg5) != 3 { panic(17044); };
    if registrator_any_queued(reg5) { panic(17045); };
}

@test "registrator contains false for unregistered"() {
    let reg = registrator_new();
    if registrator_contains(reg, 999) { panic(17046); };
}
