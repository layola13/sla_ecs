@import "lib/message_reader_writer.sla"
@import "lib/messages_buffer.sla"
@import "lib/message_iterators.sla"

@test "message reader new and len"() {
    let r = ecs_message_reader_new(5);
    if ecs_message_reader_len(r) != 5 { panic(66001); };
    if ecs_message_reader_is_empty(r) != false { panic(66002); };
}

@test "message reader read"() {
    let r = ecs_message_reader_new(3);
    let r1 = ecs_message_reader_read(r);
    if r1.1 != true { panic(66003); };
    if r1.2 != 0 { panic(66004); };
    if ecs_message_reader_len(r1.0) != 2 { panic(66005); };
}

@test "message reader read with id"() {
    let r = ecs_message_reader_new(2);
    let r1 = ecs_message_reader_read_with_id(r);
    if r1.1 != true { panic(66006); };
    if r1.3 != 0 { panic(66007); };
}

@test "message reader clear"() {
    let r = ecs_message_reader_new(5);
    let r2 = ecs_message_reader_clear(r);
    if ecs_message_reader_is_empty(r2) != true { panic(66008); };
}

@test "message reader total"() {
    let r = ecs_message_reader_new(5);
    if ecs_message_reader_total(r) != 5 { panic(66009); };
}

@test "populated message reader populated"() {
    let p = ecs_populated_message_reader_new(5);
    if ecs_populated_message_reader_is_populated(p) != true { panic(66010); };
}

@test "populated message reader empty"() {
    let p = ecs_populated_message_reader_new(0);
    if ecs_populated_message_reader_is_populated(p) != false { panic(66011); };
}

@test "message writer write"() {
    let w = ecs_message_writer_new();
    let w1 = ecs_message_writer_write(w, 100);
    if w1.1 != 0 { panic(66012); };
    if ecs_message_writer_len(w1.0) != 1 { panic(66013); };
}

@test "message writer write batch"() {
    let w = ecs_message_writer_new();
    let values: Vec<i64> = Vec::new();
    values.push(1);
    values.push(2);
    values.push(3);
    let w1 = ecs_message_writer_write_batch(w, values);
    if w1.1 != 3 { panic(66014); };
    if ecs_message_writer_at(w1.0, 2) != 3 { panic(66015); };
}

@test "message writer write default"() {
    let w = ecs_message_writer_new();
    let w1 = ecs_message_writer_write_default(w);
    if ecs_message_writer_at(w1.0, 0) != 0 { panic(66016); };
}

@test "messages buffer new and empty"() {
    let m = ecs_messages_new();
    if ecs_messages_is_empty(m) != true { panic(66017); };
}

@test "messages buffer write and len"() {
    let m = ecs_messages_new();
    let m1 = ecs_messages_write(m, 10);
    if ecs_messages_len(m1.0) != 1 { panic(66018); };
}

@test "messages buffer write batch"() {
    let m = ecs_messages_new();
    let values: Vec<i64> = Vec::new();
    values.push(1);
    values.push(2);
    let m1 = ecs_messages_write_batch(m, values);
    if ecs_messages_current_len(m1.0) != 2 { panic(66019); };
}

@test "messages buffer update rotates"() {
    let m = ecs_messages_new();
    m = ecs_messages_write(m, 10).0;
    m = ecs_messages_write(m, 20).0;
    m = ecs_messages_update(m);
    if ecs_messages_previous_len(m) != 2 { panic(66020); };
    if ecs_messages_current_len(m) != 0 { panic(66021); };
}

@test "messages buffer update drain"() {
    let m = ecs_messages_new();
    m = ecs_messages_write(m, 10).0;
    m = ecs_messages_update(m);
    m = ecs_messages_write(m, 30).0;
    let r = ecs_messages_update_drain(m);
    if r.1 != 1 { panic(66022); };
}

@test "messages buffer get cursor total"() {
    let m = ecs_messages_new();
    m = ecs_messages_write(m, 10).0;
    m = ecs_messages_write(m, 20).0;
    m = ecs_messages_update(m);
    m = ecs_messages_write(m, 30).0;
    let c = ecs_messages_get_cursor(m);
    if ecs_message_cursor_len(c) != 3 { panic(66023); };
}

@test "messages buffer get cursor current"() {
    let m = ecs_messages_new();
    m = ecs_messages_write(m, 10).0;
    m = ecs_messages_update(m);
    m = ecs_messages_write(m, 30).0;
    let c = ecs_messages_get_cursor_current(m);
    if ecs_message_cursor_len(c) != 1 { panic(66024); };
}

@test "messages buffer clear"() {
    let m = ecs_messages_new();
    m = ecs_messages_write(m, 10).0;
    m = ecs_messages_clear(m);
    if ecs_messages_is_empty(m) != true { panic(66025); };
}

@test "messages buffer oldest message count"() {
    let m = ecs_messages_new();
    m = ecs_messages_write(m, 10).0;
    m = ecs_messages_update(m);
    if ecs_messages_oldest_message_count(m) != 0 { panic(66026); };
    m = ecs_messages_update(m);
    if ecs_messages_oldest_message_count(m) != 1 { panic(66027); };
}

@test "message iterator new and len"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 5);
    let it = ecs_message_iterator_new(c);
    if ecs_message_iterator_len(it) != 5 { panic(66028); };
}

@test "message iterator next"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 3);
    let it = ecs_message_iterator_new(c);
    let r = ecs_message_iterator_next(it);
    if r.1 != true { panic(66029); };
    if r.2 != 0 { panic(66030); };
    if ecs_message_iterator_len(r.0) != 2 { panic(66031); };
}

@test "message iterator with id next"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 2);
    let it = ecs_message_iterator_with_id_new(c);
    let r = ecs_message_iterator_with_id_next(it);
    if r.1 != true { panic(66032); };
    if r.3 != 0 { panic(66033); };
}

@test "message iterator with id without id"() {
    let c = ecs_message_cursor_new();
    c = ecs_message_cursor_set_message_count(c, 2);
    let it = ecs_message_iterator_with_id_new(c);
    let plain = ecs_message_iterator_with_id_without_id(it);
    if ecs_message_iterator_len(plain) != 2 { panic(66034); };
}

@test "message par iter batching"() {
    let p = ecs_message_par_iter_new(100);
    let p2 = ecs_message_par_iter_batching_strategy(p, 25);
    if ecs_message_par_iter_batch_count(p2) != 4 { panic(66035); };
}

@test "message par iter for each"() {
    let p = ecs_message_par_iter_new(50);
    if ecs_message_par_iter_for_each(p) != 50 { panic(66036); };
}
