@import "lib/change_detection.sla"

@test "tick new and get"() {
    let t = ecs_tick_new(42);
    if ecs_tick_get(t) != 42 { panic(37001); };
}

@test "tick set"() {
    let t = ecs_tick_set(ecs_tick_new(0), 99);
    if ecs_tick_get(t) != 99 { panic(37002); };
}

@test "tick is_newer_than true"() {
    let t = ecs_tick_new(5);
    let last_run = ecs_tick_new(3);
    let this_run = ecs_tick_new(10);
    if ecs_tick_is_newer_than(t, last_run, this_run) != true { panic(37003); };
}

@test "tick is_newer_than false old"() {
    let t = ecs_tick_new(2);
    let last_run = ecs_tick_new(3);
    let this_run = ecs_tick_new(10);
    if ecs_tick_is_newer_than(t, last_run, this_run) != false { panic(37004); };
}

@test "tick is_newer_than false future"() {
    let t = ecs_tick_new(15);
    let last_run = ecs_tick_new(3);
    let this_run = ecs_tick_new(10);
    if ecs_tick_is_newer_than(t, last_run, this_run) != false { panic(37005); };
}

@test "tick eq"() {
    if ecs_tick_eq(ecs_tick_new(5), ecs_tick_new(5)) != true { panic(37006); };
    if ecs_tick_eq(ecs_tick_new(5), ecs_tick_new(6)) != false { panic(37007); };
}

@test "tick lt"() {
    if ecs_tick_lt(ecs_tick_new(5), ecs_tick_new(6)) != true { panic(37008); };
    if ecs_tick_lt(ecs_tick_new(6), ecs_tick_new(5)) != false { panic(37009); };
}

@test "check_change_ticks present_tick"() {
    let c = ecs_check_change_ticks_new(ecs_tick_new(42));
    if ecs_tick_get(ecs_check_change_ticks_present_tick(c)) != 42 { panic(37010); };
}

@test "component ticks new"() {
    let ct = ecs_component_ticks_new(ecs_tick_new(5));
    if ecs_tick_get(ecs_component_ticks_added_tick(ct)) != 5 { panic(37011); };
    if ecs_tick_get(ecs_component_ticks_changed_tick(ct)) != 5 { panic(37012); };
}

@test "component ticks is_added true"() {
    let ct = ecs_component_ticks_new(ecs_tick_new(8));
    if ecs_component_ticks_is_added(ct, ecs_tick_new(5), ecs_tick_new(10)) != true { panic(37013); };
}

@test "component ticks is_added false"() {
    let ct = ecs_component_ticks_new(ecs_tick_new(3));
    if ecs_component_ticks_is_added(ct, ecs_tick_new(5), ecs_tick_new(10)) != false { panic(37014); };
}

@test "component ticks is_changed true"() {
    let ct = ecs_component_ticks_new(ecs_tick_new(8));
    if ecs_component_ticks_is_changed(ct, ecs_tick_new(5), ecs_tick_new(10)) != true { panic(37015); };
}

@test "component ticks set_changed"() {
    let ct = ecs_component_ticks_set_changed(ecs_component_ticks_new(ecs_tick_new(5)), ecs_tick_new(20));
    if ecs_tick_get(ecs_component_ticks_changed_tick(ct)) != 20 { panic(37016); };
}

@test "component ticks set_added"() {
    let ct = ecs_component_ticks_set_added(ecs_component_ticks_new(ecs_tick_new(5)), ecs_tick_new(20));
    if ecs_tick_get(ecs_component_ticks_added_tick(ct)) != 20 { panic(37017); };
}

@test "component tick cells push and len"() {
    let c = ecs_component_tick_cells_push(ecs_component_tick_cells_push(ecs_component_tick_cells_new(), 1, 2), 3, 4);
    if ecs_component_tick_cells_len(c) != 2 { panic(37018); };
    if ecs_component_tick_cells_get_added(c, 0) != 1 { panic(37019); };
    if ecs_component_tick_cells_get_changed(c, 1) != 4 { panic(37020); };
}

@test "contiguous ticks ref"() {
    let added: Vec<i32> = Vec::new();
    added.push(1);
    added.push(2);
    let changed: Vec<i32> = Vec::new();
    changed.push(3);
    changed.push(4);
    let r = ecs_contiguous_ticks_ref_new(added, changed, ecs_tick_new(1), ecs_tick_new(10));
    if ecs_contiguous_ticks_ref_added_len(r) != 2 { panic(37021); };
    if ecs_tick_get(ecs_contiguous_ticks_ref_last_run(r)) != 1 { panic(37022); };
    if ecs_tick_get(ecs_contiguous_ticks_ref_this_run(r)) != 10 { panic(37023); };
}

@test "detect changes is_added"() {
    let d = ecs_detect_changes_new(ecs_tick_new(8), ecs_tick_new(5), ecs_tick_new(3), ecs_tick_new(10));
    if ecs_detect_changes_is_added(d) != true { panic(37024); };
}

@test "detect changes is_changed"() {
    let d = ecs_detect_changes_new(ecs_tick_new(5), ecs_tick_new(8), ecs_tick_new(3), ecs_tick_new(10));
    if ecs_detect_changes_is_changed(d) != true { panic(37025); };
}

@test "detect changes is_added_after"() {
    let d = ecs_detect_changes_new(ecs_tick_new(8), ecs_tick_new(5), ecs_tick_new(3), ecs_tick_new(10));
    if ecs_detect_changes_is_added_after(d, ecs_tick_new(5)) != true { panic(37026); };
    if ecs_detect_changes_is_added_after(d, ecs_tick_new(10)) != false { panic(37027); };
}

@test "detect changes is_changed_after"() {
    let d = ecs_detect_changes_new(ecs_tick_new(5), ecs_tick_new(8), ecs_tick_new(3), ecs_tick_new(10));
    if ecs_detect_changes_is_changed_after(d, ecs_tick_new(5)) != true { panic(37028); };
}

@test "detect changes mut set_changed"() {
    let d = ecs_detect_changes_new(ecs_tick_new(5), ecs_tick_new(3), ecs_tick_new(1), ecs_tick_new(10));
    let d2 = ecs_detect_changes_mut_set_changed(d, ecs_tick_new(10));
    if ecs_detect_changes_is_changed(d2) != true { panic(37029); };
}

@test "detect changes mut set_added"() {
    let d = ecs_detect_changes_new(ecs_tick_new(3), ecs_tick_new(3), ecs_tick_new(1), ecs_tick_new(10));
    let d2 = ecs_detect_changes_mut_set_added(d, ecs_tick_new(10));
    if ecs_detect_changes_is_added(d2) != true { panic(37030); };
}

@test "detect changes mut set_if_eq different"() {
    let d = ecs_detect_changes_new(ecs_tick_new(5), ecs_tick_new(3), ecs_tick_new(1), ecs_tick_new(10));
    let d2 = ecs_detect_changes_mut_set_if_eq(d, ecs_tick_new(7));
    if ecs_tick_get(d2.changed_tick) != 7 { panic(37031); };
}

@test "detect changes mut set_if_eq same"() {
    let d = ecs_detect_changes_new(ecs_tick_new(5), ecs_tick_new(7), ecs_tick_new(1), ecs_tick_new(10));
    let d2 = ecs_detect_changes_mut_set_if_eq(d, ecs_tick_new(7));
    if ecs_tick_get(d2.changed_tick) != 7 { panic(37032); };
}

@test "maybe location none"() {
    let m = ecs_maybe_location_none();
    if ecs_maybe_location_is_none(m) != true { panic(37033); };
    if ecs_maybe_location_is_some(m) != false { panic(37034); };
}

@test "maybe location some"() {
    let m = ecs_maybe_location_some(42);
    if ecs_maybe_location_is_some(m) != true { panic(37035); };
    if ecs_maybe_location_unwrap(m) != 42 { panic(37036); };
}

@test "maybe location unwrap_or"() {
    if ecs_maybe_location_unwrap_or(ecs_maybe_location_none(), 99) != 99 { panic(37037); };
    if ecs_maybe_location_unwrap_or(ecs_maybe_location_some(42), 99) != 42 { panic(37038); };
}

@test "maybe location assign"() {
    let m = ecs_maybe_location_assign(ecs_maybe_location_none(), ecs_maybe_location_some(42));
    if ecs_maybe_location_unwrap(m) != 42 { panic(37039); };
    let m2 = ecs_maybe_location_assign(ecs_maybe_location_some(10), ecs_maybe_location_none());
    if ecs_maybe_location_unwrap(m2) != 10 { panic(37040); };
}

@test "maybe location map"() {
    let m = ecs_maybe_location_map(ecs_maybe_location_some(10), 99);
    if ecs_maybe_location_unwrap(m) != 99 { panic(37041); };
    let m2 = ecs_maybe_location_map(ecs_maybe_location_none(), 99);
    if ecs_maybe_location_is_none(m2) != true { panic(37042); };
}

@test "maybe location into_option"() {
    let r = ecs_maybe_location_into_option(ecs_maybe_location_some(42));
    if r.0 != true { panic(37043); };
    if r.1 != 42 { panic(37044); };
    let r2 = ecs_maybe_location_into_option(ecs_maybe_location_none());
    if r2.0 != false { panic(37045); };
}

@test "contig mut new and accessors"() {
    let added: Vec<i32> = Vec::new();
    added.push(1);
    added.push(2);
    let changed: Vec<i32> = Vec::new();
    changed.push(3);
    changed.push(4);
    let m = ecs_contig_mut_new(added, changed, ecs_tick_new(1), ecs_tick_new(10));
    if ecs_contig_mut_len(m) != 2 { panic(37046); };
    if ecs_contig_mut_added_at(m, 0) != 1 { panic(37047); };
    if ecs_contig_mut_changed_at(m, 1) != 4 { panic(37048); };
}

@test "contig mut set added"() {
    let added: Vec<i32> = Vec::new();
    added.push(1);
    let changed: Vec<i32> = Vec::new();
    changed.push(3);
    let m = ecs_contig_mut_new(added, changed, ecs_tick_new(1), ecs_tick_new(10));
    let m2 = ecs_contig_mut_set_added(m, 0, 99);
    if ecs_contig_mut_added_at(m2, 0) != 99 { panic(37049); };
}

@test "contig mut set changed"() {
    let added: Vec<i32> = Vec::new();
    added.push(1);
    let changed: Vec<i32> = Vec::new();
    changed.push(3);
    let m = ecs_contig_mut_new(added, changed, ecs_tick_new(1), ecs_tick_new(10));
    let m2 = ecs_contig_mut_set_changed(m, 0, 88);
    if ecs_contig_mut_changed_at(m2, 0) != 88 { panic(37050); };
}

@test "contig mut mark changed"() {
    let added: Vec<i32> = Vec::new();
    added.push(1);
    let changed: Vec<i32> = Vec::new();
    changed.push(3);
    let m = ecs_contig_mut_new(added, changed, ecs_tick_new(1), ecs_tick_new(10));
    let m2 = ecs_contig_mut_mark_changed(m, 0);
    if ecs_contig_mut_changed_at(m2, 0) != 10 { panic(37051); };
}

@test "contig mut last run and this run"() {
    let added: Vec<i32> = Vec::new();
    added.push(1);
    let changed: Vec<i32> = Vec::new();
    changed.push(3);
    let m = ecs_contig_mut_new(added, changed, ecs_tick_new(5), ecs_tick_new(15));
    if ecs_tick_get(ecs_contig_mut_last_run(m)) != 5 { panic(37052); };
    if ecs_tick_get(ecs_contig_mut_this_run(m)) != 15 { panic(37053); };
}

@test "contig mut reborrow"() {
    let added: Vec<i32> = Vec::new();
    added.push(1);
    let changed: Vec<i32> = Vec::new();
    changed.push(3);
    let m = ecs_contig_mut_new(added, changed, ecs_tick_new(5), ecs_tick_new(15));
    let m2 = ecs_contig_mut_reborrow(m);
    if ecs_contig_mut_len(m2) != 1 { panic(37054); };
    if ecs_contig_mut_added_at(m2, 0) != 1 { panic(37055); };
}
