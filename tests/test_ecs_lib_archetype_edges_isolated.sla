@import "lib/archetype_edges.sla"

// === ArchetypeId / ArchetypeRow ===

@test "archetype id"() {
    let a = ecs_archetype_id_new(5);
    if ecs_archetype_id_value(a) != 5 { panic(81001); };
    if ecs_archetype_id_index(a) != 5 { panic(81002); };
}

@test "archetype id eq"() {
    let a = ecs_archetype_id_new(3);
    let b = ecs_archetype_id_new(3);
    let c = ecs_archetype_id_new(4);
    if ecs_archetype_id_eq(a, b) != true { panic(81010); };
    if ecs_archetype_id_eq(a, c) != false { panic(81011); };
}

@test "archetype row"() {
    let r = ecs_archetype_row_new(7);
    if ecs_archetype_row_value(r) != 7 { panic(81020); };
}

// === ComponentStatus ===

@test "component status"() {
    if ecs_component_status_not_present() != 0 { panic(81030); };
    if ecs_component_status_added() != 1 { panic(81031); };
    if ecs_component_status_existed() != 2 { panic(81032); };
}

// === ArchetypeAfterBundleInsert ===

@test "after bundle insert"() {
    let added = Vec::new();
    added.push(1);
    added.push(2);
    let existing = Vec::new();
    existing.push(3);
    let a = ecs_archetype_after_bundle_insert_new(10, added, existing);
    if ecs_archetype_after_insert_id(a) != 10 { panic(81040); };
    if ecs_archetype_after_insert_added_len(a) != 2 { panic(81041); };
    if ecs_archetype_after_insert_total_len(a) != 3 { panic(81042); };
}

// === Edges: insert ===

@test "edges insert not cached"() {
    let e = ecs_archetype_edges_new();
    let r = ecs_archetype_edges_get_insert(e, 5);
    if r.0 != false { panic(81050); };
}

@test "edges insert cache and get"() {
    let e = ecs_archetype_edges_new();
    let e2 = ecs_archetype_edges_cache_insert(e, 5, 10);
    let r = ecs_archetype_edges_get_insert(e2, 5);
    if r.0 != true { panic(81060); };
    if r.1 != 10 { panic(81061); };
}

@test "edges insert cache duplicate"() {
    let e = ecs_archetype_edges_new();
    let e2 = ecs_archetype_edges_cache_insert(e, 5, 10);
    let e3 = ecs_archetype_edges_cache_insert(e2, 5, 20);
    if ecs_archetype_edges_insert_count(e3) != 1 { panic(81070); };
    let r = ecs_archetype_edges_get_insert(e3, 5);
    if r.1 != 10 { panic(81071); };
}

@test "edges insert multiple"() {
    let e = ecs_archetype_edges_new();
    let e2 = ecs_archetype_edges_cache_insert(e, 1, 10);
    let e3 = ecs_archetype_edges_cache_insert(e2, 2, 20);
    let e4 = ecs_archetype_edges_cache_insert(e3, 3, 30);
    if ecs_archetype_edges_insert_count(e4) != 3 { panic(81080); };
}

// === Edges: remove ===

@test "edges remove not cached"() {
    let e = ecs_archetype_edges_new();
    let r = ecs_archetype_edges_get_remove(e, 5);
    if r.0 != false { panic(81090); };
}

@test "edges remove cache and get"() {
    let e = ecs_archetype_edges_new();
    let e2 = ecs_archetype_edges_cache_remove(e, 5, 10);
    let r = ecs_archetype_edges_get_remove(e2, 5);
    if r.0 != true { panic(81100); };
    if r.1 != true { panic(81101); };
    if r.2 != 10 { panic(81102); };
}

@test "edges remove cache none"() {
    let e = ecs_archetype_edges_new();
    let e2 = ecs_archetype_edges_cache_remove_none(e, 5);
    let r = ecs_archetype_edges_get_remove(e2, 5);
    if r.0 != true { panic(81110); };
    if r.1 != false { panic(81111); };
}

// === Edges: take ===

@test "edges take not cached"() {
    let e = ecs_archetype_edges_new();
    let r = ecs_archetype_edges_get_take(e, 5);
    if r.0 != false { panic(81120); };
}

@test "edges take cache and get"() {
    let e = ecs_archetype_edges_new();
    let e2 = ecs_archetype_edges_cache_take(e, 5, 15);
    let r = ecs_archetype_edges_get_take(e2, 5);
    if r.0 != true { panic(81130); };
    if r.1 != true { panic(81131); };
    if r.2 != 15 { panic(81132); };
}

@test "edges take cache none"() {
    let e = ecs_archetype_edges_new();
    let e2 = ecs_archetype_edges_cache_take_none(e, 5);
    let r = ecs_archetype_edges_get_take(e2, 5);
    if r.0 != true { panic(81140); };
    if r.1 != false { panic(81141); };
}

// === Edges stats ===

@test "edges stats"() {
    let e = ecs_archetype_edges_new();
    let e2 = ecs_archetype_edges_cache_insert(e, 1, 10);
    let e3 = ecs_archetype_edges_cache_remove(e2, 2, 20);
    let e4 = ecs_archetype_edges_cache_take(e3, 3, 30);
    if ecs_archetype_edges_insert_count(e4) != 1 { panic(81150); };
    if ecs_archetype_edges_remove_count(e4) != 1 { panic(81151); };
    if ecs_archetype_edges_take_count(e4) != 1 { panic(81152); };
}

// === ArchetypeEntity ===

@test "archetype entity"() {
    let e = ecs_archetype_entity_new(42, 7);
    if ecs_archetype_entity_id(e) != 42 { panic(81160); };
    if ecs_archetype_entity_table_row(e) != 7 { panic(81161); };
}

// === Combined insert + remove scenario ===

@test "edges insert then remove roundtrip"() {
    let e = ecs_archetype_edges_new();
    // Insert bundle 1 from archetype 0 -> archetype 1
    let e2 = ecs_archetype_edges_cache_insert(e, 1, 1);
    // Remove bundle 1 from archetype 1 -> archetype 0
    let e3 = ecs_archetype_edges_cache_remove(e2, 1, 0);
    // Verify insert
    let ri = ecs_archetype_edges_get_insert(e3, 1);
    if ri.1 != 1 { panic(81170); };
    // Verify remove
    let rr = ecs_archetype_edges_get_remove(e3, 1);
    if rr.2 != 0 { panic(81171); };
}
