@import "lib/clone_entities.sla"

// Isolated tests for lib/clone_entities.sla — SourceComponent + ComponentCloneCtx + EntityMapper + EntityClonerState
// Bevy reference: bevy_ecs/src/entity/clone_entities.rs

// === SourceComponent tests ===

@test "source_component_new"() {
    let sc = ecs_source_component_new(5, 16, 42);
    if ecs_source_component_id(sc) != 5 { panic(82400); };
    if ecs_source_component_size(sc) != 16 { panic(82401); };
    if ecs_source_component_ptr(sc) != 42 { panic(82402); };
}

@test "source_component_read_match"() {
    let sc = ecs_source_component_new(5, 16, 42);
    let r = ecs_source_component_read(sc, 5);
    if r.0 != true { panic(82403); };
    if r.1 != 42 { panic(82404); };
}

@test "source_component_read_mismatch"() {
    let sc = ecs_source_component_new(5, 16, 42);
    let r = ecs_source_component_read(sc, 6);
    if r.0 != false { panic(82405); };
}

// === EntityMapper tests ===

@test "entity_mapper_new"() {
    let m = ecs_entity_mapper_new(100);
    if ecs_entity_mapper_len(m) != 0 { panic(82406); };
}

@test "entity_mapper_get_or_alloc_new"() {
    let m = ecs_entity_mapper_new(100);
    let r = ecs_entity_mapper_get_or_alloc(m, 1);
    if r.1 != 100 { panic(82407); };
    if ecs_entity_mapper_len(r.0) != 1 { panic(82408); };
}

@test "entity_mapper_get_or_alloc_existing"() {
    let m = ecs_entity_mapper_new(100);
    let r1 = ecs_entity_mapper_get_or_alloc(m, 1);
    let r2 = ecs_entity_mapper_get_or_alloc(r1.0, 1);
    if r2.1 != 100 { panic(82409); };
    if ecs_entity_mapper_len(r2.0) != 1 { panic(82410); };
}

@test "entity_mapper_get_or_alloc_multiple"() {
    let m = ecs_entity_mapper_new(100);
    let r1 = ecs_entity_mapper_get_or_alloc(m, 1);
    let r2 = ecs_entity_mapper_get_or_alloc(r1.0, 2);
    let r3 = ecs_entity_mapper_get_or_alloc(r2.0, 3);
    if ecs_entity_mapper_len(r3.0) != 3 { panic(82411); };
}

@test "entity_mapper_get_found"() {
    let m = ecs_entity_mapper_new(100);
    let r1 = ecs_entity_mapper_get_or_alloc(m, 1);
    let r2 = ecs_entity_mapper_get(r1.0, 1);
    if r2.0 != true { panic(82412); };
    if r2.1 != 100 { panic(82413); };
}

@test "entity_mapper_get_not_found"() {
    let m = ecs_entity_mapper_new(100);
    let r = ecs_entity_mapper_get(m, 1);
    if r.0 != false { panic(82414); };
}

@test "entity_mapper_has"() {
    let m = ecs_entity_mapper_new(100);
    let r = ecs_entity_mapper_get_or_alloc(m, 1);
    if ecs_entity_mapper_has(r.0, 1) != true { panic(82415); };
    if ecs_entity_mapper_has(r.0, 2) != false { panic(82416); };
}

@test "entity_mapper_resolve_mapped"() {
    let m = ecs_entity_mapper_new(100);
    let r = ecs_entity_mapper_get_or_alloc(m, 1);
    if ecs_entity_mapper_resolve(r.0, 1) != 100 { panic(82417); };
}

@test "entity_mapper_resolve_unmapped"() {
    let m = ecs_entity_mapper_new(100);
    if ecs_entity_mapper_resolve(m, 5) != 5 { panic(82418); };
}

// === ComponentCloneCtx tests ===

@test "clone_ctx_new"() {
    let ctx = ecs_clone_ctx_new(3, 10, 20, 16, false);
    if ecs_clone_ctx_component_id(ctx) != 3 { panic(82419); };
    if ecs_clone_ctx_source(ctx) != 10 { panic(82420); };
    if ecs_clone_ctx_target(ctx) != 20 { panic(82421); };
    if ecs_clone_ctx_moving(ctx) != false { panic(82422); };
    if ecs_clone_ctx_target_component_written(ctx) != false { panic(82423); };
}

@test "clone_ctx_moving"() {
    let ctx = ecs_clone_ctx_new(3, 10, 20, 16, true);
    if ecs_clone_ctx_moving(ctx) != true { panic(82424); };
}

@test "clone_ctx_write_target_component"() {
    let ctx = ecs_clone_ctx_new(3, 10, 20, 16, false);
    let ctx2 = ecs_clone_ctx_write_target_component(ctx);
    if ecs_clone_ctx_target_component_written(ctx2) != true { panic(82425); };
    if ecs_clone_ctx_target_component_moved(ctx2) != false { panic(82426); };
}

@test "clone_ctx_write_target_component_moved"() {
    let ctx = ecs_clone_ctx_new(3, 10, 20, 16, false);
    let ctx2 = ecs_clone_ctx_write_target_component_moved(ctx);
    if ecs_clone_ctx_target_component_written(ctx2) != true { panic(82427); };
    if ecs_clone_ctx_target_component_moved(ctx2) != true { panic(82428); };
}

@test "clone_ctx_linked_cloning"() {
    let ctx = ecs_clone_ctx_new(3, 10, 20, 16, false);
    if ecs_clone_ctx_linked_cloning(ctx) != false { panic(82429); };
    let ctx2 = ecs_clone_ctx_set_linked_cloning(ctx, true);
    if ecs_clone_ctx_linked_cloning(ctx2) != true { panic(82430); };
}

@test "clone_ctx_queue_entity_clone"() {
    let ctx = ecs_clone_ctx_new(3, 10, 20, 16, false);
    let ctx2 = ecs_clone_ctx_queue_entity_clone(ctx, 30);
    let ctx3 = ecs_clone_ctx_queue_entity_clone(ctx2, 40);
    if ecs_clone_ctx_queued_count(ctx3) != 2 { panic(82431); };
    let q0 = ecs_clone_ctx_queued_at(ctx3, 0);
    if q0.0 != true { panic(82432); };
    if q0.1 != 30 { panic(82433); };
    let q1 = ecs_clone_ctx_queued_at(ctx3, 1);
    if q1.1 != 40 { panic(82434); };
}

@test "clone_ctx_queued_at_out_of_range"() {
    let ctx = ecs_clone_ctx_new(3, 10, 20, 16, false);
    let q = ecs_clone_ctx_queued_at(ctx, 0);
    if q.0 != false { panic(82435); };
}

// === EntityClonerState tests ===

@test "cloner_state_new"() {
    let s = ecs_cloner_state_new();
    if ecs_cloner_state_move_components(s) != false { panic(82436); };
    if ecs_cloner_state_linked_cloning(s) != false { panic(82437); };
    if ecs_cloner_state_filter_mode(s) != 0 { panic(82438); };
    if ecs_cloner_state_components_cloned(s) != 0 { panic(82439); };
}

@test "cloner_state_set_move_components"() {
    let s = ecs_cloner_state_new();
    let s2 = ecs_cloner_state_set_move_components(s, true);
    if ecs_cloner_state_move_components(s2) != true { panic(82440); };
}

@test "cloner_state_set_linked_cloning"() {
    let s = ecs_cloner_state_new();
    let s2 = ecs_cloner_state_set_linked_cloning(s, true);
    if ecs_cloner_state_linked_cloning(s2) != true { panic(82441); };
}

@test "cloner_state_set_insert_mode"() {
    let s = ecs_cloner_state_new();
    let s2 = ecs_cloner_state_set_insert_mode(s, 1);
    if ecs_cloner_state_insert_mode(s2) != 1 { panic(82442); };
}

@test "cloner_state_should_clone_opt_out"() {
    let s = ecs_cloner_state_new();
    // OptOut: should clone unless denied
    if ecs_cloner_state_should_clone(s, 5) != true { panic(82443); };
    let s2 = ecs_cloner_state_deny(s, 5);
    if ecs_cloner_state_should_clone(s2, 5) != false { panic(82444); };
    if ecs_cloner_state_should_clone(s2, 6) != true { panic(82445); };
}

@test "cloner_state_should_clone_opt_in"() {
    let s = ecs_cloner_state_new();
    let s2 = ecs_cloner_state_set_filter_mode(s, 1);
    // OptIn: should only clone if allowed
    if ecs_cloner_state_should_clone(s2, 5) != false { panic(82446); };
    let s3 = ecs_cloner_state_allow(s2, 5);
    if ecs_cloner_state_should_clone(s3, 5) != true { panic(82447); };
    if ecs_cloner_state_should_clone(s3, 6) != false { panic(82448); };
}

@test "cloner_state_allow_deny"() {
    let s = ecs_cloner_state_new();
    let s2 = ecs_cloner_state_allow(s, 1);
    let s3 = ecs_cloner_state_allow(s2, 2);
    let s4 = ecs_cloner_state_deny(s3, 3);
    if ecs_cloner_state_allowed_len(s4) != 2 { panic(82449); };
    if ecs_cloner_state_denied_len(s4) != 1 { panic(82450); };
}

@test "cloner_state_allow_if_new"() {
    let s = ecs_cloner_state_new();
    let s2 = ecs_cloner_state_allow_if_new(s, 5);
    if ecs_cloner_state_allow_if_new_len(s2) != 1 { panic(82451); };
}

@test "cloner_state_increment_cloned"() {
    let s = ecs_cloner_state_new();
    let s2 = ecs_cloner_state_increment_cloned(s);
    let s3 = ecs_cloner_state_increment_cloned(s2);
    if ecs_cloner_state_components_cloned(s3) != 2 { panic(82452); };
}

@test "clone_insert_mode_constants"() {
    if ECS_CLONE_INSERT_MODE_KEEP != 0 { panic(82453); };
    if ECS_CLONE_INSERT_MODE_REPLACE != 1 { panic(82454); };
}
