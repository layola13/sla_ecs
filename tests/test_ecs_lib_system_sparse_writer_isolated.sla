@import "lib/system_trait.sla"
@import "lib/sparse_set.sla"
@import "lib/bundle_writer.sla"

@test "system state flags set and has"() {
    let f = ecs_system_state_flags_new();
    f = ecs_system_state_flags_set(f, ECS_SSF_INITIALIZED);
    if ecs_system_state_flags_is_initialized(f) != true { panic(55001); };
    if ecs_system_state_flags_is_exclusive(f) != false { panic(55002); };
}

@test "system state flags unset"() {
    let f = ecs_system_state_flags_new();
    f = ecs_system_state_flags_set(f, ECS_SSF_INITIALIZED);
    f = ecs_system_state_flags_set(f, ECS_SSF_EXCLUSIVE);
    f = ecs_system_state_flags_unset(f, ECS_SSF_INITIALIZED);
    if ecs_system_state_flags_is_initialized(f) != false { panic(55003); };
    if ecs_system_state_flags_is_exclusive(f) != true { panic(55004); };
}

@test "system new and name"() {
    let s = ecs_system_new(42);
    if ecs_system_name(s) != 42 { panic(55005); };
    if ecs_system_is_initialized(s) != false { panic(55006); };
}

@test "system initialize"() {
    let s = ecs_system_new(42);
    let s2 = ecs_system_initialize(s);
    if ecs_system_is_initialized(s2) != true { panic(55007); };
}

@test "system run"() {
    let s = ecs_system_new(42);
    let r = ecs_system_run(s, 99);
    if r.1 != 99 { panic(55008); };
    if ecs_system_last_run(r.0) != 99 { panic(55009); };
}

@test "system apply deferred"() {
    let s = ecs_system_new(42);
    let s2 = ecs_system_apply_deferred(s);
    if ecs_system_state_flags_has_deferred(s2.flags) != true { panic(55010); };
}

@test "run system once ok"() {
    let s = ecs_system_new(42);
    let s2 = ecs_system_initialize(s);
    let r = ecs_run_system_once(s2, 77);
    if ecs_run_system_once_is_ok(r) != true { panic(55011); };
    if ecs_run_system_once_output(r) != 77 { panic(55012); };
}

@test "run system once not initialized"() {
    let s = ecs_system_new(42);
    let r = ecs_run_system_once(s, 77);
    if ecs_run_system_once_is_ok(r) != false { panic(55013); };
    if ecs_run_system_once_error_kind(r) != ECS_RSE_NOT_INITIALIZED { panic(55014); };
}

@test "sparse set insert and get"() {
    let s = ecs_sparse_set_new();
    s = ecs_sparse_set_insert(s, 5, 50);
    s = ecs_sparse_set_insert(s, 10, 100);
    let g = ecs_sparse_set_get(s, 5);
    if g.0 != true { panic(55015); };
    if g.1 != 50 { panic(55016); };
    let g2 = ecs_sparse_set_get(s, 10);
    if g2.1 != 100 { panic(55017); };
}

@test "sparse set contains"() {
    let s = ecs_sparse_set_new();
    s = ecs_sparse_set_insert(s, 5, 50);
    if ecs_sparse_set_contains(s, 5) != true { panic(55018); };
    if ecs_sparse_set_contains(s, 99) != false { panic(55019); };
}

@test "sparse set overwrite"() {
    let s = ecs_sparse_set_new();
    s = ecs_sparse_set_insert(s, 5, 50);
    s = ecs_sparse_set_insert(s, 5, 99);
    let g = ecs_sparse_set_get(s, 5);
    if g.1 != 99 { panic(55020); };
    if ecs_sparse_set_len(s) != 1 { panic(55021); };
}

@test "sparse set remove"() {
    let s = ecs_sparse_set_new();
    s = ecs_sparse_set_insert(s, 5, 50);
    s = ecs_sparse_set_insert(s, 10, 100);
    let r = ecs_sparse_set_remove(s, 5);
    if r.1 != true { panic(55022); };
    if ecs_sparse_set_contains(r.0, 5) != false { panic(55023); };
    if ecs_sparse_set_len(r.0) != 1 { panic(55024); };
}

@test "sparse set remove missing"() {
    let s = ecs_sparse_set_new();
    s = ecs_sparse_set_insert(s, 5, 50);
    let r = ecs_sparse_set_remove(s, 99);
    if r.1 != false { panic(55025); };
}

@test "sparse set is empty and clear"() {
    let s = ecs_sparse_set_new();
    if ecs_sparse_set_is_empty(s) != true { panic(55026); };
    s = ecs_sparse_set_insert(s, 5, 50);
    if ecs_sparse_set_is_empty(s) != false { panic(55027); };
    s = ecs_sparse_set_clear(s);
    if ecs_sparse_set_is_empty(s) != true { panic(55028); };
}

@test "component sparse set insert and get"() {
    let c = ecs_component_sparse_set_new();
    c = ecs_component_sparse_set_insert(c, 1, 100, 5);
    let g = ecs_component_sparse_set_get(c, 1);
    if g.0 != true { panic(55029); };
    if g.1 != 100 { panic(55030); };
}

@test "component sparse set get with ticks"() {
    let c = ecs_component_sparse_set_new();
    c = ecs_component_sparse_set_insert(c, 1, 100, 5);
    let g = ecs_component_sparse_set_get_with_ticks(c, 1);
    if g.0 != true { panic(55031); };
    if g.1 != 100 { panic(55032); };
    if g.2 != 5 { panic(55033); };
    if g.3 != 5 { panic(55034); };
}

@test "component sparse set contains and remove"() {
    let c = ecs_component_sparse_set_new();
    c = ecs_component_sparse_set_insert(c, 1, 100, 5);
    if ecs_component_sparse_set_contains(c, 1) != true { panic(55035); };
    let r = ecs_component_sparse_set_remove(c, 1);
    if r.1 != true { panic(55036); };
    if ecs_component_sparse_set_contains(r.0, 1) != false { panic(55037); };
}

@test "bundle scratch new and push"() {
    let s = ecs_bundle_scratch_new();
    if ecs_bundle_scratch_is_empty(s) != true { panic(55038); };
    s = ecs_bundle_scratch_push(s, 1, 10);
    s = ecs_bundle_scratch_push(s, 2, 20);
    if ecs_bundle_scratch_len(s) != 2 { panic(55039); };
    if ecs_bundle_scratch_component_at(s, 0) != 1 { panic(55040); };
    if ecs_bundle_scratch_value_at(s, 1) != 20 { panic(55041); };
}

@test "bundle scratch writer"() {
    let s = ecs_bundle_scratch_new();
    s = ecs_bundle_scratch_push(s, 1, 10);
    let w = ecs_bundle_scratch_writer(s);
    if ecs_bundle_writer_len(w) != 1 { panic(55042); };
}

@test "bundle writer push and finish"() {
    let w = ecs_bundle_writer_new();
    w = ecs_bundle_writer_push(w, 1, 10);
    w = ecs_bundle_writer_push(w, 2, 20);
    if ecs_bundle_writer_len(w) != 2 { panic(55043); };
    if ecs_bundle_writer_finish(w) != 2 { panic(55044); };
}

@test "bundle writer is empty"() {
    let w = ecs_bundle_writer_new();
    if ecs_bundle_writer_is_empty(w) != true { panic(55045); };
}
