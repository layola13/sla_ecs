@test "table erased pair query system param writes back"() {
    let w0 = table_erased_param_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w0, TABLE_ERASED_PARAM_POS_TYPE, ecs_box_drop<TableErasedParamPos>);
    let (w2, velocity) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w1, TABLE_ERASED_PARAM_VEL_TYPE, ecs_box_drop<TableErasedParamVel>);
    let (w3, entity) = table_erased_world_spawn<TableErasedParamTime, TableErasedParamEvent>(w2);
    let w4 = table_erased_world_insert<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w3, entity, position.id, TABLE_ERASED_PARAM_POS_TYPE, TableErasedParamPos { x: 8, y: 0 });
    let w5 = table_erased_world_insert<TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w4, entity, velocity.id, TABLE_ERASED_PARAM_VEL_TYPE, TableErasedParamVel { x: 3, y: 0 });
    let before = w5.registry.change_tick;
    let group_before = table_erased_world_entity_archetype_id<TableErasedParamTime, TableErasedParamEvent>(w5, entity);
    let row_before = table_erased_world_entity_row<TableErasedParamTime, TableErasedParamEvent>(w5, entity);
    let w6 = table_erased_run_pair_mut_system_auto<TableErasedParamPos, TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w5, TABLE_ERASED_PARAM_POS_TYPE, TABLE_ERASED_PARAM_VEL_TYPE, table_erased_param_movement_system);
    if table_erased_world_get<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w6, entity, position.id, TABLE_ERASED_PARAM_POS_TYPE).x != 11 { panic(12000); };
    if table_erased_world_entity_archetype_id<TableErasedParamTime, TableErasedParamEvent>(w6, entity) != group_before { panic(12001); };
    if table_erased_world_entity_row<TableErasedParamTime, TableErasedParamEvent>(w6, entity) != row_before { panic(12002); };
    if table_erased_world_changed_since<TableErasedParamTime, TableErasedParamEvent>(w6, entity, position.id, before - 1) != true { panic(12003); };
}

@test "table erased join query system param exposes two readonly queries"() {
    let w0 = table_erased_param_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w0, TABLE_ERASED_PARAM_POS_TYPE, ecs_box_drop<TableErasedParamPos>);
