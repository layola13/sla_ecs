    let cnt = len(param.query.items) as i64;
    while i < cnt {
        if param.query.items[i].value_0.has_value { first_present = first_present + 1; } else { first_missing = first_missing + 1; };
        if param.query.items[i].value_1.has_value { second_present = second_present + 1; };
