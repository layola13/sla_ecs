    let pair_marker_sum: i32 = 0;
    let i: i64 = 0;
    let cnt = len(param.query.items) as i64;
    while i < cnt {
        if param.query.items[i].pair.has_value {
            pair_present = pair_present + 1;
            pair_vel_sum = pair_vel_sum + param.query.items[i].pair.value.first.x;
            pair_marker_sum = pair_marker_sum + param.query.items[i].pair.value.second.value;
        };
        i = i + 1;
    }
    return table_erased_item_query_resource_param<TableErasedAnyOf3WithOptionalPair<TableErasedParamMarker, TableErasedParamVel, TableErasedParamPos, TableErasedParamVel, TableErasedParamMarker>, TableErasedParamTime>(param.query, TableErasedParamTime { tick: len(param.query.items) as i32 * 1000 + pair_present * 100 + pair_vel_sum * 10 + pair_marker_sum });
}

