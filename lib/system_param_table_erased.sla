}

fn table_erased_message_reader_writer_param_set<M>(read: MessageRead<M>, writer: MessageWriter<M>) -> TableErasedMessageReaderWriterParamSet<M> {
    return TableErasedMessageReaderWriterParamSet<M> { read: read, writer: writer };
}

fn table_erased_message_mutator_param<M>(messages: Messages<M>, reader: MessageReader) -> TableErasedMessageMutatorParam<M> {
    return TableErasedMessageMutatorParam<M> { messages: messages, reader: reader };
}

fn table_erased_message_mutator_len<M>(param: TableErasedMessageMutatorParam<M>) -> i64 {
    return messages_mutator_len<M>(param.messages, param.reader);
}

fn table_erased_message_mutator_is_empty<M>(param: TableErasedMessageMutatorParam<M>) -> bool {
    return messages_mutator_is_empty<M>(param.messages, param.reader);
}

fn table_erased_message_mutator_clear<M>(param: TableErasedMessageMutatorParam<M>) -> TableErasedMessageMutatorParam<M> {
    param.reader = messages_mutator_clear<M>(param.reader, param.messages);
    return param;
}

fn table_erased_message_mutator_read_next<M>(param: TableErasedMessageMutatorParam<M>, default_value: M) -> (TableErasedMessageMutatorParam<M>, MessageMutRead<M>) {
    let read = messages_mutator_read_next<M>(param.messages, param.reader, default_value);
    param.reader = read.reader;
    return (param, read);
}

fn table_erased_message_mutator_write_back<M>(param: TableErasedMessageMutatorParam<M>, item: MessageMut<M>) -> TableErasedMessageMutatorParam<M> {
    param.messages = messages_mutator_write_back<M>(param.messages, item);
    return param;
}

fn table_erased_message_mutator_write<M>(param: TableErasedMessageMutatorParam<M>, value: M) -> TableErasedMessageMutatorParam<M> {
    param.messages = messages_mutator_write<M>(param.messages, value);
    return param;
}

fn table_erased_message_mutator_write_with_message_id<M>(param: TableErasedMessageMutatorParam<M>, value: M) -> (TableErasedMessageMutatorParam<M>, MessageId<M>) {
    let written = messages_mutator_write_with_message_id<M>(param.messages, value);
    param.messages = written.messages;
    return (param, written.id);
}

fn table_erased_message_mutator_write_batch_with_message_id<M>(param: TableErasedMessageMutatorParam<M>, writer: MessageWriter<M>) -> (TableErasedMessageMutatorParam<M>, MessageBatchWriteWithMessageId<M>) {
    let written = messages_mutator_write_batch_with_message_id<M>(param.messages, writer);
    param.messages = written.messages;
    return (param, written);
}

fn table_erased_message_mutator_write_default_with_message_id<M>(param: TableErasedMessageMutatorParam<M>, default_value: M) -> (TableErasedMessageMutatorParam<M>, MessageId<M>) {
    let written = messages_mutator_write_default_with_message_id<M>(param.messages, default_value);
    param.messages = written.messages;
    return (param, written.id);
}

