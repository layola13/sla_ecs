fn table_erased_param_bonus_default() -> TableErasedParamBonus { return TableErasedParamBonus { value: 0 }; }
fn table_erased_param_vel_marker_pair_default() -> TableErasedPairValue<TableErasedParamVel, TableErasedParamMarker> { return TableErasedPairValue<TableErasedParamVel, TableErasedParamMarker> { first: table_erased_param_vel_default(), second: table_erased_param_marker_default() }; }
fn table_erased_param_world_new() -> TableErasedWorld<TableErasedParamTime, TableErasedParamEvent> { return table_erased_world_new<TableErasedParamTime, TableErasedParamEvent>(table_erased_param_time_default(), table_erased_param_event_default()); }

fn table_erased_param_movement_system(query: Query<TableErasedPairMut<TableErasedParamPos, TableErasedParamVel>>) -> Query<TableErasedPairMut<TableErasedParamPos, TableErasedParamVel>> {
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        query.items[i].first.value = TableErasedParamPos { x: query.items[i].first.value.x + query.items[i].second.x, y: query.items[i].first.value.y + query.items[i].second.y };
        i = i + 1;
    }
    return query;
}

fn table_erased_param_time_message_system(param: TableErasedResourceMessageParam<TableErasedParamTime, TableErasedParamEvent>) -> TableErasedResourceMessageParam<TableErasedParamTime, TableErasedParamEvent> {
    return table_erased_resource_message_param<TableErasedParamTime, TableErasedParamEvent>(TableErasedParamTime { tick: param.resource.tick + 1 }, TableErasedParamEvent { amount: param.resource.tick + 4 }, true);
}

fn table_erased_param_res_mut_system(res: ResMut<TableErasedParamTime>) -> ResMut<TableErasedParamTime> {
    return ResMut<TableErasedParamTime> { value: TableErasedParamTime { tick: res.value.tick + 2 }, added_tick: res.added_tick, changed_tick: res.changed_tick };
}

fn table_erased_param_reader_resmut_system(param: TableErasedResMutMessageReadParam<TableErasedParamTime, TableErasedParamEvent>) -> TableErasedResMutMessageReadParam<TableErasedParamTime, TableErasedParamEvent> {
    if param.read.has_value { param.resource.value = TableErasedParamTime { tick: param.resource.value.tick + param.read.value.amount }; };
    return param;
}

fn table_erased_param_commands_system(param: TableErasedCommandsParam<TableErasedParamTime, TableErasedParamEvent>) -> TableErasedCommandsParam<TableErasedParamTime, TableErasedParamEvent> {
    let (param1, entity) = table_erased_commands_param_reserve_entity_with_location<TableErasedParamTime, TableErasedParamEvent>(param, table_erased_spawn_location_new(95, 30, 4));
    let param2 = table_erased_commands_param_insert_auto<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(param1, entity, TABLE_ERASED_PARAM_POS_TYPE, TableErasedParamPos { x: 12, y: 0 });
    let param3 = table_erased_commands_param_insert_resource<TableErasedParamTime, TableErasedParamEvent>(param2, TableErasedParamTime { tick: 7 });
    return table_erased_commands_param_write_message<TableErasedParamTime, TableErasedParamEvent>(param3, TableErasedParamEvent { amount: 4 });
}

fn table_erased_param_writer_system(writer: MessageWriter<TableErasedParamEvent>) -> MessageWriter<TableErasedParamEvent> {
    let writer1 = message_writer_send<TableErasedParamEvent>(writer, TableErasedParamEvent { amount: 2 });
    return message_writer_send<TableErasedParamEvent>(writer1, TableErasedParamEvent { amount: 8 });
}

