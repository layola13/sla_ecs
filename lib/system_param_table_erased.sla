@test "table erased message mutator reads writes modifies and advances cursor"() {
    let w0 = table_erased_param_world_new();
    let w1 = table_erased_world_write_message<TableErasedParamTime, TableErasedParamEvent>(w0, TableErasedParamEvent { amount: 5 });
    let w2 = table_erased_world_write_message<TableErasedParamTime, TableErasedParamEvent>(w1, TableErasedParamEvent { amount: 7 });
    let (w3, reader1) = table_erased_run_message_mutator_system<TableErasedParamTime, TableErasedParamEvent>(w2, message_reader_new(), table_erased_param_message_mutator_system);
    if reader1.cursor != 3 { panic(12094); };

    let check0 = table_erased_world_read_message<TableErasedParamTime, TableErasedParamEvent>(w3, message_reader_new(), table_erased_param_event_default());
    let check1 = table_erased_world_read_message<TableErasedParamTime, TableErasedParamEvent>(w3, check0.reader, table_erased_param_event_default());
    let check2 = table_erased_world_read_message<TableErasedParamTime, TableErasedParamEvent>(w3, check1.reader, table_erased_param_event_default());
    let check3 = table_erased_world_read_message<TableErasedParamTime, TableErasedParamEvent>(w3, check2.reader, table_erased_param_event_default());
    let check4 = table_erased_world_read_message<TableErasedParamTime, TableErasedParamEvent>(w3, check3.reader, table_erased_param_event_default());
    let check5 = table_erased_world_read_message<TableErasedParamTime, TableErasedParamEvent>(w3, check4.reader, table_erased_param_event_default());
    let check6 = table_erased_world_read_message<TableErasedParamTime, TableErasedParamEvent>(w3, check5.reader, table_erased_param_event_default());
    if check0.value.amount != 105 { panic(12095); };
    if check1.value.amount != 107 { panic(12096); };
    if check2.value.amount != 103 { panic(12097); };
    if check3.value.amount != 11 { panic(12098); };
    if check4.value.amount != 13 { panic(12165); };
    if check5.value.amount != 15 { panic(12166); };
    if check6.value.amount != 0 { panic(12167); };
    if message_id_typed_value<TableErasedParamEvent>(table_erased_world_current_update_message_id_at<TableErasedParamTime, TableErasedParamEvent>(w3, 6, table_erased_param_event_default()).id) != 6 { panic(12168); };

    let next = table_erased_world_read_message<TableErasedParamTime, TableErasedParamEvent>(w3, reader1, table_erased_param_event_default());
    if next.has_value != true { panic(12099); };
    if next.value.amount != 11 { panic(12100); };
}

