// SA-native system parameter adapters for TableErasedWorld<R, M>.
// These mirror the table-value adapters but carry concrete query item types
// through erased heterogeneous table rows.
@import "schedule_table_erased.sla"

struct TableErasedResourceMessageParam<R, M> {
    resource: R,
    message: M,
    should_write_message: bool,
}

struct TableErasedResMutMessageReadParam<R, M> {
    resource: ResMut<R>,
    read: MessageRead<M>,
}

struct TableErasedResMutCommandsParam<R, M> {
    resource: ResMut<R>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedMessageReadCommandsParam<R, M> {
    read: MessageRead<M>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedMessageReadResMutCommandsParam<R, M> {
    read: MessageRead<M>,
    resource: ResMut<R>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedMessageWriterCommandsParam<R, M> {
    writer: MessageWriter<M>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedMessageWriterResMutCommandsParam<R, M> {
    writer: MessageWriter<M>,
    resource: ResMut<R>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedMessageReaderWriterCommandsParam<R, M> {
    read: MessageRead<M>,
    writer: MessageWriter<M>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedMessageReaderWriterResMutCommandsParam<R, M> {
    read: MessageRead<M>,
    writer: MessageWriter<M>,
    resource: ResMut<R>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedMessageReaderWriterParamSet<M> {
    read: MessageRead<M>,
    writer: MessageWriter<M>,
}

struct TableErasedMessageMutatorParam<M> {
    messages: Messages<M>,
    reader: MessageReader,
}

struct TableErasedPairMutReadonlyPairParamSet<A, B> {
    mut_query: Query<TableErasedPairMut<A, B>>,
    read_query: Query<TableErasedPair<A, B>>,
}

struct TableErasedPairMutCommandsParam<A, B, R, M> {
    query: Query<TableErasedPairMut<A, B>>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedPairMutMessageReadCommandsParam<A, B, R, M> {
    query: Query<TableErasedPairMut<A, B>>,
    read: MessageRead<M>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedPairMutMessageWriterCommandsParam<A, B, R, M> {
