fn table_erased_message_reader_writer_res_mut_commands_param<R, M>(read: MessageRead<M>, writer: MessageWriter<M>, resource: ResMut<R>, commands: TableErasedCommandsParam<R, M>) -> TableErasedMessageReaderWriterResMutCommandsParam<R, M> {
