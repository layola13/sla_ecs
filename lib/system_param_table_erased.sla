@test "table erased system params expose spawned and spawn details"() {
    let w0 = table_erased_param_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w0, TABLE_ERASED_PARAM_POS_TYPE, ecs_box_drop<TableErasedParamPos>);
    let (w2, velocity) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w1, TABLE_ERASED_PARAM_VEL_TYPE, ecs_box_drop<TableErasedParamVel>);
    let (w3, e1) = table_erased_world_spawn<TableErasedParamTime, TableErasedParamEvent>(w2);
    let w4 = table_erased_world_insert<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w3, e1, position.id, TABLE_ERASED_PARAM_POS_TYPE, TableErasedParamPos { x: 1, y: 0 });
    let w5 = table_erased_world_insert<TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w4, e1, velocity.id, TABLE_ERASED_PARAM_VEL_TYPE, TableErasedParamVel { x: 10, y: 0 });
    let first_tick = w5.registry.change_tick;
    let w6 = table_erased_world_increment_tick<TableErasedParamTime, TableErasedParamEvent>(w5);
    let (w7, e2) = table_erased_world_spawn_with_location<TableErasedParamTime, TableErasedParamEvent>(w6, table_erased_spawn_location_new(5, 40, 7));
    let w8 = table_erased_world_insert<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w7, e2, position.id, TABLE_ERASED_PARAM_POS_TYPE, TableErasedParamPos { x: 2, y: 0 });
    let w9 = table_erased_world_insert<TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w8, e2, velocity.id, TABLE_ERASED_PARAM_VEL_TYPE, TableErasedParamVel { x: 20, y: 0 });
    let second_tick = w9.registry.change_tick;
    let w9r = table_erased_world_insert_resource<TableErasedParamTime, TableErasedParamEvent>(w9, TableErasedParamTime { tick: 0 });

    let entity_spawned = table_erased_run_entity_spawned_query_resource_system<TableErasedParamTime, TableErasedParamEvent>(w9r, first_tick, table_erased_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(entity_spawned).tick != 1 { panic(12100); };
    let entity_repeated = table_erased_run_entity_spawned_query_resource_system<TableErasedParamTime, TableErasedParamEvent>(w9r, second_tick, table_erased_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(entity_repeated).tick != 0 { panic(12101); };
    let details = table_erased_run_spawn_details_query_resource_system<TableErasedParamTime, TableErasedParamEvent>(w9r, first_tick, table_erased_param_spawn_details_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(details).tick != 5100 + first_tick + second_tick { panic(12102); };
    let spawned_pos = table_erased_run_spawned_query_resource_system_auto<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w9r, TABLE_ERASED_PARAM_POS_TYPE, first_tick, table_erased_param_count_query_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(spawned_pos).tick != 1 { panic(12103); };
    let pos_details = table_erased_run_with_spawn_details_query_resource_system_auto<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w9r, TABLE_ERASED_PARAM_POS_TYPE, first_tick, table_erased_param_pos_spawn_details_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(pos_details).tick != 5103 { panic(12104); };
    let pair_spawned = table_erased_run_pair_spawned_query_resource_system_auto<TableErasedParamPos, TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w9r, TABLE_ERASED_PARAM_POS_TYPE, TABLE_ERASED_PARAM_VEL_TYPE, first_tick, table_erased_param_pair_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(pair_spawned).tick != 1 { panic(12105); };
    let pair_details = table_erased_run_pair_with_spawn_details_query_resource_system_auto<TableErasedParamPos, TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w9r, TABLE_ERASED_PARAM_POS_TYPE, TABLE_ERASED_PARAM_VEL_TYPE, first_tick, table_erased_param_pair_spawn_details_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(pair_details).tick != 5133 { panic(12106); };

    let w10 = table_erased_run_pair_mut_system_spawned_auto<TableErasedParamPos, TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w9, TABLE_ERASED_PARAM_POS_TYPE, TABLE_ERASED_PARAM_VEL_TYPE, first_tick, table_erased_param_movement_system);
    if table_erased_world_get<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w10, e1, position.id, TABLE_ERASED_PARAM_POS_TYPE).x != 1 { panic(12107); };
    if table_erased_world_get<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w10, e2, position.id, TABLE_ERASED_PARAM_POS_TYPE).x != 22 { panic(12108); };
    let w11 = table_erased_run_pair_mut_with_spawn_details_system_auto<TableErasedParamPos, TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w10, TABLE_ERASED_PARAM_POS_TYPE, TABLE_ERASED_PARAM_VEL_TYPE, first_tick, table_erased_param_spawn_detail_movement_system);
    if table_erased_world_get<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w11, e1, position.id, TABLE_ERASED_PARAM_POS_TYPE).x != 1 { panic(12109); };
    if table_erased_world_get<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w11, e2, position.id, TABLE_ERASED_PARAM_POS_TYPE).x != 42 { panic(12110); };
}

@test "table erased system params expose removed components"() {
    let w0 = table_erased_param_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w0, TABLE_ERASED_PARAM_POS_TYPE, ecs_box_drop<TableErasedParamPos>);
    let (w2, velocity) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w1, TABLE_ERASED_PARAM_VEL_TYPE, ecs_box_drop<TableErasedParamVel>);
    let (w3, marker) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w2, TABLE_ERASED_PARAM_MARKER_TYPE, ecs_box_drop<TableErasedParamMarker>);
    let (w4, e1) = table_erased_world_spawn<TableErasedParamTime, TableErasedParamEvent>(w3);
    let (w5, e2) = table_erased_world_spawn<TableErasedParamTime, TableErasedParamEvent>(w4);
    let w6 = table_erased_world_insert<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w5, e1, position.id, TABLE_ERASED_PARAM_POS_TYPE, TableErasedParamPos { x: 1, y: 0 });
    let w7 = table_erased_world_insert<TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w6, e1, velocity.id, TABLE_ERASED_PARAM_VEL_TYPE, TableErasedParamVel { x: 10, y: 0 });
    let w8 = table_erased_world_insert<TableErasedParamMarker, TableErasedParamTime, TableErasedParamEvent>(w7, e1, marker.id, TABLE_ERASED_PARAM_MARKER_TYPE, TableErasedParamMarker { value: 100 });
    let w9 = table_erased_world_insert<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w8, e2, position.id, TABLE_ERASED_PARAM_POS_TYPE, TableErasedParamPos { x: 2, y: 0 });
    let w10 = table_erased_world_insert<TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w9, e2, velocity.id, TABLE_ERASED_PARAM_VEL_TYPE, TableErasedParamVel { x: 20, y: 0 });

    let remove_since = w10.registry.change_tick;
    let w11 = table_erased_world_increment_tick<TableErasedParamTime, TableErasedParamEvent>(w10);
    let w12 = table_erased_world_remove_auto<TableErasedParamTime, TableErasedParamEvent>(w11, e1, TABLE_ERASED_PARAM_MARKER_TYPE);
    let w12r = table_erased_world_insert_resource<TableErasedParamTime, TableErasedParamEvent>(w12, TableErasedParamTime { tick: 0 });
    let marker_removed = table_erased_run_removed_components_query_resource_system_auto<TableErasedParamTime, TableErasedParamEvent>(w12r, TABLE_ERASED_PARAM_MARKER_TYPE, remove_since, table_erased_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(marker_removed).tick != 1 { panic(12920); };
    let marker_current = table_erased_run_removed_components_query_resource_system<TableErasedParamTime, TableErasedParamEvent>(w12r, marker.id, w12r.registry.change_tick, table_erased_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(marker_current).tick != 0 { panic(12921); };

    let despawn_since = w12.registry.change_tick;
    let w13 = table_erased_world_increment_tick<TableErasedParamTime, TableErasedParamEvent>(w12);
    let w14 = table_erased_world_despawn<TableErasedParamTime, TableErasedParamEvent>(w13, e2);
    let w14r = table_erased_world_insert_resource<TableErasedParamTime, TableErasedParamEvent>(w14, TableErasedParamTime { tick: 0 });
    let pos_removed = table_erased_run_removed_components_query_resource_system<TableErasedParamTime, TableErasedParamEvent>(w14r, position.id, despawn_since, table_erased_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(pos_removed).tick != 1 { panic(12922); };
    let vel_removed = table_erased_run_removed_components_query_resource_system_auto<TableErasedParamTime, TableErasedParamEvent>(w14r, TABLE_ERASED_PARAM_VEL_TYPE, despawn_since, table_erased_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(vel_removed).tick != 1 { panic(12923); };
    let marker_after_despawn = table_erased_run_removed_components_query_resource_system<TableErasedParamTime, TableErasedParamEvent>(w14r, marker.id, despawn_since, table_erased_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(marker_after_despawn).tick != 0 { panic(12924); };

    let w15 = table_erased_world_clear_removed_components<TableErasedParamTime, TableErasedParamEvent>(w14);
    let w15r = table_erased_world_insert_resource<TableErasedParamTime, TableErasedParamEvent>(w15, TableErasedParamTime { tick: 0 });
    let removed_after_clear = table_erased_run_removed_components_query_resource_system_auto<TableErasedParamTime, TableErasedParamEvent>(w15r, TABLE_ERASED_PARAM_POS_TYPE, 0, table_erased_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedParamTime, TableErasedParamEvent>(removed_after_clear).tick != 0 { panic(12925); };
}
