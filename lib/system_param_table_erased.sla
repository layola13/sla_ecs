// SA-native system parameter adapters for TableErasedWorld<R, M>.
// These mirror the table-value adapters but carry concrete query item types
// through erased heterogeneous table rows.
@import "schedule_table_erased.sla"

struct TableErasedResourceMessageParam<R, M> {
    resource: R,
    message: M,
    should_write_message: bool,
}

struct TableErasedResMutMessageReadParam<R, M> {
    resource: ResMut<R>,
    read: MessageRead<M>,
}

struct TableErasedCommandsParam<R, M> {
    world: TableErasedWorld<R, M>,
    commands: TableErasedCommands<R, M>,
}

struct TableErasedQueryResourceParam<T, R> {
    query: Query<EntityItem<T>>,
    resource: R,
}

struct TableErasedItemQueryResourceParam<I, R> {
    query: Query<I>,
    resource: R,
}

struct TableErasedSingleResourceParam<I, R> {
    item: I,
    resource: R,
}

struct TableErasedOptionalSingleResourceParam<I, R> {
    item: TableErasedOptional<I>,
    resource: R,
}

struct TableErasedPopulatedQueryResourceParam<I, R> {
    query: Query<I>,
    resource: R,
}

fn table_erased_resource_message_param<R, M>(resource: R, message: M, should_write_message: bool) -> TableErasedResourceMessageParam<R, M> {
    return TableErasedResourceMessageParam<R, M> { resource: resource, message: message, should_write_message: should_write_message };
}

fn table_erased_resmut_message_read_param<R, M>(resource: ResMut<R>, read: MessageRead<M>) -> TableErasedResMutMessageReadParam<R, M> {
    return TableErasedResMutMessageReadParam<R, M> { resource: resource, read: read };
}

fn table_erased_commands_param_new<R, M>(world: TableErasedWorld<R, M>) -> TableErasedCommandsParam<R, M> {
    return TableErasedCommandsParam<R, M> { world: world, commands: table_erased_commands_new<R, M>() };
}

fn table_erased_commands_param_reserve_entity<R, M>(param: TableErasedCommandsParam<R, M>) -> (TableErasedCommandsParam<R, M>, Entity) {
    let (world, commands, entity) = table_erased_commands_reserve_entity<R, M>(param.world, param.commands);
    return (TableErasedCommandsParam<R, M> { world: world, commands: commands }, entity);
}

fn table_erased_commands_param_reserve_entity_with_location<R, M>(param: TableErasedCommandsParam<R, M>, spawned_by: TableErasedSpawnLocation) -> (TableErasedCommandsParam<R, M>, Entity) {
    let (world, commands, entity) = table_erased_commands_reserve_entity_with_location<R, M>(param.world, param.commands, spawned_by);
    return (TableErasedCommandsParam<R, M> { world: world, commands: commands }, entity);
}

fn table_erased_commands_param_insert<T, R, M>(param: TableErasedCommandsParam<R, M>, entity: Entity, component_id: i32, type_id: i32, value: T) -> TableErasedCommandsParam<R, M> {
    return TableErasedCommandsParam<R, M> { world: param.world, commands: table_erased_commands_insert<T, R, M>(param.commands, entity, component_id, type_id, value) };
}

fn table_erased_commands_param_insert_auto<T, R, M>(param: TableErasedCommandsParam<R, M>, entity: Entity, type_id: i32, value: T) -> TableErasedCommandsParam<R, M> {
    let component_id = table_erased_world_component_id_for_type<R, M>(param.world, type_id);
    return TableErasedCommandsParam<R, M> { world: param.world, commands: table_erased_commands_insert<T, R, M>(param.commands, entity, component_id, type_id, value) };
}

fn table_erased_commands_param_insert_resource<R, M>(param: TableErasedCommandsParam<R, M>, value: R) -> TableErasedCommandsParam<R, M> {
    return TableErasedCommandsParam<R, M> { world: param.world, commands: table_erased_commands_insert_resource<R, M>(param.commands, value) };
}

fn table_erased_commands_param_write_message<R, M>(param: TableErasedCommandsParam<R, M>, value: M) -> TableErasedCommandsParam<R, M> {
    return TableErasedCommandsParam<R, M> { world: param.world, commands: table_erased_commands_write_message<R, M>(param.commands, value) };
}

fn table_erased_query_resource_param<T, R>(query: Query<EntityItem<T>>, resource: R) -> TableErasedQueryResourceParam<T, R> {
    return TableErasedQueryResourceParam<T, R> { query: query, resource: resource };
}

fn table_erased_item_query_resource_param<I, R>(query: Query<I>, resource: R) -> TableErasedItemQueryResourceParam<I, R> {
    return TableErasedItemQueryResourceParam<I, R> { query: query, resource: resource };
}

fn table_erased_single_resource_param<I, R>(item: I, resource: R) -> TableErasedSingleResourceParam<I, R> {
    return TableErasedSingleResourceParam<I, R> { item: item, resource: resource };
}

fn table_erased_optional_single_resource_param<I, R>(item: TableErasedOptional<I>, resource: R) -> TableErasedOptionalSingleResourceParam<I, R> {
    return TableErasedOptionalSingleResourceParam<I, R> { item: item, resource: resource };
}

fn table_erased_populated_query_resource_param<I, R>(query: Query<I>, resource: R) -> TableErasedPopulatedQueryResourceParam<I, R> {
    return TableErasedPopulatedQueryResourceParam<I, R> { query: query, resource: resource };
}

fn table_erased_query_resource_count<T, R>(param: TableErasedQueryResourceParam<T, R>) -> i64 {
    return table_erased_query_count<EntityItem<T>>(param.query);
}

fn table_erased_query_resource_is_empty<T, R>(param: TableErasedQueryResourceParam<T, R>) -> bool {
    return table_erased_query_is_empty<EntityItem<T>>(param.query);
}

fn table_erased_query_resource_contains<T, R>(param: TableErasedQueryResourceParam<T, R>, entity: Entity) -> bool {
    return table_erased_query_entity_item_contains<T>(param.query, entity);
}

fn table_erased_item_query_resource_count<I, R>(param: TableErasedItemQueryResourceParam<I, R>) -> i64 {
    return table_erased_query_count<I>(param.query);
}

fn table_erased_item_query_resource_is_empty<I, R>(param: TableErasedItemQueryResourceParam<I, R>) -> bool {
    return table_erased_query_is_empty<I>(param.query);
}

fn table_erased_populated_query_resource_count<I, R>(param: TableErasedPopulatedQueryResourceParam<I, R>) -> i64 {
    return table_erased_query_count<I>(param.query);
}

fn table_erased_populated_query_resource_is_empty<I, R>(param: TableErasedPopulatedQueryResourceParam<I, R>) -> bool {
    return table_erased_query_is_empty<I>(param.query);
}

fn table_erased_entity_query_resource_contains<R>(param: TableErasedItemQueryResourceParam<Entity, R>, entity: Entity) -> bool {
    return table_erased_query_entities_contains(param.query, entity);
}

fn table_erased_pair_query_resource_contains<A, B, R>(param: TableErasedItemQueryResourceParam<TableErasedPair<A, B>, R>, entity: Entity) -> bool {
    return table_erased_query_pair_contains<A, B>(param.query, entity);
}

fn table_erased_pair_mut_item_query_resource_contains<A, B, R>(param: TableErasedItemQueryResourceParam<TableErasedPairMut<A, B>, R>, entity: Entity) -> bool {
    return table_erased_query_pair_mut_contains<A, B>(param.query, entity);
}

fn table_erased_pair_mut_populated_query_resource_contains<A, B, R>(param: TableErasedPopulatedQueryResourceParam<TableErasedPairMut<A, B>, R>, entity: Entity) -> bool {
    return table_erased_query_pair_mut_contains<A, B>(param.query, entity);
}

fn table_erased_query_optional_single<I>(query: Query<I>, default_item: fn() -> I) -> TableErasedOptional<I> {
    let cnt = len(query.items);
    if cnt == 0 { return TableErasedOptional<I> { has_value: false, value: default_item() }; };
    if cnt > 1 { panic(12080); };
    return TableErasedOptional<I> { has_value: true, value: query.items[0] };
}

fn table_erased_query_populated<I>(query: Query<I>) -> Query<I> {
    if len(query.items) == 0 { panic(12081); };
    return query;
}

fn table_erased_apply_pair_mut_updates<A, B, R, M>(world: TableErasedWorld<R, M>, updated: Query<TableErasedPairMut<A, B>>) -> TableErasedWorld<R, M> {
    let i: i64 = 0;
    let cnt = len(updated.items) as i64;
    while i < cnt {
        let item = updated.items[i];
        world = table_erased_world_pair_write_first<A, B, R, M>(world, item, item.first.value);
        i = i + 1;
    }
    return world;
}

fn table_erased_apply_pair_mut_with_spawn_details_updates<A, B, R, M>(world: TableErasedWorld<R, M>, updated: Query<TableErasedPairMutWithSpawnDetails<A, B>>) -> TableErasedWorld<R, M> {
    let i: i64 = 0;
    let cnt = len(updated.items) as i64;
    while i < cnt {
        let item = updated.items[i];
        world = table_erased_world_pair_mut_with_spawn_details_write_first<A, B, R, M>(world, item, item.first.value);
        i = i + 1;
    }
    return world;
}

fn table_erased_run_pair_mut_system<A, B, R, M>(world: TableErasedWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedWorld<R, M> {
    let query = table_erased_world_query_pair_mut_first<A, B, R, M>(world, first_component_id, first_type_id, second_component_id, second_type_id);
    let updated = run(query);
    return table_erased_apply_pair_mut_updates<A, B, R, M>(world, updated);
}

fn table_erased_run_pair_mut_system_auto<A, B, R, M>(world: TableErasedWorld<R, M>, first_type_id: i32, second_type_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedWorld<R, M> {
    let first_component_id = table_erased_world_component_id_for_type<R, M>(world, first_type_id);
    let second_component_id = table_erased_world_component_id_for_type<R, M>(world, second_type_id);
    return table_erased_run_pair_mut_system<A, B, R, M>(world, first_component_id, first_type_id, second_component_id, second_type_id, run);
}

fn table_erased_run_pair_mut_system_with<A, B, R, M>(world: TableErasedWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, with_component_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedWorld<R, M> {
