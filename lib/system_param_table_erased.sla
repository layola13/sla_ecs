    return table_erased_item_query_resource_param<TableErasedPairWithAnyOf3<TableErasedParamPos, TableErasedParamVel, TableErasedParamMarker, TableErasedParamTag, TableErasedParamAux>, TableErasedParamTime>(param.query, TableErasedParamTime { tick: len(param.query.items) as i32 * 10000 + first_present * 1000 + second_present * 100 + third_present * 10 + first_missing });
}

fn table_erased_param_pair_with_anyof4_count_system(param: TableErasedItemQueryResourceParam<TableErasedPairWithAnyOf4<TableErasedParamPos, TableErasedParamVel, TableErasedParamMarker, TableErasedParamTag, TableErasedParamAux, TableErasedParamExtra>, TableErasedParamTime>) -> TableErasedItemQueryResourceParam<TableErasedPairWithAnyOf4<TableErasedParamPos, TableErasedParamVel, TableErasedParamMarker, TableErasedParamTag, TableErasedParamAux, TableErasedParamExtra>, TableErasedParamTime> {
    let first_present: i32 = 0;
    let first_missing: i32 = 0;
    let second_present: i32 = 0;
    let third_present: i32 = 0;
    let fourth_present: i32 = 0;
    let i: i64 = 0;
    let cnt = len(param.query.items) as i64;
    while i < cnt {
        if param.query.items[i].any_first.has_value {
            first_present = first_present + 1;
        } else {
            first_missing = first_missing + 1;
        };
        if param.query.items[i].any_second.has_value { second_present = second_present + 1; };
        if param.query.items[i].any_third.has_value { third_present = third_present + 1; };
        if param.query.items[i].any_fourth.has_value { fourth_present = fourth_present + 1; };
        i = i + 1;
    }
    return table_erased_item_query_resource_param<TableErasedPairWithAnyOf4<TableErasedParamPos, TableErasedParamVel, TableErasedParamMarker, TableErasedParamTag, TableErasedParamAux, TableErasedParamExtra>, TableErasedParamTime>(param.query, TableErasedParamTime { tick: len(param.query.items) as i32 * 100000 + first_present * 10000 + second_present * 1000 + third_present * 100 + fourth_present * 10 + first_missing });
}

fn table_erased_param_pair_with_anyof6_count_system(param: TableErasedItemQueryResourceParam<TableErasedPairWithAnyOf6<TableErasedParamPos, TableErasedParamVel, TableErasedParamMarker, TableErasedParamTag, TableErasedParamAux, TableErasedParamExtra, TableErasedParamMore, TableErasedParamBonus>, TableErasedParamTime>) -> TableErasedItemQueryResourceParam<TableErasedPairWithAnyOf6<TableErasedParamPos, TableErasedParamVel, TableErasedParamMarker, TableErasedParamTag, TableErasedParamAux, TableErasedParamExtra, TableErasedParamMore, TableErasedParamBonus>, TableErasedParamTime> {
    let first_present: i32 = 0;
    let first_missing: i32 = 0;
    let second_present: i32 = 0;
    let third_present: i32 = 0;
    let fourth_present: i32 = 0;
    let fifth_present: i32 = 0;
    let sixth_present: i32 = 0;
    let i: i64 = 0;
    let cnt = len(param.query.items) as i64;
    while i < cnt {
        if param.query.items[i].any_0.has_value {
            first_present = first_present + 1;
        } else {
            first_missing = first_missing + 1;
        };
        if param.query.items[i].any_1.has_value { second_present = second_present + 1; };
        if param.query.items[i].any_2.has_value { third_present = third_present + 1; };
        if param.query.items[i].any_3.has_value { fourth_present = fourth_present + 1; };
        if param.query.items[i].any_4.has_value { fifth_present = fifth_present + 1; };
        if param.query.items[i].any_5.has_value { sixth_present = sixth_present + 1; };
        i = i + 1;
    }
    return table_erased_item_query_resource_param<TableErasedPairWithAnyOf6<TableErasedParamPos, TableErasedParamVel, TableErasedParamMarker, TableErasedParamTag, TableErasedParamAux, TableErasedParamExtra, TableErasedParamMore, TableErasedParamBonus>, TableErasedParamTime>(param.query, TableErasedParamTime { tick: len(param.query.items) as i32 * 10000000 + first_present * 1000000 + second_present * 100000 + third_present * 10000 + fourth_present * 1000 + fifth_present * 100 + sixth_present * 10 + first_missing });
}

fn table_erased_param_triple_marker_velocity_pos_count_system(param: TableErasedItemQueryResourceParam<TableErasedTriple<TableErasedParamMarker, TableErasedParamVel, TableErasedParamPos>, TableErasedParamTime>) -> TableErasedItemQueryResourceParam<TableErasedTriple<TableErasedParamMarker, TableErasedParamVel, TableErasedParamPos>, TableErasedParamTime> {
    let sum: i32 = 0;
    let i: i64 = 0;
    let cnt = len(param.query.items) as i64;
    while i < cnt {
        sum = sum + param.query.items[i].first.value + param.query.items[i].second.x + param.query.items[i].third.x;
        i = i + 1;
    }
    return table_erased_item_query_resource_param<TableErasedTriple<TableErasedParamMarker, TableErasedParamVel, TableErasedParamPos>, TableErasedParamTime>(param.query, TableErasedParamTime { tick: len(param.query.items) as i32 * 1000 + sum });
}

@test "table erased pair query system param writes back"() {
    let w0 = table_erased_param_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w0, TABLE_ERASED_PARAM_POS_TYPE, ecs_box_drop<TableErasedParamPos>);
    let (w2, velocity) = table_erased_world_register_table<TableErasedParamTime, TableErasedParamEvent>(w1, TABLE_ERASED_PARAM_VEL_TYPE, ecs_box_drop<TableErasedParamVel>);
    let (w3, entity) = table_erased_world_spawn<TableErasedParamTime, TableErasedParamEvent>(w2);
    let w4 = table_erased_world_insert<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w3, entity, position.id, TABLE_ERASED_PARAM_POS_TYPE, TableErasedParamPos { x: 8, y: 0 });
    let w5 = table_erased_world_insert<TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w4, entity, velocity.id, TABLE_ERASED_PARAM_VEL_TYPE, TableErasedParamVel { x: 3, y: 0 });
    let before = w5.registry.change_tick;
    let group_before = table_erased_world_entity_archetype_id<TableErasedParamTime, TableErasedParamEvent>(w5, entity);
    let row_before = table_erased_world_entity_row<TableErasedParamTime, TableErasedParamEvent>(w5, entity);
    let w6 = table_erased_run_pair_mut_system_auto<TableErasedParamPos, TableErasedParamVel, TableErasedParamTime, TableErasedParamEvent>(w5, TABLE_ERASED_PARAM_POS_TYPE, TABLE_ERASED_PARAM_VEL_TYPE, table_erased_param_movement_system);
    if table_erased_world_get<TableErasedParamPos, TableErasedParamTime, TableErasedParamEvent>(w6, entity, position.id, TABLE_ERASED_PARAM_POS_TYPE).x != 11 { panic(12000); };
    if table_erased_world_entity_archetype_id<TableErasedParamTime, TableErasedParamEvent>(w6, entity) != group_before { panic(12001); };
    if table_erased_world_entity_row<TableErasedParamTime, TableErasedParamEvent>(w6, entity) != row_before { panic(12002); };
    if table_erased_world_changed_since<TableErasedParamTime, TableErasedParamEvent>(w6, entity, position.id, before - 1) != true { panic(12003); };
}

