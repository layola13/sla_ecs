    read: MessageRead<M>,
    writer: MessageWriter<M>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedPairMutMessageReadResMutCommandsParam<A, B, R, M> {
    query: Query<TableErasedPairMut<A, B>>,
    read: MessageRead<M>,
    resource: ResMut<R>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedPairMutMessageWriterResMutCommandsParam<A, B, R, M> {
    query: Query<TableErasedPairMut<A, B>>,
    writer: MessageWriter<M>,
    resource: ResMut<R>,
    commands: TableErasedCommandsParam<R, M>,
}

struct TableErasedPairMutMessageReaderWriterResMutCommandsParam<A, B, R, M> {
    query: Query<TableErasedPairMut<A, B>>,
    read: MessageRead<M>,
    writer: MessageWriter<M>,
    resource: ResMut<R>,
    commands: TableErasedCommandsParam<R, M>,
