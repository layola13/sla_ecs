fn table_erased_param_inspect_query_system(param: TableErasedQueryResourceParam<TableErasedParamPos, TableErasedParamTime>) -> TableErasedQueryResourceParam<TableErasedParamPos, TableErasedParamTime> {
    let count = table_erased_query_resource_count<TableErasedParamPos, TableErasedParamTime>(param);
    let has_items = count > 0;
    let tick = len(param.query.items) as i32 * 100;
    if table_erased_query_resource_is_empty<TableErasedParamPos, TableErasedParamTime>(param) { tick = tick + 10; };
    if has_items {
        let first = param.query.items[0].entity;
        if table_erased_query_resource_contains<TableErasedParamPos, TableErasedParamTime>(param, first) { tick = tick + 1; };
    };
    if table_erased_query_resource_contains<TableErasedParamPos, TableErasedParamTime>(param, entity_placeholder()) { tick = tick + 50; };
    return table_erased_query_resource_param<TableErasedParamPos, TableErasedParamTime>(param.query, TableErasedParamTime { tick: tick });
}

