}

fn table_erased_run_resource_message_system<R, M>(world: TableErasedWorld<R, M>, default_message: M, run: fn(TableErasedResourceMessageParam<R, M>) -> TableErasedResourceMessageParam<R, M>) -> TableErasedWorld<R, M> {
    let param0 = table_erased_resource_message_param<R, M>(table_erased_world_get_resource<R, M>(world), default_message, false);
    let param1 = run(param0);
    world = table_erased_world_insert_resource<R, M>(world, param1.resource);
    if param1.should_write_message { world = table_erased_world_write_message<R, M>(world, param1.message); };
    return world;
}

fn table_erased_run_res_mut_system<R, M>(world: TableErasedWorld<R, M>, run: fn(ResMut<R>) -> ResMut<R>) -> TableErasedWorld<R, M> {
    let param0 = table_erased_world_res_mut<R, M>(world);
    let param1 = run(param0);
    return table_erased_world_res_mut_write<R, M>(world, param1, param1.value);
}

fn table_erased_run_message_reader_res_mut_system<R, M>(world: TableErasedWorld<R, M>, reader: MessageReader, default_message: M, run: fn(TableErasedResMutMessageReadParam<R, M>) -> TableErasedResMutMessageReadParam<R, M>) -> (TableErasedWorld<R, M>, MessageReader) {
    let read = table_erased_world_read_message<R, M>(world, reader, default_message);
    let param0 = table_erased_resmut_message_read_param<R, M>(table_erased_world_res_mut<R, M>(world), read);
    let param1 = run(param0);
    world = table_erased_world_res_mut_write<R, M>(world, param1.resource, param1.resource.value);
    return (world, param1.read.reader);
}

fn table_erased_run_commands_system<R, M>(world: TableErasedWorld<R, M>, run: fn(TableErasedCommandsParam<R, M>) -> TableErasedCommandsParam<R, M>) -> TableErasedWorld<R, M> {
    let param0 = table_erased_commands_param_new<R, M>(world);
    let param1 = run(param0);
    let (world2, cleared) = table_erased_commands_apply<R, M>(param1.world, param1.commands);
    return world2;
}

fn table_erased_run_message_writer_system<R, M>(world: TableErasedWorld<R, M>, run: fn(MessageWriter<M>) -> MessageWriter<M>) -> TableErasedWorld<R, M> {
    let writer0 = message_writer_new<M>();
    let writer1 = run(writer0);
    world.messages = messages_apply_writer<M>(world.messages, writer1);
    return world;
}

fn table_erased_run_without_query_resource_system<T, R, M>(world: TableErasedWorld<R, M>, component_id: i32, type_id: i32, without_component_id: i32, run: fn(TableErasedQueryResourceParam<T, R>) -> TableErasedQueryResourceParam<T, R>) -> TableErasedWorld<R, M> {
    let query = table_erased_world_query_without<T, R, M>(world, component_id, type_id, without_component_id);
    let param0 = table_erased_query_resource_param<T, R>(query, table_erased_world_get_resource<R, M>(world));
    let param1 = run(param0);
