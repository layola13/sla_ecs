L_LOOP_HEAD_1542:
    tmp_5651 = load entity_slot+0 as i64
    tmp_5652 = slt tmp_5651, tmp_5650
    br tmp_5652 -> L_LOOP_BODY_1543, L_LOOP_COND_FALSE_1545

