L_LOOP_HEAD_1265:
    tmp_4754 = load entity_slot+0 as i64
    tmp_4755 = slt tmp_4754, tmp_4753
    br tmp_4755 -> L_LOOP_BODY_1266, L_LOOP_COND_FALSE_1268

