@test "relationship linked despawn follows target collection"():
L_TEST_ENTRY_651:
    tmp_1965 = call @sla__relationship_world_new()
    w0 = tmp_1965
    tmp_1966 = 1
    tmp_1967 = 0
    tmp_1968 = call @sla__relationship_world_register_many(w0, tmp_1966, tmp_1967)
    !tmp_1966
    !tmp_1967
    w1 = load tmp_1968+0 as ptr
    linked = load tmp_1968+8 as ptr
    !tmp_1968
    tmp_1969 = call @sla__relationship_world_spawn(w1)
    w2 = load tmp_1969+0 as ptr
    root = load tmp_1969+8 as ptr
    !tmp_1969
    tmp_1970 = load linked+0 as i32
    tmp_1971 = call @sla__relationship_world_spawn_related(w2, tmp_1970, root)
    !tmp_1970
    w3 = load tmp_1971+0 as ptr
    child = load tmp_1971+8 as ptr
    !tmp_1971
    tmp_1972 = load linked+0 as i32
    tmp_1973 = call @sla__relationship_world_spawn_related(w3, tmp_1972, child)
    !tmp_1972
    w4 = load tmp_1973+0 as ptr
    grandchild = load tmp_1973+8 as ptr
    !tmp_1973
    tmp_1974 = call @sla__relationship_world_despawn(w4, root)
    w5 = tmp_1974
    tmp_1975 = call @sla__relationship_world_is_alive(w5, root)
    tmp_1976 = 0
    tmp_1977 = ne tmp_1975, tmp_1976
    !tmp_1975
    !tmp_1976
    br tmp_1977 -> L_THEN_652, L_ELSE_653

L_THEN_652:
    !tmp_1977
    panic(9550)

L_ELSE_653:
    !tmp_1977
    jmp L_MERGE_654

