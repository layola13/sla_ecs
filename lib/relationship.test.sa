@test "relationship one to one target replaces previous source"():
L_TEST_ENTRY_518:
    tmp_1574 = call @sla__relationship_world_new()
    w0 = tmp_1574
    tmp_1575 = 0
    tmp_1576 = 0
    tmp_1577 = call @sla__relationship_world_register_one(w0, tmp_1575, tmp_1576)
    !tmp_1575
    !tmp_1576
    w1 = load tmp_1577+0 as ptr
    kind = load tmp_1577+8 as ptr
    !tmp_1577
    tmp_1578 = call @sla__relationship_world_spawn(w1)
    w2 = load tmp_1578+0 as ptr
    target = load tmp_1578+8 as ptr
    !tmp_1578
    tmp_1579 = call @sla__relationship_world_spawn(w2)
    w3 = load tmp_1579+0 as ptr
    first = load tmp_1579+8 as ptr
    !tmp_1579
    tmp_1580 = call @sla__relationship_world_spawn(w3)
    w4 = load tmp_1580+0 as ptr
    second = load tmp_1580+8 as ptr
    !tmp_1580
    tmp_1581 = load kind+0 as i32
    tmp_1582 = call @sla__relationship_world_set_related(w4, tmp_1581, first, target)
    !tmp_1581
    w5 = tmp_1582
    tmp_1583 = load kind+0 as i32
    tmp_1584 = call @sla__relationship_world_set_related(w5, tmp_1583, second, target)
    !tmp_1583
    w6 = tmp_1584
    tmp_1585 = load kind+0 as i32
    tmp_1586 = call @sla__relationship_world_has_related(w6, tmp_1585, first)
    !tmp_1585
    tmp_1587 = 0
    tmp_1588 = ne tmp_1586, tmp_1587
    !tmp_1586
    !tmp_1587
    br tmp_1588 -> L_THEN_519, L_ELSE_520

L_THEN_519:
    !tmp_1588
    panic(9540)

L_ELSE_520:
    !tmp_1588
    jmp L_MERGE_521

L_MERGE_521:
    tmp_1591 = load kind+0 as i32
    tmp_1592 = call @sla__relationship_world_has_related(w6, tmp_1591, second)
    !tmp_1591
    tmp_1593 = 1
    tmp_1594 = ne tmp_1592, tmp_1593
    !tmp_1592
    !tmp_1593
    br tmp_1594 -> L_THEN_522, L_ELSE_523

L_THEN_522:
    !tmp_1594
    panic(9541)

L_ELSE_523:
    !tmp_1594
    jmp L_MERGE_524

L_MERGE_524:
    tmp_1597 = load kind+0 as i32
    tmp_1598 = call @sla__relationship_world_source_count(w6, tmp_1597, target)
    !tmp_1597
    tmp_1599 = 1
    tmp_1600 = ne tmp_1598, tmp_1599
    !tmp_1598
    !tmp_1599
    br tmp_1600 -> L_THEN_525, L_ELSE_526

L_THEN_525:
    !tmp_1600
    panic(9542)

L_ELSE_526:
    !tmp_1600
    jmp L_MERGE_527

L_MERGE_527:
    tmp_1603 = load kind+0 as i32
    tmp_1604 = 0
    tmp_1605 = call @sla__relationship_world_source_at(w6, tmp_1603, target, tmp_1604)
    !tmp_1603
    !tmp_1604
    tmp_1606 = call @sla__entity_eq(tmp_1605, second)
    !tmp_1605
    tmp_1607 = 1
    tmp_1608 = ne tmp_1606, tmp_1607
    !tmp_1606
    !tmp_1607
    br tmp_1608 -> L_THEN_528, L_ELSE_529

L_THEN_528:
    !tmp_1608
    panic(9543)

L_ELSE_529:
    !tmp_1608
    jmp L_MERGE_530

L_MERGE_530:
    !w0
    !w4
    !target
    !second
    !kind
    !w5
    !first
    !w3
    !w1
    !w2
    !w6
    return

@test "relationship linked despawn follows target collection"():
L_TEST_ENTRY_531:
    tmp_1611 = call @sla__relationship_world_new()
    w0 = tmp_1611
    tmp_1612 = 1
    tmp_1613 = 0
    tmp_1614 = call @sla__relationship_world_register_many(w0, tmp_1612, tmp_1613)
    !tmp_1612
    !tmp_1613
    w1 = load tmp_1614+0 as ptr
    linked = load tmp_1614+8 as ptr
    !tmp_1614
    tmp_1615 = call @sla__relationship_world_spawn(w1)
    w2 = load tmp_1615+0 as ptr
    root = load tmp_1615+8 as ptr
    !tmp_1615
    tmp_1616 = load linked+0 as i32
    tmp_1617 = call @sla__relationship_world_spawn_related(w2, tmp_1616, root)
    !tmp_1616
    w3 = load tmp_1617+0 as ptr
    child = load tmp_1617+8 as ptr
    !tmp_1617
    tmp_1618 = load linked+0 as i32
    tmp_1619 = call @sla__relationship_world_spawn_related(w3, tmp_1618, child)
    !tmp_1618
    w4 = load tmp_1619+0 as ptr
    grandchild = load tmp_1619+8 as ptr
    !tmp_1619
    tmp_1620 = call @sla__relationship_world_despawn(w4, root)
    w5 = tmp_1620
    tmp_1621 = call @sla__relationship_world_is_alive(w5, root)
    tmp_1622 = 0
    tmp_1623 = ne tmp_1621, tmp_1622
    !tmp_1621
    !tmp_1622
    br tmp_1623 -> L_THEN_532, L_ELSE_533

L_THEN_532:
    !tmp_1623
    panic(9550)

L_ELSE_533:
    !tmp_1623
    jmp L_MERGE_534

L_MERGE_534:
    tmp_1626 = call @sla__relationship_world_is_alive(w5, child)
    tmp_1627 = 0
    tmp_1628 = ne tmp_1626, tmp_1627
    !tmp_1626
    !tmp_1627
    br tmp_1628 -> L_THEN_535, L_ELSE_536

L_THEN_535:
    !tmp_1628
    panic(9551)

L_ELSE_536:
    !tmp_1628
    jmp L_MERGE_537

L_MERGE_537:
    tmp_1631 = call @sla__relationship_world_is_alive(w5, grandchild)
    tmp_1632 = 0
    tmp_1633 = ne tmp_1631, tmp_1632
    !tmp_1631
    !tmp_1632
    br tmp_1633 -> L_THEN_538, L_ELSE_539

L_THEN_538:
    !tmp_1633
    panic(9552)

L_ELSE_539:
    !tmp_1633
    jmp L_MERGE_540

L_MERGE_540:
    !w0
    !linked
    !w4
    !grandchild
    !w5
    !root
    !w1
    !w2
    !w3
    !child
    return

