L_LOOP_HEAD_1675:
    tmp_5897 = load entity_slot+0 as i64
    tmp_5898 = slt tmp_5897, tmp_5896
    br tmp_5898 -> L_LOOP_BODY_1676, L_LOOP_COND_FALSE_1678

