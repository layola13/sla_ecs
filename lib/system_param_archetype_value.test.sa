    tmp_4602 = load e1+0 as i32
    tmp_4603 = load e2+0 as i32
    tmp_4604 = add tmp_4602, tmp_4603
    !tmp_4602
    !tmp_4603
    tmp_4605 = ne total, tmp_4604
    !tmp_4604
