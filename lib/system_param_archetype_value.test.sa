    w3 = load tmp_4588+0 as ptr
    e2 = load tmp_4588+8 as ptr
    !tmp_4588
    tmp_4589 = load component+0 as i32
    tmp_4590 = call @sla__registry_world_insert_component(w3, e1, tmp_4589)
    !tmp_4589
    w4 = tmp_4590
