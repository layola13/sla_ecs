    tmp_4594 = call @sla__registry_world_query_component(w5, tmp_4593)
    !tmp_4593
    q = tmp_4594
    tmp_4595 = 0
    total = tmp_4595
    tmp_4596 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1241

L_LOOP_HEAD_1241:
    tmp_4597 = load entity_slot+0 as i64
    tmp_4598 = slt tmp_4597, tmp_4596
    br tmp_4598 -> L_LOOP_BODY_1242, L_LOOP_COND_FALSE_1244

L_LOOP_BODY_1242:
    !tmp_4598
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_4597)
    tmp_4599 = load entity+0 as i32
    tmp_4600 = add total, tmp_4599
    !tmp_4599
    !total
    total = tmp_4600
