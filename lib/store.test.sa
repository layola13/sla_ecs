    tmp_210 = mul last, 4
    tmp_211 = ptr_add tmp_209, tmp_210
    !tmp_210
    tmp_212 = load tmp_211+0 as i32
    !tmp_211
    !tmp_209
    store tmp_208+0, tmp_212 as i32
