L_ELSE_75:
    !tmp_272
    jmp L_MERGE_76

L_MERGE_76:
    tmp_275 = call @sla__is_alive(a3, e2)
    tmp_276 = 1
    tmp_277 = ne tmp_275, tmp_276
    !tmp_275
    !tmp_276
    br tmp_277 -> L_THEN_77, L_ELSE_78

L_THEN_77:
    !tmp_277
