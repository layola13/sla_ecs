    !tmp_264
    !tmp_265
    br tmp_266 -> L_THEN_71, L_ELSE_72

L_THEN_71:
    !tmp_266
    panic(2121)

L_ELSE_72:
    !tmp_266
    jmp L_MERGE_73

L_MERGE_73:
    tmp_269 = call @sla__alloc_entity(a2)
    a3 = load tmp_269+0 as ptr
    e2 = load tmp_269+8 as ptr
    !tmp_269
    tmp_270 = call @sla__entity_eq(e2, fabricated)
    tmp_271 = 1
    tmp_272 = ne tmp_270, tmp_271
    !tmp_270
    !tmp_271
