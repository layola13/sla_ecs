    tmp_1993 = call @sla__hierarchy_world_new()
    w0 = tmp_1993
    tmp_1994 = call @sla__hierarchy_world_spawn(w0)
    w1 = load tmp_1994+0 as ptr
    parent = load tmp_1994+8 as ptr
    !tmp_1994
    tmp_1995 = call @sla__hierarchy_world_spawn(w1)
    w2 = load tmp_1995+0 as ptr
    c0 = load tmp_1995+8 as ptr
    !tmp_1995
    tmp_1996 = call @sla__hierarchy_world_spawn(w2)
    w3 = load tmp_1996+0 as ptr
    c1 = load tmp_1996+8 as ptr
    !tmp_1996
    tmp_1997 = call @sla__hierarchy_world_spawn(w3)
    w4 = load tmp_1997+0 as ptr
    c2 = load tmp_1997+8 as ptr
    !tmp_1997
    tmp_1998 = call @sla__hierarchy_world_add_child(w4, parent, c0)
    w5 = tmp_1998
    tmp_1999 = call @sla__hierarchy_world_add_child(w5, parent, c1)
    w6 = tmp_1999
    tmp_2000 = call @sla__hierarchy_world_add_child(w6, parent, c2)
    w7 = tmp_2000
    tmp_2001 = 0
    tmp_2002 = 2
    tmp_2003 = call @sla__hierarchy_world_swap_children(w7, parent, tmp_2001, tmp_2002)
    !tmp_2001
    !tmp_2002
    w8 = tmp_2003
    tmp_2004 = 0
    tmp_2005 = call @sla__hierarchy_world_child_at(w8, parent, tmp_2004)
    !tmp_2004
    tmp_2006 = call @sla__entity_eq(tmp_2005, c2)
    !tmp_2005
    tmp_2007 = 1
    tmp_2008 = ne tmp_2006, tmp_2007
    !tmp_2006
    !tmp_2007
    br tmp_2008 -> L_THEN_654, L_ELSE_655

L_THEN_654:
