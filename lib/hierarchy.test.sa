    tmp_32 = 1
    store tmp_31+0, tmp_32 as i32
    !tmp_32
    tmp_33 = 0
    store tmp_31+4, tmp_33 as i32
    !tmp_33
    tmp_34 = alloc 128
    tmp_35 = 0
    store tmp_34+0, tmp_35 as i64
    store tmp_34+8, tmp_35 as i64
    store tmp_34+16, tmp_35 as i64
    store tmp_34+24, tmp_35 as i64
