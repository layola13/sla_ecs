    tmp_1757 = call @sla__is_alive(a1, tmp_1754)
    !tmp_1754
    tmp_1758 = 0
    tmp_1759 = ne tmp_1757, tmp_1758
    !tmp_1757
    !tmp_1758
    br tmp_1759 -> L_THEN_500, L_ELSE_501

L_THEN_500:
