@sla__dyn_allocator_new() -> ptr:
L_ENTRY:
    EXPAND VEC_NEW tmp_138
    free_ids = tmp_138
    EXPAND VEC_NEW tmp_139
    generations = tmp_139
    EXPAND VEC_NEW tmp_140
    occupied = tmp_140
    tmp_141 = 0
    EXPAND VEC_PUSH generations, tmp_141, 8
    !tmp_141
    tmp_142 = 0
    EXPAND VEC_PUSH occupied, tmp_142, 8
    !tmp_142
    tmp_143 = alloc 24
    store tmp_143+0, free_ids as ptr
    store tmp_143+8, generations as ptr
