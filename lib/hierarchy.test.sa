@test "hierarchy invalid target and self relation are discarded"():
L_TEST_ENTRY_798:
    tmp_3099 = call @sla__hierarchy_world_new()
    w0 = tmp_3099
    tmp_3100 = call @sla__hierarchy_world_spawn(w0)
    w1 = load tmp_3100+0 as ptr
    parent = load tmp_3100+8 as ptr
    !tmp_3100
    tmp_3101 = call @sla__hierarchy_world_spawn(w1)
    w2 = load tmp_3101+0 as ptr
    child = load tmp_3101+8 as ptr
    !tmp_3101
    tmp_3102 = alloc 8
    tmp_3103 = load parent+0 as i32
    store tmp_3102+0, tmp_3103 as i32
