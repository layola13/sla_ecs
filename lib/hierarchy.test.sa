L_ELSE_17:
    !tmp_88
    jmp L_MERGE_18

L_MERGE_18:
    tmp_91 = load entity+0 as i32
    tmp_92 = 16
    tmp_93 = sge tmp_91, tmp_92
    !tmp_91
    !tmp_92
    br tmp_93 -> L_THEN_19, L_ELSE_20

L_THEN_19:
    !tmp_93
    tmp_94 = 0
    !entity
    !a
