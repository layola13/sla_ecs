    !tmp_3102
    !tmp_3105
    w3 = tmp_3108
    tmp_3109 = alloc 8
    tmp_3110 = load child+0 as i32
    store tmp_3109+0, tmp_3110 as i32
    tmp_3111 = load child+4 as i32
