    tmp_36 = alloc 64
    tmp_37 = 0
    store tmp_36+0, tmp_37 as i32
    store tmp_36+4, tmp_37 as i32
    store tmp_36+8, tmp_37 as i32
    store tmp_36+12, tmp_37 as i32
    store tmp_36+16, tmp_37 as i32
    store tmp_36+20, tmp_37 as i32
    store tmp_36+24, tmp_37 as i32
