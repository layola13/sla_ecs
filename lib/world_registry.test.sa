    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_998)
    tmp_1000 = load entity+0 as i32
    tmp_1001 = add total, tmp_1000
    !tmp_1000
    !total
    total = tmp_1001
L_LOOP_CONTINUE_314:
    tmp_1002 = add tmp_998, 1
    store entity_slot+0, tmp_1002 as i64
    !tmp_1002
    !tmp_998
    !entity
    jmp L_LOOP_HEAD_312

L_LOOP_COND_FALSE_315:
