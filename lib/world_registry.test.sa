@test "registry entity query supports for in"():
L_TEST_ENTRY_311:
    entity_slot = stack_alloc 8
    tmp_986 = call @sla__registry_world_new()
    w0 = tmp_986
    tmp_987 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_987+0 as ptr
    component = load tmp_987+8 as ptr
    !tmp_987
    tmp_988 = call @sla__registry_world_spawn(w1)
    w2 = load tmp_988+0 as ptr
    e1 = load tmp_988+8 as ptr
    !tmp_988
    tmp_989 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_989+0 as ptr
    e2 = load tmp_989+8 as ptr
    !tmp_989
    tmp_990 = load component+0 as i32
    tmp_991 = call @sla__registry_world_insert_component(w3, e1, tmp_990)
    !tmp_990
    w4 = tmp_991
    tmp_992 = load component+0 as i32
    tmp_993 = call @sla__registry_world_insert_component(w4, e2, tmp_992)
    !tmp_992
    w5 = tmp_993
    tmp_994 = load component+0 as i32
    tmp_995 = call @sla__registry_world_query_component(w5, tmp_994)
    !tmp_994
    q = tmp_995
    tmp_996 = 0
    total = tmp_996
    tmp_997 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_312

L_LOOP_HEAD_312:
