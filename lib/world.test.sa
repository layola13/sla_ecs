    return

@test "allocator rejects stale generation"():
L_TEST_ENTRY_182:
    tmp_803 = call @sla__allocator_new()
    a0 = tmp_803
    tmp_804 = call @sla__alloc_entity(a0)
    a1 = load tmp_804+0 as ptr
    e1 = load tmp_804+8 as ptr
    !tmp_804
    tmp_805 = call @sla__free_entity(a1, e1)
    a2 = tmp_805
    tmp_806 = load e1+0 as i32
    tmp_807 = load e1+4 as i32
    tmp_808 = call @sla__entity_new(tmp_806, tmp_807)
    !tmp_806
    !tmp_807
    stale = tmp_808
    tmp_809 = load e1+0 as i32
    tmp_810 = load e1+4 as i32
    tmp_811 = 1
    tmp_812 = add tmp_810, tmp_811
    !tmp_810
    !tmp_811
    tmp_813 = call @sla__entity_new(tmp_809, tmp_812)
    !tmp_809
    !tmp_812
    fabricated = tmp_813
    tmp_814 = call @sla__is_alive(a2, stale)
    tmp_815 = 0
    tmp_816 = ne tmp_814, tmp_815
    !tmp_814
    !tmp_815
    br tmp_816 -> L_THEN_183, L_ELSE_184

L_THEN_183:
    !tmp_816
    panic(2120)

L_ELSE_184:
    !tmp_816
    jmp L_MERGE_185

L_MERGE_185:
    tmp_819 = call @sla__is_alive(a2, fabricated)
    tmp_820 = 0
    tmp_821 = ne tmp_819, tmp_820
    !tmp_819
    !tmp_820
    br tmp_821 -> L_THEN_186, L_ELSE_187

L_THEN_186:
    !tmp_821
    panic(2121)

L_ELSE_187:
    !tmp_821
    jmp L_MERGE_188

L_MERGE_188:
    tmp_824 = call @sla__alloc_entity(a2)
    a3 = load tmp_824+0 as ptr
    e2 = load tmp_824+8 as ptr
    !tmp_824
    tmp_825 = call @sla__entity_eq(e2, fabricated)
    tmp_826 = 1
    tmp_827 = ne tmp_825, tmp_826
    !tmp_825
    !tmp_826
    br tmp_827 -> L_THEN_189, L_ELSE_190

L_THEN_189:
    !tmp_827
    panic(2122)

L_ELSE_190:
    !tmp_827
    jmp L_MERGE_191

L_MERGE_191:
    tmp_830 = call @sla__is_alive(a3, e2)
    tmp_831 = 1
    tmp_832 = ne tmp_830, tmp_831
    !tmp_830
    !tmp_831
    br tmp_832 -> L_THEN_192, L_ELSE_193

L_THEN_192:
    !tmp_832
    panic(2123)

L_ELSE_193:
    !tmp_832
    jmp L_MERGE_194

L_MERGE_194:
    !e2
    !a0
    !a2
    !fabricated
    !stale
    !e1
    !a3
    !a1
    return

