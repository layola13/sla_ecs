    tmp_780 = call @sla__entity_placeholder()
    placeholder = tmp_780
    tmp_781 = call @sla__allocator_new()
    a = tmp_781
    tmp_782 = call @sla__alloc_entity(a)
    a1 = load tmp_782+0 as ptr
    e1 = load tmp_782+8 as ptr
    !tmp_782
    tmp_783 = load placeholder+0 as i32
    tmp_784 = load e1+0 as i32
    tmp_785 = eq tmp_783, tmp_784
    !tmp_783
    !tmp_784
    br tmp_785 -> L_THEN_172, L_ELSE_173

L_THEN_172:
    !tmp_785
    panic(2100)

L_ELSE_173:
    !tmp_785
    jmp L_MERGE_174

L_MERGE_174:
    tmp_788 = call @sla__is_alive(a1, placeholder)
    tmp_789 = 0
    tmp_790 = ne tmp_788, tmp_789
    !tmp_788
    !tmp_789
    br tmp_790 -> L_THEN_175, L_ELSE_176

L_THEN_175:
    !tmp_790
    panic(2101)

L_ELSE_176:
    !tmp_790
    jmp L_MERGE_177

L_MERGE_177:
    !a
    !placeholder
    !e1
    !a1
    return

