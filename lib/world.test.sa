    tmp_123 = ptr_add tmp_120, tmp_122
    !tmp_122
    !tmp_121
    tmp_124 = load tmp_123+0 as i32
    !tmp_123
    !tmp_120
    tmp_125 = 1
    tmp_126 = add tmp_124, tmp_125
    !tmp_124
    !tmp_125
    store tmp_119+0, tmp_126 as i32
    !tmp_119
    !tmp_116
    !tmp_126
    tmp_127 = load a+16 as ptr
    tmp_128 = load a+4 as i32
    tmp_129 = mul tmp_128, 4
