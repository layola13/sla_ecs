L_LOOP_HEAD_1672:
    tmp_6001 = load entity_slot+0 as i64
    tmp_6002 = slt tmp_6001, tmp_6000
    br tmp_6002 -> L_LOOP_BODY_1673, L_LOOP_COND_FALSE_1675

