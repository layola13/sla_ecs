@test "allocator rejects stale generation"():
L_TEST_ENTRY_552:
    tmp_1819 = call @sla__allocator_new()
    a0 = tmp_1819
    tmp_1820 = call @sla__alloc_entity(a0)
    a1 = load tmp_1820+0 as ptr
    e1 = load tmp_1820+8 as ptr
    !tmp_1820
    tmp_1821 = call @sla__free_entity(a1, e1)
    a2 = tmp_1821
    tmp_1822 = load e1+0 as i32
    tmp_1823 = load e1+4 as i32
    tmp_1824 = call @sla__entity_new(tmp_1822, tmp_1823)
    !tmp_1822
    !tmp_1823
    stale = tmp_1824
    tmp_1825 = load e1+0 as i32
    tmp_1826 = load e1+4 as i32
    tmp_1827 = 1
    tmp_1828 = add tmp_1826, tmp_1827
    !tmp_1826
    !tmp_1827
    tmp_1829 = call @sla__entity_new(tmp_1825, tmp_1828)
    !tmp_1825
    !tmp_1828
    fabricated = tmp_1829
    tmp_1830 = call @sla__is_alive(a2, stale)
    tmp_1831 = 0
    tmp_1832 = ne tmp_1830, tmp_1831
    !tmp_1830
    !tmp_1831
    br tmp_1832 -> L_THEN_553, L_ELSE_554

L_THEN_553:
    !tmp_1832
    panic(2120)

