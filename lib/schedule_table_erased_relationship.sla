// Sequential schedule for TableErasedRelationshipWorld<R, M>.
// Access metadata covers table-erased components plus generic relationship kinds.
@import "commands_table_erased_relationship.sla"

struct TableErasedRelationshipSystemAccess {
    read_components: Vec<i32>,
    write_components: Vec<i32>,
    read_relationships: Vec<i32>,
    write_relationships: Vec<i32>,
    reads_resource: bool,
    writes_resource: bool,
    reads_messages: bool,
    writes_messages: bool,
}

struct TableErasedRelationshipSystem<R, M> {
    run: fn(TableErasedRelationshipWorld<R, M>) -> TableErasedRelationshipWorld<R, M>,
    access: TableErasedRelationshipSystemAccess,
}

struct TableErasedRelationshipSchedule<R, M> {
    systems: Vec<TableErasedRelationshipSystem<R, M>>,
    batch_ids: Vec<i32>,
    conflict_count: i32,
    batch_count: i32,
}

fn table_erased_relationship_system_access_none() -> TableErasedRelationshipSystemAccess {
    let read_components: Vec<i32> = Vec::new();
    let write_components: Vec<i32> = Vec::new();
    let read_relationships: Vec<i32> = Vec::new();
    let write_relationships: Vec<i32> = Vec::new();
    return TableErasedRelationshipSystemAccess {
        read_components: read_components,
        write_components: write_components,
        read_relationships: read_relationships,
        write_relationships: write_relationships,
        reads_resource: false,
        writes_resource: false,
        reads_messages: false,
        writes_messages: false,
    };
}

fn table_erased_relationship_access_read_component(access: TableErasedRelationshipSystemAccess, component_id: i32) -> TableErasedRelationshipSystemAccess { access.read_components.push(component_id); return access; }
fn table_erased_relationship_access_write_component(access: TableErasedRelationshipSystemAccess, component_id: i32) -> TableErasedRelationshipSystemAccess { access.write_components.push(component_id); return access; }
fn table_erased_relationship_access_read_type<R, M>(world: TableErasedRelationshipWorld<R, M>, access: TableErasedRelationshipSystemAccess, type_id: i32) -> TableErasedRelationshipSystemAccess { return table_erased_relationship_access_read_component(access, table_erased_world_component_id_for_type<R, M>(world.table, type_id)); }
fn table_erased_relationship_access_write_type<R, M>(world: TableErasedRelationshipWorld<R, M>, access: TableErasedRelationshipSystemAccess, type_id: i32) -> TableErasedRelationshipSystemAccess { return table_erased_relationship_access_write_component(access, table_erased_world_component_id_for_type<R, M>(world.table, type_id)); }
fn table_erased_relationship_access_read_relationship(access: TableErasedRelationshipSystemAccess, kind_id: i32) -> TableErasedRelationshipSystemAccess { access.read_relationships.push(kind_id); return access; }
fn table_erased_relationship_access_write_relationship(access: TableErasedRelationshipSystemAccess, kind_id: i32) -> TableErasedRelationshipSystemAccess { access.write_relationships.push(kind_id); return access; }
fn table_erased_relationship_access_read_resource(access: TableErasedRelationshipSystemAccess) -> TableErasedRelationshipSystemAccess { access.reads_resource = true; return access; }
fn table_erased_relationship_access_write_resource(access: TableErasedRelationshipSystemAccess) -> TableErasedRelationshipSystemAccess { access.writes_resource = true; return access; }
fn table_erased_relationship_access_read_messages(access: TableErasedRelationshipSystemAccess) -> TableErasedRelationshipSystemAccess { access.reads_messages = true; return access; }
fn table_erased_relationship_access_write_messages(access: TableErasedRelationshipSystemAccess) -> TableErasedRelationshipSystemAccess { access.writes_messages = true; return access; }

fn table_erased_relationship_list_has(values: Vec<i32>, id: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(values) as i64;
    while i < cnt {
        if values[i] == id { return true; };
        i = i + 1;
    }
    return false;
}

fn table_erased_relationship_access_id_lists_conflict(left_reads: Vec<i32>, left_writes: Vec<i32>, right_reads: Vec<i32>, right_writes: Vec<i32>) -> bool {
    let i: i64 = 0;
    let left_write_count = len(left_writes) as i64;
    while i < left_write_count {
        let id = left_writes[i];
        if table_erased_relationship_list_has(right_reads, id) { return true; };
        if table_erased_relationship_list_has(right_writes, id) { return true; };
        i = i + 1;
    }
    let j: i64 = 0;
    let right_write_count = len(right_writes) as i64;
    while j < right_write_count {
        let id = right_writes[j];
        if table_erased_relationship_list_has(left_reads, id) { return true; };
        if table_erased_relationship_list_has(left_writes, id) { return true; };
        j = j + 1;
    }
    return false;
}

fn table_erased_relationship_access_conflicts(left: TableErasedRelationshipSystemAccess, right: TableErasedRelationshipSystemAccess) -> bool {
    if table_erased_relationship_access_id_lists_conflict(left.read_components, left.write_components, right.read_components, right.write_components) { return true; };
    if table_erased_relationship_access_id_lists_conflict(left.read_relationships, left.write_relationships, right.read_relationships, right.write_relationships) { return true; };
    if left.writes_resource { if right.reads_resource { return true; }; if right.writes_resource { return true; }; };
    if right.writes_resource { if left.reads_resource { return true; }; if left.writes_resource { return true; }; };
    if left.writes_messages { if right.reads_messages { return true; }; if right.writes_messages { return true; }; };
    if right.writes_messages { if left.reads_messages { return true; }; if left.writes_messages { return true; }; };
    return false;
}

fn table_erased_relationship_system_new<R, M>(run: fn(TableErasedRelationshipWorld<R, M>) -> TableErasedRelationshipWorld<R, M>, access: TableErasedRelationshipSystemAccess) -> TableErasedRelationshipSystem<R, M> {
    return TableErasedRelationshipSystem<R, M> { run: run, access: access };
}

fn table_erased_relationship_schedule_default<R, M>() -> TableErasedRelationshipSchedule<R, M> {
    let systems: Vec<TableErasedRelationshipSystem<R, M>> = Vec::new();
    let batch_ids: Vec<i32> = Vec::new();
    return TableErasedRelationshipSchedule<R, M> { systems: systems, batch_ids: batch_ids, conflict_count: 0, batch_count: 0 };
}

fn table_erased_relationship_schedule_batch_accepts<R, M>(schedule: TableErasedRelationshipSchedule<R, M>, batch_id: i32, access: TableErasedRelationshipSystemAccess) -> bool {
    let i: i64 = 0;
    let cnt = len(schedule.systems) as i64;
    while i < cnt {
        if schedule.batch_ids[i] == batch_id {
            if table_erased_relationship_access_conflicts(schedule.systems[i].access, access) { return false; };
        };
        i = i + 1;
    }
    return true;
}

fn table_erased_relationship_schedule_choose_batch<R, M>(schedule: TableErasedRelationshipSchedule<R, M>, access: TableErasedRelationshipSystemAccess) -> i32 {
    let batch: i32 = 0;
    while batch < schedule.batch_count {
        if table_erased_relationship_schedule_batch_accepts<R, M>(schedule, batch, access) { return batch; };
        batch = batch + 1;
    }
    return schedule.batch_count;
}

fn table_erased_relationship_schedule_add_systems<R, M>(schedule: TableErasedRelationshipSchedule<R, M>, system: TableErasedRelationshipSystem<R, M>) -> TableErasedRelationshipSchedule<R, M> {
    let i: i64 = 0;
    let cnt = len(schedule.systems) as i64;
    while i < cnt {
        if table_erased_relationship_access_conflicts(schedule.systems[i].access, system.access) { schedule.conflict_count = schedule.conflict_count + 1; };
        i = i + 1;
    }
    let batch = table_erased_relationship_schedule_choose_batch<R, M>(schedule, system.access);
    if batch == schedule.batch_count { schedule.batch_count = schedule.batch_count + 1; };
    schedule.systems.push(system);
    schedule.batch_ids.push(batch);
    return schedule;
}

fn table_erased_relationship_schedule_conflict_count<R, M>(schedule: TableErasedRelationshipSchedule<R, M>) -> i32 { return schedule.conflict_count; }
fn table_erased_relationship_schedule_batch_count<R, M>(schedule: TableErasedRelationshipSchedule<R, M>) -> i32 { return schedule.batch_count; }

fn table_erased_relationship_schedule_system_batch<R, M>(schedule: TableErasedRelationshipSchedule<R, M>, system_index: i64) -> i32 {
    if system_index < 0 { return -1; };
    if system_index >= (len(schedule.batch_ids) as i64) { return -1; };
    return schedule.batch_ids[system_index];
}

fn table_erased_relationship_schedule_batch_width<R, M>(schedule: TableErasedRelationshipSchedule<R, M>, batch_id: i32) -> i32 {
    let count: i32 = 0;
    let i: i64 = 0;
    let cnt = len(schedule.batch_ids) as i64;
    while i < cnt {
        if schedule.batch_ids[i] == batch_id { count = count + 1; };
        i = i + 1;
    }
    return count;
}

fn table_erased_relationship_schedule_max_parallel_width<R, M>(schedule: TableErasedRelationshipSchedule<R, M>) -> i32 {
    let max_width: i32 = 0;
    let batch: i32 = 0;
    while batch < schedule.batch_count {
        if table_erased_relationship_schedule_batch_width<R, M>(schedule, batch) > max_width {
            max_width = table_erased_relationship_schedule_batch_width<R, M>(schedule, batch);
        };
        batch = batch + 1;
    }
    return max_width;
}

fn table_erased_relationship_schedule_increment_tick<R, M>(world: TableErasedRelationshipWorld<R, M>) -> TableErasedRelationshipWorld<R, M> {
    world.table = table_erased_world_increment_tick<R, M>(world.table);
    return world;
}

fn table_erased_relationship_schedule_run<R, M>(schedule: TableErasedRelationshipSchedule<R, M>, world: TableErasedRelationshipWorld<R, M>) -> TableErasedRelationshipWorld<R, M> {
    world = table_erased_relationship_schedule_increment_tick<R, M>(world);
    let i: i64 = 0;
    let cnt = len(schedule.systems) as i64;
    while i < cnt {
        let system = schedule.systems[i];
        let run = system.run;
        world = run(world);
        i = i + 1;
    }
    return world;
}

fn table_erased_relationship_schedule_run_planned<R, M>(schedule: TableErasedRelationshipSchedule<R, M>, world: TableErasedRelationshipWorld<R, M>) -> TableErasedRelationshipWorld<R, M> {
    world = table_erased_relationship_schedule_increment_tick<R, M>(world);
    let batch: i32 = 0;
    while batch < schedule.batch_count {
        let i: i64 = 0;
        let cnt = len(schedule.systems) as i64;
        while i < cnt {
            if schedule.batch_ids[i] == batch {
                let system = schedule.systems[i];
                let run = system.run;
                world = run(world);
            };
            i = i + 1;
        }
        batch = batch + 1;
    }
    return world;
}

fn table_erased_rel_schedule_move_system(world: TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> {
    let q = table_erased_world_query_pair_mut_first_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(world.table, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE);
    let i: i64 = 0;
    let cnt = len(q.items) as i64;
    while i < cnt {
        let item = q.items[i];
        world.table = table_erased_world_pair_write_first<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(world.table, item, TableErasedPos { x: item.first.value.x + item.second.x, y: item.first.value.y + item.second.y });
        i = i + 1;
    }
    return world;
}

fn table_erased_rel_schedule_relationship_count_system(world: TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> {
    let count: i32 = 0;
    if len(world.relationships.targets) > 0 {
        let target_entry = world.relationships.targets[0];
        count = relationship_world_source_count(world.relationships, target_entry.kind_id, target_entry.target) as i32;
    };
    world.table = table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(world.table, TableErasedTime { tick: count });
    return world;
}

fn table_erased_rel_schedule_message_system(world: TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> {
    world.table = table_erased_world_write_message<TableErasedTime, TableErasedEvent>(world.table, TableErasedEvent { amount: world.table.registry.change_tick });
    return world;
}

fn table_erased_rel_schedule_relate_first_two_system(world: TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> {
    if len(world.table.archetypes[0].entity_ids) <= 0 { return world; };
    let root_id = world.table.archetypes[0].entity_ids[0];
    let root = entity_new(root_id, world.table.registry.entities.generations[root_id]);
    let q = table_erased_world_query_pair<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(world.table, table_erased_world_component_id_for_type<TableErasedTime, TableErasedEvent>(world.table, TABLE_ERASED_POS_TYPE), TABLE_ERASED_POS_TYPE, table_erased_world_component_id_for_type<TableErasedTime, TableErasedEvent>(world.table, TABLE_ERASED_VEL_TYPE), TABLE_ERASED_VEL_TYPE);
    if len(q.items) > 0 { world.relationships = relationship_world_set_related(world.relationships, 1, q.items[0].entity, root); };
    return world;
}

@test "table erased relationship schedule runs systems in order"() {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, position) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let (w2, velocity) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, table_erased_vel_drop);
    let (w3, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w2, true, false);
    let (w4, root) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let (w5, child) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let w6 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, child, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 4, y: 0 });
    let w7 = table_erased_relationship_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w6, child, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 6, y: 0 });
    let w8 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w7, kind.id, child, root);
    let move_access = table_erased_relationship_access_read_component(table_erased_relationship_access_write_component(table_erased_relationship_system_access_none(), position.id), velocity.id);
    let relationship_access = table_erased_relationship_access_write_resource(table_erased_relationship_access_read_relationship(table_erased_relationship_system_access_none(), kind.id));
    let message_access = table_erased_relationship_access_write_messages(table_erased_relationship_system_access_none());
    let s0 = table_erased_relationship_schedule_default<TableErasedTime, TableErasedEvent>();
    let s1 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s0, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_rel_schedule_move_system, move_access));
    let s2 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s1, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_rel_schedule_relationship_count_system, relationship_access));
    let s3 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s2, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_rel_schedule_message_system, message_access));
    let w9 = table_erased_relationship_schedule_run<TableErasedTime, TableErasedEvent>(s3, w8);
    if table_erased_relationship_schedule_batch_count<TableErasedTime, TableErasedEvent>(s3) != 1 { panic(12400); };
    if table_erased_relationship_schedule_max_parallel_width<TableErasedTime, TableErasedEvent>(s3) != 3 { panic(12401); };
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, child, position.id, TABLE_ERASED_POS_TYPE).x != 10 { panic(12402); };
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(w9.table).tick != 1 { panic(12403); };
    let event = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w9.table, message_reader_new(), table_erased_event_default());
    if event.value.amount != 2 { panic(12404); };
}

@test "table erased relationship schedule records relationship conflicts"() {
    let read_rel = table_erased_relationship_access_read_relationship(table_erased_relationship_system_access_none(), 1);
    let write_rel = table_erased_relationship_access_write_relationship(table_erased_relationship_system_access_none(), 1);
    let write_messages = table_erased_relationship_access_write_messages(table_erased_relationship_system_access_none());
    let s0 = table_erased_relationship_schedule_default<TableErasedTime, TableErasedEvent>();
    let s1 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s0, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_rel_schedule_relationship_count_system, read_rel));
    let s2 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s1, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_rel_schedule_relate_first_two_system, write_rel));
    let s3 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s2, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_rel_schedule_message_system, write_messages));
    if table_erased_relationship_schedule_conflict_count<TableErasedTime, TableErasedEvent>(s3) != 1 { panic(12410); };
    if table_erased_relationship_schedule_batch_count<TableErasedTime, TableErasedEvent>(s3) != 2 { panic(12411); };
    if table_erased_relationship_schedule_system_batch<TableErasedTime, TableErasedEvent>(s3, 0) != 0 { panic(12412); };
    if table_erased_relationship_schedule_system_batch<TableErasedTime, TableErasedEvent>(s3, 1) != 1 { panic(12413); };
    if table_erased_relationship_schedule_system_batch<TableErasedTime, TableErasedEvent>(s3, 2) != 0 { panic(12414); };
    if table_erased_relationship_schedule_batch_width<TableErasedTime, TableErasedEvent>(s3, 0) != 2 { panic(12415); };
    if table_erased_relationship_schedule_max_parallel_width<TableErasedTime, TableErasedEvent>(s3) != 2 { panic(12416); };
}

@test "table erased relationship planned schedule and type access declarations"() {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, position) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let (w2, velocity) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, table_erased_vel_drop);
    let (w3, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w2, true, false);
    let (w4, root) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let (w5, child) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let w6 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, child, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 1, y: 0 });
    let w7 = table_erased_relationship_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w6, child, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 2, y: 0 });
    let move_access = table_erased_relationship_access_read_type<TableErasedTime, TableErasedEvent>(w7, table_erased_relationship_access_write_type<TableErasedTime, TableErasedEvent>(w7, table_erased_relationship_system_access_none(), TABLE_ERASED_POS_TYPE), TABLE_ERASED_VEL_TYPE);
    let relate_access = table_erased_relationship_access_write_relationship(table_erased_relationship_system_access_none(), kind.id);
    let s0 = table_erased_relationship_schedule_default<TableErasedTime, TableErasedEvent>();
    let s1 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s0, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_rel_schedule_move_system, move_access));
    let s2 = table_erased_relationship_schedule_add_systems<TableErasedTime, TableErasedEvent>(s1, table_erased_relationship_system_new<TableErasedTime, TableErasedEvent>(table_erased_rel_schedule_relate_first_two_system, relate_access));
    let w8 = table_erased_relationship_schedule_run_planned<TableErasedTime, TableErasedEvent>(s2, w7);
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w8, child, position.id, TABLE_ERASED_POS_TYPE).x != 3 { panic(12420); };
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w8, kind.id, root) != 1 { panic(12421); };
    if table_erased_world_component_id_for_type<TableErasedTime, TableErasedEvent>(w8.table, TABLE_ERASED_POS_TYPE) != position.id { panic(12422); };
    if table_erased_world_component_id_for_type<TableErasedTime, TableErasedEvent>(w8.table, TABLE_ERASED_VEL_TYPE) != velocity.id { panic(12423); };
}
