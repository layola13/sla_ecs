@test "component registry defaults to table and supports sparse opt in"():
L_TEST_ENTRY_3561:
    tmp_13201 = call @sla__component_registry_new()
    reg0 = tmp_13201
    tmp_13202 = call @sla__component_register_table(reg0)
    reg1 = load tmp_13202+0 as ptr
