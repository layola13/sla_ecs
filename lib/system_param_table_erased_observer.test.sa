    !tmp_5723
    tmp_5724 = load table_info+0 as i32
    tmp_5725 = 1
    tmp_5726 = ne tmp_5724, tmp_5725
    !tmp_5724
    !tmp_5725
    br tmp_5726 -> L_THEN_1419, L_ELSE_1420

L_THEN_1419:
    !tmp_5726
    panic(4310)

L_ELSE_1420:
    !tmp_5726
    jmp L_MERGE_1421

L_MERGE_1421:
    tmp_5729 = load sparse_info+0 as i32
    tmp_5730 = 2
    tmp_5731 = ne tmp_5729, tmp_5730
    !tmp_5729
    !tmp_5730
    br tmp_5731 -> L_THEN_1422, L_ELSE_1423

L_THEN_1422:
