@test "registry entity query supports for in"():
L_TEST_ENTRY_1705:
    entity_slot = stack_alloc 8
    tmp_6717 = call @sla__registry_world_new()
    w0 = tmp_6717
    tmp_6718 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_6718+0 as ptr
    component = load tmp_6718+8 as ptr
    !tmp_6718
    tmp_6719 = call @sla__registry_world_spawn(w1)
    w2 = load tmp_6719+0 as ptr
    e1 = load tmp_6719+8 as ptr
    !tmp_6719
    tmp_6720 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_6720+0 as ptr
    e2 = load tmp_6720+8 as ptr
    !tmp_6720
    tmp_6721 = load component+0 as i32
    tmp_6722 = call @sla__registry_world_insert_component(w3, e1, tmp_6721)
    !tmp_6721
    w4 = tmp_6722
    tmp_6723 = load component+0 as i32
    tmp_6724 = call @sla__registry_world_insert_component(w4, e2, tmp_6723)
    !tmp_6723
    w5 = tmp_6724
    tmp_6725 = load component+0 as i32
    tmp_6726 = call @sla__registry_world_query_component(w5, tmp_6725)
    !tmp_6725
    q = tmp_6726
    tmp_6727 = 0
    total = tmp_6727
    tmp_6728 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1706

L_LOOP_HEAD_1706:
    tmp_6729 = load entity_slot+0 as i64
    tmp_6730 = slt tmp_6729, tmp_6728
    br tmp_6730 -> L_LOOP_BODY_1707, L_LOOP_COND_FALSE_1709

L_LOOP_BODY_1707:
    !tmp_6730
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_6729)
    tmp_6731 = load entity+0 as i32
    tmp_6732 = add total, tmp_6731
    !tmp_6731
    !total
    total = tmp_6732
L_LOOP_CONTINUE_1708:
    tmp_6733 = add tmp_6729, 1
    store entity_slot+0, tmp_6733 as i64
    !tmp_6733
    !tmp_6729
    !entity
    jmp L_LOOP_HEAD_1706

L_LOOP_COND_FALSE_1709:
    !tmp_6730
    !tmp_6729
    jmp L_LOOP_EXIT_1710

L_LOOP_EXIT_1710:
    !tmp_6728
    tmp_6734 = load e1+0 as i32
    tmp_6735 = load e2+0 as i32
    tmp_6736 = add tmp_6734, tmp_6735
    !tmp_6734
    !tmp_6735
    tmp_6737 = ne total, tmp_6736
    !tmp_6736
    br tmp_6737 -> L_THEN_1711, L_ELSE_1712

L_THEN_1711:
    !tmp_6737
    panic(8730)

L_ELSE_1712:
    !tmp_6737
    jmp L_MERGE_1713

L_MERGE_1713:
    !component
    !w0
    !e2
    !w4
    !total
    !w5
    !e1
    !w1
    !w2
    !w3
    !q
    return

