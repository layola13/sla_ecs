@test "allocator rejects stale generation"():
L_TEST_ENTRY_1448:
    tmp_5782 = call @sla__allocator_new()
    a0 = tmp_5782
    tmp_5783 = call @sla__alloc_entity(a0)
    a1 = load tmp_5783+0 as ptr
    e1 = load tmp_5783+8 as ptr
    !tmp_5783
    tmp_5784 = call @sla__free_entity(a1, e1)
    a2 = tmp_5784
    tmp_5785 = load e1+0 as i32
    tmp_5786 = load e1+4 as i32
    tmp_5787 = call @sla__entity_new(tmp_5785, tmp_5786)
    !tmp_5785
    !tmp_5786
    stale = tmp_5787
    tmp_5788 = load e1+0 as i32
    tmp_5789 = load e1+4 as i32
    tmp_5790 = 1
    tmp_5791 = add tmp_5789, tmp_5790
    !tmp_5789
    !tmp_5790
    tmp_5792 = call @sla__entity_new(tmp_5788, tmp_5791)
    !tmp_5788
    !tmp_5791
    fabricated = tmp_5792
    tmp_5793 = call @sla__is_alive(a2, stale)
    tmp_5794 = 0
    tmp_5795 = ne tmp_5793, tmp_5794
    !tmp_5793
    !tmp_5794
    br tmp_5795 -> L_THEN_1449, L_ELSE_1450

L_THEN_1449:
