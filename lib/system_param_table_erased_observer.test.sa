L_ELSE_1456:
    !tmp_5806
    jmp L_MERGE_1457

L_MERGE_1457:
    tmp_5809 = call @sla__is_alive(a3, e2)
    tmp_5810 = 1
    tmp_5811 = ne tmp_5809, tmp_5810
    !tmp_5809
    !tmp_5810
    br tmp_5811 -> L_THEN_1458, L_ELSE_1459

L_THEN_1458:
    !tmp_5811
    panic(2123)

L_ELSE_1459:
    !tmp_5811
    jmp L_MERGE_1460

L_MERGE_1460:
