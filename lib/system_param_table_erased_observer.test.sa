    tmp_5735 = call @sla__storage_kind_is_table(^tmp_5734)
    tmp_5736 = 1
    tmp_5737 = ne tmp_5735, tmp_5736
    !tmp_5735
    !tmp_5736
    br tmp_5737 -> L_THEN_1425, L_ELSE_1426

L_THEN_1425:
    !tmp_5737
    panic(4312)

L_ELSE_1426:
    !tmp_5737
    jmp L_MERGE_1427

L_MERGE_1427:
    tmp_5740 = load sparse_info+8 as ptr
    tmp_5741 = call @sla__storage_kind_is_sparse_set(^tmp_5740)
