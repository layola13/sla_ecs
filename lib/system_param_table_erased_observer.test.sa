    a3 = load tmp_5803+0 as ptr
    e2 = load tmp_5803+8 as ptr
    !tmp_5803
    tmp_5804 = call @sla__entity_eq(e2, fabricated)
    tmp_5805 = 1
    tmp_5806 = ne tmp_5804, tmp_5805
    !tmp_5804
    !tmp_5805
