@test "component registry defaults to table and supports sparse opt in"():
L_TEST_ENTRY_1418:
    tmp_5721 = call @sla__component_registry_new()
    reg0 = tmp_5721
    tmp_5722 = call @sla__component_register_table(reg0)
    reg1 = load tmp_5722+0 as ptr
