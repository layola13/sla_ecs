@test "dynamic allocator rejects fabricated next generation before reuse"():
L_TEST_ENTRY_1642:
    tmp_6552 = call @sla__dyn_allocator_new()
    a0 = tmp_6552
    tmp_6553 = call @sla__dyn_alloc_entity(a0)
    a1 = load tmp_6553+0 as ptr
    e1 = load tmp_6553+8 as ptr
    !tmp_6553
    tmp_6554 = call @sla__dyn_free_entity(a1, e1)
    a2 = tmp_6554
    tmp_6555 = load e1+0 as i32
    tmp_6556 = load e1+4 as i32
    tmp_6557 = 1
    tmp_6558 = add tmp_6556, tmp_6557
    !tmp_6556
    !tmp_6557
    tmp_6559 = call @sla__entity_new(tmp_6555, tmp_6558)
    !tmp_6555
    !tmp_6558
    fake = tmp_6559
    tmp_6560 = call @sla__dyn_is_alive(a2, e1)
    tmp_6561 = 0
    tmp_6562 = ne tmp_6560, tmp_6561
    !tmp_6560
    !tmp_6561
    br tmp_6562 -> L_THEN_1643, L_ELSE_1644

L_THEN_1643:
    !tmp_6562
    panic(2160)

L_ELSE_1644:
    !tmp_6562
    jmp L_MERGE_1645

L_MERGE_1645:
    tmp_6565 = call @sla__dyn_is_alive(a2, fake)
    tmp_6566 = 0
    tmp_6567 = ne tmp_6565, tmp_6566
    !tmp_6565
    !tmp_6566
    br tmp_6567 -> L_THEN_1646, L_ELSE_1647

L_THEN_1646:
    !tmp_6567
    panic(2161)

L_ELSE_1647:
    !tmp_6567
    jmp L_MERGE_1648

L_MERGE_1648:
    tmp_6570 = call @sla__dyn_alloc_entity(a2)
    a3 = load tmp_6570+0 as ptr
    e2 = load tmp_6570+8 as ptr
    !tmp_6570
    tmp_6571 = call @sla__entity_eq(e2, fake)
    tmp_6572 = 1
    tmp_6573 = ne tmp_6571, tmp_6572
    !tmp_6571
    !tmp_6572
    br tmp_6573 -> L_THEN_1649, L_ELSE_1650

L_THEN_1649:
    !tmp_6573
    panic(2162)

L_ELSE_1650:
    !tmp_6573
    jmp L_MERGE_1651

L_MERGE_1651:
    tmp_6576 = call @sla__dyn_is_alive(a3, e2)
    tmp_6577 = 1
    tmp_6578 = ne tmp_6576, tmp_6577
    !tmp_6576
    !tmp_6577
    br tmp_6578 -> L_THEN_1652, L_ELSE_1653

L_THEN_1652:
    !tmp_6578
    panic(2163)

L_ELSE_1653:
    !tmp_6578
    jmp L_MERGE_1654

L_MERGE_1654:
    !e2
    !a0
    !fake
    !a2
    !e1
    !a3
    !a1
    return

