    !tmp_5746
    again = tmp_5747
    tmp_5748 = load again+0 as i32
    tmp_5749 = load sparse_info+0 as i32
    tmp_5750 = ne tmp_5748, tmp_5749
    !tmp_5748
    !tmp_5749
