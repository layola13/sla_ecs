@test "resource replace overwrites value"():
L_TEST_ENTRY_1731:
    tmp_6774 = call @sla__test_time_slot_new()
    r0 = tmp_6774
    tmp_6775 = alloc 4
    tmp_6776 = 1
    store tmp_6775+0, tmp_6776 as i32
    !tmp_6776
    tmp_6777 = call @sla__resource_insert_TestTime(r0, tmp_6775)
    !tmp_6775
    r1 = tmp_6777
    tmp_6778 = alloc 4
    tmp_6779 = 2
    store tmp_6778+0, tmp_6779 as i32
    !tmp_6779
    tmp_6780 = call @sla__resource_insert_TestTime(r1, tmp_6778)
    !tmp_6778
    r2 = tmp_6780
    tmp_6781 = call @sla__resource_get_TestTime(r2)
    t = tmp_6781
    tmp_6782 = load t+0 as i32
    tmp_6783 = 2
    tmp_6784 = ne tmp_6782, tmp_6783
    !tmp_6782
    !tmp_6783
    br tmp_6784 -> L_THEN_1732, L_ELSE_1733

