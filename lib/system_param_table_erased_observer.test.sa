@test "erased observers trigger matching event immediately"():
L_TEST_ENTRY_2370:
    tmp_9086 = call @sla__ErasedSpeakEvent_event_type_id()
    speak_type = tmp_9086
    tmp_9087 = call @sla__ErasedExplodeEvent_event_type_id()
    explode_type = tmp_9087
    tmp_9088 = 0
    tmp_9089 = sle speak_type, tmp_9088
    !tmp_9088
    br tmp_9089 -> L_THEN_2371, L_ELSE_2372

L_THEN_2371:
    !tmp_9089
    panic(12910)

L_ELSE_2372:
    !tmp_9089
    jmp L_MERGE_2373

L_MERGE_2373:
    tmp_9092 = 0
    tmp_9093 = sle explode_type, tmp_9092
    !tmp_9092
    br tmp_9093 -> L_THEN_2374, L_ELSE_2375

