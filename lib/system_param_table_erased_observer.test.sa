L_ELSE_1450:
    !tmp_5795
    jmp L_MERGE_1451

L_MERGE_1451:
    tmp_5798 = call @sla__is_alive(a2, fabricated)
    tmp_5799 = 0
    tmp_5800 = ne tmp_5798, tmp_5799
    !tmp_5798
    !tmp_5799
