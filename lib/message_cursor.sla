// Bevy ECS message::message_cursor (src/message/message_cursor.rs): MessageCursor.
// Tracks the read position into a Messages buffer.

struct EcsMessageCursor {
    last_read_index: i64,   // index of the last-read message
    message_count: i64,     // total messages in the buffer
    missed: i64,            // missed messages (overwritten before read)
}

fn ecs_message_cursor_new() -> EcsMessageCursor {
    return EcsMessageCursor { last_read_index: 0, message_count: 0, missed: 0 };
}

fn ecs_message_cursor_set_message_count(c: EcsMessageCursor, count: i64) -> EcsMessageCursor {
    c.message_count = count;
    return c;
}

// read: advance the cursor, returns (has_unread, index)
fn ecs_message_cursor_read(c: EcsMessageCursor) -> (EcsMessageCursor, bool, i64) {
    if c.last_read_index >= c.message_count {
        return (c, false, 0);
    };
    let idx = c.last_read_index;
    c.last_read_index = idx + 1;
    return (c, true, idx);
}

// len: number of unread messages
fn ecs_message_cursor_len(c: EcsMessageCursor) -> i64 {
    let unread = c.message_count - c.last_read_index;
    if unread < 0 { return 0; };
    return unread;
}

fn ecs_message_cursor_is_empty(c: EcsMessageCursor) -> bool { return ecs_message_cursor_len(c) == 0; }

// missed_messages: messages that were overwritten before being read
fn ecs_message_cursor_missed_messages(c: EcsMessageCursor) -> i64 { return c.missed; }

fn ecs_message_cursor_set_missed(c: EcsMessageCursor, missed: i64) -> EcsMessageCursor {
    c.missed = missed;
    return c;
}

// clear: reset the cursor to the current message count (mark all as read)
fn ecs_message_cursor_clear(c: EcsMessageCursor) -> EcsMessageCursor {
    c.last_read_index = c.message_count;
    return c;
}

// read_with_id: returns (has_unread, index, message_id). message_id modeled as index.
fn ecs_message_cursor_read_with_id(c: EcsMessageCursor) -> (EcsMessageCursor, bool, i64, i64) {
    let r = ecs_message_cursor_read(c);
    return (r.0, r.1, r.2, r.2);
}

// par_read: modeled as returning the unread count (parallel iteration marker)
fn ecs_message_cursor_par_read_len(c: EcsMessageCursor) -> i64 { return ecs_message_cursor_len(c); }
