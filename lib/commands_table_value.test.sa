    tmp_3607 = call @sla__registry_world_query_component(w5, tmp_3606)
    !tmp_3606
    q = tmp_3607
    tmp_3608 = 0
    total = tmp_3608
    tmp_3609 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_997

L_LOOP_HEAD_997:
    tmp_3610 = load entity_slot+0 as i64
    tmp_3611 = slt tmp_3610, tmp_3609
    br tmp_3611 -> L_LOOP_BODY_998, L_LOOP_COND_FALSE_1000

L_LOOP_BODY_998:
    !tmp_3611
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_3610)
    tmp_3612 = load entity+0 as i32
    tmp_3613 = add total, tmp_3612
    !tmp_3612
    !total
    total = tmp_3613
L_LOOP_CONTINUE_999:
    tmp_3614 = add tmp_3610, 1
    store entity_slot+0, tmp_3614 as i64
    !tmp_3614
    !tmp_3610
    !entity
    jmp L_LOOP_HEAD_997

L_LOOP_COND_FALSE_1000:
    !tmp_3611
    !tmp_3610
    jmp L_LOOP_EXIT_1001

L_LOOP_EXIT_1001:
    !tmp_3609
    tmp_3615 = load e1+0 as i32
    tmp_3616 = load e2+0 as i32
    tmp_3617 = add tmp_3615, tmp_3616
    !tmp_3615
    !tmp_3616
    tmp_3618 = ne total, tmp_3617
    !tmp_3617
    br tmp_3618 -> L_THEN_1002, L_ELSE_1003

L_THEN_1002:
    !tmp_3618
    panic(8730)

L_ELSE_1003:
