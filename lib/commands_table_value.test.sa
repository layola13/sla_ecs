    w2 = load tmp_3600+0 as ptr
    e1 = load tmp_3600+8 as ptr
    !tmp_3600
    tmp_3601 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_3601+0 as ptr
    e2 = load tmp_3601+8 as ptr
    !tmp_3601
    tmp_3602 = load component+0 as i32
    tmp_3603 = call @sla__registry_world_insert_component(w3, e1, tmp_3602)
    !tmp_3602
    w4 = tmp_3603
    tmp_3604 = load component+0 as i32
    tmp_3605 = call @sla__registry_world_insert_component(w4, e2, tmp_3604)
    !tmp_3604
    w5 = tmp_3605
