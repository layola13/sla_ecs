L_LOOP_HEAD_1225:
    tmp_4401 = load entity_slot+0 as i64
    tmp_4402 = slt tmp_4401, tmp_4400
    br tmp_4402 -> L_LOOP_BODY_1226, L_LOOP_COND_FALSE_1228

