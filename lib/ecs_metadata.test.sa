@test "component registry defaults to table and supports sparse opt in"():
L_TEST_ENTRY_2026:
    tmp_7467 = call @sla__component_registry_new()
    reg0 = tmp_7467
    tmp_7468 = call @sla__component_register_table(reg0)
    reg1 = load tmp_7468+0 as ptr
