@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_message_reader_new = vtable { call = @sla__message_reader_new }
@const SLA_FNPTR_VT_test_damage_messages_new = vtable { call = @sla__test_damage_messages_new }
@const SLA_FNPTR_VT_test_damage_default = vtable { call = @sla__test_damage_default }
@const SLA_FNPTR_VT_messages_new_TestDamageMessage = vtable { call = @sla__messages_new_TestDamageMessage }
@const SLA_FNPTR_VT_messages_write_TestDamageMessage = vtable { call = @sla__messages_write_TestDamageMessage }
@const SLA_FNPTR_VT_messages_read_next_TestDamageMessage = vtable { call = @sla__messages_read_next_TestDamageMessage }
@sla__message_reader_new() -> ptr:
L_ENTRY:
    tmp_0 = alloc 8
    tmp_1 = 0
    store tmp_0+0, tmp_1 as i64
    !tmp_1
    return tmp_0

@sla__test_damage_messages_new() -> ptr:
L_ENTRY:
    tmp_2 = alloc 4
    tmp_3 = 0
    store tmp_2+0, tmp_3 as i32
    !tmp_3
    tmp_4 = call @sla__messages_new_TestDamageMessage(tmp_2)
    !tmp_2
    return tmp_4

@sla__test_damage_default() -> ptr:
L_ENTRY:
    tmp_5 = alloc 4
    tmp_6 = 0
    store tmp_5+0, tmp_6 as i32
    !tmp_6
    return tmp_5

@sla__messages_new_TestDamageMessage(default_value: ptr) -> ptr:
L_ENTRY:
    tmp_7 = alloc 16
    tmp_8 = 0
    store tmp_7+0, tmp_8 as i64
    !tmp_8
    tmp_9 = alloc 128
    store tmp_9+0, default_value as ptr
    store tmp_9+8, default_value as ptr
    store tmp_9+16, default_value as ptr
    store tmp_9+24, default_value as ptr
    store tmp_9+32, default_value as ptr
    store tmp_9+40, default_value as ptr
    store tmp_9+48, default_value as ptr
    store tmp_9+56, default_value as ptr
    store tmp_9+64, default_value as ptr
    store tmp_9+72, default_value as ptr
    store tmp_9+80, default_value as ptr
    store tmp_9+88, default_value as ptr
    store tmp_9+96, default_value as ptr
    store tmp_9+104, default_value as ptr
    store tmp_9+112, default_value as ptr
    store tmp_9+120, default_value as ptr
    store tmp_7+8, tmp_9 as ptr
    !tmp_9
    return tmp_7

@sla__messages_write_TestDamageMessage(messages: ptr, value: ptr) -> ptr:
L_ENTRY:
    tmp_10 = load messages+0 as i64
    slot = tmp_10
    tmp_11 = 16
    tmp_12 = sge slot, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_12
    panic(6001)

L_ELSE_1:
    !tmp_12
    jmp L_MERGE_2

L_MERGE_2:
    tmp_15 = load messages+8 as ptr
    tmp_16 = mul slot, 8
    tmp_17 = ptr_add tmp_15, tmp_16
    !tmp_16
    store tmp_17+0, value as ptr
    !tmp_17
    !tmp_15
    !value
    tmp_18 = 1
    tmp_19 = add slot, tmp_18
    !tmp_18
    store messages+0, tmp_19 as i64
    !tmp_19
    !slot
    return messages

@sla__messages_read_next_TestDamageMessage(messages: ptr, reader: ptr, default_value: ptr) -> ptr:
L_ENTRY:
    tmp_20 = load reader+0 as i64
    tmp_21 = load messages+0 as i64
    tmp_22 = sge tmp_20, tmp_21
    !tmp_20
    !tmp_21
    br tmp_22 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_22
    tmp_23 = alloc 24
    tmp_24 = 0
    store tmp_23+0, tmp_24 as u8
    !tmp_24
    store tmp_23+8, default_value as ptr
    store tmp_23+16, reader as ptr
    !messages
    return tmp_23

L_ELSE_4:
    !tmp_22
    jmp L_MERGE_5

L_MERGE_5:
    tmp_26 = load messages+8 as ptr
    tmp_27 = load reader+0 as i64
    tmp_28 = mul tmp_27, 8
    tmp_29 = ptr_add tmp_26, tmp_28
    !tmp_28
    !tmp_27
    tmp_30 = load tmp_29+0 as ptr
    !tmp_29
    !tmp_26
    value = tmp_30
    tmp_31 = load reader+0 as i64
    tmp_32 = 1
    tmp_33 = add tmp_31, tmp_32
    !tmp_31
    !tmp_32
    store reader+0, tmp_33 as i64
    !tmp_33
    tmp_34 = alloc 24
    tmp_35 = 1
    store tmp_34+0, tmp_35 as u8
    !tmp_35
    store tmp_34+8, value as ptr
    store tmp_34+16, reader as ptr
    !messages
    !default_value
    return tmp_34

@test "messages generic constructor"():
L_TEST_ENTRY_6:
    tmp_36 = call @sla__test_damage_default()
    tmp_37 = call @sla__messages_new_TestDamageMessage(tmp_36)
    !tmp_36
    m = tmp_37
    tmp_38 = load m+0 as i64
    tmp_39 = 0
    tmp_40 = ne tmp_38, tmp_39
    !tmp_38
    !tmp_39
    br tmp_40 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_40
    panic(2390)

L_ELSE_8:
    !tmp_40
    jmp L_MERGE_9

L_MERGE_9:
    !m
    return

@test "messages writer appends"():
L_TEST_ENTRY_10:
    tmp_43 = call @sla__test_damage_messages_new()
    m0 = tmp_43
    tmp_44 = alloc 4
    tmp_45 = 5
    store tmp_44+0, tmp_45 as i32
    !tmp_45
    tmp_46 = call @sla__messages_write_TestDamageMessage(m0, tmp_44)
    !tmp_44
    m1 = tmp_46
    tmp_47 = alloc 4
    tmp_48 = 7
    store tmp_47+0, tmp_48 as i32
    !tmp_48
    tmp_49 = call @sla__messages_write_TestDamageMessage(m1, tmp_47)
    !tmp_47
    m2 = tmp_49
    tmp_50 = load m2+0 as i64
    tmp_51 = 2
    tmp_52 = ne tmp_50, tmp_51
    !tmp_50
    !tmp_51
    br tmp_52 -> L_THEN_11, L_ELSE_12

L_THEN_11:
    !tmp_52
    panic(2400)

L_ELSE_12:
    !tmp_52
    jmp L_MERGE_13

L_MERGE_13:
    !m2
    !m0
    !m1
    return

@test "message reader cursor advances independently"():
L_TEST_ENTRY_14:
    tmp_55 = call @sla__test_damage_messages_new()
    m0 = tmp_55
    tmp_56 = alloc 4
    tmp_57 = 5
    store tmp_56+0, tmp_57 as i32
    !tmp_57
    tmp_58 = call @sla__messages_write_TestDamageMessage(m0, tmp_56)
    !tmp_56
    m1 = tmp_58
    tmp_59 = alloc 4
    tmp_60 = 7
    store tmp_59+0, tmp_60 as i32
    !tmp_60
    tmp_61 = call @sla__messages_write_TestDamageMessage(m1, tmp_59)
    !tmp_59
    m2 = tmp_61
    tmp_62 = call @sla__message_reader_new()
    r0 = tmp_62
    tmp_63 = call @sla__message_reader_new()
    r_other = tmp_63
    tmp_64 = call @sla__test_damage_default()
    tmp_65 = call @sla__messages_read_next_TestDamageMessage(m2, r0, tmp_64)
    !tmp_64
    read1 = tmp_65
    tmp_66 = load read1+0 as u8
    tmp_67 = 1
    tmp_68 = ne tmp_66, tmp_67
    !tmp_66
    !tmp_67
    br tmp_68 -> L_THEN_15, L_ELSE_16

L_THEN_15:
    !tmp_68
    panic(2410)

L_ELSE_16:
    !tmp_68
    jmp L_MERGE_17

L_MERGE_17:
    tmp_71 = load read1+8 as ptr
    tmp_72 = load tmp_71+0 as i32
    !tmp_71
    tmp_73 = 5
    tmp_74 = ne tmp_72, tmp_73
    !tmp_72
    !tmp_73
    br tmp_74 -> L_THEN_18, L_ELSE_19

L_THEN_18:
    !tmp_74
    panic(2411)

L_ELSE_19:
    !tmp_74
    jmp L_MERGE_20

L_MERGE_20:
    tmp_77 = load read1+16 as ptr
    tmp_78 = call @sla__test_damage_default()
    tmp_79 = call @sla__messages_read_next_TestDamageMessage(m2, tmp_77, tmp_78)
    !tmp_77
    !tmp_78
    read2 = tmp_79
    tmp_80 = load read2+0 as u8
    tmp_81 = 1
    tmp_82 = ne tmp_80, tmp_81
    !tmp_80
    !tmp_81
    br tmp_82 -> L_THEN_21, L_ELSE_22

L_THEN_21:
    !tmp_82
    panic(2412)

L_ELSE_22:
    !tmp_82
    jmp L_MERGE_23

L_MERGE_23:
    tmp_85 = load read2+8 as ptr
    tmp_86 = load tmp_85+0 as i32
    !tmp_85
    tmp_87 = 7
    tmp_88 = ne tmp_86, tmp_87
    !tmp_86
    !tmp_87
    br tmp_88 -> L_THEN_24, L_ELSE_25

L_THEN_24:
    !tmp_88
    panic(2413)

L_ELSE_25:
    !tmp_88
    jmp L_MERGE_26

L_MERGE_26:
    tmp_91 = load read2+16 as ptr
    tmp_92 = call @sla__test_damage_default()
    tmp_93 = call @sla__messages_read_next_TestDamageMessage(m2, tmp_91, tmp_92)
    !tmp_91
    !tmp_92
    read3 = tmp_93
    tmp_94 = load read3+0 as u8
    tmp_95 = 0
    tmp_96 = ne tmp_94, tmp_95
    !tmp_94
    !tmp_95
    br tmp_96 -> L_THEN_27, L_ELSE_28

L_THEN_27:
    !tmp_96
    panic(2414)

L_ELSE_28:
    !tmp_96
    jmp L_MERGE_29

L_MERGE_29:
    tmp_99 = call @sla__test_damage_default()
    tmp_100 = call @sla__messages_read_next_TestDamageMessage(m2, r_other, tmp_99)
    !tmp_99
    other = tmp_100
    tmp_101 = load other+8 as ptr
    tmp_102 = load tmp_101+0 as i32
    !tmp_101
    tmp_103 = 5
    tmp_104 = ne tmp_102, tmp_103
    !tmp_102
    !tmp_103
    br tmp_104 -> L_THEN_30, L_ELSE_31

L_THEN_30:
    !tmp_104
    panic(2415)

L_ELSE_31:
    !tmp_104
    jmp L_MERGE_32

L_MERGE_32:
    !m2
    !m0
    !read1
    !r_other
    !other
    !read3
    !m1
    !read2
    !r0
    return

