@import "sa_std/vec.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/vec.sa"
@const SLA_FNPTR_VT_message_reader_new = vtable { call = @sla__message_reader_new }
@const SLA_FNPTR_VT_test_damage_messages_new = vtable { call = @sla__test_damage_messages_new }
@const SLA_FNPTR_VT_test_damage_default = vtable { call = @sla__test_damage_default }
@const SLA_FNPTR_VT_messages_new_TestDamageMessage = vtable { call = @sla__messages_new_TestDamageMessage }
@const SLA_FNPTR_VT_messages_write_TestDamageMessage = vtable { call = @sla__messages_write_TestDamageMessage }
@const SLA_FNPTR_VT_message_writer_new_TestDamageMessage = vtable { call = @sla__message_writer_new_TestDamageMessage }
@const SLA_FNPTR_VT_message_writer_send_TestDamageMessage = vtable { call = @sla__message_writer_send_TestDamageMessage }
@const SLA_FNPTR_VT_messages_apply_writer_TestDamageMessage = vtable { call = @sla__messages_apply_writer_TestDamageMessage }
@const SLA_FNPTR_VT_messages_read_next_TestDamageMessage = vtable { call = @sla__messages_read_next_TestDamageMessage }
@sla__message_reader_new() -> ptr:
L_ENTRY:
    tmp_0 = alloc 8
    tmp_1 = 0
    store tmp_0+0, tmp_1 as i64
    !tmp_1
    return tmp_0

@sla__test_damage_messages_new() -> ptr:
L_ENTRY:
    tmp_2 = alloc 4
    tmp_3 = 0
    store tmp_2+0, tmp_3 as i32
    !tmp_3
    tmp_4 = call @sla__messages_new_TestDamageMessage(tmp_2)
    !tmp_2
    return tmp_4

@sla__test_damage_default() -> ptr:
L_ENTRY:
    tmp_5 = alloc 4
    tmp_6 = 0
    store tmp_5+0, tmp_6 as i32
    !tmp_6
    return tmp_5

@sla__messages_new_TestDamageMessage(default_value: ptr) -> ptr:
L_ENTRY:
    tmp_7 = alloc 16
    tmp_8 = 0
    store tmp_7+0, tmp_8 as i64
    !tmp_8
    tmp_9 = alloc 128
    store tmp_9+0, default_value as ptr
    store tmp_9+8, default_value as ptr
    store tmp_9+16, default_value as ptr
    store tmp_9+24, default_value as ptr
    store tmp_9+32, default_value as ptr
    store tmp_9+40, default_value as ptr
    store tmp_9+48, default_value as ptr
    store tmp_9+56, default_value as ptr
    store tmp_9+64, default_value as ptr
    store tmp_9+72, default_value as ptr
    store tmp_9+80, default_value as ptr
    store tmp_9+88, default_value as ptr
    store tmp_9+96, default_value as ptr
    store tmp_9+104, default_value as ptr
    store tmp_9+112, default_value as ptr
    store tmp_9+120, default_value as ptr
    store tmp_7+8, tmp_9 as ptr
    !tmp_9
    return tmp_7

@sla__messages_write_TestDamageMessage(messages: ptr, value: ptr) -> ptr:
L_ENTRY:
    tmp_10 = load messages+0 as i64
    slot = tmp_10
    tmp_11 = 16
    tmp_12 = sge slot, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_12
    panic(6001)

L_ELSE_1:
    !tmp_12
    jmp L_MERGE_2

L_MERGE_2:
    tmp_15 = load messages+8 as ptr
    tmp_16 = mul slot, 8
    tmp_17 = ptr_add tmp_15, tmp_16
    !tmp_16
    store tmp_17+0, value as ptr
    !tmp_17
    !tmp_15
    !value
    tmp_18 = 1
    tmp_19 = add slot, tmp_18
    !tmp_18
    store messages+0, tmp_19 as i64
    !tmp_19
    !slot
    return messages

@sla__message_writer_new_TestDamageMessage() -> ptr:
L_ENTRY:
    EXPAND VEC_NEW tmp_20
    values = tmp_20
    tmp_21 = alloc 8
    store tmp_21+0, values as ptr
    return tmp_21

@sla__message_writer_send_TestDamageMessage(writer: ptr, value: ptr) -> ptr:
L_ENTRY:
    tmp_22 = load writer+0 as ptr
    EXPAND VEC_PUSH tmp_22, value, 8
    !tmp_22
    !value
    return writer

@sla__messages_apply_writer_TestDamageMessage(messages: ptr, writer: ptr) -> ptr:
L_ENTRY:
    tmp_23 = 0
    i = tmp_23
    tmp_24 = load writer+0 as ptr
    EXPAND VEC_LEN tmp_25, tmp_24
    !tmp_24
    tmp_26 = tmp_25 as i64
    cnt = tmp_26
    jmp L_WHILE_HEAD_3

L_WHILE_HEAD_3:
    tmp_27 = slt i, cnt
    br tmp_27 -> L_WHILE_BODY_4, L_WHILE_COND_FALSE_5

L_WHILE_BODY_4:
    !tmp_27
    tmp_28 = load writer+0 as ptr
    EXPAND VEC_GET tmp_29, tmp_28, i
    !tmp_28
    tmp_30 = tmp_29 as ptr
    tmp_31 = call @sla__messages_write_TestDamageMessage(messages, tmp_30)
    !tmp_30
    !messages
    messages = tmp_31
    tmp_32 = 1
    tmp_33 = add i, tmp_32
    !tmp_32
    !i
    i = tmp_33
    jmp L_WHILE_HEAD_3

L_WHILE_COND_FALSE_5:
    !tmp_27
    jmp L_WHILE_EXIT_6

L_WHILE_EXIT_6:
    !cnt
    !i
    !writer
    return messages

@sla__messages_read_next_TestDamageMessage(messages: ptr, reader: ptr, default_value: ptr) -> ptr:
L_ENTRY:
    tmp_34 = load reader+0 as i64
    tmp_35 = load messages+0 as i64
    tmp_36 = sge tmp_34, tmp_35
    !tmp_34
    !tmp_35
    br tmp_36 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_36
    tmp_37 = alloc 24
    tmp_38 = 0
    store tmp_37+0, tmp_38 as u8
    !tmp_38
    store tmp_37+8, default_value as ptr
    store tmp_37+16, reader as ptr
    !messages
    return tmp_37

L_ELSE_8:
    !tmp_36
    jmp L_MERGE_9

L_MERGE_9:
    tmp_40 = load messages+8 as ptr
    tmp_41 = load reader+0 as i64
    tmp_42 = mul tmp_41, 8
    tmp_43 = ptr_add tmp_40, tmp_42
    !tmp_42
    !tmp_41
    tmp_44 = load tmp_43+0 as ptr
    !tmp_43
    !tmp_40
    value = tmp_44
    tmp_45 = load reader+0 as i64
    tmp_46 = 1
    tmp_47 = add tmp_45, tmp_46
    !tmp_45
    !tmp_46
    store reader+0, tmp_47 as i64
    !tmp_47
    tmp_48 = alloc 24
    tmp_49 = 1
    store tmp_48+0, tmp_49 as u8
    !tmp_49
    store tmp_48+8, value as ptr
    store tmp_48+16, reader as ptr
    !messages
    !default_value
    return tmp_48

@test "messages generic constructor"():
L_TEST_ENTRY_10:
    tmp_50 = call @sla__test_damage_default()
    tmp_51 = call @sla__messages_new_TestDamageMessage(tmp_50)
    !tmp_50
    m = tmp_51
    tmp_52 = load m+0 as i64
    tmp_53 = 0
    tmp_54 = ne tmp_52, tmp_53
    !tmp_52
    !tmp_53
    br tmp_54 -> L_THEN_11, L_ELSE_12

L_THEN_11:
    !tmp_54
    panic(2390)

L_ELSE_12:
    !tmp_54
    jmp L_MERGE_13

L_MERGE_13:
    !m
    return

@test "messages writer appends"():
L_TEST_ENTRY_14:
    tmp_57 = call @sla__test_damage_messages_new()
    m0 = tmp_57
    tmp_58 = alloc 4
    tmp_59 = 5
    store tmp_58+0, tmp_59 as i32
    !tmp_59
    tmp_60 = call @sla__messages_write_TestDamageMessage(m0, tmp_58)
    !tmp_58
    m1 = tmp_60
    tmp_61 = alloc 4
    tmp_62 = 7
    store tmp_61+0, tmp_62 as i32
    !tmp_62
    tmp_63 = call @sla__messages_write_TestDamageMessage(m1, tmp_61)
    !tmp_61
    m2 = tmp_63
    tmp_64 = load m2+0 as i64
    tmp_65 = 2
    tmp_66 = ne tmp_64, tmp_65
    !tmp_64
    !tmp_65
    br tmp_66 -> L_THEN_15, L_ELSE_16

L_THEN_15:
    !tmp_66
    panic(2400)

L_ELSE_16:
    !tmp_66
    jmp L_MERGE_17

L_MERGE_17:
    !m2
    !m0
    !m1
    return

@test "message writer param batches appends"():
L_TEST_ENTRY_18:
    tmp_69 = call @sla__test_damage_messages_new()
    m0 = tmp_69
    tmp_70 = call @sla__message_writer_new_TestDamageMessage()
    w0 = tmp_70
    tmp_71 = alloc 4
    tmp_72 = 3
    store tmp_71+0, tmp_72 as i32
    !tmp_72
    tmp_73 = call @sla__message_writer_send_TestDamageMessage(w0, tmp_71)
    !tmp_71
    w1 = tmp_73
    tmp_74 = alloc 4
    tmp_75 = 9
    store tmp_74+0, tmp_75 as i32
    !tmp_75
    tmp_76 = call @sla__message_writer_send_TestDamageMessage(w1, tmp_74)
    !tmp_74
    w2 = tmp_76
    tmp_77 = call @sla__messages_apply_writer_TestDamageMessage(m0, w2)
    m1 = tmp_77
    tmp_78 = call @sla__message_reader_new()
    r0 = tmp_78
    tmp_79 = call @sla__test_damage_default()
    tmp_80 = call @sla__messages_read_next_TestDamageMessage(m1, r0, tmp_79)
    !tmp_79
    read1 = tmp_80
    tmp_81 = load read1+16 as ptr
    tmp_82 = call @sla__test_damage_default()
    tmp_83 = call @sla__messages_read_next_TestDamageMessage(m1, tmp_81, tmp_82)
    !tmp_81
    !tmp_82
    read2 = tmp_83
    tmp_84 = load read1+8 as ptr
    tmp_85 = load tmp_84+0 as i32
    !tmp_84
    tmp_86 = 3
    tmp_87 = ne tmp_85, tmp_86
    !tmp_85
    !tmp_86
    br tmp_87 -> L_THEN_19, L_ELSE_20

L_THEN_19:
    !tmp_87
    panic(2420)

L_ELSE_20:
    !tmp_87
    jmp L_MERGE_21

L_MERGE_21:
    tmp_90 = load read2+8 as ptr
    tmp_91 = load tmp_90+0 as i32
    !tmp_90
    tmp_92 = 9
    tmp_93 = ne tmp_91, tmp_92
    !tmp_91
    !tmp_92
    br tmp_93 -> L_THEN_22, L_ELSE_23

L_THEN_22:
    !tmp_93
    panic(2421)

L_ELSE_23:
    !tmp_93
    jmp L_MERGE_24

L_MERGE_24:
    !read1
    !m0
    !w0
    !m1
    !w1
    !w2
    !read2
    !r0
    return

@test "message reader cursor advances independently"():
L_TEST_ENTRY_25:
    tmp_96 = call @sla__test_damage_messages_new()
    m0 = tmp_96
    tmp_97 = alloc 4
    tmp_98 = 5
    store tmp_97+0, tmp_98 as i32
    !tmp_98
    tmp_99 = call @sla__messages_write_TestDamageMessage(m0, tmp_97)
    !tmp_97
    m1 = tmp_99
    tmp_100 = alloc 4
    tmp_101 = 7
    store tmp_100+0, tmp_101 as i32
    !tmp_101
    tmp_102 = call @sla__messages_write_TestDamageMessage(m1, tmp_100)
    !tmp_100
    m2 = tmp_102
    tmp_103 = call @sla__message_reader_new()
    r0 = tmp_103
    tmp_104 = call @sla__message_reader_new()
    r_other = tmp_104
    tmp_105 = call @sla__test_damage_default()
    tmp_106 = call @sla__messages_read_next_TestDamageMessage(m2, r0, tmp_105)
    !tmp_105
    read1 = tmp_106
    tmp_107 = load read1+0 as u8
    tmp_108 = 1
    tmp_109 = ne tmp_107, tmp_108
    !tmp_107
    !tmp_108
    br tmp_109 -> L_THEN_26, L_ELSE_27

L_THEN_26:
    !tmp_109
    panic(2410)

L_ELSE_27:
    !tmp_109
    jmp L_MERGE_28

L_MERGE_28:
    tmp_112 = load read1+8 as ptr
    tmp_113 = load tmp_112+0 as i32
    !tmp_112
    tmp_114 = 5
    tmp_115 = ne tmp_113, tmp_114
    !tmp_113
    !tmp_114
    br tmp_115 -> L_THEN_29, L_ELSE_30

L_THEN_29:
    !tmp_115
    panic(2411)

L_ELSE_30:
    !tmp_115
    jmp L_MERGE_31

L_MERGE_31:
    tmp_118 = load read1+16 as ptr
    tmp_119 = call @sla__test_damage_default()
    tmp_120 = call @sla__messages_read_next_TestDamageMessage(m2, tmp_118, tmp_119)
    !tmp_118
    !tmp_119
    read2 = tmp_120
    tmp_121 = load read2+0 as u8
    tmp_122 = 1
    tmp_123 = ne tmp_121, tmp_122
    !tmp_121
    !tmp_122
    br tmp_123 -> L_THEN_32, L_ELSE_33

L_THEN_32:
    !tmp_123
    panic(2412)

L_ELSE_33:
    !tmp_123
    jmp L_MERGE_34

L_MERGE_34:
    tmp_126 = load read2+8 as ptr
    tmp_127 = load tmp_126+0 as i32
    !tmp_126
    tmp_128 = 7
    tmp_129 = ne tmp_127, tmp_128
    !tmp_127
    !tmp_128
    br tmp_129 -> L_THEN_35, L_ELSE_36

L_THEN_35:
    !tmp_129
    panic(2413)

L_ELSE_36:
    !tmp_129
    jmp L_MERGE_37

L_MERGE_37:
    tmp_132 = load read2+16 as ptr
    tmp_133 = call @sla__test_damage_default()
    tmp_134 = call @sla__messages_read_next_TestDamageMessage(m2, tmp_132, tmp_133)
    !tmp_132
    !tmp_133
    read3 = tmp_134
    tmp_135 = load read3+0 as u8
    tmp_136 = 0
    tmp_137 = ne tmp_135, tmp_136
    !tmp_135
    !tmp_136
    br tmp_137 -> L_THEN_38, L_ELSE_39

L_THEN_38:
    !tmp_137
    panic(2414)

L_ELSE_39:
    !tmp_137
    jmp L_MERGE_40

L_MERGE_40:
    tmp_140 = call @sla__test_damage_default()
    tmp_141 = call @sla__messages_read_next_TestDamageMessage(m2, r_other, tmp_140)
    !tmp_140
    other = tmp_141
    tmp_142 = load other+8 as ptr
    tmp_143 = load tmp_142+0 as i32
    !tmp_142
    tmp_144 = 5
    tmp_145 = ne tmp_143, tmp_144
    !tmp_143
    !tmp_144
    br tmp_145 -> L_THEN_41, L_ELSE_42

L_THEN_41:
    !tmp_145
    panic(2415)

L_ELSE_42:
    !tmp_145
    jmp L_MERGE_43

L_MERGE_43:
    !m2
    !m0
    !read1
    !r_other
    !other
    !read3
    !m1
    !read2
    !r0
    return

