// TableErasedWorld plus generic RelationshipWorld with synchronized entity ids.
@import "world_table_erased.sla"
@import "relationship.sla"

struct TableErasedRelationshipWorld<R, M> {
    table: TableErasedWorld<R, M>,
    relationships: RelationshipWorld,
}

fn table_erased_relationship_world_new<R, M>(default_r: R, default_m: M) -> TableErasedRelationshipWorld<R, M> {
    return TableErasedRelationshipWorld<R, M> { table: table_erased_world_new<R, M>(default_r, default_m), relationships: relationship_world_new() };
}

fn table_erased_relationship_world_register_table<R, M>(world: TableErasedRelationshipWorld<R, M>, type_id: i32, drop_fn: fn(*u8) -> void) -> (TableErasedRelationshipWorld<R, M>, ComponentInfo) {
    let (table, info) = table_erased_world_register_table<R, M>(world.table, type_id, drop_fn);
    world.table = table;
    return (world, info);
}

fn table_erased_relationship_world_register_sparse_set<R, M>(world: TableErasedRelationshipWorld<R, M>, type_id: i32, drop_fn: fn(*u8) -> void) -> (TableErasedRelationshipWorld<R, M>, ComponentInfo) {
    let (table, info) = table_erased_world_register_sparse_set<R, M>(world.table, type_id, drop_fn);
    world.table = table;
    return (world, info);
}

fn table_erased_relationship_world_register_disabling_component<R, M>(world: TableErasedRelationshipWorld<R, M>, component_id: i32) -> TableErasedRelationshipWorld<R, M> {
    world.table = table_erased_world_register_disabling_component<R, M>(world.table, component_id);
    return world;
}

fn table_erased_relationship_world_register_disabling_component_auto<R, M>(world: TableErasedRelationshipWorld<R, M>, type_id: i32) -> TableErasedRelationshipWorld<R, M> {
    world.table = table_erased_world_register_disabling_component_auto<R, M>(world.table, type_id);
    return world;
}

fn table_erased_relationship_world_query_entities<R, M>(world: TableErasedRelationshipWorld<R, M>) -> Query<Entity> { return table_erased_world_query_entities<R, M>(world.table); }
fn table_erased_relationship_world_query_entities_allow<R, M>(world: TableErasedRelationshipWorld<R, M>, allow_component_id: i32) -> Query<Entity> { return table_erased_world_query_entities_allow<R, M>(world.table, allow_component_id); }
fn table_erased_relationship_world_query_entities_allow_auto<R, M>(world: TableErasedRelationshipWorld<R, M>, allow_type_id: i32) -> Query<Entity> { return table_erased_world_query_entities_allow_auto<R, M>(world.table, allow_type_id); }
fn table_erased_relationship_world_query_entities_allow_two<R, M>(world: TableErasedRelationshipWorld<R, M>, first_allow_component_id: i32, second_allow_component_id: i32) -> Query<Entity> { return table_erased_world_query_entities_allow_two<R, M>(world.table, first_allow_component_id, second_allow_component_id); }
fn table_erased_relationship_world_query_entities_allow_two_auto<R, M>(world: TableErasedRelationshipWorld<R, M>, first_allow_type_id: i32, second_allow_type_id: i32) -> Query<Entity> { return table_erased_world_query_entities_allow_two_auto<R, M>(world.table, first_allow_type_id, second_allow_type_id); }
fn table_erased_relationship_world_query_allow<T, R, M>(world: TableErasedRelationshipWorld<R, M>, component_id: i32, type_id: i32, allow_component_id: i32) -> Query<EntityItem<T>> { return table_erased_world_query_allow<T, R, M>(world.table, component_id, type_id, allow_component_id); }
fn table_erased_relationship_world_query_allow_auto<T, R, M>(world: TableErasedRelationshipWorld<R, M>, type_id: i32, allow_type_id: i32) -> Query<EntityItem<T>> { return table_erased_world_query_allow_auto<T, R, M>(world.table, type_id, allow_type_id); }
fn table_erased_relationship_world_query_allow_two<T, R, M>(world: TableErasedRelationshipWorld<R, M>, component_id: i32, type_id: i32, first_allow_component_id: i32, second_allow_component_id: i32) -> Query<EntityItem<T>> { return table_erased_world_query_allow_two<T, R, M>(world.table, component_id, type_id, first_allow_component_id, second_allow_component_id); }
fn table_erased_relationship_world_query_allow_two_auto<T, R, M>(world: TableErasedRelationshipWorld<R, M>, type_id: i32, first_allow_type_id: i32, second_allow_type_id: i32) -> Query<EntityItem<T>> { return table_erased_world_query_allow_two_auto<T, R, M>(world.table, type_id, first_allow_type_id, second_allow_type_id); }
fn table_erased_relationship_world_query_pair_allow<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, allow_component_id: i32) -> Query<TableErasedPair<A, B>> { return table_erased_world_query_pair_allow<A, B, R, M>(world.table, first_component_id, first_type_id, second_component_id, second_type_id, allow_component_id); }
fn table_erased_relationship_world_query_pair_allow_auto<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_type_id: i32, second_type_id: i32, allow_type_id: i32) -> Query<TableErasedPair<A, B>> { return table_erased_world_query_pair_allow_auto<A, B, R, M>(world.table, first_type_id, second_type_id, allow_type_id); }
fn table_erased_relationship_world_query_pair_allow_two<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, first_allow_component_id: i32, second_allow_component_id: i32) -> Query<TableErasedPair<A, B>> { return table_erased_world_query_pair_allow_two<A, B, R, M>(world.table, first_component_id, first_type_id, second_component_id, second_type_id, first_allow_component_id, second_allow_component_id); }
fn table_erased_relationship_world_query_pair_allow_two_auto<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_type_id: i32, second_type_id: i32, first_allow_type_id: i32, second_allow_type_id: i32) -> Query<TableErasedPair<A, B>> { return table_erased_world_query_pair_allow_two_auto<A, B, R, M>(world.table, first_type_id, second_type_id, first_allow_type_id, second_allow_type_id); }
fn table_erased_relationship_world_query_pair_mut_first_allow<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, allow_component_id: i32) -> Query<TableErasedPairMut<A, B>> { return table_erased_world_query_pair_mut_first_allow<A, B, R, M>(world.table, first_component_id, first_type_id, second_component_id, second_type_id, allow_component_id); }
fn table_erased_relationship_world_query_pair_mut_first_allow_auto<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_type_id: i32, second_type_id: i32, allow_type_id: i32) -> Query<TableErasedPairMut<A, B>> { return table_erased_world_query_pair_mut_first_allow_auto<A, B, R, M>(world.table, first_type_id, second_type_id, allow_type_id); }
fn table_erased_relationship_world_query_pair_mut_first_allow_two<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, first_allow_component_id: i32, second_allow_component_id: i32) -> Query<TableErasedPairMut<A, B>> { return table_erased_world_query_pair_mut_first_allow_two<A, B, R, M>(world.table, first_component_id, first_type_id, second_component_id, second_type_id, first_allow_component_id, second_allow_component_id); }
fn table_erased_relationship_world_query_pair_mut_first_allow_two_auto<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_type_id: i32, second_type_id: i32, first_allow_type_id: i32, second_allow_type_id: i32) -> Query<TableErasedPairMut<A, B>> { return table_erased_world_query_pair_mut_first_allow_two_auto<A, B, R, M>(world.table, first_type_id, second_type_id, first_allow_type_id, second_allow_type_id); }

fn table_erased_relationship_world_register_many<R, M>(world: TableErasedRelationshipWorld<R, M>, linked_spawn: bool, allow_self: bool) -> (TableErasedRelationshipWorld<R, M>, RelationshipKind) {
    let (relationships, kind) = relationship_world_register_many(world.relationships, linked_spawn, allow_self);
    world.relationships = relationships;
    return (world, kind);
}

fn table_erased_relationship_world_register_one<R, M>(world: TableErasedRelationshipWorld<R, M>, linked_spawn: bool, allow_self: bool) -> (TableErasedRelationshipWorld<R, M>, RelationshipKind) {
    let (relationships, kind) = relationship_world_register_one(world.relationships, linked_spawn, allow_self);
    world.relationships = relationships;
    return (world, kind);
}

fn table_erased_relationship_world_spawn<R, M>(world: TableErasedRelationshipWorld<R, M>) -> (TableErasedRelationshipWorld<R, M>, Entity) {
    return table_erased_relationship_world_spawn_with_location<R, M>(world, table_erased_spawn_location_none());
}

fn table_erased_relationship_world_spawn_with_location<R, M>(world: TableErasedRelationshipWorld<R, M>, spawned_by: TableErasedSpawnLocation) -> (TableErasedRelationshipWorld<R, M>, Entity) {
    let (table, table_entity) = table_erased_world_spawn_with_location<R, M>(world.table, spawned_by);
    let (relationships, relationship_entity) = relationship_world_spawn(world.relationships);
    if entity_eq(table_entity, relationship_entity) != true { panic(12200); };
    world.table = table;
    world.relationships = relationships;
    return (world, table_entity);
}

fn table_erased_relationship_world_message_reader_current<R, M>(world: TableErasedRelationshipWorld<R, M>) -> MessageReader { return table_erased_world_message_reader_current<R, M>(world.table); }
fn table_erased_relationship_world_message_reader_current_update<R, M>(world: TableErasedRelationshipWorld<R, M>) -> MessageReader { return table_erased_world_message_reader_current_update<R, M>(world.table); }
fn table_erased_relationship_world_message_reader_len<R, M>(world: TableErasedRelationshipWorld<R, M>, reader: MessageReader) -> i64 { return table_erased_world_message_reader_len<R, M>(world.table, reader); }
fn table_erased_relationship_world_message_reader_missed<R, M>(world: TableErasedRelationshipWorld<R, M>, reader: MessageReader) -> i64 { return table_erased_world_message_reader_missed<R, M>(world.table, reader); }
fn table_erased_relationship_world_message_reader_is_empty<R, M>(world: TableErasedRelationshipWorld<R, M>, reader: MessageReader) -> bool { return table_erased_world_message_reader_is_empty<R, M>(world.table, reader); }
fn table_erased_relationship_world_message_reader_clear<R, M>(world: TableErasedRelationshipWorld<R, M>, reader: MessageReader) -> MessageReader { return table_erased_world_message_reader_clear<R, M>(world.table, reader); }
fn table_erased_relationship_world_messages_len<R, M>(world: TableErasedRelationshipWorld<R, M>) -> i64 { return table_erased_world_messages_len<R, M>(world.table); }
fn table_erased_relationship_world_messages_is_empty<R, M>(world: TableErasedRelationshipWorld<R, M>) -> bool { return table_erased_world_messages_is_empty<R, M>(world.table); }
fn table_erased_relationship_world_messages_message_count<R, M>(world: TableErasedRelationshipWorld<R, M>) -> i64 { return table_erased_world_messages_message_count<R, M>(world.table); }
fn table_erased_relationship_world_messages_oldest_message_count<R, M>(world: TableErasedRelationshipWorld<R, M>) -> i64 { return table_erased_world_messages_oldest_message_count<R, M>(world.table); }
fn table_erased_relationship_world_current_update_message_len<R, M>(world: TableErasedRelationshipWorld<R, M>) -> i64 { return table_erased_world_current_update_message_len<R, M>(world.table); }
fn table_erased_relationship_world_current_update_message_at<R, M>(world: TableErasedRelationshipWorld<R, M>, index: i64, default_value: M) -> MessageReadWithId<M> { return table_erased_world_current_update_message_at<R, M>(world.table, index, default_value); }
fn table_erased_relationship_world_current_update_message_id_at<R, M>(world: TableErasedRelationshipWorld<R, M>, index: i64, default_value: M) -> MessageReadWithMessageId<M> { return table_erased_world_current_update_message_id_at<R, M>(world.table, index, default_value); }

fn table_erased_relationship_world_is_alive<R, M>(world: TableErasedRelationshipWorld<R, M>, entity: Entity) -> bool {
    if table_erased_world_is_alive<R, M>(world.table, entity) != true { return false; };
    return relationship_world_is_alive(world.relationships, entity);
}

fn table_erased_relationship_world_insert<T, R, M>(world: TableErasedRelationshipWorld<R, M>, entity: Entity, component_id: i32, type_id: i32, value: T) -> TableErasedRelationshipWorld<R, M> {
    world.table = table_erased_world_insert<T, R, M>(world.table, entity, component_id, type_id, value);
    return world;
}

fn table_erased_relationship_world_get<T, R, M>(world: TableErasedRelationshipWorld<R, M>, entity: Entity, component_id: i32, type_id: i32) -> T {
    return table_erased_world_get<T, R, M>(world.table, entity, component_id, type_id);
}

fn table_erased_relationship_world_has<R, M>(world: TableErasedRelationshipWorld<R, M>, entity: Entity, component_id: i32) -> bool {
    return table_erased_world_has<R, M>(world.table, entity, component_id);
}

fn table_erased_relationship_world_remove<R, M>(world: TableErasedRelationshipWorld<R, M>, entity: Entity, component_id: i32) -> TableErasedRelationshipWorld<R, M> {
    world.table = table_erased_world_remove<R, M>(world.table, entity, component_id);
    return world;
}

fn table_erased_relationship_world_remove_auto<R, M>(world: TableErasedRelationshipWorld<R, M>, entity: Entity, type_id: i32) -> TableErasedRelationshipWorld<R, M> {
    world.table = table_erased_world_remove_auto<R, M>(world.table, entity, type_id);
    return world;
}

fn table_erased_relationship_world_removed_components<R, M>(world: TableErasedRelationshipWorld<R, M>, component_id: i32, since_tick: i32) -> Query<Entity> {
    return table_erased_world_removed_components<R, M>(world.table, component_id, since_tick);
}

