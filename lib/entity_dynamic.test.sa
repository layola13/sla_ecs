@test "dynamic allocator grows beyond fixed capacity"():
L_TEST_ENTRY_85:
    tmp_297 = call @sla__dyn_allocator_new()
    a = tmp_297
    tmp_298 = 0
    i = tmp_298
    jmp L_WHILE_HEAD_86

L_WHILE_HEAD_86:
    tmp_299 = 20
    tmp_300 = slt i, tmp_299
    !tmp_299
    br tmp_300 -> L_WHILE_BODY_87, L_WHILE_COND_FALSE_88

L_WHILE_BODY_87:
    !tmp_300
    tmp_301 = call @sla__dyn_alloc_entity(a)
    next_a = load tmp_301+0 as ptr
    entity = load tmp_301+8 as ptr
    !tmp_301
    !a
    a = next_a
    tmp_302 = load entity+0 as i32
    tmp_303 = 1
    tmp_304 = add i, tmp_303
    !tmp_303
    tmp_305 = ne tmp_302, tmp_304
    !tmp_302
    !tmp_304
    br tmp_305 -> L_THEN_90, L_ELSE_91

L_THEN_90:
    !tmp_305
    panic(2150)

L_ELSE_91:
    !tmp_305
    jmp L_MERGE_92

L_MERGE_92:
    tmp_308 = call @sla__dyn_is_alive(a, entity)
    tmp_309 = 1
    tmp_310 = ne tmp_308, tmp_309
    !tmp_308
    !tmp_309
    br tmp_310 -> L_THEN_93, L_ELSE_94

L_THEN_93:
    !tmp_310
    panic(2151)

L_ELSE_94:
    !tmp_310
    jmp L_MERGE_95

L_MERGE_95:
    tmp_313 = 1
    tmp_314 = add i, tmp_313
    !tmp_313
    !i
    i = tmp_314
    !entity
    jmp L_WHILE_HEAD_86

L_WHILE_COND_FALSE_88:
    !tmp_300
    jmp L_WHILE_EXIT_89

L_WHILE_EXIT_89:
    tmp_315 = load a+8 as ptr
    EXPAND VEC_LEN tmp_316, tmp_315
    !tmp_315
    tmp_317 = 21
    tmp_318 = ne tmp_316, tmp_317
    !tmp_316
    !tmp_317
    br tmp_318 -> L_THEN_96, L_ELSE_97

L_THEN_96:
    !tmp_318
    panic(2152)

L_ELSE_97:
    !tmp_318
    jmp L_MERGE_98

L_MERGE_98:
    !a
    !i
    return

