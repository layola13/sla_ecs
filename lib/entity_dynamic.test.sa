    !out
    !bits
    !e
    return

@test "allocator rejects stale generation"():
L_TEST_ENTRY_53:
    tmp_256 = call @sla__allocator_new()
    a0 = tmp_256
    tmp_257 = call @sla__alloc_entity(a0)
    a1 = load tmp_257+0 as ptr
    e1 = load tmp_257+8 as ptr
    !tmp_257
    tmp_258 = call @sla__free_entity(a1, e1)
    a2 = tmp_258
    tmp_259 = call @sla__is_alive(a2, e1)
    tmp_260 = 0
    tmp_261 = ne tmp_259, tmp_260
    !tmp_259
    !tmp_260
    br tmp_261 -> L_THEN_54, L_ELSE_55

L_THEN_54:
    !tmp_261
    panic(2130)

L_ELSE_55:
    !tmp_261
    jmp L_MERGE_56

L_MERGE_56:
    tmp_264 = call @sla__alloc_entity(a2)
    a3 = load tmp_264+0 as ptr
    e2 = load tmp_264+8 as ptr
    !tmp_264
    tmp_265 = load e2+0 as i32
    tmp_266 = load e1+0 as i32
    tmp_267 = ne tmp_265, tmp_266
    !tmp_265
    !tmp_266
    br tmp_267 -> L_THEN_57, L_ELSE_58

L_THEN_57:
    !tmp_267
    panic(2131)

L_ELSE_58:
    !tmp_267
    jmp L_MERGE_59

L_MERGE_59:
    tmp_270 = load e2+4 as i32
    tmp_271 = load e1+4 as i32
    tmp_272 = 1
    tmp_273 = add tmp_271, tmp_272
    !tmp_271
    !tmp_272
    tmp_274 = ne tmp_270, tmp_273
    !tmp_270
    !tmp_273
    br tmp_274 -> L_THEN_60, L_ELSE_61

L_THEN_60:
    !tmp_274
    panic(2132)

L_ELSE_61:
    !tmp_274
    jmp L_MERGE_62

L_MERGE_62:
    tmp_277 = call @sla__is_alive(a3, e2)
    tmp_278 = 1
