    jmp L_MERGE_65

L_MERGE_65:
    !e2
    !e1
    !a0
    !a3
    !a2
    !a1
    return

@test "dynamic allocator grows beyond fixed capacity"():
L_TEST_ENTRY_66:
    tmp_282 = call @sla__dyn_allocator_new()
    a = tmp_282
    tmp_283 = 0
    i = tmp_283
    jmp L_WHILE_HEAD_67

L_WHILE_HEAD_67:
    tmp_284 = 20
    tmp_285 = slt i, tmp_284
    !tmp_284
    br tmp_285 -> L_WHILE_BODY_68, L_WHILE_COND_FALSE_69

L_WHILE_BODY_68:
    !tmp_285
    tmp_286 = call @sla__dyn_alloc_entity(a)
    next_a = load tmp_286+0 as ptr
    entity = load tmp_286+8 as ptr
    !tmp_286
    !a
    a = next_a
    tmp_287 = load entity+0 as i32
    tmp_288 = 1
    tmp_289 = add i, tmp_288
    !tmp_288
    tmp_290 = ne tmp_287, tmp_289
    !tmp_287
    !tmp_289
    br tmp_290 -> L_THEN_71, L_ELSE_72

L_THEN_71:
    !tmp_290
    panic(2150)

L_ELSE_72:
    !tmp_290
    jmp L_MERGE_73

L_MERGE_73:
    tmp_293 = call @sla__dyn_is_alive(a, entity)
    tmp_294 = 1
    tmp_295 = ne tmp_293, tmp_294
    !tmp_293
    !tmp_294
    br tmp_295 -> L_THEN_74, L_ELSE_75

L_THEN_74:
    !tmp_295
    panic(2151)

L_ELSE_75:
    !tmp_295
    jmp L_MERGE_76

L_MERGE_76:
    tmp_298 = 1
    tmp_299 = add i, tmp_298
    !tmp_298
    !i
    i = tmp_299
    !entity
    jmp L_WHILE_HEAD_67

L_WHILE_COND_FALSE_69:
    !tmp_285
    jmp L_WHILE_EXIT_70

L_WHILE_EXIT_70:
    tmp_300 = load a+8 as ptr
    EXPAND VEC_LEN tmp_301, tmp_300
    !tmp_300
    tmp_302 = 21
    tmp_303 = ne tmp_301, tmp_302
    !tmp_301
    !tmp_302
    br tmp_303 -> L_THEN_77, L_ELSE_78

L_THEN_77:
    !tmp_303
    panic(2152)

L_ELSE_78:
    !tmp_303
    jmp L_MERGE_79

L_MERGE_79:
    !a
    !i
    return

@test "dynamic allocator rejects fabricated next generation before reuse"():
L_TEST_ENTRY_80:
    tmp_306 = call @sla__dyn_allocator_new()
    a0 = tmp_306
    tmp_307 = call @sla__dyn_alloc_entity(a0)
    a1 = load tmp_307+0 as ptr
    e1 = load tmp_307+8 as ptr
    !tmp_307
    tmp_308 = call @sla__dyn_free_entity(a1, e1)
    a2 = tmp_308
    tmp_309 = load e1+0 as i32
    tmp_310 = load e1+4 as i32
    tmp_311 = 1
    tmp_312 = add tmp_310, tmp_311
    !tmp_310
    !tmp_311
    tmp_313 = call @sla__entity_new(tmp_309, tmp_312)
    !tmp_309
    !tmp_312
    fake = tmp_313
    tmp_314 = call @sla__dyn_is_alive(a2, e1)
    tmp_315 = 0
    tmp_316 = ne tmp_314, tmp_315
    !tmp_314
    !tmp_315
    br tmp_316 -> L_THEN_81, L_ELSE_82

L_THEN_81:
    !tmp_316
    panic(2160)

L_ELSE_82:
    !tmp_316
    jmp L_MERGE_83

L_MERGE_83:
    tmp_319 = call @sla__dyn_is_alive(a2, fake)
    tmp_320 = 0
    tmp_321 = ne tmp_319, tmp_320
    !tmp_319
    !tmp_320
    br tmp_321 -> L_THEN_84, L_ELSE_85

L_THEN_84:
    !tmp_321
