L_MERGE_89:
    tmp_330 = call @sla__dyn_is_alive(a3, e2)
    tmp_331 = 1
    tmp_332 = ne tmp_330, tmp_331
    !tmp_330
    !tmp_331
    br tmp_332 -> L_THEN_90, L_ELSE_91

L_THEN_90:
    !tmp_332
    panic(2163)

L_ELSE_91:
    !tmp_332
    jmp L_MERGE_92

L_MERGE_92:
    !e2
    !a0
    !fake
    !a2
    !e1
    !a3
    !a1
