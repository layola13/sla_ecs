L_MERGE_86:
    tmp_324 = call @sla__dyn_alloc_entity(a2)
    a3 = load tmp_324+0 as ptr
    e2 = load tmp_324+8 as ptr
    !tmp_324
    tmp_325 = call @sla__entity_eq(e2, fake)
    tmp_326 = 1
    tmp_327 = ne tmp_325, tmp_326
    !tmp_325
    !tmp_326
    br tmp_327 -> L_THEN_87, L_ELSE_88

L_THEN_87:
    !tmp_327
