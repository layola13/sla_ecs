    tmp_6470 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_6470+0 as ptr
    e2 = load tmp_6470+8 as ptr
    !tmp_6470
    tmp_6471 = load component+0 as i32
    tmp_6472 = call @sla__registry_world_insert_component(w3, e1, tmp_6471)
    !tmp_6471
    w4 = tmp_6472
