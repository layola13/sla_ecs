    !tmp_6479
    jmp L_LOOP_EXIT_1881

L_LOOP_EXIT_1881:
    !tmp_6478
    tmp_6484 = load e1+0 as i32
    tmp_6485 = load e2+0 as i32
    tmp_6486 = add tmp_6484, tmp_6485
    !tmp_6484
    !tmp_6485
    tmp_6487 = ne total, tmp_6486
    !tmp_6486
    br tmp_6487 -> L_THEN_1882, L_ELSE_1883

L_THEN_1882:
