    tmp_6476 = call @sla__registry_world_query_component(w5, tmp_6475)
    !tmp_6475
    q = tmp_6476
    tmp_6477 = 0
    total = tmp_6477
    tmp_6478 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1877

L_LOOP_HEAD_1877:
    tmp_6479 = load entity_slot+0 as i64
    tmp_6480 = slt tmp_6479, tmp_6478
    br tmp_6480 -> L_LOOP_BODY_1878, L_LOOP_COND_FALSE_1880

L_LOOP_BODY_1878:
    !tmp_6480
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_6479)
    tmp_6481 = load entity+0 as i32
    tmp_6482 = add total, tmp_6481
    !tmp_6481
    !total
    total = tmp_6482
L_LOOP_CONTINUE_1879:
    tmp_6483 = add tmp_6479, 1
    store entity_slot+0, tmp_6483 as i64
    !tmp_6483
    !tmp_6479
    !entity
    jmp L_LOOP_HEAD_1877

L_LOOP_COND_FALSE_1880:
