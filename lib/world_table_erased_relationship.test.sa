@test "messages update drain returns older buffer and keeps current"():
L_TEST_ENTRY_4141:
    tmp_17853 = call @sla__test_damage_messages_new()
    m0 = tmp_17853
    tmp_17854 = call @sla__messages_update_TestDamageMessage(m0)
    m1 = tmp_17854
    tmp_17855 = alloc 4
    tmp_17856 = 1
    store tmp_17855+0, tmp_17856 as i32
    !tmp_17856
    tmp_17857 = call @sla__messages_write_TestDamageMessage(m1, tmp_17855)
    !tmp_17855
    m2 = tmp_17857
    tmp_17858 = call @sla__messages_update_TestDamageMessage(m2)
    m3 = tmp_17858
    tmp_17859 = alloc 4
    tmp_17860 = 2
    store tmp_17859+0, tmp_17860 as i32
    !tmp_17860
    tmp_17861 = call @sla__messages_write_TestDamageMessage(m3, tmp_17859)
    !tmp_17859
    m4 = tmp_17861
    tmp_17862 = alloc 4
    tmp_17863 = 3
    store tmp_17862+0, tmp_17863 as i32
    !tmp_17863
    tmp_17864 = call @sla__messages_write_TestDamageMessage(m4, tmp_17862)
    !tmp_17862
    m5 = tmp_17864
    tmp_17865 = call @sla__test_damage_default()
    tmp_17866 = call @sla__messages_update_drain_TestDamageMessage(m5, tmp_17865)
    !tmp_17865
    d1 = tmp_17866
    tmp_17867 = load d1+8 as i64
