    w2 = load tmp_4399+0 as ptr
    e1 = load tmp_4399+8 as ptr
    !tmp_4399
    tmp_4400 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_4400+0 as ptr
    e2 = load tmp_4400+8 as ptr
    !tmp_4400
    tmp_4401 = load component+0 as i32
    tmp_4402 = call @sla__registry_world_insert_component(w3, e1, tmp_4401)
    !tmp_4401
    w4 = tmp_4402
    tmp_4403 = load component+0 as i32
    tmp_4404 = call @sla__registry_world_insert_component(w4, e2, tmp_4403)
    !tmp_4403
    w5 = tmp_4404
