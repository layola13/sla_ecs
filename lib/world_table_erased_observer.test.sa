    !tmp_5007
    q = tmp_5008
    tmp_5009 = 0
    total = tmp_5009
    tmp_5010 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1394

L_LOOP_HEAD_1394:
    tmp_5011 = load entity_slot+0 as i64
    tmp_5012 = slt tmp_5011, tmp_5010
    br tmp_5012 -> L_LOOP_BODY_1395, L_LOOP_COND_FALSE_1397

