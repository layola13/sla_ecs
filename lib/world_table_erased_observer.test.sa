    tmp_4406 = call @sla__registry_world_query_component(w5, tmp_4405)
    !tmp_4405
    q = tmp_4406
    tmp_4407 = 0
    total = tmp_4407
    tmp_4408 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1210

L_LOOP_HEAD_1210:
    tmp_4409 = load entity_slot+0 as i64
    tmp_4410 = slt tmp_4409, tmp_4408
    br tmp_4410 -> L_LOOP_BODY_1211, L_LOOP_COND_FALSE_1213

L_LOOP_BODY_1211:
    !tmp_4410
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_4409)
    tmp_4411 = load entity+0 as i32
    tmp_4412 = add total, tmp_4411
    !tmp_4411
    !total
    total = tmp_4412
L_LOOP_CONTINUE_1212:
    tmp_4413 = add tmp_4409, 1
    store entity_slot+0, tmp_4413 as i64
    !tmp_4413
    !tmp_4409
    !entity
    jmp L_LOOP_HEAD_1210

L_LOOP_COND_FALSE_1213:
