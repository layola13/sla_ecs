L_LOOP_HEAD_1117:
    tmp_4114 = load entity_slot+0 as i64
    tmp_4115 = slt tmp_4114, tmp_4113
    br tmp_4115 -> L_LOOP_BODY_1118, L_LOOP_COND_FALSE_1120

L_LOOP_BODY_1118:
