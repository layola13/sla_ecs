    !tmp_4409
    jmp L_LOOP_EXIT_1214

L_LOOP_EXIT_1214:
    !tmp_4408
    tmp_4414 = load e1+0 as i32
    tmp_4415 = load e2+0 as i32
    tmp_4416 = add tmp_4414, tmp_4415
    !tmp_4414
    !tmp_4415
    tmp_4417 = ne total, tmp_4416
    !tmp_4416
    br tmp_4417 -> L_THEN_1215, L_ELSE_1216

L_THEN_1215:
    !tmp_4417
    panic(8730)

L_ELSE_1216:
    !tmp_4417
    jmp L_MERGE_1217

L_MERGE_1217:
