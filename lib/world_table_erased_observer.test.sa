    tmp_5002 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_5002+0 as ptr
    e2 = load tmp_5002+8 as ptr
    !tmp_5002
    tmp_5003 = load component+0 as i32
    tmp_5004 = call @sla__registry_world_insert_component(w3, e1, tmp_5003)
    !tmp_5003
    w4 = tmp_5004
