@test "registry entity query supports for in"():
L_TEST_ENTRY_1342:
    entity_slot = stack_alloc 8
    tmp_4744 = call @sla__registry_world_new()
    w0 = tmp_4744
    tmp_4745 = call @sla__registry_world_register_table(w0)
    w1 = load tmp_4745+0 as ptr
    component = load tmp_4745+8 as ptr
    !tmp_4745
    tmp_4746 = call @sla__registry_world_spawn(w1)
    w2 = load tmp_4746+0 as ptr
    e1 = load tmp_4746+8 as ptr
    !tmp_4746
    tmp_4747 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_4747+0 as ptr
    e2 = load tmp_4747+8 as ptr
    !tmp_4747
    tmp_4748 = load component+0 as i32
    tmp_4749 = call @sla__registry_world_insert_component(w3, e1, tmp_4748)
    !tmp_4748
    w4 = tmp_4749
    tmp_4750 = load component+0 as i32
    tmp_4751 = call @sla__registry_world_insert_component(w4, e2, tmp_4750)
    !tmp_4750
    w5 = tmp_4751
    tmp_4752 = load component+0 as i32
    tmp_4753 = call @sla__registry_world_query_component(w5, tmp_4752)
    !tmp_4752
    q = tmp_4753
    tmp_4754 = 0
    total = tmp_4754
    tmp_4755 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1343

L_LOOP_HEAD_1343:
    tmp_4756 = load entity_slot+0 as i64
    tmp_4757 = slt tmp_4756, tmp_4755
    br tmp_4757 -> L_LOOP_BODY_1344, L_LOOP_COND_FALSE_1346

L_LOOP_BODY_1344:
    !tmp_4757
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_4756)
    tmp_4758 = load entity+0 as i32
    tmp_4759 = add total, tmp_4758
    !tmp_4758
    !total
    total = tmp_4759
L_LOOP_CONTINUE_1345:
    tmp_4760 = add tmp_4756, 1
    store entity_slot+0, tmp_4760 as i64
    !tmp_4760
    !tmp_4756
    !entity
    jmp L_LOOP_HEAD_1343

L_LOOP_COND_FALSE_1346:
    !tmp_4757
    !tmp_4756
    jmp L_LOOP_EXIT_1347

L_LOOP_EXIT_1347:
    !tmp_4755
    tmp_4761 = load e1+0 as i32
    tmp_4762 = load e2+0 as i32
    tmp_4763 = add tmp_4761, tmp_4762
    !tmp_4761
    !tmp_4762
    tmp_4764 = ne total, tmp_4763
    !tmp_4763
    br tmp_4764 -> L_THEN_1348, L_ELSE_1349

L_THEN_1348:
    !tmp_4764
    panic(8730)

L_ELSE_1349:
    !tmp_4764
    jmp L_MERGE_1350

L_MERGE_1350:
