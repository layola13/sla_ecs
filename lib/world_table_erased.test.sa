    tmp_4555 = call @sla__dyn_allocator_new()
    a = tmp_4555
    tmp_4556 = 0
    i = tmp_4556
    jmp L_WHILE_HEAD_1266

L_WHILE_HEAD_1266:
    tmp_4557 = 20
    tmp_4558 = slt i, tmp_4557
    !tmp_4557
    br tmp_4558 -> L_WHILE_BODY_1267, L_WHILE_COND_FALSE_1268

L_WHILE_BODY_1267:
    !tmp_4558
    tmp_4559 = call @sla__dyn_alloc_entity(a)
    next_a = load tmp_4559+0 as ptr
    entity = load tmp_4559+8 as ptr
    !tmp_4559
    !a
    a = next_a
    tmp_4560 = load entity+0 as i32
    tmp_4561 = 1
    tmp_4562 = add i, tmp_4561
    !tmp_4561
    tmp_4563 = ne tmp_4560, tmp_4562
    !tmp_4560
    !tmp_4562
    br tmp_4563 -> L_THEN_1270, L_ELSE_1271

L_THEN_1270:
    !tmp_4563
    panic(2150)

L_ELSE_1271:
    !tmp_4563
    jmp L_MERGE_1272

L_MERGE_1272:
    tmp_4566 = call @sla__dyn_is_alive(a, entity)
    tmp_4567 = 1
    tmp_4568 = ne tmp_4566, tmp_4567
    !tmp_4566
    !tmp_4567
    br tmp_4568 -> L_THEN_1273, L_ELSE_1274

L_THEN_1273:
    !tmp_4568
    panic(2151)

L_ELSE_1274:
    !tmp_4568
    jmp L_MERGE_1275

L_MERGE_1275:
    tmp_4571 = 1
    tmp_4572 = add i, tmp_4571
    !tmp_4571
    !i
    i = tmp_4572
    !entity
    jmp L_WHILE_HEAD_1266

L_WHILE_COND_FALSE_1268:
    !tmp_4558
    jmp L_WHILE_EXIT_1269

L_WHILE_EXIT_1269:
    tmp_4573 = load a+8 as ptr
    EXPAND VEC_LEN tmp_4574, tmp_4573
    !tmp_4573
    tmp_4575 = 21
    tmp_4576 = ne tmp_4574, tmp_4575
    !tmp_4574
    !tmp_4575
    br tmp_4576 -> L_THEN_1276, L_ELSE_1277

L_THEN_1276:
    !tmp_4576
    panic(2152)

L_ELSE_1277:
    !tmp_4576
    jmp L_MERGE_1278

L_MERGE_1278:
    !a
    !i
    return

@test "dynamic allocator rejects fabricated next generation before reuse"():
L_TEST_ENTRY_1279:
    tmp_4579 = call @sla__dyn_allocator_new()
    a0 = tmp_4579
    tmp_4580 = call @sla__dyn_alloc_entity(a0)
    a1 = load tmp_4580+0 as ptr
    e1 = load tmp_4580+8 as ptr
    !tmp_4580
    tmp_4581 = call @sla__dyn_free_entity(a1, e1)
    a2 = tmp_4581
    tmp_4582 = load e1+0 as i32
    tmp_4583 = load e1+4 as i32
    tmp_4584 = 1
    tmp_4585 = add tmp_4583, tmp_4584
    !tmp_4583
    !tmp_4584
    tmp_4586 = call @sla__entity_new(tmp_4582, tmp_4585)
    !tmp_4582
    !tmp_4585
    fake = tmp_4586
    tmp_4587 = call @sla__dyn_is_alive(a2, e1)
    tmp_4588 = 0
    tmp_4589 = ne tmp_4587, tmp_4588
    !tmp_4587
    !tmp_4588
    br tmp_4589 -> L_THEN_1280, L_ELSE_1281

L_THEN_1280:
    !tmp_4589
    panic(2160)

L_ELSE_1281:
    !tmp_4589
    jmp L_MERGE_1282

L_MERGE_1282:
    tmp_4592 = call @sla__dyn_is_alive(a2, fake)
    tmp_4593 = 0
    tmp_4594 = ne tmp_4592, tmp_4593
    !tmp_4592
    !tmp_4593
    br tmp_4594 -> L_THEN_1283, L_ELSE_1284

L_THEN_1283:
    !tmp_4594
    panic(2161)

L_ELSE_1284:
    !tmp_4594
    jmp L_MERGE_1285

L_MERGE_1285:
    tmp_4597 = call @sla__dyn_alloc_entity(a2)
    a3 = load tmp_4597+0 as ptr
    e2 = load tmp_4597+8 as ptr
    !tmp_4597
    tmp_4598 = call @sla__entity_eq(e2, fake)
    tmp_4599 = 1
    tmp_4600 = ne tmp_4598, tmp_4599
    !tmp_4598
    !tmp_4599
    br tmp_4600 -> L_THEN_1286, L_ELSE_1287

L_THEN_1286:
    !tmp_4600
    panic(2162)

L_ELSE_1287:
    !tmp_4600
    jmp L_MERGE_1288

L_MERGE_1288:
    tmp_4603 = call @sla__dyn_is_alive(a3, e2)
    tmp_4604 = 1
    tmp_4605 = ne tmp_4603, tmp_4604
    !tmp_4603
    !tmp_4604
    br tmp_4605 -> L_THEN_1289, L_ELSE_1290

L_THEN_1289:
    !tmp_4605
    panic(2163)

L_ELSE_1290:
    !tmp_4605
    jmp L_MERGE_1291

L_MERGE_1291:
    !e2
    !a0
    !fake
    !a2
    !e1
    !a3
    !a1
    return

