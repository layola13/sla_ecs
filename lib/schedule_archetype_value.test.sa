    tmp_3796 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_3796+0 as ptr
    e2 = load tmp_3796+8 as ptr
    !tmp_3796
    tmp_3797 = load component+0 as i32
    tmp_3798 = call @sla__registry_world_insert_component(w3, e1, tmp_3797)
    !tmp_3797
    w4 = tmp_3798
    tmp_3799 = load component+0 as i32
    tmp_3800 = call @sla__registry_world_insert_component(w4, e2, tmp_3799)
    !tmp_3799
    w5 = tmp_3800
    tmp_3801 = load component+0 as i32
    tmp_3802 = call @sla__registry_world_query_component(w5, tmp_3801)
    !tmp_3801
    q = tmp_3802
    tmp_3803 = 0
    total = tmp_3803
    tmp_3804 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1081

L_LOOP_HEAD_1081:
    tmp_3805 = load entity_slot+0 as i64
    tmp_3806 = slt tmp_3805, tmp_3804
    br tmp_3806 -> L_LOOP_BODY_1082, L_LOOP_COND_FALSE_1084

L_LOOP_BODY_1082:
    !tmp_3806
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_3805)
    tmp_3807 = load entity+0 as i32
    tmp_3808 = add total, tmp_3807
    !tmp_3807
    !total
    total = tmp_3808
L_LOOP_CONTINUE_1083:
    tmp_3809 = add tmp_3805, 1
    store entity_slot+0, tmp_3809 as i64
    !tmp_3809
    !tmp_3805
    !entity
    jmp L_LOOP_HEAD_1081

L_LOOP_COND_FALSE_1084:
