    tmp_3784 = call @sla__registry_world_query_component(w5, tmp_3783)
    !tmp_3783
    q = tmp_3784
    tmp_3785 = 0
    total = tmp_3785
    tmp_3786 = call @sla__RegistryEntityQuery_iter_len(&q)
    store entity_slot+0, 0 as i64
    jmp L_LOOP_HEAD_1074

L_LOOP_HEAD_1074:
    tmp_3787 = load entity_slot+0 as i64
    tmp_3788 = slt tmp_3787, tmp_3786
    br tmp_3788 -> L_LOOP_BODY_1075, L_LOOP_COND_FALSE_1077

L_LOOP_BODY_1075:
    !tmp_3788
    entity = call @sla__RegistryEntityQuery_iter_at(&q, tmp_3787)
    tmp_3789 = load entity+0 as i32
    tmp_3790 = add total, tmp_3789
    !tmp_3789
    !total
    total = tmp_3790
L_LOOP_CONTINUE_1076:
