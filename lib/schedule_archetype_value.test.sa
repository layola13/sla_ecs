    !tmp_3805
    jmp L_LOOP_EXIT_1085

L_LOOP_EXIT_1085:
    !tmp_3804
    tmp_3810 = load e1+0 as i32
    tmp_3811 = load e2+0 as i32
    tmp_3812 = add tmp_3810, tmp_3811
    !tmp_3810
    !tmp_3811
    tmp_3813 = ne total, tmp_3812
    !tmp_3812
    br tmp_3813 -> L_THEN_1086, L_ELSE_1087

L_THEN_1086:
    !tmp_3813
    panic(8730)

L_ELSE_1087:
    !tmp_3813
    jmp L_MERGE_1088

L_MERGE_1088:
