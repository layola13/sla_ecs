    w2 = load tmp_3777+0 as ptr
    e1 = load tmp_3777+8 as ptr
    !tmp_3777
    tmp_3778 = call @sla__registry_world_spawn(w2)
    w3 = load tmp_3778+0 as ptr
    e2 = load tmp_3778+8 as ptr
    !tmp_3778
    tmp_3779 = load component+0 as i32
    tmp_3780 = call @sla__registry_world_insert_component(w3, e1, tmp_3779)
    !tmp_3779
    w4 = tmp_3780
