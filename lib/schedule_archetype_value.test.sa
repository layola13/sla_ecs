    tmp_3792 = load e1+0 as i32
    tmp_3793 = load e2+0 as i32
    tmp_3794 = add tmp_3792, tmp_3793
    !tmp_3792
    !tmp_3793
    tmp_3795 = ne total, tmp_3794
    !tmp_3794
    br tmp_3795 -> L_THEN_1079, L_ELSE_1080

L_THEN_1079:
