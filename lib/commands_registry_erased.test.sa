L_MERGE_842:
    tmp_3516 = alloc 8
    tmp_3517 = load fabricated+0 as i32
    store tmp_3516+0, tmp_3517 as i32
    tmp_3518 = load fabricated+4 as i32
    store tmp_3516+4, tmp_3518 as i32
    tmp_3519 = call @sla__is_alive(a2, tmp_3516)
    !tmp_3516
    tmp_3520 = 0
    tmp_3521 = ne tmp_3519, tmp_3520
    !tmp_3519
    !tmp_3520
    br tmp_3521 -> L_THEN_843, L_ELSE_844

L_THEN_843:
