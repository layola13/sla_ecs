L_MERGE_848:
    tmp_3536 = alloc 8
    tmp_3537 = load e2+0 as i32
    store tmp_3536+0, tmp_3537 as i32
    tmp_3538 = load e2+4 as i32
    store tmp_3536+4, tmp_3538 as i32
    tmp_3539 = call @sla__is_alive(a3, tmp_3536)
    !tmp_3536
    tmp_3540 = 1
    tmp_3541 = ne tmp_3539, tmp_3540
    !tmp_3539
    !tmp_3540
