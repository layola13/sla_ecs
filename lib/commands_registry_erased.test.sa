@test "dynamic allocator grows beyond fixed capacity"():
L_TEST_ENTRY_859:
    tmp_3563 = call @sla__dyn_allocator_new()
    a = tmp_3563
    tmp_3564 = 0
    i = tmp_3564
    jmp L_WHILE_HEAD_860

L_WHILE_HEAD_860:
    tmp_3565 = 20
    tmp_3566 = slt i, tmp_3565
    !tmp_3565
    br tmp_3566 -> L_WHILE_BODY_861, L_WHILE_COND_FALSE_862

L_WHILE_BODY_861:
    !tmp_3566
    tmp_3567 = call @sla__dyn_alloc_entity(a)
    next_a = load tmp_3567+0 as ptr
    entity = load tmp_3567+8 as ptr
    !tmp_3567
    !a
    a = next_a
    tmp_3568 = load entity+0 as i32
    tmp_3569 = 1
    tmp_3570 = add i, tmp_3569
    !tmp_3569
    tmp_3571 = ne tmp_3568, tmp_3570
    !tmp_3568
    !tmp_3570
    br tmp_3571 -> L_THEN_864, L_ELSE_865

L_THEN_864:
    !tmp_3571
    panic(2150)

L_ELSE_865:
    !tmp_3571
    jmp L_MERGE_866

L_MERGE_866:
    tmp_3574 = alloc 8
    tmp_3575 = load entity+0 as i32
    store tmp_3574+0, tmp_3575 as i32
    tmp_3576 = load entity+4 as i32
    store tmp_3574+4, tmp_3576 as i32
    tmp_3577 = call @sla__dyn_is_alive(a, tmp_3574)
    !tmp_3574
    tmp_3578 = 1
    tmp_3579 = ne tmp_3577, tmp_3578
    !tmp_3577
    !tmp_3578
    br tmp_3579 -> L_THEN_867, L_ELSE_868

L_THEN_867:
    !tmp_3579
    panic(2151)

L_ELSE_868:
    !tmp_3579
    jmp L_MERGE_869

L_MERGE_869:
    tmp_3582 = 1
    tmp_3583 = add i, tmp_3582
    !tmp_3582
    !i
    i = tmp_3583
    !entity
    jmp L_WHILE_HEAD_860

L_WHILE_COND_FALSE_862:
    !tmp_3566
    jmp L_WHILE_EXIT_863

L_WHILE_EXIT_863:
    tmp_3584 = load a+8 as ptr
    EXPAND VEC_LEN tmp_3585, tmp_3584
    !tmp_3584
    tmp_3586 = 21
    tmp_3587 = ne tmp_3585, tmp_3586
    !tmp_3585
    !tmp_3586
    br tmp_3587 -> L_THEN_870, L_ELSE_871

L_THEN_870:
    !tmp_3587
    panic(2152)

L_ELSE_871:
    !tmp_3587
    jmp L_MERGE_872

L_MERGE_872:
    !a
    !i
    return

