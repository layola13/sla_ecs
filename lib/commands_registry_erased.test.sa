    panic(2121)

L_ELSE_844:
    !tmp_3521
    jmp L_MERGE_845

L_MERGE_845:
    tmp_3524 = call @sla__alloc_entity(a2)
    a3 = load tmp_3524+0 as ptr
    e2 = load tmp_3524+8 as ptr
    !tmp_3524
    tmp_3525 = alloc 8
    tmp_3526 = load e2+0 as i32
    store tmp_3525+0, tmp_3526 as i32
    tmp_3527 = load e2+4 as i32
    store tmp_3525+4, tmp_3527 as i32
    tmp_3528 = alloc 8
    tmp_3529 = load fabricated+0 as i32
    store tmp_3528+0, tmp_3529 as i32
    tmp_3530 = load fabricated+4 as i32
    store tmp_3528+4, tmp_3530 as i32
    tmp_3531 = call @sla__entity_eq(tmp_3525, tmp_3528)
    !tmp_3525
    !tmp_3528
    tmp_3532 = 1
    tmp_3533 = ne tmp_3531, tmp_3532
    !tmp_3531
    !tmp_3532
    br tmp_3533 -> L_THEN_846, L_ELSE_847

L_THEN_846:
