@test "entity placeholder is never allocated"():
L_TEST_ENTRY_809:
    tmp_3356 = call @sla__entity_placeholder()
    placeholder = tmp_3356
    tmp_3357 = call @sla__allocator_new()
    a = tmp_3357
    tmp_3358 = call @sla__alloc_entity(a)
    a1 = load tmp_3358+0 as ptr
    e1 = load tmp_3358+8 as ptr
    !tmp_3358
    tmp_3359 = load placeholder+0 as i32
    tmp_3360 = load e1+0 as i32
    tmp_3361 = eq tmp_3359, tmp_3360
    !tmp_3359
    !tmp_3360
    br tmp_3361 -> L_THEN_810, L_ELSE_811

L_THEN_810:
    !tmp_3361
    panic(2100)

L_ELSE_811:
    !tmp_3361
    jmp L_MERGE_812

L_MERGE_812:
    tmp_3364 = alloc 8
    tmp_3365 = load placeholder+0 as i32
    store tmp_3364+0, tmp_3365 as i32
    tmp_3366 = load placeholder+4 as i32
    store tmp_3364+4, tmp_3366 as i32
    tmp_3367 = call @sla__is_alive(a1, tmp_3364)
    !tmp_3364
    tmp_3368 = 0
    tmp_3369 = ne tmp_3367, tmp_3368
    !tmp_3367
    !tmp_3368
    br tmp_3369 -> L_THEN_813, L_ELSE_814

L_THEN_813:
    !tmp_3369
    panic(2101)

L_ELSE_814:
    !tmp_3369
    jmp L_MERGE_815

L_MERGE_815:
    !a
    !placeholder
    !e1
    !a1
    return

@test "entity bit roundtrip"():
L_TEST_ENTRY_816:
    tmp_3372 = 42
    tmp_3373 = 7
    tmp_3374 = call @sla__entity_new(tmp_3372, tmp_3373)
    !tmp_3372
    !tmp_3373
    e = tmp_3374
    tmp_3375 = alloc 8
    tmp_3376 = load e+0 as i32
    store tmp_3375+0, tmp_3376 as i32
    tmp_3377 = load e+4 as i32
    store tmp_3375+4, tmp_3377 as i32
    tmp_3378 = call @sla__entity_to_bits(tmp_3375)
    !tmp_3375
    bits = tmp_3378
    tmp_3379 = call @sla__entity_from_bits(bits)
    out = tmp_3379
    tmp_3380 = alloc 8
    tmp_3381 = load e+0 as i32
    store tmp_3380+0, tmp_3381 as i32
    tmp_3382 = load e+4 as i32
    store tmp_3380+4, tmp_3382 as i32
    tmp_3383 = alloc 8
    tmp_3384 = load out+0 as i32
    store tmp_3383+0, tmp_3384 as i32
    tmp_3385 = load out+4 as i32
    store tmp_3383+4, tmp_3385 as i32
    tmp_3386 = call @sla__entity_eq(tmp_3380, tmp_3383)
    !tmp_3380
    !tmp_3383
    tmp_3387 = 1
    tmp_3388 = ne tmp_3386, tmp_3387
    !tmp_3386
    !tmp_3387
    br tmp_3388 -> L_THEN_817, L_ELSE_818

L_THEN_817:
    !tmp_3388
    panic(2110)

L_ELSE_818:
    !tmp_3388
    jmp L_MERGE_819

L_MERGE_819:
    !out
    !bits
    !e
    return

@test "entity derives value semantics"():
L_TEST_ENTRY_820:
    tmp_3391 = 42
    tmp_3392 = 7
    tmp_3393 = call @sla__entity_new(tmp_3391, tmp_3392)
    !tmp_3391
    !tmp_3392
    e = tmp_3393
    copied = alloc 8
    tmp_3394 = load e+0 as i32
    store copied+0, tmp_3394 as i32
    tmp_3395 = load e+4 as i32
    store copied+4, tmp_3395 as i32
    tmp_3396 = load copied+0 as i32
    tmp_3397 = load e+0 as i32
    tmp_3398 = eq tmp_3396, tmp_3397
    tmp_3399 = load copied+4 as i32
    tmp_3400 = load e+4 as i32
    tmp_3401 = eq tmp_3399, tmp_3400
    tmp_3402 = and tmp_3398, tmp_3401
    tmp_3403 = ne tmp_3402, 1
    br tmp_3403 -> L_THEN_821, L_ELSE_822

L_THEN_821:
    !tmp_3403
    panic(2115)

L_ELSE_822:
    !tmp_3403
    jmp L_MERGE_823

L_MERGE_823:
    tmp_3406 = load e+0 as i32
    tmp_3407 = 42
    tmp_3408 = ne tmp_3406, tmp_3407
    !tmp_3406
    !tmp_3407
    br tmp_3408 -> L_THEN_824, L_ELSE_825

L_THEN_824:
    !tmp_3408
    panic(2116)

L_ELSE_825:
    !tmp_3408
    jmp L_MERGE_826

L_MERGE_826:
    tmp_3411 = 1469598103934665603
    tmp_3412 = load copied+0 as i32
    tmp_3413 = tmp_3412 as u64
    tmp_3414 = xor tmp_3411, tmp_3413
    tmp_3415 = mul tmp_3414, 1099511628211
    tmp_3416 = load copied+4 as i32
    tmp_3417 = tmp_3416 as u64
    tmp_3418 = xor tmp_3415, tmp_3417
    tmp_3419 = mul tmp_3418, 1099511628211
    tmp_3420 = 1469598103934665603
    tmp_3421 = load e+0 as i32
    tmp_3422 = tmp_3421 as u64
    tmp_3423 = xor tmp_3420, tmp_3422
    tmp_3424 = mul tmp_3423, 1099511628211
    tmp_3425 = load e+4 as i32
    tmp_3426 = tmp_3425 as u64
    tmp_3427 = xor tmp_3424, tmp_3426
    tmp_3428 = mul tmp_3427, 1099511628211
    tmp_3429 = ne tmp_3419, tmp_3428
    !tmp_3419
    !tmp_3428
    br tmp_3429 -> L_THEN_827, L_ELSE_828

L_THEN_827:
    !tmp_3429
    panic(2117)

L_ELSE_828:
    !tmp_3429
    jmp L_MERGE_829

L_MERGE_829:
    tmp_3432 = 42
    tmp_3433 = 8
    tmp_3434 = call @sla__entity_new(tmp_3432, tmp_3433)
    !tmp_3432
    !tmp_3433
    later = tmp_3434
    tmp_3435 = load e+0 as i32
    tmp_3436 = load later+0 as i32
    tmp_3437 = slt tmp_3435, tmp_3436
    tmp_3438 = eq tmp_3435, tmp_3436
    tmp_3439 = load e+4 as i32
    tmp_3440 = load later+4 as i32
    tmp_3441 = slt tmp_3439, tmp_3440
    tmp_3442 = eq tmp_3439, tmp_3440
    tmp_3443 = and tmp_3438, tmp_3441
    tmp_3444 = or tmp_3437, tmp_3443
    tmp_3445 = and tmp_3438, tmp_3442
    tmp_3446 = or tmp_3444, 0
    tmp_3447 = 1
    tmp_3448 = ne tmp_3446, tmp_3447
    !tmp_3446
    !tmp_3447
    br tmp_3448 -> L_THEN_830, L_ELSE_831

L_THEN_830:
    !tmp_3448
    panic(2118)

L_ELSE_831:
    !tmp_3448
    jmp L_MERGE_832

L_MERGE_832:
    tmp_3451 = load later+0 as i32
    tmp_3452 = load e+0 as i32
    tmp_3453 = sgt tmp_3451, tmp_3452
    tmp_3454 = eq tmp_3451, tmp_3452
    tmp_3455 = load later+4 as i32
    tmp_3456 = load e+4 as i32
    tmp_3457 = sgt tmp_3455, tmp_3456
    tmp_3458 = eq tmp_3455, tmp_3456
    tmp_3459 = and tmp_3454, tmp_3457
    tmp_3460 = or tmp_3453, tmp_3459
    tmp_3461 = and tmp_3454, tmp_3458
    tmp_3462 = or tmp_3460, 0
    tmp_3463 = 1
    tmp_3464 = ne tmp_3462, tmp_3463
    !tmp_3462
    !tmp_3463
    br tmp_3464 -> L_THEN_833, L_ELSE_834

L_THEN_833:
    !tmp_3464
    panic(2119)

L_ELSE_834:
    !tmp_3464
    jmp L_MERGE_835

L_MERGE_835:
    EXPAND FORMAT_BEGIN tmp_3467, 128
    @const SLA_STR_0 = utf8:"Entity"
    tmp_3468 = &SLA_STR_0
    EXPAND FORMAT_PUSH_BYTES tmp_3469, tmp_3467, tmp_3468, 6
    !tmp_3468
    @const SLA_STR_1 = utf8:" { "
    tmp_3470 = &SLA_STR_1
    EXPAND FORMAT_PUSH_BYTES tmp_3471, tmp_3467, tmp_3470, 3
    !tmp_3470
    @const SLA_STR_2 = utf8:"id"
    tmp_3472 = &SLA_STR_2
    EXPAND FORMAT_PUSH_BYTES tmp_3473, tmp_3467, tmp_3472, 2
    !tmp_3472
    @const SLA_STR_3 = utf8:": "
    tmp_3474 = &SLA_STR_3
    EXPAND FORMAT_PUSH_BYTES tmp_3475, tmp_3467, tmp_3474, 2
    !tmp_3474
    tmp_3476 = load e+0 as i32
    EXPAND FORMAT_PUSH_I64 tmp_3477, tmp_3467, tmp_3476
    @const SLA_STR_4 = utf8:", "
    tmp_3478 = &SLA_STR_4
    EXPAND FORMAT_PUSH_BYTES tmp_3479, tmp_3467, tmp_3478, 2
    !tmp_3478
    @const SLA_STR_5 = utf8:"gen"
    tmp_3480 = &SLA_STR_5
    EXPAND FORMAT_PUSH_BYTES tmp_3481, tmp_3467, tmp_3480, 3
    !tmp_3480
    @const SLA_STR_6 = utf8:": "
    tmp_3482 = &SLA_STR_6
    EXPAND FORMAT_PUSH_BYTES tmp_3483, tmp_3467, tmp_3482, 2
    !tmp_3482
    tmp_3484 = load e+4 as i32
    EXPAND FORMAT_PUSH_I64 tmp_3485, tmp_3467, tmp_3484
    @const SLA_STR_7 = utf8:" }"
    tmp_3486 = &SLA_STR_7
    EXPAND FORMAT_PUSH_BYTES tmp_3487, tmp_3467, tmp_3486, 2
    !tmp_3486
    text = tmp_3467
    EXPAND STRING_BUF_AS_STR tmp_3488, text
    EXPAND STRING_LEN tmp_3489, tmp_3488
    !tmp_3488
    tmp_3490 = 0
    tmp_3491 = eq tmp_3489, tmp_3490
    !tmp_3489
    !tmp_3490
    br tmp_3491 -> L_THEN_836, L_ELSE_837

L_THEN_836:
    !tmp_3491
    panic(2124)

L_ELSE_837:
    !tmp_3491
    jmp L_MERGE_838

L_MERGE_838:
    EXPAND STRING_BUF_FREE text
    !copied
    !e
    !later
    return

@test "allocator rejects stale generation"():
L_TEST_ENTRY_839:
    tmp_3494 = call @sla__allocator_new()
    a0 = tmp_3494
    tmp_3495 = call @sla__alloc_entity(a0)
    a1 = load tmp_3495+0 as ptr
    e1 = load tmp_3495+8 as ptr
    !tmp_3495
    tmp_3496 = alloc 8
    tmp_3497 = load e1+0 as i32
    store tmp_3496+0, tmp_3497 as i32
    tmp_3498 = load e1+4 as i32
    store tmp_3496+4, tmp_3498 as i32
    tmp_3499 = call @sla__free_entity(a1, tmp_3496)
    !tmp_3496
    a2 = tmp_3499
    tmp_3500 = load e1+0 as i32
    tmp_3501 = load e1+4 as i32
    tmp_3502 = call @sla__entity_new(tmp_3500, tmp_3501)
    !tmp_3500
    !tmp_3501
    stale = tmp_3502
    tmp_3503 = load e1+0 as i32
    tmp_3504 = load e1+4 as i32
    tmp_3505 = 1
    tmp_3506 = add tmp_3504, tmp_3505
    !tmp_3504
    !tmp_3505
    tmp_3507 = call @sla__entity_new(tmp_3503, tmp_3506)
    !tmp_3503
    !tmp_3506
    fabricated = tmp_3507
    tmp_3508 = alloc 8
    tmp_3509 = load stale+0 as i32
    store tmp_3508+0, tmp_3509 as i32
    tmp_3510 = load stale+4 as i32
    store tmp_3508+4, tmp_3510 as i32
    tmp_3511 = call @sla__is_alive(a2, tmp_3508)
    !tmp_3508
    tmp_3512 = 0
    tmp_3513 = ne tmp_3511, tmp_3512
    !tmp_3511
    !tmp_3512
    br tmp_3513 -> L_THEN_840, L_ELSE_841

L_THEN_840:
    !tmp_3513
    panic(2120)

L_ELSE_841:
    !tmp_3513
