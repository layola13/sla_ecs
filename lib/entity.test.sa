@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_entity_new = vtable { call = @sla__entity_new }
@const SLA_FNPTR_VT_entity_placeholder = vtable { call = @sla__entity_placeholder }
@const SLA_FNPTR_VT_entity_index = vtable { call = @sla__entity_index }
@const SLA_FNPTR_VT_entity_generation = vtable { call = @sla__entity_generation }
@const SLA_FNPTR_VT_entity_eq = vtable { call = @sla__entity_eq }
@const SLA_FNPTR_VT_entity_to_bits = vtable { call = @sla__entity_to_bits }
@const SLA_FNPTR_VT_entity_from_bits = vtable { call = @sla__entity_from_bits }
@const SLA_FNPTR_VT_allocator_new = vtable { call = @sla__allocator_new }
@const SLA_FNPTR_VT_alloc_entity = vtable { call = @sla__alloc_entity }
@const SLA_FNPTR_VT_allocator_id_is_free = vtable { call = @sla__allocator_id_is_free }
@const SLA_FNPTR_VT_is_alive = vtable { call = @sla__is_alive }
@const SLA_FNPTR_VT_free_entity = vtable { call = @sla__free_entity }
@sla__entity_new(id: i32, gen: i32) -> ptr:
L_ENTRY:
    tmp_0 = alloc 8
    store tmp_0+0, id as i32
    store tmp_0+4, gen as i32
    return tmp_0

@sla__entity_placeholder() -> ptr:
L_ENTRY:
    tmp_1 = alloc 8
    tmp_2 = 0
    store tmp_1+0, tmp_2 as i32
    !tmp_2
    tmp_3 = 0
    tmp_4 = 1
    tmp_5 = sub tmp_3, tmp_4
    !tmp_3
    !tmp_4
    store tmp_1+4, tmp_5 as i32
    !tmp_5
    return tmp_1

@sla__entity_index(entity: ptr) -> i32:
L_ENTRY:
    tmp_6 = load entity+0 as i32
    !entity
    return tmp_6

@sla__entity_generation(entity: ptr) -> i32:
L_ENTRY:
    tmp_7 = load entity+4 as i32
    !entity
    return tmp_7

@sla__entity_eq(a: ptr, b: ptr) -> u8:
L_ENTRY:
    tmp_8 = load a+0 as i32
    tmp_9 = load b+0 as i32
    tmp_10 = ne tmp_8, tmp_9
    !tmp_8
    !tmp_9
    br tmp_10 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_10
    tmp_11 = 0
    !b
    !a
    return tmp_11

L_ELSE_1:
    !tmp_10
    jmp L_MERGE_2

L_MERGE_2:
    tmp_13 = load a+4 as i32
    tmp_14 = load b+4 as i32
    tmp_15 = eq tmp_13, tmp_14
    !tmp_13
    !tmp_14
    !b
    !a
    return tmp_15

@sla__entity_to_bits(entity: ptr) -> i64:
L_ENTRY:
    tmp_16 = load entity+4 as i32
    tmp_17 = tmp_16 as i64
    gen_part = tmp_17
    tmp_18 = load entity+0 as i32
    tmp_19 = tmp_18 as i64
    id_part = tmp_19
    tmp_20 = 4294967296
    tmp_21 = mul gen_part, tmp_20
    !tmp_20
    tmp_22 = add tmp_21, id_part
    !tmp_21
    !entity
    return tmp_22

@sla__entity_from_bits(bits: i64) -> ptr:
L_ENTRY:
    tmp_23 = 4294967296
    tmp_24 = div bits, tmp_23
    !tmp_23
    gen64 = tmp_24
    tmp_25 = 4294967296
    tmp_26 = mul gen64, tmp_25
    !tmp_25
    tmp_27 = sub bits, tmp_26
    !tmp_26
    id64 = tmp_27
    tmp_28 = alloc 8
    tmp_29 = id64 as i32
    store tmp_28+0, tmp_29 as i32
    !tmp_29
    tmp_30 = gen64 as i32
    store tmp_28+4, tmp_30 as i32
    !tmp_30
    !bits
    return tmp_28

@sla__allocator_new() -> ptr:
L_ENTRY:
    tmp_31 = alloc 24
    tmp_32 = 1
    store tmp_31+0, tmp_32 as i32
    !tmp_32
    tmp_33 = 0
    store tmp_31+4, tmp_33 as i32
    !tmp_33
    tmp_34 = alloc 64
    tmp_35 = 0
    store tmp_34+0, tmp_35 as i32
    store tmp_34+4, tmp_35 as i32
    store tmp_34+8, tmp_35 as i32
    store tmp_34+12, tmp_35 as i32
    store tmp_34+16, tmp_35 as i32
    store tmp_34+20, tmp_35 as i32
    store tmp_34+24, tmp_35 as i32
    store tmp_34+28, tmp_35 as i32
    store tmp_34+32, tmp_35 as i32
    store tmp_34+36, tmp_35 as i32
    store tmp_34+40, tmp_35 as i32
    store tmp_34+44, tmp_35 as i32
    store tmp_34+48, tmp_35 as i32
    store tmp_34+52, tmp_35 as i32
    store tmp_34+56, tmp_35 as i32
    store tmp_34+60, tmp_35 as i32
    !tmp_35
    store tmp_31+8, tmp_34 as ptr
    !tmp_34
    tmp_36 = alloc 64
    tmp_37 = 0
    store tmp_36+0, tmp_37 as i32
    store tmp_36+4, tmp_37 as i32
    store tmp_36+8, tmp_37 as i32
    store tmp_36+12, tmp_37 as i32
    store tmp_36+16, tmp_37 as i32
    store tmp_36+20, tmp_37 as i32
    store tmp_36+24, tmp_37 as i32
    store tmp_36+28, tmp_37 as i32
    store tmp_36+32, tmp_37 as i32
    store tmp_36+36, tmp_37 as i32
    store tmp_36+40, tmp_37 as i32
    store tmp_36+44, tmp_37 as i32
    store tmp_36+48, tmp_37 as i32
    store tmp_36+52, tmp_37 as i32
    store tmp_36+56, tmp_37 as i32
    store tmp_36+60, tmp_37 as i32
    !tmp_37
    store tmp_31+16, tmp_36 as ptr
    !tmp_36
    return tmp_31

@sla__alloc_entity(a: ptr) -> ptr:
L_ENTRY:
    tmp_38 = load a+4 as i32
    tmp_39 = 0
    tmp_40 = sgt tmp_38, tmp_39
    !tmp_38
    !tmp_39
    br tmp_40 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_40
    tmp_41 = load a+4 as i32
    tmp_42 = 1
    tmp_43 = sub tmp_41, tmp_42
    !tmp_41
    !tmp_42
    next_free_count = tmp_43
    tmp_44 = load a+16 as ptr
    tmp_45 = mul next_free_count, 4
    tmp_46 = ptr_add tmp_44, tmp_45
    !tmp_45
    tmp_47 = load tmp_46+0 as i32
    !tmp_46
    !tmp_44
    id = tmp_47
    store a+4, next_free_count as i32
    tmp_48 = load a+16 as ptr
    tmp_49 = mul next_free_count, 4
    tmp_50 = ptr_add tmp_48, tmp_49
    !tmp_49
    tmp_51 = 0
    store tmp_50+0, tmp_51 as i32
    !tmp_50
    !tmp_48
    !tmp_51
    tmp_52 = alloc 16
    store tmp_52+0, a as ptr
    tmp_53 = load a+8 as ptr
    tmp_54 = mul id, 4
    tmp_55 = ptr_add tmp_53, tmp_54
    !tmp_54
    tmp_56 = load tmp_55+0 as i32
    !tmp_55
    !tmp_53
    tmp_57 = call @sla__entity_new(id, tmp_56)
    !tmp_56
    store tmp_52+8, tmp_57 as ptr
    !next_free_count
    return tmp_52

L_ELSE_4:
    !tmp_40
    jmp L_MERGE_5

L_MERGE_5:
    tmp_59 = load a+0 as i32
    tmp_60 = 16
    tmp_61 = sge tmp_59, tmp_60
    !tmp_59
    !tmp_60
    br tmp_61 -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !tmp_61
    panic(2001)

L_ELSE_7:
    !tmp_61
    jmp L_MERGE_8

L_MERGE_8:
    tmp_64 = load a+0 as i32
    id = tmp_64
    tmp_65 = 1
    tmp_66 = add id, tmp_65
    !tmp_65
    store a+0, tmp_66 as i32
    !tmp_66
    tmp_67 = alloc 16
    store tmp_67+0, a as ptr
    tmp_68 = load a+8 as ptr
    tmp_69 = mul id, 4
    tmp_70 = ptr_add tmp_68, tmp_69
    !tmp_69
    tmp_71 = load tmp_70+0 as i32
    !tmp_70
    !tmp_68
    tmp_72 = call @sla__entity_new(id, tmp_71)
    !tmp_71
    store tmp_67+8, tmp_72 as ptr
    return tmp_67

@sla__allocator_id_is_free(a: ptr, id: i32) -> u8:
L_ENTRY:
    tmp_73 = 0
    i = tmp_73
    jmp L_WHILE_HEAD_9

L_WHILE_HEAD_9:
    tmp_74 = load a+4 as i32
    tmp_75 = slt i, tmp_74
    !tmp_74
    br tmp_75 -> L_WHILE_BODY_10, L_WHILE_COND_FALSE_11

L_WHILE_BODY_10:
    !tmp_75
    tmp_76 = load a+16 as ptr
    tmp_77 = mul i, 4
    tmp_78 = ptr_add tmp_76, tmp_77
    !tmp_77
    tmp_79 = load tmp_78+0 as i32
    !tmp_78
    !tmp_76
    tmp_80 = eq tmp_79, id
    !tmp_79
    br tmp_80 -> L_THEN_13, L_ELSE_14

L_THEN_13:
    !tmp_80
    tmp_81 = 1
    !i
    !a
    !id
    return tmp_81

L_ELSE_14:
    !tmp_80
    jmp L_MERGE_15

L_MERGE_15:
    tmp_83 = 1
    tmp_84 = add i, tmp_83
    !tmp_83
    !i
    i = tmp_84
    jmp L_WHILE_HEAD_9

L_WHILE_COND_FALSE_11:
    !tmp_75
    jmp L_WHILE_EXIT_12

L_WHILE_EXIT_12:
    tmp_85 = 0
    !i
    !a
    !id
    return tmp_85

@sla__is_alive(a: ptr, entity: ptr) -> u8:
L_ENTRY:
    tmp_86 = load entity+0 as i32
    tmp_87 = 0
    tmp_88 = sle tmp_86, tmp_87
    !tmp_86
    !tmp_87
    br tmp_88 -> L_THEN_16, L_ELSE_17

L_THEN_16:
    !tmp_88
    tmp_89 = 0
    !entity
    !a
    return tmp_89

L_ELSE_17:
    !tmp_88
    jmp L_MERGE_18

L_MERGE_18:
    tmp_91 = load entity+0 as i32
    tmp_92 = 16
    tmp_93 = sge tmp_91, tmp_92
    !tmp_91
    !tmp_92
    br tmp_93 -> L_THEN_19, L_ELSE_20

L_THEN_19:
    !tmp_93
    tmp_94 = 0
    !entity
    !a
    return tmp_94

L_ELSE_20:
    !tmp_93
    jmp L_MERGE_21

L_MERGE_21:
    tmp_96 = load entity+0 as i32
    tmp_97 = load a+0 as i32
    tmp_98 = sge tmp_96, tmp_97
    !tmp_96
    !tmp_97
    br tmp_98 -> L_THEN_22, L_ELSE_23

L_THEN_22:
    !tmp_98
    tmp_99 = 0
    !entity
    !a
    return tmp_99

L_ELSE_23:
    !tmp_98
    jmp L_MERGE_24

L_MERGE_24:
    tmp_101 = load entity+0 as i32
    tmp_102 = call @sla__allocator_id_is_free(a, tmp_101)
    !tmp_101
    br tmp_102 -> L_THEN_25, L_ELSE_26

L_THEN_25:
    !tmp_102
    tmp_103 = 0
    !entity
    !a
    return tmp_103

L_ELSE_26:
    !tmp_102
    jmp L_MERGE_27

L_MERGE_27:
    tmp_105 = load a+8 as ptr
    tmp_106 = load entity+0 as i32
    tmp_107 = mul tmp_106, 4
    tmp_108 = ptr_add tmp_105, tmp_107
    !tmp_107
    !tmp_106
    tmp_109 = load tmp_108+0 as i32
    !tmp_108
    !tmp_105
    tmp_110 = load entity+4 as i32
    tmp_111 = eq tmp_109, tmp_110
    !tmp_109
    !tmp_110
    !entity
    !a
    return tmp_111

@sla__free_entity(a: ptr, entity: ptr) -> ptr:
L_ENTRY:
    tmp_112 = call @sla__is_alive(a, entity)
    tmp_113 = 1
    tmp_114 = ne tmp_112, tmp_113
    !tmp_112
    !tmp_113
    br tmp_114 -> L_THEN_28, L_ELSE_29

L_THEN_28:
    !tmp_114
    !entity
    return a

L_ELSE_29:
    !tmp_114
    jmp L_MERGE_30

L_MERGE_30:
    tmp_116 = load a+8 as ptr
    tmp_117 = load entity+0 as i32
    tmp_118 = mul tmp_117, 4
    tmp_119 = ptr_add tmp_116, tmp_118
    !tmp_118
    !tmp_117
    tmp_120 = load a+8 as ptr
    tmp_121 = load entity+0 as i32
    tmp_122 = mul tmp_121, 4
    tmp_123 = ptr_add tmp_120, tmp_122
    !tmp_122
    !tmp_121
    tmp_124 = load tmp_123+0 as i32
    !tmp_123
    !tmp_120
    tmp_125 = 1
    tmp_126 = add tmp_124, tmp_125
    !tmp_124
    !tmp_125
    store tmp_119+0, tmp_126 as i32
    !tmp_119
    !tmp_116
    !tmp_126
    tmp_127 = load a+16 as ptr
    tmp_128 = load a+4 as i32
    tmp_129 = mul tmp_128, 4
    tmp_130 = ptr_add tmp_127, tmp_129
    !tmp_129
    !tmp_128
    tmp_131 = load entity+0 as i32
    store tmp_130+0, tmp_131 as i32
    !tmp_130
    !tmp_127
    !tmp_131
    tmp_132 = load a+4 as i32
    tmp_133 = 1
    tmp_134 = add tmp_132, tmp_133
    !tmp_132
    !tmp_133
    store a+4, tmp_134 as i32
    !tmp_134
    !entity
    return a

@test "entity placeholder is never allocated"():
L_TEST_ENTRY_31:
    tmp_135 = call @sla__entity_placeholder()
    placeholder = tmp_135
    tmp_136 = call @sla__allocator_new()
    a = tmp_136
    tmp_137 = call @sla__alloc_entity(a)
    a1 = load tmp_137+0 as ptr
    e1 = load tmp_137+8 as ptr
    !tmp_137
    tmp_138 = load placeholder+0 as i32
    tmp_139 = load e1+0 as i32
    tmp_140 = eq tmp_138, tmp_139
    !tmp_138
    !tmp_139
    br tmp_140 -> L_THEN_32, L_ELSE_33

L_THEN_32:
    !tmp_140
    panic(2100)

L_ELSE_33:
    !tmp_140
    jmp L_MERGE_34

L_MERGE_34:
    tmp_143 = call @sla__is_alive(a1, placeholder)
    tmp_144 = 0
    tmp_145 = ne tmp_143, tmp_144
    !tmp_143
    !tmp_144
    br tmp_145 -> L_THEN_35, L_ELSE_36

L_THEN_35:
    !tmp_145
    panic(2101)

L_ELSE_36:
    !tmp_145
    jmp L_MERGE_37

L_MERGE_37:
    !a
    !placeholder
    !e1
    !a1
    return

@test "entity bit roundtrip"():
L_TEST_ENTRY_38:
    tmp_148 = 42
    tmp_149 = 7
    tmp_150 = call @sla__entity_new(tmp_148, tmp_149)
    !tmp_148
    !tmp_149
    e = tmp_150
    tmp_151 = call @sla__entity_to_bits(e)
    bits = tmp_151
    tmp_152 = call @sla__entity_from_bits(bits)
    out = tmp_152
    tmp_153 = call @sla__entity_eq(e, out)
    tmp_154 = 1
    tmp_155 = ne tmp_153, tmp_154
    !tmp_153
    !tmp_154
    br tmp_155 -> L_THEN_39, L_ELSE_40

L_THEN_39:
    !tmp_155
    panic(2110)

L_ELSE_40:
    !tmp_155
    jmp L_MERGE_41

L_MERGE_41:
    !out
    !bits
    !e
    return

@test "allocator rejects stale generation"():
L_TEST_ENTRY_42:
    tmp_158 = call @sla__allocator_new()
    a0 = tmp_158
    tmp_159 = call @sla__alloc_entity(a0)
    a1 = load tmp_159+0 as ptr
    e1 = load tmp_159+8 as ptr
    !tmp_159
    tmp_160 = call @sla__free_entity(a1, e1)
    a2 = tmp_160
    tmp_161 = load e1+0 as i32
    tmp_162 = load e1+4 as i32
    tmp_163 = call @sla__entity_new(tmp_161, tmp_162)
    !tmp_161
    !tmp_162
    stale = tmp_163
    tmp_164 = load e1+0 as i32
    tmp_165 = load e1+4 as i32
    tmp_166 = 1
    tmp_167 = add tmp_165, tmp_166
    !tmp_165
    !tmp_166
    tmp_168 = call @sla__entity_new(tmp_164, tmp_167)
    !tmp_164
    !tmp_167
    fabricated = tmp_168
    tmp_169 = call @sla__is_alive(a2, stale)
    tmp_170 = 0
    tmp_171 = ne tmp_169, tmp_170
    !tmp_169
    !tmp_170
    br tmp_171 -> L_THEN_43, L_ELSE_44

L_THEN_43:
    !tmp_171
    panic(2120)

L_ELSE_44:
    !tmp_171
    jmp L_MERGE_45

L_MERGE_45:
    tmp_174 = call @sla__is_alive(a2, fabricated)
    tmp_175 = 0
    tmp_176 = ne tmp_174, tmp_175
    !tmp_174
    !tmp_175
    br tmp_176 -> L_THEN_46, L_ELSE_47

L_THEN_46:
    !tmp_176
    panic(2121)

L_ELSE_47:
    !tmp_176
    jmp L_MERGE_48

L_MERGE_48:
    tmp_179 = call @sla__alloc_entity(a2)
    a3 = load tmp_179+0 as ptr
    e2 = load tmp_179+8 as ptr
    !tmp_179
    tmp_180 = call @sla__entity_eq(e2, fabricated)
    tmp_181 = 1
    tmp_182 = ne tmp_180, tmp_181
    !tmp_180
    !tmp_181
    br tmp_182 -> L_THEN_49, L_ELSE_50

L_THEN_49:
    !tmp_182
    panic(2122)

L_ELSE_50:
    !tmp_182
    jmp L_MERGE_51

L_MERGE_51:
    tmp_185 = call @sla__is_alive(a3, e2)
    tmp_186 = 1
    tmp_187 = ne tmp_185, tmp_186
    !tmp_185
    !tmp_186
    br tmp_187 -> L_THEN_52, L_ELSE_53

L_THEN_52:
    !tmp_187
    panic(2123)

L_ELSE_53:
    !tmp_187
    jmp L_MERGE_54

L_MERGE_54:
    !e2
    !a0
    !a2
    !fabricated
    !stale
    !e1
    !a3
    !a1
    return

@test "entity index generation accessors"():
L_TEST_ENTRY_55:
    tmp_190 = 5
    tmp_191 = 3
    tmp_192 = call @sla__entity_new(tmp_190, tmp_191)
    !tmp_190
    !tmp_191
    e = tmp_192
    tmp_193 = call @sla__entity_index(e)
    tmp_194 = 5
    tmp_195 = ne tmp_193, tmp_194
    !tmp_193
    !tmp_194
    br tmp_195 -> L_THEN_56, L_ELSE_57

L_THEN_56:
    !tmp_195
    panic(2130)

L_ELSE_57:
    !tmp_195
    jmp L_MERGE_58

L_MERGE_58:
    tmp_198 = call @sla__entity_generation(e)
    tmp_199 = 3
    tmp_200 = ne tmp_198, tmp_199
    !tmp_198
    !tmp_199
    br tmp_200 -> L_THEN_59, L_ELSE_60

L_THEN_59:
    !tmp_200
    panic(2131)

L_ELSE_60:
    !tmp_200
    jmp L_MERGE_61

L_MERGE_61:
    !e
    return
