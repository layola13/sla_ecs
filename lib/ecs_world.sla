// Query four components on the same entity: Query<(A, B, C, D)>.
fn ecs_world_query_quad<A, B, C, D, R, M>(world: TableErasedWorld<R, M>, first_type_id: i32, second_type_id: i32, third_type_id: i32, fourth_type_id: i32) -> Query<TableErasedQuad<A, B, C, D>> {
    return table_erased_world_query_quad_auto<A, B, C, D, R, M>(world, first_type_id, second_type_id, third_type_id, fourth_type_id);
}

// Query five components on the same entity: Query<(A, B, C, D, E)>.
fn ecs_world_query_quintuple<A, B, C, D, E, R, M>(world: TableErasedWorld<R, M>, first_type_id: i32, second_type_id: i32, third_type_id: i32, fourth_type_id: i32, fifth_type_id: i32) -> Query<TableErasedQuintuple<A, B, C, D, E>> {
    return table_erased_world_query_quintuple_auto<A, B, C, D, E, R, M>(world, first_type_id, second_type_id, third_type_id, fourth_type_id, fifth_type_id);
}

fn ecs_world_query_pair_count<R, M>(world: TableErasedWorld<R, M>, first_type_id: i32, second_type_id: i32) -> i64 {
    return table_erased_world_query_pair_count_auto<R, M>(world, first_type_id, second_type_id);
}

fn ecs_world_query_pair_is_empty<R, M>(world: TableErasedWorld<R, M>, first_type_id: i32, second_type_id: i32) -> bool {
    return table_erased_world_query_pair_is_empty_auto<R, M>(world, first_type_id, second_type_id);
}

fn ecs_world_query_pair_contains<R, M>(world: TableErasedWorld<R, M>, entity: Entity, first_type_id: i32, second_type_id: i32) -> bool {
    return table_erased_world_query_pair_contains_auto<R, M>(world, entity, first_type_id, second_type_id);
