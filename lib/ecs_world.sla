fn ecs_world_query_pair_mut<A, B, R, M>(world: TableErasedWorld<R, M>, first_type_id: i32, second_type_id: i32) -> Query<TableErasedPairMut<A, B>> {
    return table_erased_world_query_pair_mut_first_auto<A, B, R, M>(world, first_type_id, second_type_id);
}

fn ecs_world_apply_pair_mut<A, B, R, M>(world: TableErasedWorld<R, M>, updated: Query<TableErasedPairMut<A, B>>) -> TableErasedWorld<R, M> {
    return table_erased_apply_pair_mut_updates<A, B, R, M>(world, updated);
}

// Multi-entity fetch (Bevy Query::get_many / iter_many). Fetch components for a
// specific list of entities, preserving input order and skipping non-matching.
fn ecs_world_get_many<T, R, M>(world: TableErasedWorld<R, M>, entities: Vec<Entity>, type_id: i32) -> Query<EntityItem<T>> {
    return table_erased_world_query_get_many_auto<T, R, M>(world, entities, type_id);
}

fn ecs_world_get_many_unique<T, R, M>(world: TableErasedWorld<R, M>, entities: Vec<Entity>, type_id: i32) -> Query<EntityItem<T>> {
    return table_erased_world_query_get_many_unique_auto<T, R, M>(world, entities, type_id);
}

fn ecs_world_iter_many<T, R, M>(world: TableErasedWorld<R, M>, entities: Vec<Entity>, type_id: i32) -> Query<EntityItem<T>> {
    return table_erased_world_query_iter_many_auto<T, R, M>(world, entities, type_id);
}

fn ecs_world_iter_many_unique<T, R, M>(world: TableErasedWorld<R, M>, entities: Vec<Entity>, type_id: i32) -> Query<EntityItem<T>> {
    return table_erased_world_query_iter_many_unique_auto<T, R, M>(world, entities, type_id);
}

// --- Change detection ---

fn ecs_world_added_since<R, M>(world: TableErasedWorld<R, M>, entity: Entity, type_id: i32, tick: i32) -> bool {
    return table_erased_world_added_since_auto<R, M>(world, entity, type_id, tick);
}

fn ecs_world_changed_since<R, M>(world: TableErasedWorld<R, M>, entity: Entity, type_id: i32, tick: i32) -> bool {
    return table_erased_world_changed_since_auto<R, M>(world, entity, type_id, tick);
}

fn ecs_world_removed_components<R, M>(world: TableErasedWorld<R, M>, type_id: i32, since_tick: i32) -> Query<Entity> {
    return table_erased_world_removed_components_auto<R, M>(world, type_id, since_tick);
}

