}

fn ecs_world_has_resource<R, M>(world: TableErasedWorld<R, M>) -> bool {
    return table_erased_world_has_resource<R, M>(world);
}

fn ecs_world_remove_resource<R, M>(world: TableErasedWorld<R, M>) -> TableErasedWorld<R, M> {
    return table_erased_world_remove_resource<R, M>(world);
}

// --- Messages ---

fn ecs_world_write_message<R, M>(world: TableErasedWorld<R, M>, value: M) -> TableErasedWorld<R, M> {
    return table_erased_world_write_message<R, M>(world, value);
}

fn ecs_world_read_message<R, M>(world: TableErasedWorld<R, M>, reader: MessageReader, default_m: M) -> MessageRead<M> {
    return table_erased_world_read_message<R, M>(world, reader, default_m);
}

fn ecs_world_messages_len<R, M>(world: TableErasedWorld<R, M>) -> i64 {
    return table_erased_world_messages_len<R, M>(world);
}

// --- Tick ---

fn ecs_world_increment_tick<R, M>(world: TableErasedWorld<R, M>) -> TableErasedWorld<R, M> {
