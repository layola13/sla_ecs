// Unified Bevy-style World facade over the table-erased full stack.
//
// This is the single outward-facing entry point: it wraps TableErasedWorld
// (archetype + type-erased columns + resources + messages + change ticks) and
// exposes Bevy-README-shaped helpers so users do not touch the many
// stepping-stone world types directly. Component identity still flows through
// explicit type_id values because Sla generic functions cannot call
// T::component_type_id(); register components once with ecs_world_register_*,
// then use ecs_world_insert/get/query which resolve component_id from type_id
// automatically.
@import "schedule_table_erased.sla"
@import "world_table_erased.sla"
@import "box_drop.sla"
@import "ecs_metadata.sla"
@import "bundle_info.sla"
@import "result.sla"
@import "system_param_table_erased.sla"

// --- World lifecycle ---

fn ecs_world_new<R, M>(default_r: R, default_m: M) -> TableErasedWorld<R, M> {
    return table_erased_world_new<R, M>(default_r, default_m);
}

// Register a table-backed component type. Returns the updated world.
fn ecs_world_register_table<T, R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> TableErasedWorld<R, M> {
    let (next, _info) = table_erased_world_register_table<R, M>(world, type_id, ecs_box_drop<T>);
    return next;
}

// Register a sparse-set-backed component type. Returns the updated world.
fn ecs_world_register_sparse_set<T, R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> TableErasedWorld<R, M> {
    let (next, _info) = table_erased_world_register_sparse_set<R, M>(world, type_id, ecs_box_drop<T>);
    return next;
}

// Register a component type choosing storage by the user-supplied storage kind.
// storage_kind 0 = table, 1 = sparse-set (matches Component::component_storage_kind).
fn ecs_world_register<T, R, M>(world: TableErasedWorld<R, M>, type_id: i32, storage_kind: i32) -> TableErasedWorld<R, M> {
    if storage_kind == 1 {
        return ecs_world_register_sparse_set<T, R, M>(world, type_id);
    };
    return ecs_world_register_table<T, R, M>(world, type_id);
}

// --- Entity lifecycle ---

fn ecs_world_spawn<R, M>(world: TableErasedWorld<R, M>) -> (TableErasedWorld<R, M>, Entity) {
    return table_erased_world_spawn<R, M>(world);
}

fn ecs_world_despawn<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> TableErasedWorld<R, M> {
    return table_erased_world_despawn<R, M>(world, entity);
}

fn ecs_world_is_alive<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> bool {
    return table_erased_world_is_alive<R, M>(world, entity);
}

// --- Component access (auto resolves component_id from type_id) ---

fn ecs_world_insert<T, R, M>(world: TableErasedWorld<R, M>, entity: Entity, type_id: i32, value: T) -> TableErasedWorld<R, M> {
    return table_erased_world_insert_auto<T, R, M>(world, entity, type_id, value);
}

fn ecs_world_get<T, R, M>(world: TableErasedWorld<R, M>, entity: Entity, type_id: i32) -> T {
    return table_erased_world_get_auto<T, R, M>(world, entity, type_id);
}

fn ecs_world_has<R, M>(world: TableErasedWorld<R, M>, entity: Entity, type_id: i32) -> bool {
    return table_erased_world_has_type<R, M>(world, entity, type_id);
}

fn ecs_world_remove<R, M>(world: TableErasedWorld<R, M>, entity: Entity, type_id: i32) -> TableErasedWorld<R, M> {
    return table_erased_world_remove_auto<R, M>(world, entity, type_id);
}

// --- Query access (auto resolves component_id from type_id) ---

fn ecs_world_query<T, R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> Query<EntityItem<T>> {
    return table_erased_world_query_auto<T, R, M>(world, type_id);
}

fn ecs_world_query_count<R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> i64 {
    return table_erased_world_query_count_auto<R, M>(world, type_id);
}

fn ecs_world_query_is_empty<R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> bool {
    return table_erased_world_query_is_empty_auto<R, M>(world, type_id);
}

fn ecs_world_query_single<T, R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> EntityItem<T> {
    return table_erased_world_query_single_auto<T, R, M>(world, type_id);
}

fn ecs_world_component_id_for_type<R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> i32 {
    return table_erased_world_component_id_for_type<R, M>(world, type_id);
}

// --- Multi-component queries (Bevy Query<(A,B)>, Query<(A,B,C)>) ---

fn ecs_world_query_pair<A, B, R, M>(world: TableErasedWorld<R, M>, first_type_id: i32, second_type_id: i32) -> Query<TableErasedPair<A, B>> {
    return table_erased_world_query_pair_auto<A, B, R, M>(world, first_type_id, second_type_id);
}

fn ecs_world_query_triple<A, B, C, R, M>(world: TableErasedWorld<R, M>, first_type_id: i32, second_type_id: i32, third_type_id: i32) -> Query<TableErasedTriple<A, B, C>> {
    return table_erased_world_query_triple_auto<A, B, C, R, M>(world, first_type_id, second_type_id, third_type_id);
