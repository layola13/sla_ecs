    tmp_1225 = mul tmp_1224, 1099511628211
    tmp_1226 = load e+4 as i32
    tmp_1227 = tmp_1226 as u64
    tmp_1228 = xor tmp_1225, tmp_1227
    tmp_1229 = mul tmp_1228, 1099511628211
    tmp_1230 = ne tmp_1220, tmp_1229
    !tmp_1220
    !tmp_1229
    br tmp_1230 -> L_THEN_307, L_ELSE_308

L_THEN_307:
