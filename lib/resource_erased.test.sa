@test "entity placeholder is never allocated"():
L_TEST_ENTRY_289:
    tmp_1157 = call @sla__entity_placeholder()
    placeholder = tmp_1157
    tmp_1158 = call @sla__allocator_new()
    a = tmp_1158
    tmp_1159 = call @sla__alloc_entity(a)
    a1 = load tmp_1159+0 as ptr
    e1 = load tmp_1159+8 as ptr
    !tmp_1159
    tmp_1160 = load placeholder+0 as i32
    tmp_1161 = load e1+0 as i32
    tmp_1162 = eq tmp_1160, tmp_1161
    !tmp_1160
    !tmp_1161
    br tmp_1162 -> L_THEN_290, L_ELSE_291

L_THEN_290:
    !tmp_1162
    panic(2100)

L_ELSE_291:
    !tmp_1162
    jmp L_MERGE_292

L_MERGE_292:
    tmp_1165 = alloc 8
    tmp_1166 = load placeholder+0 as i32
    store tmp_1165+0, tmp_1166 as i32
    tmp_1167 = load placeholder+4 as i32
    store tmp_1165+4, tmp_1167 as i32
    tmp_1168 = call @sla__is_alive(a1, tmp_1165)
    !tmp_1165
    tmp_1169 = 0
    tmp_1170 = ne tmp_1168, tmp_1169
    !tmp_1168
    !tmp_1169
    br tmp_1170 -> L_THEN_293, L_ELSE_294

L_THEN_293:
    !tmp_1170
    panic(2101)

L_ELSE_294:
    !tmp_1170
    jmp L_MERGE_295

L_MERGE_295:
    !a
    !placeholder
    !e1
    !a1
    return

@test "entity bit roundtrip"():
L_TEST_ENTRY_296:
    tmp_1173 = 42
    tmp_1174 = 7
    tmp_1175 = call @sla__entity_new(tmp_1173, tmp_1174)
    !tmp_1173
    !tmp_1174
    e = tmp_1175
    tmp_1176 = alloc 8
    tmp_1177 = load e+0 as i32
    store tmp_1176+0, tmp_1177 as i32
    tmp_1178 = load e+4 as i32
    store tmp_1176+4, tmp_1178 as i32
    tmp_1179 = call @sla__entity_to_bits(tmp_1176)
    !tmp_1176
    bits = tmp_1179
    tmp_1180 = call @sla__entity_from_bits(bits)
    out = tmp_1180
    tmp_1181 = alloc 8
    tmp_1182 = load e+0 as i32
    store tmp_1181+0, tmp_1182 as i32
    tmp_1183 = load e+4 as i32
    store tmp_1181+4, tmp_1183 as i32
    tmp_1184 = alloc 8
    tmp_1185 = load out+0 as i32
    store tmp_1184+0, tmp_1185 as i32
    tmp_1186 = load out+4 as i32
    store tmp_1184+4, tmp_1186 as i32
    tmp_1187 = call @sla__entity_eq(tmp_1181, tmp_1184)
    !tmp_1181
    !tmp_1184
    tmp_1188 = 1
    tmp_1189 = ne tmp_1187, tmp_1188
    !tmp_1187
    !tmp_1188
    br tmp_1189 -> L_THEN_297, L_ELSE_298

L_THEN_297:
    !tmp_1189
    panic(2110)

L_ELSE_298:
    !tmp_1189
    jmp L_MERGE_299

L_MERGE_299:
    !out
    !bits
    !e
    return

@test "entity derives value semantics"():
L_TEST_ENTRY_300:
    tmp_1192 = 42
    tmp_1193 = 7
    tmp_1194 = call @sla__entity_new(tmp_1192, tmp_1193)
    !tmp_1192
    !tmp_1193
    e = tmp_1194
    copied = alloc 8
    tmp_1195 = load e+0 as i32
    store copied+0, tmp_1195 as i32
    tmp_1196 = load e+4 as i32
    store copied+4, tmp_1196 as i32
    tmp_1197 = load copied+0 as i32
    tmp_1198 = load e+0 as i32
    tmp_1199 = eq tmp_1197, tmp_1198
    tmp_1200 = load copied+4 as i32
    tmp_1201 = load e+4 as i32
    tmp_1202 = eq tmp_1200, tmp_1201
    tmp_1203 = and tmp_1199, tmp_1202
    tmp_1204 = ne tmp_1203, 1
