@sla__alloc_entity(a: ptr) -> ptr:
L_ENTRY:
    tmp_38 = load a+4 as i32
    tmp_39 = 0
    tmp_40 = sgt tmp_38, tmp_39
    !tmp_38
    !tmp_39
    br tmp_40 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_40
    tmp_41 = load a+4 as i32
    tmp_42 = 1
    tmp_43 = sub tmp_41, tmp_42
    !tmp_41
    !tmp_42
    next_free_count = tmp_43
    tmp_44 = load a+16 as ptr
    tmp_45 = mul next_free_count, 4
    tmp_46 = ptr_add tmp_44, tmp_45
    !tmp_45
    tmp_47 = load tmp_46+0 as i32
    !tmp_46
    !tmp_44
    id = tmp_47
    store a+4, next_free_count as i32
    tmp_48 = load a+16 as ptr
    tmp_49 = mul next_free_count, 4
    tmp_50 = ptr_add tmp_48, tmp_49
    !tmp_49
    tmp_51 = 0
    store tmp_50+0, tmp_51 as i32
    !tmp_50
    !tmp_48
    !tmp_51
    tmp_52 = alloc 16
    store tmp_52+0, a as ptr
    tmp_53 = load a+8 as ptr
    tmp_54 = mul id, 4
    tmp_55 = ptr_add tmp_53, tmp_54
    !tmp_54
    tmp_56 = load tmp_55+0 as i32
    !tmp_55
    !tmp_53
    tmp_57 = call @sla__entity_new(id, tmp_56)
    !tmp_56
    store tmp_52+8, tmp_57 as ptr
    !next_free_count
    return tmp_52

L_ELSE_4:
    !tmp_40
    jmp L_MERGE_5

L_MERGE_5:
    tmp_59 = load a+0 as i32
    tmp_60 = 16
    tmp_61 = sge tmp_59, tmp_60
    !tmp_59
    !tmp_60
    br tmp_61 -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !tmp_61
    panic(2001)

L_ELSE_7:
    !tmp_61
    jmp L_MERGE_8

L_MERGE_8:
    tmp_64 = load a+0 as i32
    id = tmp_64
    tmp_65 = 1
    tmp_66 = add id, tmp_65
    !tmp_65
    store a+0, tmp_66 as i32
    !tmp_66
    tmp_67 = alloc 16
    store tmp_67+0, a as ptr
    tmp_68 = load a+8 as ptr
    tmp_69 = mul id, 4
    tmp_70 = ptr_add tmp_68, tmp_69
    !tmp_69
    tmp_71 = load tmp_70+0 as i32
    !tmp_70
    !tmp_68
    tmp_72 = call @sla__entity_new(id, tmp_71)
    !tmp_71
    store tmp_67+8, tmp_72 as ptr
    return tmp_67

@sla__allocator_id_is_free(a: ptr, id: i32) -> u8:
L_ENTRY:
    tmp_73 = 0
    i = tmp_73
    jmp L_WHILE_HEAD_9

L_WHILE_HEAD_9:
    tmp_74 = load a+4 as i32
    tmp_75 = slt i, tmp_74
    !tmp_74
    br tmp_75 -> L_WHILE_BODY_10, L_WHILE_COND_FALSE_11

L_WHILE_BODY_10:
    !tmp_75
    tmp_76 = load a+16 as ptr
    tmp_77 = mul i, 4
    tmp_78 = ptr_add tmp_76, tmp_77
    !tmp_77
    tmp_79 = load tmp_78+0 as i32
    !tmp_78
    !tmp_76
    tmp_80 = eq tmp_79, id
    !tmp_79
    br tmp_80 -> L_THEN_13, L_ELSE_14

L_THEN_13:
    !tmp_80
    tmp_81 = 1
    !i
    !a
    !id
