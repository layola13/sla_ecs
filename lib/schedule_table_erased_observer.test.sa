    !tmp_8575
    tmp_8577 = call @sla__erased_observers_add(observers0, tmp_8576)
    !tmp_8576
    observers1 = tmp_8577
    tmp_8578 = alloc 16
    store tmp_8578+0, 0 as ptr
    store tmp_8578+8, &SLA_FNPTR_VT_erased_explode_observer as ptr
    tmp_8579 = call @sla__erased_observer_new(explode_type, tmp_8578)
    !tmp_8578
