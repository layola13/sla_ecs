@test "erased observers trigger matching event immediately"():
L_TEST_ENTRY_2416:
    tmp_8561 = call @sla__ErasedSpeakEvent_event_type_id()
    speak_type = tmp_8561
    tmp_8562 = call @sla__ErasedExplodeEvent_event_type_id()
    explode_type = tmp_8562
    tmp_8563 = 0
    tmp_8564 = sle speak_type, tmp_8563
    !tmp_8563
