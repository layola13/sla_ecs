    tmp_13536 = call @sla__dynamic_world_spawn_DynamicWorldPos_DynamicWorldVel_DynamicWorldTime_DynamicWorldDamage(w)
    next_w = load tmp_13536+0 as ptr
    entity = load tmp_13536+8 as ptr
    !tmp_13536
    !w
    w = next_w
    tmp_13537 = load entity+0 as i32
