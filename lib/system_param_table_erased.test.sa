@test "dynamic allocator grows beyond fixed capacity"():
L_TEST_ENTRY_1677:
    tmp_6678 = call @sla__dyn_allocator_new()
    a = tmp_6678
    tmp_6679 = 0
    i = tmp_6679
    jmp L_WHILE_HEAD_1678

L_WHILE_HEAD_1678:
    tmp_6680 = 20
    tmp_6681 = slt i, tmp_6680
    !tmp_6680
    br tmp_6681 -> L_WHILE_BODY_1679, L_WHILE_COND_FALSE_1680

L_WHILE_BODY_1679:
    !tmp_6681
    tmp_6682 = call @sla__dyn_alloc_entity(a)
    next_a = load tmp_6682+0 as ptr
    entity = load tmp_6682+8 as ptr
    !tmp_6682
    !a
    a = next_a
    tmp_6683 = load entity+0 as i32
    tmp_6684 = 1
    tmp_6685 = add i, tmp_6684
    !tmp_6684
    tmp_6686 = ne tmp_6683, tmp_6685
    !tmp_6683
    !tmp_6685
    br tmp_6686 -> L_THEN_1682, L_ELSE_1683

L_THEN_1682:
    !tmp_6686
    panic(2150)

L_ELSE_1683:
    !tmp_6686
    jmp L_MERGE_1684

L_MERGE_1684:
    tmp_6689 = call @sla__dyn_is_alive(a, entity)
    tmp_6690 = 1
    tmp_6691 = ne tmp_6689, tmp_6690
    !tmp_6689
    !tmp_6690
    br tmp_6691 -> L_THEN_1685, L_ELSE_1686

L_THEN_1685:
    !tmp_6691
    panic(2151)

L_ELSE_1686:
    !tmp_6691
    jmp L_MERGE_1687

L_MERGE_1687:
    tmp_6694 = 1
    tmp_6695 = add i, tmp_6694
    !tmp_6694
    !i
    i = tmp_6695
    !entity
    jmp L_WHILE_HEAD_1678

L_WHILE_COND_FALSE_1680:
    !tmp_6681
    jmp L_WHILE_EXIT_1681

L_WHILE_EXIT_1681:
    tmp_6696 = load a+8 as ptr
    EXPAND VEC_LEN tmp_6697, tmp_6696
    !tmp_6696
    tmp_6698 = 21
    tmp_6699 = ne tmp_6697, tmp_6698
    !tmp_6697
    !tmp_6698
    br tmp_6699 -> L_THEN_1688, L_ELSE_1689

L_THEN_1688:
    !tmp_6699
    panic(2152)

L_ELSE_1689:
    !tmp_6699
    jmp L_MERGE_1690

L_MERGE_1690:
    !a
    !i
    return

