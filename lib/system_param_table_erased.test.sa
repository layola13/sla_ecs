    tmp_13532 = call @sla__test_dynamic_world_new()
    w = tmp_13532
    tmp_13533 = 0
    i = tmp_13533
    jmp L_WHILE_HEAD_3678

L_WHILE_HEAD_3678:
    tmp_13534 = 20
    tmp_13535 = slt i, tmp_13534
    !tmp_13534
