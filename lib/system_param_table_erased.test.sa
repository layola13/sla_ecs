L_MERGE_3684:
    tmp_13543 = call @sla__dynamic_world_is_alive_DynamicWorldPos_DynamicWorldVel_DynamicWorldTime_DynamicWorldDamage(w, entity)
    tmp_13544 = 1
    tmp_13545 = ne tmp_13543, tmp_13544
    !tmp_13543
    !tmp_13544
    br tmp_13545 -> L_THEN_3685, L_ELSE_3686

L_THEN_3685:
