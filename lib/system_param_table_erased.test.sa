    tmp_20632 = call @sla__dyn_store_new_DynPoint()
    s = tmp_20632
    tmp_20633 = 0
    i = tmp_20633
    jmp L_WHILE_HEAD_4584

L_WHILE_HEAD_4584:
    tmp_20634 = 20
    tmp_20635 = slt i, tmp_20634
    !tmp_20634
    br tmp_20635 -> L_WHILE_BODY_4585, L_WHILE_COND_FALSE_4586

L_WHILE_BODY_4585:
    !tmp_20635
    tmp_20636 = 1
    tmp_20637 = add i, tmp_20636
    !tmp_20636
    tmp_20638 = call @sla__dyn_point(i, tmp_20637)
    !tmp_20637
    tmp_20639 = call @sla__dyn_store_insert_DynPoint(s, i, tmp_20638)
    !tmp_20638
    !s
    s = tmp_20639
    tmp_20640 = 1
    tmp_20641 = add i, tmp_20640
    !tmp_20640
    !i
    i = tmp_20641
    jmp L_WHILE_HEAD_4584

L_WHILE_COND_FALSE_4586:
    !tmp_20635
    jmp L_WHILE_EXIT_4587

L_WHILE_EXIT_4587:
    tmp_20642 = call @sla__dyn_store_count_DynPoint(s)
    tmp_20643 = 20
    tmp_20644 = ne tmp_20642, tmp_20643
    !tmp_20642
    !tmp_20643
