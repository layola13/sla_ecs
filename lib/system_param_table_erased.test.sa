@test "allocator rejects stale generation"():
L_TEST_ENTRY_3483:
    tmp_13043 = call @sla__allocator_new()
    a0 = tmp_13043
    tmp_13044 = call @sla__alloc_entity(a0)
    a1 = load tmp_13044+0 as ptr
