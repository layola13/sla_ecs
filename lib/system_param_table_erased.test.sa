@test "entity bit roundtrip"():
L_TEST_ENTRY_1653:
    tmp_6623 = 42
    tmp_6624 = 7
    tmp_6625 = call @sla__entity_new(tmp_6623, tmp_6624)
    !tmp_6623
    !tmp_6624
    e = tmp_6625
    tmp_6626 = call @sla__entity_to_bits(e)
    bits = tmp_6626
    tmp_6627 = call @sla__entity_from_bits(bits)
    out = tmp_6627
    tmp_6628 = call @sla__entity_eq(e, out)
    tmp_6629 = 1
    tmp_6630 = ne tmp_6628, tmp_6629
    !tmp_6628
    !tmp_6629
    br tmp_6630 -> L_THEN_1654, L_ELSE_1655

L_THEN_1654:
    !tmp_6630
    panic(2110)

L_ELSE_1655:
    !tmp_6630
    jmp L_MERGE_1656

L_MERGE_1656:
    !out
    !bits
    !e
    return

@test "allocator rejects stale generation"():
L_TEST_ENTRY_1657:
    tmp_6633 = call @sla__allocator_new()
    a0 = tmp_6633
    tmp_6634 = call @sla__alloc_entity(a0)
    a1 = load tmp_6634+0 as ptr
    e1 = load tmp_6634+8 as ptr
    !tmp_6634
    tmp_6635 = call @sla__free_entity(a1, e1)
    a2 = tmp_6635
    tmp_6636 = load e1+0 as i32
    tmp_6637 = load e1+4 as i32
    tmp_6638 = call @sla__entity_new(tmp_6636, tmp_6637)
    !tmp_6636
    !tmp_6637
    stale = tmp_6638
    tmp_6639 = load e1+0 as i32
    tmp_6640 = load e1+4 as i32
    tmp_6641 = 1
    tmp_6642 = add tmp_6640, tmp_6641
    !tmp_6640
    !tmp_6641
    tmp_6643 = call @sla__entity_new(tmp_6639, tmp_6642)
    !tmp_6639
    !tmp_6642
    fabricated = tmp_6643
    tmp_6644 = call @sla__is_alive(a2, stale)
    tmp_6645 = 0
    tmp_6646 = ne tmp_6644, tmp_6645
    !tmp_6644
    !tmp_6645
    br tmp_6646 -> L_THEN_1658, L_ELSE_1659

L_THEN_1658:
    !tmp_6646
    panic(2120)

L_ELSE_1659:
    !tmp_6646
    jmp L_MERGE_1660

L_MERGE_1660:
    tmp_6649 = call @sla__is_alive(a2, fabricated)
    tmp_6650 = 0
    tmp_6651 = ne tmp_6649, tmp_6650
    !tmp_6649
    !tmp_6650
    br tmp_6651 -> L_THEN_1661, L_ELSE_1662

L_THEN_1661:
    !tmp_6651
    panic(2121)

L_ELSE_1662:
    !tmp_6651
    jmp L_MERGE_1663

L_MERGE_1663:
    tmp_6654 = call @sla__alloc_entity(a2)
    a3 = load tmp_6654+0 as ptr
    e2 = load tmp_6654+8 as ptr
    !tmp_6654
    tmp_6655 = call @sla__entity_eq(e2, fabricated)
    tmp_6656 = 1
    tmp_6657 = ne tmp_6655, tmp_6656
    !tmp_6655
    !tmp_6656
    br tmp_6657 -> L_THEN_1664, L_ELSE_1665

L_THEN_1664:
    !tmp_6657
    panic(2122)

L_ELSE_1665:
    !tmp_6657
    jmp L_MERGE_1666

L_MERGE_1666:
    tmp_6660 = call @sla__is_alive(a3, e2)
    tmp_6661 = 1
    tmp_6662 = ne tmp_6660, tmp_6661
    !tmp_6660
    !tmp_6661
    br tmp_6662 -> L_THEN_1667, L_ELSE_1668

L_THEN_1667:
    !tmp_6662
    panic(2123)

L_ELSE_1668:
    !tmp_6662
    jmp L_MERGE_1669

L_MERGE_1669:
    !e2
    !a0
    !a2
    !fabricated
    !stale
    !e1
    !a3
    !a1
    return

