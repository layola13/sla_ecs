    panic(4210)

L_ELSE_4589:
    !tmp_20644
    jmp L_MERGE_4590

L_MERGE_4590:
    tmp_20647 = 19
    tmp_20648 = call @sla__dyn_store_get_DynPoint(s, tmp_20647)
    !tmp_20647
    p = tmp_20648
