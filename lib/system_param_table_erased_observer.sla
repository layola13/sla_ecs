// SA-native system parameter adapters for TableErasedObserverWorld<R, M>.
@import "schedule_table_erased_observer.sla"

struct TableErasedObserverResourceMessageParam<R, M> {
    resource: R,
    message: M,
    should_write_message: bool,
}

struct TableErasedObserverResMutMessageReadParam<R, M> {
    resource: ResMut<R>,
    read: MessageRead<M>,
}

struct TableErasedObserverCommandsParam<R, M> {
    world: TableErasedObserverWorld<R, M>,
    commands: TableErasedObserverCommands<R, M>,
}

struct TableErasedObserverEventTriggerParam<R, M> {
    world: TableErasedObserverWorld<R, M>,
}

struct TableErasedObserverQueryResourceParam<T, R> {
    query: Query<EntityItem<T>>,
    resource: R,
}

struct TableErasedObserverItemQueryResourceParam<I, R> {
    query: Query<I>,
    resource: R,
}

fn table_erased_observer_resource_message_param<R, M>(resource: R, message: M, should_write_message: bool) -> TableErasedObserverResourceMessageParam<R, M> {
    return TableErasedObserverResourceMessageParam<R, M> { resource: resource, message: message, should_write_message: should_write_message };
}

fn table_erased_observer_resmut_message_read_param<R, M>(resource: ResMut<R>, read: MessageRead<M>) -> TableErasedObserverResMutMessageReadParam<R, M> {
    return TableErasedObserverResMutMessageReadParam<R, M> { resource: resource, read: read };
}

fn table_erased_observer_commands_param_new<R, M>(world: TableErasedObserverWorld<R, M>) -> TableErasedObserverCommandsParam<R, M> {
    return TableErasedObserverCommandsParam<R, M> { world: world, commands: table_erased_observer_commands_new<R, M>() };
}

fn table_erased_observer_commands_param_reserve_entity<R, M>(param: TableErasedObserverCommandsParam<R, M>) -> (TableErasedObserverCommandsParam<R, M>, Entity) {
    let (world, commands, entity) = table_erased_observer_commands_reserve_entity<R, M>(param.world, param.commands);
    return (TableErasedObserverCommandsParam<R, M> { world: world, commands: commands }, entity);
}

fn table_erased_observer_commands_param_reserve_entity_with_location<R, M>(param: TableErasedObserverCommandsParam<R, M>, spawned_by: TableErasedSpawnLocation) -> (TableErasedObserverCommandsParam<R, M>, Entity) {
    let (world, commands, entity) = table_erased_observer_commands_reserve_entity_with_location<R, M>(param.world, param.commands, spawned_by);
    return (TableErasedObserverCommandsParam<R, M> { world: world, commands: commands }, entity);
}

fn table_erased_observer_commands_param_insert<T, R, M>(param: TableErasedObserverCommandsParam<R, M>, entity: Entity, component_id: i32, type_id: i32, value: T) -> TableErasedObserverCommandsParam<R, M> {
    return TableErasedObserverCommandsParam<R, M> { world: param.world, commands: table_erased_observer_commands_insert<T, R, M>(param.commands, entity, component_id, type_id, value) };
}

fn table_erased_observer_commands_param_insert_auto<T, R, M>(param: TableErasedObserverCommandsParam<R, M>, entity: Entity, type_id: i32, value: T) -> TableErasedObserverCommandsParam<R, M> {
    let component_id = table_erased_world_component_id_for_type<R, M>(param.world.table, type_id);
    return TableErasedObserverCommandsParam<R, M> { world: param.world, commands: table_erased_observer_commands_insert<T, R, M>(param.commands, entity, component_id, type_id, value) };
}

fn table_erased_observer_commands_param_remove<R, M>(param: TableErasedObserverCommandsParam<R, M>, entity: Entity, component_id: i32) -> TableErasedObserverCommandsParam<R, M> {
    return TableErasedObserverCommandsParam<R, M> { world: param.world, commands: table_erased_observer_commands_remove<R, M>(param.commands, entity, component_id) };
}

fn table_erased_observer_commands_param_despawn<R, M>(param: TableErasedObserverCommandsParam<R, M>, entity: Entity) -> TableErasedObserverCommandsParam<R, M> {
    return TableErasedObserverCommandsParam<R, M> { world: param.world, commands: table_erased_observer_commands_despawn<R, M>(param.commands, entity) };
}

fn table_erased_observer_commands_param_insert_resource<R, M>(param: TableErasedObserverCommandsParam<R, M>, value: R) -> TableErasedObserverCommandsParam<R, M> {
    return TableErasedObserverCommandsParam<R, M> { world: param.world, commands: table_erased_observer_commands_insert_resource<R, M>(param.commands, value) };
}

fn table_erased_observer_commands_param_write_message<R, M>(param: TableErasedObserverCommandsParam<R, M>, value: M) -> TableErasedObserverCommandsParam<R, M> {
    return TableErasedObserverCommandsParam<R, M> { world: param.world, commands: table_erased_observer_commands_write_message<R, M>(param.commands, value) };
}

fn table_erased_observer_commands_param_trigger<T, R, M>(param: TableErasedObserverCommandsParam<R, M>, type_id: i32, drop_fn: fn(*u8) -> void, value: T) -> TableErasedObserverCommandsParam<R, M> {
    return TableErasedObserverCommandsParam<R, M> { world: param.world, commands: table_erased_observer_commands_trigger<T, R, M>(param.commands, type_id, drop_fn, value) };
}

fn table_erased_observer_commands_param_trigger_entity<T, R, M>(param: TableErasedObserverCommandsParam<R, M>, entity: Entity, type_id: i32, drop_fn: fn(*u8) -> void, value: T) -> TableErasedObserverCommandsParam<R, M> {
    return TableErasedObserverCommandsParam<R, M> { world: param.world, commands: table_erased_observer_commands_trigger_entity<T, R, M>(param.commands, entity, type_id, drop_fn, value) };
}

fn table_erased_observer_event_trigger_param_new<R, M>(world: TableErasedObserverWorld<R, M>) -> TableErasedObserverEventTriggerParam<R, M> {
    return TableErasedObserverEventTriggerParam<R, M> { world: world };
}

fn table_erased_observer_event_trigger_param_trigger<T, R, M>(param: TableErasedObserverEventTriggerParam<R, M>, type_id: i32, drop_fn: fn(*u8) -> void, value: T) -> TableErasedObserverEventTriggerParam<R, M> {
    return TableErasedObserverEventTriggerParam<R, M> { world: table_erased_observer_world_trigger<T, R, M>(param.world, type_id, drop_fn, value) };
}

fn table_erased_observer_event_trigger_param_trigger_entity<T, R, M>(param: TableErasedObserverEventTriggerParam<R, M>, entity: Entity, type_id: i32, drop_fn: fn(*u8) -> void, value: T) -> TableErasedObserverEventTriggerParam<R, M> {
    return TableErasedObserverEventTriggerParam<R, M> { world: table_erased_observer_world_trigger_entity<T, R, M>(param.world, entity, type_id, drop_fn, value) };
}

fn table_erased_observer_query_resource_param<T, R>(query: Query<EntityItem<T>>, resource: R) -> TableErasedObserverQueryResourceParam<T, R> {
    return TableErasedObserverQueryResourceParam<T, R> { query: query, resource: resource };
}

fn table_erased_observer_item_query_resource_param<I, R>(query: Query<I>, resource: R) -> TableErasedObserverItemQueryResourceParam<I, R> {
    return TableErasedObserverItemQueryResourceParam<I, R> { query: query, resource: resource };
}

fn table_erased_observer_apply_pair_mut_updates<A, B, R, M>(world: TableErasedObserverWorld<R, M>, updated: Query<TableErasedPairMut<A, B>>) -> TableErasedObserverWorld<R, M> {
    let i: i64 = 0;
    let cnt = len(updated.items) as i64;
    while i < cnt {
        let item = updated.items[i];
        world.table = table_erased_world_pair_write_first<A, B, R, M>(world.table, item, item.first.value);
        i = i + 1;
    }
    return world;
}

fn table_erased_observer_apply_pair_mut_with_spawn_details_updates<A, B, R, M>(world: TableErasedObserverWorld<R, M>, updated: Query<TableErasedPairMutWithSpawnDetails<A, B>>) -> TableErasedObserverWorld<R, M> {
    let i: i64 = 0;
    let cnt = len(updated.items) as i64;
    while i < cnt {
        let item = updated.items[i];
        world.table = table_erased_world_pair_mut_with_spawn_details_write_first<A, B, R, M>(world.table, item, item.first.value);
        i = i + 1;
    }
    return world;
}

fn table_erased_observer_run_pair_mut_system<A, B, R, M>(world: TableErasedObserverWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedObserverWorld<R, M> {
    let query = table_erased_world_query_pair_mut_first<A, B, R, M>(world.table, first_component_id, first_type_id, second_component_id, second_type_id);
    let updated = run(query);
    return table_erased_observer_apply_pair_mut_updates<A, B, R, M>(world, updated);
}

fn table_erased_observer_run_pair_mut_system_auto<A, B, R, M>(world: TableErasedObserverWorld<R, M>, first_type_id: i32, second_type_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedObserverWorld<R, M> {
    let first_component_id = table_erased_world_component_id_for_type<R, M>(world.table, first_type_id);
    let second_component_id = table_erased_world_component_id_for_type<R, M>(world.table, second_type_id);
    return table_erased_observer_run_pair_mut_system<A, B, R, M>(world, first_component_id, first_type_id, second_component_id, second_type_id, run);
}

fn table_erased_observer_run_pair_mut_system_with<A, B, R, M>(world: TableErasedObserverWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, with_component_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedObserverWorld<R, M> {
