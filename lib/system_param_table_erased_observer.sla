    while i < cnt {
        if param.query.items[i].details.is_spawned() { spawned = spawned + 1; };
        value_sum = value_sum + param.query.items[i].first.x + param.query.items[i].second.x;
        file_sum = file_sum + param.query.items[i].details.spawned_by().file_id;
        i = i + 1;
    }
    return table_erased_observer_item_query_resource_param<TableErasedPairWithSpawnDetails<TableErasedPos, TableErasedVel>, TableErasedTime>(param.query, TableErasedTime { tick: spawned * 100 + value_sum + file_sum * 1000 });
