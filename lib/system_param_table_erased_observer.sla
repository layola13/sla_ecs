@test "table erased observer system params expose spawned and spawn details"() {
    let w0 = table_erased_observer_test_world_new();
    let (w1, position) = table_erased_observer_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let (w2, velocity) = table_erased_observer_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, table_erased_vel_drop);
    let (w3, e1) = table_erased_observer_world_spawn<TableErasedTime, TableErasedEvent>(w2);
    let w4 = table_erased_observer_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w3, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 1, y: 0 });
    let w5 = table_erased_observer_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w4, e1, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 10, y: 0 });
    let first_tick = w5.table.registry.change_tick;
    let w6 = TableErasedObserverWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_increment_tick<TableErasedTime, TableErasedEvent>(w5.table), observers: w5.observers };
    let (w7, e2) = table_erased_observer_world_spawn_with_location<TableErasedTime, TableErasedEvent>(w6, table_erased_spawn_location_new(6, 44, 8));
    let w8 = table_erased_observer_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w7, e2, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 2, y: 0 });
    let w9 = table_erased_observer_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w8, e2, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 20, y: 0 });
    let second_tick = w9.table.registry.change_tick;
    let w9r = TableErasedObserverWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(w9.table, TableErasedTime { tick: 0 }), observers: w9.observers };

    let entity_spawned = table_erased_observer_run_entity_spawned_query_resource_system<TableErasedTime, TableErasedEvent>(w9r, first_tick, table_erased_observer_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(entity_spawned.table).tick != 1 { panic(14500); };
    let entity_repeated = table_erased_observer_run_entity_spawned_query_resource_system<TableErasedTime, TableErasedEvent>(w9r, second_tick, table_erased_observer_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(entity_repeated.table).tick != 0 { panic(14501); };
    let details = table_erased_observer_run_spawn_details_query_resource_system<TableErasedTime, TableErasedEvent>(w9r, first_tick, table_erased_observer_param_spawn_details_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(details.table).tick != 6100 + first_tick + second_tick { panic(14502); };
    let spawned_pos = table_erased_observer_run_spawned_query_resource_system_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w9r, TABLE_ERASED_POS_TYPE, first_tick, table_erased_observer_param_count_query_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(spawned_pos.table).tick != 1 { panic(14503); };
    let pos_details = table_erased_observer_run_with_spawn_details_query_resource_system_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w9r, TABLE_ERASED_POS_TYPE, first_tick, table_erased_observer_param_pos_spawn_details_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(pos_details.table).tick != 6103 { panic(14504); };
    let pair_spawned = table_erased_observer_run_pair_spawned_query_resource_system_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w9r, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, first_tick, table_erased_observer_param_pair_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(pair_spawned.table).tick != 1 { panic(14505); };
    let pair_details = table_erased_observer_run_pair_with_spawn_details_query_resource_system_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w9r, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, first_tick, table_erased_observer_param_pair_spawn_details_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(pair_details.table).tick != 6133 { panic(14506); };

    let w10 = table_erased_observer_run_pair_mut_system_spawned_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w9, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, first_tick, table_erased_observer_param_movement_system);
    if table_erased_observer_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, e1, position.id, TABLE_ERASED_POS_TYPE).x != 1 { panic(14507); };
    if table_erased_observer_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, e2, position.id, TABLE_ERASED_POS_TYPE).x != 22 { panic(14508); };
    let w11 = table_erased_observer_run_pair_mut_with_spawn_details_system_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w10, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, first_tick, table_erased_observer_param_spawn_detail_movement_system);
    if table_erased_observer_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w11, e1, position.id, TABLE_ERASED_POS_TYPE).x != 1 { panic(14509); };
    if table_erased_observer_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w11, e2, position.id, TABLE_ERASED_POS_TYPE).x != 42 { panic(14510); };
}
