        pos_sum = pos_sum + param.query.items[i].value.x;
        file_sum = file_sum + param.query.items[i].details.spawned_by().file_id;
        i = i + 1;
    }
    return table_erased_observer_item_query_resource_param<TableErasedWithSpawnDetails<TableErasedPos>, TableErasedTime>(param.query, TableErasedTime { tick: spawned * 100 + pos_sum + file_sum * 1000 });
}

