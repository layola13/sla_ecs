fn table_erased_observer_param_spawn_details_count_system(param: TableErasedObserverItemQueryResourceParam<TableErasedSpawnDetails, TableErasedTime>) -> TableErasedObserverItemQueryResourceParam<TableErasedSpawnDetails, TableErasedTime> {
    let spawned: i32 = 0;
    let tick_sum: i32 = 0;
    let file_sum: i32 = 0;
    let i: i64 = 0;
    let cnt = len(param.query.items) as i64;
    while i < cnt {
        if param.query.items[i].is_spawned() { spawned = spawned + 1; };
        tick_sum = tick_sum + param.query.items[i].spawn_tick();
        file_sum = file_sum + param.query.items[i].spawned_by().file_id;
        i = i + 1;
    }
    return table_erased_observer_item_query_resource_param<TableErasedSpawnDetails, TableErasedTime>(param.query, TableErasedTime { tick: spawned * 100 + tick_sum + file_sum * 1000 });
}

fn table_erased_observer_param_pos_spawn_details_count_system(param: TableErasedObserverItemQueryResourceParam<TableErasedWithSpawnDetails<TableErasedPos>, TableErasedTime>) -> TableErasedObserverItemQueryResourceParam<TableErasedWithSpawnDetails<TableErasedPos>, TableErasedTime> {
