fn table_erased_observer_param_direct_event_system(param: TableErasedObserverEventTriggerParam<TableErasedTime, TableErasedEvent>) -> TableErasedObserverEventTriggerParam<TableErasedTime, TableErasedEvent> {
    if len(param.world.table.archetypes[0].entity_ids) <= 0 { return param; };
    let entity_id = param.world.table.archetypes[0].entity_ids[0];
    let entity = entity_new(entity_id, param.world.table.registry.entities.generations[entity_id]);
    return table_erased_observer_event_trigger_param_trigger_entity<TableErasedObserverPing, TableErasedTime, TableErasedEvent>(param, entity, TableErasedObserverPing::event_type_id(), table_erased_observer_ping_drop, TableErasedObserverPing { amount: 9 });
}

@test "table erased observer pair mut param writes back"() {
    let w0 = table_erased_observer_test_world_new();
    let (w1, position) = table_erased_observer_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let (w2, velocity) = table_erased_observer_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, table_erased_vel_drop);
    let (w3, entity) = table_erased_observer_world_spawn<TableErasedTime, TableErasedEvent>(w2);
    let w4 = table_erased_observer_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w3, entity, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 8, y: 0 });
    let w5 = table_erased_observer_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w4, entity, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 4, y: 0 });
    let before = w5.table.registry.change_tick;
    let w6 = table_erased_observer_run_pair_mut_system_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w5, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, table_erased_observer_param_movement_system);
    if table_erased_observer_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w6, entity, position.id, TABLE_ERASED_POS_TYPE).x != 12 { panic(14400); };
    if table_erased_world_changed_since<TableErasedTime, TableErasedEvent>(w6.table, entity, position.id, before - 1) != true { panic(14401); };
}

@test "table erased observer resource message writer and reader params"() {
    let w0 = table_erased_observer_test_world_new();
    let w1 = TableErasedObserverWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(w0.table, TableErasedTime { tick: 5 }), observers: w0.observers };
    let w2 = table_erased_observer_run_resource_message_system<TableErasedTime, TableErasedEvent>(w1, table_erased_event_default(), table_erased_observer_param_time_message_system);
    let w3 = table_erased_observer_run_message_writer_system<TableErasedTime, TableErasedEvent>(w2, table_erased_observer_param_writer_system);
    let read1 = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w3.table, message_reader_new(), table_erased_event_default());
    let (w4, reader2) = table_erased_observer_run_message_reader_res_mut_system<TableErasedTime, TableErasedEvent>(w3, read1.reader, table_erased_event_default(), table_erased_observer_param_reader_resmut_system);
    let w5 = table_erased_observer_run_res_mut_system<TableErasedTime, TableErasedEvent>(w4, table_erased_observer_param_res_mut_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(w5.table).tick != 10 { panic(14410); };
    if read1.value.amount != 9 { panic(14411); };
    if reader2.cursor != 2 { panic(14412); };
}

@test "table erased observer commands param applies lifecycle resources messages and events"() {
    let w0 = table_erased_observer_test_world_new();
    let w1 = table_erased_observer_world_add_observer<TableErasedTime, TableErasedEvent>(w0, TableErasedLifecycleEvent::event_type_id(), table_erased_lifecycle_score);
    let w2 = table_erased_observer_world_add_observer<TableErasedTime, TableErasedEvent>(w1, TableErasedObserverPing::event_type_id(), table_erased_observer_ping_score);
    let (w3, position) = table_erased_observer_world_register_table<TableErasedTime, TableErasedEvent>(w2, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let w4 = table_erased_observer_run_commands_system<TableErasedTime, TableErasedEvent>(w3, table_erased_observer_param_commands_system);
    let query = table_erased_world_query<TableErasedPos, TableErasedTime, TableErasedEvent>(w4.table, position.id, TABLE_ERASED_POS_TYPE);
    let read = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w4.table, message_reader_new(), table_erased_event_default());
    if len(query.items) != 1 { panic(14420); };
    if query.items[0].value.x != 12 { panic(14421); };
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(w4.table).tick != 7 { panic(14422); };
    if read.value.amount != 4 { panic(14423); };
    if w4.observers.trigger_count != 3 { panic(14424); };
    if w4.observers.last_event_type_id != TableErasedObserverPing::event_type_id() { panic(14425); };
    let spawned_by = table_erased_world_spawned_by<TableErasedTime, TableErasedEvent>(w4.table, query.items[0].entity);
    if spawned_by.file_id != 96 { panic(14426); };
    if spawned_by.line != 31 { panic(14427); };
}

