@test "table erased observer with added changed query resource params"() {
    let w0 = table_erased_observer_test_world_new();
    let (w1, position) = table_erased_observer_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let (w2, marker) = table_erased_observer_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_MARKER_TYPE, table_erased_marker_drop);
    let (w3, e1) = table_erased_observer_world_spawn<TableErasedTime, TableErasedEvent>(w2);
    let (w4, e2) = table_erased_observer_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let w5 = TableErasedObserverWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(w4.table, TableErasedTime { tick: 0 }), observers: w4.observers };
    let before_add = w5.table.registry.change_tick;
    let w6 = TableErasedObserverWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_increment_tick<TableErasedTime, TableErasedEvent>(w5.table), observers: w5.observers };
    let w7 = table_erased_observer_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w6, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 1, y: 0 });
    let w8 = table_erased_observer_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w7, e2, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 2, y: 0 });
    let w9 = table_erased_observer_world_insert<TableErasedMarker, TableErasedTime, TableErasedEvent>(w8, e2, marker.id, TABLE_ERASED_MARKER_TYPE, TableErasedMarker { value: 1 });
    let w10 = table_erased_observer_run_with_query_resource_system_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, TABLE_ERASED_POS_TYPE, TABLE_ERASED_MARKER_TYPE, table_erased_observer_param_count_query_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(w10.table).tick != 1 { panic(14434); };
    let w11 = table_erased_observer_run_added_query_resource_system_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, TABLE_ERASED_POS_TYPE, before_add, table_erased_observer_param_count_query_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(w11.table).tick != 2 { panic(14435); };
