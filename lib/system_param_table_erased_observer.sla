fn table_erased_observer_run_pair_mut_system_or_added_auto<A, B, R, M>(world: TableErasedObserverWorld<R, M>, first_type_id: i32, second_type_id: i32, left_added_type_id: i32, right_added_type_id: i32, since_tick: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedObserverWorld<R, M> {
    let first_component_id = table_erased_world_component_id_for_type<R, M>(world.table, first_type_id);
