fn table_erased_observer_param_pair_spawn_details_count_system(param: TableErasedObserverItemQueryResourceParam<TableErasedPairWithSpawnDetails<TableErasedPos, TableErasedVel>, TableErasedTime>) -> TableErasedObserverItemQueryResourceParam<TableErasedPairWithSpawnDetails<TableErasedPos, TableErasedVel>, TableErasedTime> {
