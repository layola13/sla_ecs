fn table_erased_observer_param_movement_system(query: Query<TableErasedPairMut<TableErasedPos, TableErasedVel>>) -> Query<TableErasedPairMut<TableErasedPos, TableErasedVel>> {
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        query.items[i].first.value = TableErasedPos { x: query.items[i].first.value.x + query.items[i].second.x, y: query.items[i].first.value.y + query.items[i].second.y };
        i = i + 1;
    }
    return query;
}

fn table_erased_observer_param_time_message_system(param: TableErasedObserverResourceMessageParam<TableErasedTime, TableErasedEvent>) -> TableErasedObserverResourceMessageParam<TableErasedTime, TableErasedEvent> {
    return table_erased_observer_resource_message_param<TableErasedTime, TableErasedEvent>(TableErasedTime { tick: param.resource.tick + 1 }, TableErasedEvent { amount: param.resource.tick + 4 }, true);
}

fn table_erased_observer_param_res_mut_system(res: ResMut<TableErasedTime>) -> ResMut<TableErasedTime> {
    return ResMut<TableErasedTime> { value: TableErasedTime { tick: res.value.tick + 2 }, added_tick: res.added_tick, changed_tick: res.changed_tick };
}

fn table_erased_observer_param_reader_resmut_system(param: TableErasedObserverResMutMessageReadParam<TableErasedTime, TableErasedEvent>) -> TableErasedObserverResMutMessageReadParam<TableErasedTime, TableErasedEvent> {
    if param.read.has_value { param.resource.value = TableErasedTime { tick: param.resource.value.tick + param.read.value.amount }; };
    return param;
}

fn table_erased_observer_param_commands_system(param: TableErasedObserverCommandsParam<TableErasedTime, TableErasedEvent>) -> TableErasedObserverCommandsParam<TableErasedTime, TableErasedEvent> {
    let (param1, entity) = table_erased_observer_commands_param_reserve_entity_with_location<TableErasedTime, TableErasedEvent>(param, table_erased_spawn_location_new(96, 31, 5));
    let param2 = table_erased_observer_commands_param_insert_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(param1, entity, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 12, y: 0 });
