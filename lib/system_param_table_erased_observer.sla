}

fn table_erased_observer_run_resource_message_system<R, M>(world: TableErasedObserverWorld<R, M>, default_message: M, run: fn(TableErasedObserverResourceMessageParam<R, M>) -> TableErasedObserverResourceMessageParam<R, M>) -> TableErasedObserverWorld<R, M> {
    let param0 = table_erased_observer_resource_message_param<R, M>(table_erased_world_get_resource<R, M>(world.table), default_message, false);
    let param1 = run(param0);
    world.table = table_erased_world_insert_resource<R, M>(world.table, param1.resource);
    if param1.should_write_message { world.table = table_erased_world_write_message<R, M>(world.table, param1.message); };
    return world;
}

fn table_erased_observer_run_res_mut_system<R, M>(world: TableErasedObserverWorld<R, M>, run: fn(ResMut<R>) -> ResMut<R>) -> TableErasedObserverWorld<R, M> {
    let param0 = table_erased_world_res_mut<R, M>(world.table);
    let param1 = run(param0);
    world.table = table_erased_world_res_mut_write<R, M>(world.table, param1, param1.value);
    return world;
}

fn table_erased_observer_run_message_reader_res_mut_system<R, M>(world: TableErasedObserverWorld<R, M>, reader: MessageReader, default_message: M, run: fn(TableErasedObserverResMutMessageReadParam<R, M>) -> TableErasedObserverResMutMessageReadParam<R, M>) -> (TableErasedObserverWorld<R, M>, MessageReader) {
    let read = table_erased_world_read_message<R, M>(world.table, reader, default_message);
    let param0 = table_erased_observer_resmut_message_read_param<R, M>(table_erased_world_res_mut<R, M>(world.table), read);
    let param1 = run(param0);
    world.table = table_erased_world_res_mut_write<R, M>(world.table, param1.resource, param1.resource.value);
    return (world, param1.read.reader);
}

fn table_erased_observer_run_commands_system<R, M>(world: TableErasedObserverWorld<R, M>, run: fn(TableErasedObserverCommandsParam<R, M>) -> TableErasedObserverCommandsParam<R, M>) -> TableErasedObserverWorld<R, M> {
    let param0 = table_erased_observer_commands_param_new<R, M>(world);
    let param1 = run(param0);
    let (world2, cleared) = table_erased_observer_commands_apply<R, M>(param1.world, param1.commands);
    return world2;
}

fn table_erased_observer_run_message_writer_system<R, M>(world: TableErasedObserverWorld<R, M>, run: fn(MessageWriter<M>) -> MessageWriter<M>) -> TableErasedObserverWorld<R, M> {
    let writer0 = message_writer_new<M>();
    let writer1 = run(writer0);
    world.table.messages = messages_apply_writer<M>(world.table.messages, writer1);
    return world;
}

fn table_erased_observer_run_event_trigger_system<R, M>(world: TableErasedObserverWorld<R, M>, run: fn(TableErasedObserverEventTriggerParam<R, M>) -> TableErasedObserverEventTriggerParam<R, M>) -> TableErasedObserverWorld<R, M> {
    let param0 = table_erased_observer_event_trigger_param_new<R, M>(world);
    let param1 = run(param0);
    return param1.world;
}

