fn table_erased_observer_event_trigger_param_new<R, M>(world: TableErasedObserverWorld<R, M>) -> TableErasedObserverEventTriggerParam<R, M> {
    return TableErasedObserverEventTriggerParam<R, M> { world: world };
}

fn table_erased_observer_event_trigger_param_trigger<T, R, M>(param: TableErasedObserverEventTriggerParam<R, M>, type_id: i32, drop_fn: fn(*u8) -> void, value: T) -> TableErasedObserverEventTriggerParam<R, M> {
    return TableErasedObserverEventTriggerParam<R, M> { world: table_erased_observer_world_trigger<T, R, M>(param.world, type_id, drop_fn, value) };
}

fn table_erased_observer_event_trigger_param_trigger_entity<T, R, M>(param: TableErasedObserverEventTriggerParam<R, M>, entity: Entity, type_id: i32, drop_fn: fn(*u8) -> void, value: T) -> TableErasedObserverEventTriggerParam<R, M> {
    return TableErasedObserverEventTriggerParam<R, M> { world: table_erased_observer_world_trigger_entity<T, R, M>(param.world, entity, type_id, drop_fn, value) };
}

fn table_erased_observer_query_resource_param<T, R>(query: Query<EntityItem<T>>, resource: R) -> TableErasedObserverQueryResourceParam<T, R> {
    return TableErasedObserverQueryResourceParam<T, R> { query: query, resource: resource };
}

fn table_erased_observer_apply_pair_mut_updates<A, B, R, M>(world: TableErasedObserverWorld<R, M>, updated: Query<TableErasedPairMut<A, B>>) -> TableErasedObserverWorld<R, M> {
    let i: i64 = 0;
    let cnt = len(updated.items) as i64;
    while i < cnt {
        let item = updated.items[i];
        world.table = table_erased_world_pair_write_first<A, B, R, M>(world.table, item, item.first.value);
        i = i + 1;
    }
    return world;
}

fn table_erased_observer_run_pair_mut_system<A, B, R, M>(world: TableErasedObserverWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedObserverWorld<R, M> {
    let query = table_erased_world_query_pair_mut_first<A, B, R, M>(world.table, first_component_id, first_type_id, second_component_id, second_type_id);
    let updated = run(query);
    return table_erased_observer_apply_pair_mut_updates<A, B, R, M>(world, updated);
}

fn table_erased_observer_run_pair_mut_system_auto<A, B, R, M>(world: TableErasedObserverWorld<R, M>, first_type_id: i32, second_type_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedObserverWorld<R, M> {
    let first_component_id = table_erased_world_component_id_for_type<R, M>(world.table, first_type_id);
    let second_component_id = table_erased_world_component_id_for_type<R, M>(world.table, second_type_id);
    return table_erased_observer_run_pair_mut_system<A, B, R, M>(world, first_component_id, first_type_id, second_component_id, second_type_id, run);
}

fn table_erased_observer_run_pair_mut_system_with<A, B, R, M>(world: TableErasedObserverWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, with_component_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedObserverWorld<R, M> {
    let query = table_erased_world_query_pair_mut_first_with<A, B, R, M>(world.table, first_component_id, first_type_id, second_component_id, second_type_id, with_component_id);
    let updated = run(query);
    return table_erased_observer_apply_pair_mut_updates<A, B, R, M>(world, updated);
}

