fn table_erased_observer_param_spawn_detail_movement_system(query: Query<TableErasedPairMutWithSpawnDetails<TableErasedPos, TableErasedVel>>) -> Query<TableErasedPairMutWithSpawnDetails<TableErasedPos, TableErasedVel>> {
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        if query.items[i].details.is_spawned() {
            query.items[i].first.value.x = query.items[i].first.value.x + query.items[i].second.x;
        };
        i = i + 1;
    }
    return query;
}

