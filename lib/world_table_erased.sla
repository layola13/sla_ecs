    let marked_next = TableErasedPos { x: marked_mover.first.value.x + marked_mover.second.x, y: 0 };
    let w13 = table_erased_world_pair_write_first<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w12, marked_mover, marked_next);
    if table_erased_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w13, e2, position.id, TABLE_ERASED_POS_TYPE).x != 48 { panic(11654); };
    let pair_changed = table_erased_world_query_pair_changed<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w13, position.id, TABLE_ERASED_POS_TYPE, velocity.id, TABLE_ERASED_VEL_TYPE, position.id, before_change);
    if len(pair_changed.items) != 1 { panic(11655); };
    if pair_changed.items[0].entity.id != e2.id { panic(11656); };
    let any_changed = table_erased_world_query_or_changed_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_MARKER_TYPE, before_change);
    if len(any_changed.items) != 1 { panic(11681); };
    if any_changed.items[0].entity.id != e2.id { panic(11682); };
    let changed_entities = table_erased_world_query_entities_changed_auto<TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, before_change);
    if len(changed_entities.items) != 1 { panic(11725); };
