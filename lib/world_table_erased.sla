fn table_erased_world_removed_components<R, M>(world: TableErasedWorld<R, M>, component_id: i32, since_tick: i32) -> Query<Entity> {
    let query = query_new<Entity>();
    let i: i64 = 0;
    let cnt = len(world.removed_components) as i64;
    while i < cnt {
        let removed = world.removed_components[i];
        if removed.component_id == component_id {
            if removed.tick > since_tick { query.items.push(removed.entity); };
        };
        i = i + 1;
    }
    return query;
}

