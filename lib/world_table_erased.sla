// Heterogeneous archetype table-row storage.
// Component payloads are type-erased boxed values stored inside archetype table
// columns and aligned by entity row.
@import "world_registry_erased.sla"
@import "box_drop.sla"

struct TableErasedColumnDef {
    component_id: i32,
    type_id: i32,
    drop_fn: fn(*u8) -> void,
}

struct TableErasedColumn {
    component_id: i32,
    type_id: i32,
    drop_fn: fn(*u8) -> void,
    values: Vec<ErasedComponentValue>,
}

struct TableErasedArchetype {
    id: i32,
    component_ids: Vec<i32>,
    entity_ids: Vec<i32>,
    columns: Vec<TableErasedColumn>,
}

struct TableErasedLocation {
    entity_id: i32,
    archetype_id: i32,
    row: i64,
}

struct TableErasedSpawnLocation {
    has_location: bool,
    file_id: i32,
    line: i32,
    column: i32,
}

struct TableErasedSpawnDetails {
    entity: Entity,
    spawn_tick_value: i32,
    last_run_tick: i32,
    this_run_tick: i32,
    spawned_by_value: TableErasedSpawnLocation,
}

struct TableErasedRemovedComponent {
    entity: Entity,
    component_id: i32,
    tick: i32,
}

struct TableErasedWorld<R, M> {
    registry: RegistryWorld,
    component_defs: Vec<TableErasedColumnDef>,
    archetypes: Vec<TableErasedArchetype>,
    locations: Vec<TableErasedLocation>,
    spawn_ticks: Vec<i32>,
    spawn_locations: Vec<TableErasedSpawnLocation>,
    removed_components: Vec<TableErasedRemovedComponent>,
    resource: ResourceSlot<R>,
    messages: Messages<M>,
    resource_added_tick: i32,
    resource_changed_tick: i32,
}

struct TableErasedMut<T> {
    entity: Entity,
    component_id: i32,
    type_id: i32,
    archetype_id: i32,
    row: i64,
    value: T,
}

struct TableErasedPair<A, B> {
    entity: Entity,
    first: A,
    second: B,
}

struct TableErasedWithSpawnDetails<T> {
    entity: Entity,
    value: T,
    details: TableErasedSpawnDetails,
}

struct TableErasedPairWithSpawnDetails<A, B> {
    entity: Entity,
    first: A,
    second: B,
    details: TableErasedSpawnDetails,
}

struct TableErasedPairMutWithSpawnDetails<A, B> {
    first: TableErasedMut<A>,
    second_component_id: i32,
    second_type_id: i32,
    second: B,
    details: TableErasedSpawnDetails,
}

struct TableErasedTriple<A, B, C> {
    entity: Entity,
    first: A,
    second: B,
    third: C,
}

struct TableErasedOptional<T> {
    has_value: bool,
    value: T,
}

struct TableErasedPairValue<A, B> {
    first: A,
    second: B,
}

struct TableErasedPairOptionalSecond<A, B> {
    entity: Entity,
    first: A,
    second: TableErasedOptional<B>,
}

struct TableErasedPairOptionalFirst<A, B> {
    entity: Entity,
    first: TableErasedOptional<A>,
    second: B,
}

struct TableErasedPairHasSecond<A, B> {
    entity: Entity,
    first: A,
    second_has: bool,
}

@expand_tuple(2, 4, T) {
struct TableErasedAnyOf$N<@join(T, ", ") { $T }> {
    entity: Entity,
@each(T) {
    $ORD: TableErasedOptional<$T>,
}
}
}

@expand_tuple(5, 6, T) {
struct TableErasedAnyOf$N<@join(T, ", ") { $T }> {
    entity: Entity,
@each(T) {
    value_$I: TableErasedOptional<$T>,
}
}
}

@expand_tuple(2, 4, T) {
struct TableErasedWithAnyOf$N<A, @join(T, ", ") { $T }> {
    entity: Entity,
    value: A,
@each(T) {
    any_$ORD: TableErasedOptional<$T>,
}
}
}

@expand_tuple(5, 6, T) {
struct TableErasedWithAnyOf$N<A, @join(T, ", ") { $T }> {
    entity: Entity,
    value: A,
@each(T) {
    any_$I: TableErasedOptional<$T>,
}
}
}

@expand_tuple(2, 4, T) {
struct TableErasedPairWithAnyOf$N<A, B, @join(T, ", ") { $T }> {
    entity: Entity,
    first: A,
    second: B,
@each(T) {
    any_$ORD: TableErasedOptional<$T>,
}
}
}

@expand_tuple(5, 6, T) {
struct TableErasedPairWithAnyOf$N<A, B, @join(T, ", ") { $T }> {
    entity: Entity,
    first: A,
    second: B,
@each(T) {
    any_$I: TableErasedOptional<$T>,
}
}
}

struct TableErasedAnyOf3WithOptionalPair<A, B, C, D, E> {
    entity: Entity,
    first: TableErasedOptional<A>,
    second: TableErasedOptional<B>,
    third: TableErasedOptional<C>,
    pair: TableErasedOptional<TableErasedPairValue<D, E>>,
}

@expand_tuple(2, 12, C) {
struct TableErasedCombination$N<T> {
@each(C) {
    $ORD: T,
}
}
}

struct TableErasedIndexCombination {
    indices: Vec<i64>,
}

struct TableErasedPairMut<A, B> {
    first: TableErasedMut<A>,
    second_component_id: i32,
    second_type_id: i32,
    second: B,
}

impl TableErasedSpawnDetails {
    fn is_spawned(&self) -> bool {
        return self.is_spawned_after(self.last_run_tick);
    }

    fn is_spawned_after(&self, tick: i32) -> bool {
        if self.spawn_tick_value <= tick { return false; };
        return self.spawn_tick_value <= self.this_run_tick;
    }

    fn spawn_tick(&self) -> i32 {
        return self.spawn_tick_value;
    }

    fn spawned_by(&self) -> TableErasedSpawnLocation {
        return self.spawned_by_value;
    }

    fn has_spawned_by(&self) -> bool {
        return self.spawned_by_value.has_location;
    }
}

impl TableErasedSpawnLocation {
    fn is_some(&self) -> bool {
        return self.has_location;
    }
}

const TABLE_ERASED_FILTER_WITH: i32 = 1;
const TABLE_ERASED_FILTER_WITHOUT: i32 = 2;
const TABLE_ERASED_FILTER_ADDED: i32 = 3;
const TABLE_ERASED_FILTER_CHANGED: i32 = 4;

fn table_erased_world_filter_matches<R, M>(world: TableErasedWorld<R, M>, entity: Entity, filter_kind: i32, component_id: i32, tick: i32) -> bool {
    if filter_kind == TABLE_ERASED_FILTER_WITH { return table_erased_world_has<R, M>(world, entity, component_id); };
    if filter_kind == TABLE_ERASED_FILTER_WITHOUT { return table_erased_world_has<R, M>(world, entity, component_id) != true; };
    if filter_kind == TABLE_ERASED_FILTER_ADDED { return table_erased_world_added_since<R, M>(world, entity, component_id, tick); };
    if filter_kind == TABLE_ERASED_FILTER_CHANGED { return table_erased_world_changed_since<R, M>(world, entity, component_id, tick); };
    return false;
}

fn table_erased_world_filter_or_matches<R, M>(world: TableErasedWorld<R, M>, entity: Entity, left_kind: i32, left_component_id: i32, left_tick: i32, right_kind: i32, right_component_id: i32, right_tick: i32) -> bool {
    if table_erased_world_filter_matches<R, M>(world, entity, left_kind, left_component_id, left_tick) { return true; };
    return table_erased_world_filter_matches<R, M>(world, entity, right_kind, right_component_id, right_tick);
}

fn table_erased_world_filter_and_matches<R, M>(world: TableErasedWorld<R, M>, entity: Entity, left_kind: i32, left_component_id: i32, left_tick: i32, right_kind: i32, right_component_id: i32, right_tick: i32) -> bool {
    if table_erased_world_filter_matches<R, M>(world, entity, left_kind, left_component_id, left_tick) != true { return false; };
    return table_erased_world_filter_matches<R, M>(world, entity, right_kind, right_component_id, right_tick);
}

fn table_erased_optional_some<T>(value: T) -> TableErasedOptional<T> {
    return TableErasedOptional<T> { has_value: true, value: value };
}

fn table_erased_optional_none<T>(default_value: fn() -> T) -> TableErasedOptional<T> {
    return TableErasedOptional<T> { has_value: false, value: default_value() };
}

fn table_erased_column_def_new(component_id: i32, type_id: i32, drop_fn: fn(*u8) -> void) -> TableErasedColumnDef {
    return TableErasedColumnDef { component_id: component_id, type_id: type_id, drop_fn: drop_fn };
}

fn table_erased_column_new(def: TableErasedColumnDef) -> TableErasedColumn {
    let values: Vec<ErasedComponentValue> = Vec::new();
    return TableErasedColumn { component_id: def.component_id, type_id: def.type_id, drop_fn: def.drop_fn, values: values };
}

fn table_erased_column_copy_last_to(column: TableErasedColumn, row: i64, last: i64) -> TableErasedColumn {
    column.values[row] = column.values[last];
    return column;
}

fn table_erased_column_remove_last(column: TableErasedColumn, last: i64) -> TableErasedColumn {
    let removed = column.values.remove(last);
    return column;
}

fn table_erased_signature_empty() -> Vec<i32> {
    let ids: Vec<i32> = Vec::new();
    return ids;
}

fn table_erased_location_empty(entity_id: i32) -> TableErasedLocation {
    return TableErasedLocation { entity_id: entity_id, archetype_id: -1, row: -1 };
}

fn table_erased_spawn_location_none() -> TableErasedSpawnLocation {
    return TableErasedSpawnLocation { has_location: false, file_id: 0, line: 0, column: 0 };
}

fn table_erased_spawn_location_new(file_id: i32, line: i32, column: i32) -> TableErasedSpawnLocation {
    return TableErasedSpawnLocation { has_location: true, file_id: file_id, line: line, column: column };
}

fn table_erased_spawn_details_new(entity: Entity, spawn_tick: i32, last_run_tick: i32, this_run_tick: i32, spawned_by: TableErasedSpawnLocation) -> TableErasedSpawnDetails {
    return TableErasedSpawnDetails { entity: entity, spawn_tick_value: spawn_tick, last_run_tick: last_run_tick, this_run_tick: this_run_tick, spawned_by_value: spawned_by };
}

fn table_erased_removed_component_new(entity: Entity, component_id: i32, tick: i32) -> TableErasedRemovedComponent {
    return TableErasedRemovedComponent { entity: entity, component_id: component_id, tick: tick };
}

fn table_erased_entity_vec_has_duplicate(entities: Vec<Entity>) -> bool {
    let i: i64 = 0;
    let cnt = len(entities) as i64;
    while i < cnt {
        let j = i + 1;
        while j < cnt {
            if entity_eq(entities[i], entities[j]) { return true; };
            j = j + 1;
        }
        i = i + 1;
    }
    return false;
}

fn table_erased_query_single<T>(query: Query<T>) -> T {
    let cnt = len(query.items);
    if cnt == 0 { panic(11860); };
    if cnt > 1 { panic(11861); };
    return query.items[0];
}

fn table_erased_query_count<T>(query: Query<T>) -> i64 {
    return len(query.items) as i64;
}

fn table_erased_query_is_empty<T>(query: Query<T>) -> bool {
    return len(query.items) == 0;
}

fn table_erased_query_entities_contains(query: Query<Entity>, entity: Entity) -> bool {
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        if query.items[i] == entity { return true; };
        i = i + 1;
    }
    return false;
}

