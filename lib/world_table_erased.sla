        if table_erased_world_changed_since<R, M>(world, item.first.entity, filter_component_id, tick) { query.items.push(item); };
        i = i + 1;
    }
    return query;
}

fn table_erased_world_query_pair_mut_first_changed_auto<A, B, R, M>(world: TableErasedWorld<R, M>, first_type_id: i32, second_type_id: i32, filter_type_id: i32, tick: i32) -> Query<TableErasedPairMut<A, B>> {
    let first_component_id = table_erased_world_component_id_for_type<R, M>(world, first_type_id);
    let second_component_id = table_erased_world_component_id_for_type<R, M>(world, second_type_id);
    let filter_component_id = table_erased_world_component_id_for_type<R, M>(world, filter_type_id);
    return table_erased_world_query_pair_mut_first_changed<A, B, R, M>(world, first_component_id, first_type_id, second_component_id, second_type_id, filter_component_id, tick);
}

fn table_erased_world_query_pair_mut_first_without<A, B, R, M>(world: TableErasedWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, without_component_id: i32) -> Query<TableErasedPairMut<A, B>> {
    let query = query_new<TableErasedPairMut<A, B>>();
    let a: i64 = 0;
    let archetype_count = len(world.archetypes) as i64;
    while a < archetype_count {
        if table_erased_signature_has(world.archetypes[a].component_ids, first_component_id) {
            if table_erased_signature_has(world.archetypes[a].component_ids, second_component_id) {
                if table_erased_signature_has(world.archetypes[a].component_ids, without_component_id) != true {
                    let column_slot = table_erased_world_column_slot<R, M>(world, a, first_component_id);
                    let row: i64 = 0;
                    let row_count = len(world.archetypes[a].entity_ids) as i64;
                    while row < row_count {
                        let eid = world.archetypes[a].entity_ids[row];
                        let entity = entity_new(eid, world.registry.entities.generations[eid]);
                        query.items.push(TableErasedPairMut<A, B> {
                            first: TableErasedMut<A> { entity: entity, component_id: first_component_id, type_id: first_type_id, archetype_id: world.archetypes[a].id, row: row, value: registry_erased_value_read<A>(world.archetypes[a].columns[column_slot].values[row], first_type_id) },
                            second_component_id: second_component_id,
                            second_type_id: second_type_id,
                            second: table_erased_world_get<B, R, M>(world, entity, second_component_id, second_type_id),
                        });
                        row = row + 1;
                    }
                }
            }
        };
        a = a + 1;
    }
    return query;
}

