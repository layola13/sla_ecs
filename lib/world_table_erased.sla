fn table_erased_query_combinations2<T>(query: Query<T>) -> Query<TableErasedCombination2<T>> {
    let result = query_new<TableErasedCombination2<T>>();
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        let j = i + 1;
        while j < cnt {
            result.items.push(TableErasedCombination2<T> { first: query.items[i], second: query.items[j] });
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

