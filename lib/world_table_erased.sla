fn table_erased_world_query_pair_mut_first_with_without<A, B, R, M>(world: TableErasedWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, with_component_id: i32, without_component_id: i32) -> Query<TableErasedPairMut<A, B>> {
    let query = query_new<TableErasedPairMut<A, B>>();
    let base = table_erased_world_query_pair_mut_first<A, B, R, M>(world, first_component_id, first_type_id, second_component_id, second_type_id);
    let i: i64 = 0;
    let cnt = len(base.items) as i64;
    while i < cnt {
        let item = base.items[i];
        if table_erased_world_has<R, M>(world, item.first.entity, with_component_id) {
            if table_erased_world_has<R, M>(world, item.first.entity, without_component_id) != true { query.items.push(item); };
        };
        i = i + 1;
    }
    return query;
}

