fn table_erased_query_pair_mut_as_readonly<A, B>(query: Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPair<A, B>> {
    let result = query_new<TableErasedPair<A, B>>();
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        let item = query.items[i];
        result.items.push(TableErasedPair<A, B> { entity: item.first.entity, first: item.first.value, second: item.second });
        i = i + 1;
    }
    return result;
}

