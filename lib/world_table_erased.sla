    let marked = table_erased_world_query_with<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, position.id, TABLE_ERASED_POS_TYPE, marker.id);
    if len(marked.items) != 1 { panic(11643); };
    if marked.items[0].entity.id != e2.id { panic(11644); };
    let mobile_positions = table_erased_world_query_with_without<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, position.id, TABLE_ERASED_POS_TYPE, velocity.id, marker.id);
