fn table_erased_world_write<T, R, M>(world: TableErasedWorld<R, M>, item: TableErasedMut<T>, value: T) -> TableErasedWorld<R, M> {
    if table_erased_world_is_alive<R, M>(world, item.entity) != true { return world; };
    if table_erased_world_entity_archetype_id<R, M>(world, item.entity) != item.archetype_id { return world; };
    if table_erased_world_entity_row<R, M>(world, item.entity) != item.row { return world; };
    let archetype_slot = item.archetype_id as i64;
    let column_slot = table_erased_world_column_slot<R, M>(world, archetype_slot, item.component_id);
    if column_slot < 0 { return world; };
    let drop_fn = world.archetypes[archetype_slot].columns[column_slot].drop_fn;
    drop_fn(world.archetypes[archetype_slot].columns[column_slot].values[item.row].raw);
    world.archetypes[archetype_slot].columns[column_slot].values[item.row] = registry_erased_value_new<T>(item.type_id, value);
    world.registry = registry_world_insert_component(world.registry, item.entity, item.component_id);
    return world;
}

fn table_erased_world_pair_write_first<A, B, R, M>(world: TableErasedWorld<R, M>, item: TableErasedPairMut<A, B>, value: A) -> TableErasedWorld<R, M> {
    return table_erased_world_write<A, R, M>(world, item.first, value);
}

fn table_erased_world_insert_resource<R, M>(world: TableErasedWorld<R, M>, value: R) -> TableErasedWorld<R, M> {
    if resource_has<R>(world.resource) != true { world.resource_added_tick = world.registry.change_tick; };
    world.resource = resource_insert<R>(world.resource, value);
    world.resource_changed_tick = world.registry.change_tick;
    return world;
}
fn table_erased_world_get_resource<R, M>(world: TableErasedWorld<R, M>) -> R { return resource_get<R>(world.resource); }
fn table_erased_world_has_resource<R, M>(world: TableErasedWorld<R, M>) -> bool { return resource_has<R>(world.resource); }

fn table_erased_world_res<R, M>(world: TableErasedWorld<R, M>) -> Res<R> {
    return Res<R> { value: table_erased_world_get_resource<R, M>(world), added_tick: world.resource_added_tick, changed_tick: world.resource_changed_tick };
}

fn table_erased_world_res_mut<R, M>(world: TableErasedWorld<R, M>) -> ResMut<R> {
    return ResMut<R> { value: table_erased_world_get_resource<R, M>(world), added_tick: world.resource_added_tick, changed_tick: world.resource_changed_tick };
}

fn table_erased_world_resource_added_since<R, M>(world: TableErasedWorld<R, M>, tick: i32) -> bool {
    if table_erased_world_has_resource<R, M>(world) != true { return false; };
    return world.resource_added_tick > tick;
}

fn table_erased_world_resource_changed_since<R, M>(world: TableErasedWorld<R, M>, tick: i32) -> bool {
    if table_erased_world_has_resource<R, M>(world) != true { return false; };
    return world.resource_changed_tick > tick;
}

fn table_erased_world_res_mut_write<R, M>(world: TableErasedWorld<R, M>, res: ResMut<R>, value: R) -> TableErasedWorld<R, M> {
    if table_erased_world_has_resource<R, M>(world) != true { return world; };
    world.resource = resource_insert<R>(world.resource, value);
    world.resource_changed_tick = world.registry.change_tick;
    return world;
}

fn table_erased_world_remove_resource<R, M>(world: TableErasedWorld<R, M>) -> TableErasedWorld<R, M> {
    world.resource = resource_remove<R>(world.resource);
    world.resource_added_tick = 0;
    world.resource_changed_tick = 0;
    return world;
}
fn table_erased_world_write_message<R, M>(world: TableErasedWorld<R, M>, value: M) -> TableErasedWorld<R, M> { world.messages = messages_write<M>(world.messages, value); return world; }
fn table_erased_world_write_message_with_id<R, M>(world: TableErasedWorld<R, M>, value: M) -> (TableErasedWorld<R, M>, i64) {
    let written = messages_write_with_id<M>(world.messages, value);
    world.messages = written.messages;
    return (world, written.id);
}
fn table_erased_world_write_default_message<R, M>(world: TableErasedWorld<R, M>, default_value: M) -> (TableErasedWorld<R, M>, i64) {
    let written = messages_write_default<M>(world.messages, default_value);
    world.messages = written.messages;
    return (world, written.id);
}
fn table_erased_world_write_message_batch<R, M>(world: TableErasedWorld<R, M>, writer: MessageWriter<M>) -> (TableErasedWorld<R, M>, i64, i64) {
    let written = messages_write_batch<M>(world.messages, writer);
    world.messages = written.messages;
    return (world, written.first_id, written.count);
}
fn table_erased_world_read_message<R, M>(world: TableErasedWorld<R, M>, reader: MessageReader, default_value: M) -> MessageRead<M> { return messages_read_next<M>(world.messages, reader, default_value); }
fn table_erased_world_read_message_with_id<R, M>(world: TableErasedWorld<R, M>, reader: MessageReader, default_value: M) -> MessageReadWithId<M> { return messages_read_next_with_id<M>(world.messages, reader, default_value); }
fn table_erased_world_get_message<R, M>(world: TableErasedWorld<R, M>, id: i64, default_value: M) -> MessageReadWithId<M> { return messages_get_message<M>(world.messages, id, default_value); }
fn table_erased_world_update_messages<R, M>(world: TableErasedWorld<R, M>) -> TableErasedWorld<R, M> { world.messages = messages_update<M>(world.messages); return world; }
fn table_erased_world_current_update_message_len<R, M>(world: TableErasedWorld<R, M>) -> i64 { return messages_current_update_len<M>(world.messages); }
fn table_erased_world_update_messages_drain<R, M>(world: TableErasedWorld<R, M>, default_value: M) -> (TableErasedWorld<R, M>, MessageDrainItems<M>) {
    let drained = messages_update_drain<M>(world.messages, default_value);
    let items = MessageDrainItems<M> { count: drained.count, ids: drained.ids, values: drained.values };
    world.messages = drained.messages;
    return (world, items);
}
fn table_erased_world_drain_messages<R, M>(world: TableErasedWorld<R, M>, default_value: M) -> (TableErasedWorld<R, M>, MessageDrainItems<M>) {
    let drained = messages_drain<M>(world.messages, default_value);
    let items = MessageDrainItems<M> { count: drained.count, ids: drained.ids, values: drained.values };
    world.messages = drained.messages;
    return (world, items);
}

const TABLE_ERASED_POS_TYPE: i32 = 301;
const TABLE_ERASED_VEL_TYPE: i32 = 302;
const TABLE_ERASED_MARKER_TYPE: i32 = 303;
const TABLE_ERASED_TAG_TYPE: i32 = 304;
const TABLE_ERASED_AUX_TYPE: i32 = 305;
const TABLE_ERASED_EXTRA_TYPE: i32 = 306;
const TABLE_ERASED_MORE_TYPE: i32 = 307;
const TABLE_ERASED_BONUS_TYPE: i32 = 308;

struct TableErasedPos { x: i32, y: i32 }
struct TableErasedVel { x: i32, y: i32 }
struct TableErasedMarker { value: i32 }
struct TableErasedTag { value: i32 }
struct TableErasedAux { value: i32 }
struct TableErasedExtra { value: i32 }
struct TableErasedMore { value: i32 }
struct TableErasedBonus { value: i32 }
struct TableErasedTime { tick: i32 }
struct TableErasedEvent { amount: i32 }

fn table_erased_time_default() -> TableErasedTime { return TableErasedTime { tick: 0 }; }
fn table_erased_event_default() -> TableErasedEvent { return TableErasedEvent { amount: 0 }; }
fn table_erased_pos_default() -> TableErasedPos { return TableErasedPos { x: 0, y: 0 }; }
fn table_erased_vel_default() -> TableErasedVel { return TableErasedVel { x: 0, y: 0 }; }
fn table_erased_marker_default() -> TableErasedMarker { return TableErasedMarker { value: 0 }; }
fn table_erased_tag_default() -> TableErasedTag { return TableErasedTag { value: 0 }; }
fn table_erased_aux_default() -> TableErasedAux { return TableErasedAux { value: 0 }; }
fn table_erased_extra_default() -> TableErasedExtra { return TableErasedExtra { value: 0 }; }
fn table_erased_more_default() -> TableErasedMore { return TableErasedMore { value: 0 }; }
fn table_erased_bonus_default() -> TableErasedBonus { return TableErasedBonus { value: 0 }; }
fn table_erased_vel_marker_pair_default() -> TableErasedPairValue<TableErasedVel, TableErasedMarker> { return TableErasedPairValue<TableErasedVel, TableErasedMarker> { first: table_erased_vel_default(), second: table_erased_marker_default() }; }
fn table_erased_test_world_new() -> TableErasedWorld<TableErasedTime, TableErasedEvent> { return table_erased_world_new<TableErasedTime, TableErasedEvent>(table_erased_time_default(), table_erased_event_default()); }

@test "table erased world stores heterogeneous values by archetype row"() {
    let w0 = table_erased_test_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, velocity) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, ecs_box_drop<TableErasedVel>);
    let (w3, marker) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w2, TABLE_ERASED_MARKER_TYPE, ecs_box_drop<TableErasedMarker>);
    let (w4, e1) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let (w5, e2) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let w6 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 10, y: 0 });
    let w7 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w6, e1, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 4, y: 0 });
    let w8 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w7, e2, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 8, y: 0 });
    let w9 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w8, e2, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 2, y: 0 });
    let shared = table_erased_world_entity_archetype_id<TableErasedTime, TableErasedEvent>(w9, e1);
    if shared != table_erased_world_entity_archetype_id<TableErasedTime, TableErasedEvent>(w9, e2) { panic(11620); };
    let w10 = table_erased_world_insert<TableErasedMarker, TableErasedTime, TableErasedEvent>(w9, e1, marker.id, TABLE_ERASED_MARKER_TYPE, TableErasedMarker { value: 1 });
    if table_erased_world_entity_row<TableErasedTime, TableErasedEvent>(w10, e2) != 0 { panic(11621); };
    if table_erased_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, e2, position.id, TABLE_ERASED_POS_TYPE).x != 8 { panic(11622); };
    if table_erased_world_get<TableErasedVel, TableErasedTime, TableErasedEvent>(w10, e2, velocity.id, TABLE_ERASED_VEL_TYPE).x != 2 { panic(11623); };
}

@test "table erased world pair query writeback and cleanup"() {
    let w0 = table_erased_test_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, velocity) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, ecs_box_drop<TableErasedVel>);
    let (w3, marker) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w2, TABLE_ERASED_MARKER_TYPE, ecs_box_drop<TableErasedMarker>);
    let (w4, e1) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let (w5, e2) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let w6 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 2, y: 0 });
    let w7 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w6, e1, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 5, y: 0 });
    let w8 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w7, e2, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 20, y: 0 });
    let w9 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w8, e2, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 1, y: 0 });
    let w10 = table_erased_world_insert<TableErasedMarker, TableErasedTime, TableErasedEvent>(w9, e2, marker.id, TABLE_ERASED_MARKER_TYPE, TableErasedMarker { value: 1 });
    let unmarked = table_erased_world_query_without<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, position.id, TABLE_ERASED_POS_TYPE, marker.id);
    if len(unmarked.items) != 1 { panic(11630); };
    if unmarked.items[0].entity.id != e1.id { panic(11631); };
    let before = w10.registry.change_tick;
    let w11 = table_erased_world_increment_tick<TableErasedTime, TableErasedEvent>(w10);
    let movers = table_erased_world_query_pair_mut_first<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w11, position.id, TABLE_ERASED_POS_TYPE, velocity.id, TABLE_ERASED_VEL_TYPE);
    let item = movers.items[0];
    let w12 = table_erased_world_pair_write_first<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w11, item, TableErasedPos { x: item.first.value.x + item.second.x, y: 0 });
    if table_erased_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w12, item.first.entity, position.id, TABLE_ERASED_POS_TYPE).x != 7 { panic(11632); };
    let changed = table_erased_world_query_changed<TableErasedPos, TableErasedTime, TableErasedEvent>(w12, position.id, TABLE_ERASED_POS_TYPE, before);
    if len(changed.items) != 1 { panic(11633); };
    let w13 = table_erased_world_remove<TableErasedTime, TableErasedEvent>(w12, e2, marker.id);
    if table_erased_world_has<TableErasedTime, TableErasedEvent>(w13, e2, marker.id) != false { panic(11634); };
    let w14 = table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(w13, TableErasedTime { tick: w13.registry.change_tick });
    let w15 = table_erased_world_write_message<TableErasedTime, TableErasedEvent>(w14, TableErasedEvent { amount: 6 });
    let w16 = table_erased_world_despawn<TableErasedTime, TableErasedEvent>(w15, e2);
    if table_erased_world_is_alive<TableErasedTime, TableErasedEvent>(w16, e2) != false { panic(11635); };
    if table_erased_world_has<TableErasedTime, TableErasedEvent>(w16, e2, position.id) != false { panic(11636); };
    let time = table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(w16);
    let event = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w16, message_reader_new(), table_erased_event_default());
    if time.tick != 2 { panic(11637); };
    if event.value.amount != 6 { panic(11638); };
}

@test "table erased world messages expose monotonic ids"() {
    let w0 = table_erased_test_world_new();
    let (w1, id1) = table_erased_world_write_message_with_id<TableErasedTime, TableErasedEvent>(w0, TableErasedEvent { amount: 5 });
    let (w2, id2) = table_erased_world_write_message_with_id<TableErasedTime, TableErasedEvent>(w1, TableErasedEvent { amount: 7 });
    if id1 != 0 { panic(11639); };
    if id2 != 1 { panic(11640); };
    if message_id_lt(id1, id2) != true { panic(11641); };

    let read1 = table_erased_world_read_message_with_id<TableErasedTime, TableErasedEvent>(w2, message_reader_new(), table_erased_event_default());
    let read2 = table_erased_world_read_message_with_id<TableErasedTime, TableErasedEvent>(w2, read1.reader, table_erased_event_default());
    let read3 = table_erased_world_read_message_with_id<TableErasedTime, TableErasedEvent>(w2, read2.reader, table_erased_event_default());
    if read1.has_value != true { panic(11642); };
    if read1.id != 0 { panic(11643); };
    if read1.value.amount != 5 { panic(11644); };
    if read2.has_value != true { panic(11645); };
    if read2.id != 1 { panic(11646); };
    if read2.value.amount != 7 { panic(11647); };
    if read3.has_value { panic(11648); };

    let found = table_erased_world_get_message<TableErasedTime, TableErasedEvent>(w2, id2, table_erased_event_default());
    if found.has_value != true { panic(11649); };
    if found.value.amount != 7 { panic(11650); };
    let current = message_reader_current<TableErasedEvent>(w2.messages);
    let (w3, id3) = table_erased_world_write_message_with_id<TableErasedTime, TableErasedEvent>(w2, TableErasedEvent { amount: 11 });
    let read_current = table_erased_world_read_message_with_id<TableErasedTime, TableErasedEvent>(w3, current, table_erased_event_default());
    if id3 != 2 { panic(11651); };
    if read_current.id != 2 { panic(11652); };
    if read_current.value.amount != 11 { panic(11653); };
}

@test "table erased world message batch and default writes expose ids"() {
    let w0 = table_erased_test_world_new();
    let (w1, default_id) = table_erased_world_write_default_message<TableErasedTime, TableErasedEvent>(w0, TableErasedEvent { amount: 4 });
    if default_id != 0 { panic(11679); };
    let writer0 = message_writer_new<TableErasedEvent>();
    let writer1 = message_writer_send<TableErasedEvent>(writer0, TableErasedEvent { amount: 6 });
    let writer2 = message_writer_send<TableErasedEvent>(writer1, TableErasedEvent { amount: 8 });
    let (w2, first_id, count) = table_erased_world_write_message_batch<TableErasedTime, TableErasedEvent>(w1, writer2);
    if first_id != 1 { panic(11680); };
    if count != 2 { panic(11681); };
    if w2.messages.next_id != 3 { panic(11682); };

    let first = table_erased_world_get_message<TableErasedTime, TableErasedEvent>(w2, message_id_new(first_id), table_erased_event_default());
    let second = table_erased_world_get_message<TableErasedTime, TableErasedEvent>(w2, message_id_new(first_id + 1), table_erased_event_default());
    if first.has_value != true { panic(11683); };
    if first.value.amount != 6 { panic(11684); };
    if second.has_value != true { panic(11685); };
    if second.value.amount != 8 { panic(11686); };

    let empty_writer = message_writer_new<TableErasedEvent>();
    let (w3, empty_first, empty_count) = table_erased_world_write_message_batch<TableErasedTime, TableErasedEvent>(w2, empty_writer);
    if empty_first != 3 { panic(11687); };
    if empty_count != 0 { panic(11688); };
    if w3.messages.next_id != 3 { panic(11689); };
}

@test "table erased world messages update retains one frame"() {
    let w0 = table_erased_test_world_new();
    let w1 = table_erased_world_update_messages<TableErasedTime, TableErasedEvent>(w0);
    let w2 = table_erased_world_write_message<TableErasedTime, TableErasedEvent>(w1, TableErasedEvent { amount: 1 });
    if messages_len<TableErasedEvent>(w2.messages) != 1 { panic(11654); };
    if table_erased_world_current_update_message_len<TableErasedTime, TableErasedEvent>(w2) != 1 { panic(11655); };

    let w3 = table_erased_world_update_messages<TableErasedTime, TableErasedEvent>(w2);
    if messages_len<TableErasedEvent>(w3.messages) != 1 { panic(11656); };
    if table_erased_world_current_update_message_len<TableErasedTime, TableErasedEvent>(w3) != 0 { panic(11657); };

    let w4 = table_erased_world_write_message<TableErasedTime, TableErasedEvent>(w3, TableErasedEvent { amount: 2 });
    let w5 = table_erased_world_write_message<TableErasedTime, TableErasedEvent>(w4, TableErasedEvent { amount: 3 });
    if messages_len<TableErasedEvent>(w5.messages) != 3 { panic(11658); };
    if table_erased_world_current_update_message_len<TableErasedTime, TableErasedEvent>(w5) != 2 { panic(11659); };

    let w6 = table_erased_world_update_messages<TableErasedTime, TableErasedEvent>(w5);
    if messages_len<TableErasedEvent>(w6.messages) != 2 { panic(11660); };
    let dropped = table_erased_world_get_message<TableErasedTime, TableErasedEvent>(w6, message_id_new(0), table_erased_event_default());
    if dropped.has_value { panic(11661); };
    let kept = table_erased_world_get_message<TableErasedTime, TableErasedEvent>(w6, message_id_new(1), table_erased_event_default());
    if kept.has_value != true { panic(11662); };
    if kept.value.amount != 2 { panic(11663); };

    let w7 = table_erased_world_update_messages<TableErasedTime, TableErasedEvent>(w6);
    if messages_len<TableErasedEvent>(w7.messages) != 0 { panic(11664); };
}

@test "table erased world message drains return retained buffers"() {
    let w0 = table_erased_test_world_new();
    let w1 = table_erased_world_update_messages<TableErasedTime, TableErasedEvent>(w0);
    let w2 = table_erased_world_write_message<TableErasedTime, TableErasedEvent>(w1, TableErasedEvent { amount: 1 });
    let w3 = table_erased_world_update_messages<TableErasedTime, TableErasedEvent>(w2);
    let w4 = table_erased_world_write_message<TableErasedTime, TableErasedEvent>(w3, TableErasedEvent { amount: 2 });
    let w5 = table_erased_world_write_message<TableErasedTime, TableErasedEvent>(w4, TableErasedEvent { amount: 3 });

    let (w6, drained_old) = table_erased_world_update_messages_drain<TableErasedTime, TableErasedEvent>(w5, table_erased_event_default());
    if drained_old.count != 1 { panic(11665); };
    if drained_old.ids[0] != 0 { panic(11666); };
    if drained_old.values[0].amount != 1 { panic(11667); };
    if messages_len<TableErasedEvent>(w6.messages) != 2 { panic(11668); };
    let kept = table_erased_world_get_message<TableErasedTime, TableErasedEvent>(w6, message_id_new(1), table_erased_event_default());
    if kept.has_value != true { panic(11669); };
    if kept.value.amount != 2 { panic(11670); };

    let (w7, drained_all) = table_erased_world_drain_messages<TableErasedTime, TableErasedEvent>(w6, table_erased_event_default());
    if drained_all.count != 2 { panic(11671); };
    if drained_all.ids[0] != 1 { panic(11672); };
    if drained_all.ids[1] != 2 { panic(11673); };
    if drained_all.values[0].amount != 2 { panic(11674); };
    if drained_all.values[1].amount != 3 { panic(11675); };
    if messages_len<TableErasedEvent>(w7.messages) != 0 { panic(11676); };
    if w7.messages.next_id != 3 { panic(11677); };
    if w7.messages.current_start_id != 3 { panic(11678); };
}

@test "table erased world tracks removed components"() {
    let w0 = table_erased_test_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, velocity) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, ecs_box_drop<TableErasedVel>);
    let (w3, marker) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w2, TABLE_ERASED_MARKER_TYPE, ecs_box_drop<TableErasedMarker>);
    let (w4, tag) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w3, TABLE_ERASED_TAG_TYPE, ecs_box_drop<TableErasedTag>);
    let (w5, e1) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let (w6, e2) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w5);
    let w7 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w6, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 1, y: 0 });
    let w8 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w7, e1, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 10, y: 0 });
    let w9 = table_erased_world_insert<TableErasedMarker, TableErasedTime, TableErasedEvent>(w8, e1, marker.id, TABLE_ERASED_MARKER_TYPE, TableErasedMarker { value: 100 });
    let w10 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, e2, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 2, y: 0 });
    let w11 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w10, e2, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 20, y: 0 });
    let w12 = table_erased_world_insert<TableErasedTag, TableErasedTime, TableErasedEvent>(w11, e2, tag.id, TABLE_ERASED_TAG_TYPE, TableErasedTag { value: 200 });
    let replace_before = w12.registry.change_tick;
    let w13 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w12, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 3, y: 0 });
    let replaced_removed = table_erased_world_removed_components<TableErasedTime, TableErasedEvent>(w13, position.id, replace_before - 1);
    if len(replaced_removed.items) != 0 { panic(12900); };

    let remove_since = w13.registry.change_tick;
    let w14 = table_erased_world_increment_tick<TableErasedTime, TableErasedEvent>(w13);
    let w15 = table_erased_world_remove_auto<TableErasedTime, TableErasedEvent>(w14, e1, TABLE_ERASED_MARKER_TYPE);
    let removed_marker = table_erased_world_removed_components_auto<TableErasedTime, TableErasedEvent>(w15, TABLE_ERASED_MARKER_TYPE, remove_since);
    if len(removed_marker.items) != 1 { panic(12901); };
    if removed_marker.items[0].id != e1.id { panic(12902); };
    let removed_marker_current = table_erased_world_removed_components<TableErasedTime, TableErasedEvent>(w15, marker.id, w15.registry.change_tick);
    if len(removed_marker_current.items) != 0 { panic(12903); };

    let despawn_since = w15.registry.change_tick;
    let w16 = table_erased_world_increment_tick<TableErasedTime, TableErasedEvent>(w15);
    let w17 = table_erased_world_despawn<TableErasedTime, TableErasedEvent>(w16, e2);
    let removed_pos = table_erased_world_removed_components<TableErasedTime, TableErasedEvent>(w17, position.id, despawn_since);
    let removed_vel = table_erased_world_removed_components_auto<TableErasedTime, TableErasedEvent>(w17, TABLE_ERASED_VEL_TYPE, despawn_since);
    let removed_tag = table_erased_world_removed_components<TableErasedTime, TableErasedEvent>(w17, tag.id, despawn_since);
    let removed_marker_after_despawn = table_erased_world_removed_components<TableErasedTime, TableErasedEvent>(w17, marker.id, despawn_since);
    if len(removed_pos.items) != 1 { panic(12904); };
    if removed_pos.items[0].id != e2.id { panic(12905); };
    if len(removed_vel.items) != 1 { panic(12906); };
    if removed_vel.items[0].id != e2.id { panic(12907); };
    if len(removed_tag.items) != 1 { panic(12908); };
    if removed_tag.items[0].id != e2.id { panic(12909); };
    if len(removed_marker_after_despawn.items) != 0 { panic(12910); };

    let w18 = table_erased_world_clear_removed_components<TableErasedTime, TableErasedEvent>(w17);
    let removed_after_clear = table_erased_world_removed_components<TableErasedTime, TableErasedEvent>(w18, position.id, 0);
    if len(removed_after_clear.items) != 0 { panic(12911); };
}

@test "table erased query get single and get many preserve entity order"() {
    let w0 = table_erased_test_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, velocity) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, ecs_box_drop<TableErasedVel>);
    let (w3, e1) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w2);
    let w4 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w3, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 10, y: 0 });
    let w5 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w4, e1, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 1, y: 0 });

    let single_entity = table_erased_world_query_entities_single<TableErasedTime, TableErasedEvent>(w5);
    if single_entity.id != e1.id { panic(11872); };
    let single_pos = table_erased_world_query_single_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, TABLE_ERASED_POS_TYPE);
    if single_pos.entity.id != e1.id { panic(11873); };
    if single_pos.value.x != 10 { panic(11874); };
    let single_pair = table_erased_world_query_pair_single_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w5, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE);
    if single_pair.first.x != 10 { panic(11875); };
    if single_pair.second.x != 1 { panic(11876); };
    let single_mut = table_erased_world_query_pair_mut_first_single_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w5, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE);
    if single_mut.first.value.x != 10 { panic(11877); };
    if single_mut.second.x != 1 { panic(11878); };
    let single_mut_alias = table_erased_world_query_pair_mut_first_single_mut_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w5, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE);
    if single_mut_alias.first.value.x != 10 { panic(12842); };
    if single_mut_alias.second.x != 1 { panic(12843); };
    let single_mover_query = table_erased_world_query_pair_mut_first_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w5, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE);
    let query_mover_single_alias = table_erased_query_pair_mut_single_mut<TableErasedPos, TableErasedVel>(single_mover_query);
    if query_mover_single_alias.first.value.x != 10 { panic(12848); };

    let (w6, e2) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w5);
    let w7 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w6, e2, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 20, y: 0 });
    let w8 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w7, e2, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 2, y: 0 });
    let (w9, e3) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w8);
    let w10 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, e3, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 30, y: 0 });
    let w11 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w10, e3, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 3, y: 0 });
    let (w12, e4) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w11);
    let w13 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w12, e4, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 40, y: 0 });
    let w14 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w13, e4, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 4, y: 0 });

    let order: Vec<Entity> = Vec::new();
    order.push(e3);
    order.push(e1);
    order.push(e2);
    if table_erased_entity_vec_has_duplicate(order) { panic(11879); };
    let duplicate_order: Vec<Entity> = Vec::new();
    duplicate_order.push(e1);
    duplicate_order.push(e2);
    duplicate_order.push(e1);
