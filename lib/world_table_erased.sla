    if len(changed_marked_positions.items) != 1 { panic(11729); };
    if changed_marked_positions.items[0].entity.id != e2.id { panic(11730); };
    let pair_any_changed = table_erased_world_query_pair_or_changed_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_MARKER_TYPE, before_change);
    if len(pair_any_changed.items) != 1 { panic(11683); };
    if pair_any_changed.items[0].entity.id != e2.id { panic(11684); };
    let changed_marked_pairs = table_erased_world_query_pair_filter_and_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_FILTER_CHANGED, TABLE_ERASED_POS_TYPE, before_change, TABLE_ERASED_FILTER_WITH, TABLE_ERASED_MARKER_TYPE, 0);
    if len(changed_marked_pairs.items) != 1 { panic(11731); };
    if changed_marked_pairs.items[0].entity.id != e2.id { panic(11732); };
    let triple_changed = table_erased_world_query_triple_changed_auto<TableErasedMarker, TableErasedVel, TableErasedPos, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_MARKER_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_POS_TYPE, before_change);
    if len(triple_changed.items) != 1 { panic(11771); };
