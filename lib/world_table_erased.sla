    if len(triple_added.items) != 1 { panic(11765); };
    if triple_added.items[0].entity.id != e2.id { panic(11766); };
    let triple_or = table_erased_world_query_triple_filter_or_auto<TableErasedMarker, TableErasedVel, TableErasedPos, TableErasedTime, TableErasedEvent>(w10, TABLE_ERASED_MARKER_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_FILTER_WITH, TABLE_ERASED_MARKER_TYPE, 0, TABLE_ERASED_FILTER_WITHOUT, TABLE_ERASED_MARKER_TYPE, 0);
    if len(triple_or.items) != 1 { panic(11767); };
    if triple_or.items[0].entity.id != e2.id { panic(11768); };
    let triple_and = table_erased_world_query_triple_filter_and_auto<TableErasedMarker, TableErasedVel, TableErasedPos, TableErasedTime, TableErasedEvent>(w10, TABLE_ERASED_MARKER_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_FILTER_WITH, TABLE_ERASED_MARKER_TYPE, 0, TABLE_ERASED_FILTER_WITH, TABLE_ERASED_VEL_TYPE, 0);
