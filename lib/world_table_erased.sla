    if len(added_entities.items) != 2 { panic(11724); };
    let any_added = table_erased_world_query_or_added_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, TABLE_ERASED_POS_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_MARKER_TYPE, 0);
