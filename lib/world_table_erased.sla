fn table_erased_world_query<T, R, M>(world: TableErasedWorld<R, M>, component_id: i32, type_id: i32) -> Query<EntityItem<T>> {
    let query = query_new<EntityItem<T>>();
    let a: i64 = 0;
    let archetype_count = len(world.archetypes) as i64;
    while a < archetype_count {
        if table_erased_signature_has(world.archetypes[a].component_ids, component_id) {
            let column_slot = table_erased_world_column_slot<R, M>(world, a, component_id);
            let row: i64 = 0;
            let row_count = len(world.archetypes[a].entity_ids) as i64;
            while row < row_count {
                let eid = world.archetypes[a].entity_ids[row];
                let entity = entity_new(eid, world.registry.entities.generations[eid]);
                query.items.push(EntityItem<T> { entity: entity, value: registry_erased_value_read<T>(world.archetypes[a].columns[column_slot].values[row], type_id) });
                row = row + 1;
            }
        };
        a = a + 1;
    }
    return query;
}

