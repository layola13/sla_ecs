    let first_mover = movers.items[0];
    let w15 = table_erased_world_pair_write_first<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w14, first_mover, TableErasedPos { x: first_mover.first.value.x + first_mover.second.x, y: 0 });
    if table_erased_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w15, e3, position.id, TABLE_ERASED_POS_TYPE).x != 33 { panic(11908); };
}

@test "table erased high k query combinations preserve entity order"() {
    let w0 = table_erased_test_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let (w2, velocity) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, table_erased_vel_drop);
    let (w3, e1) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w2);
    let w4 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w3, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 10, y: 0 });
    let w5 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w4, e1, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 1, y: 0 });
    let (w6, e2) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w5);
    let w7 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w6, e2, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 20, y: 0 });
    let w8 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w7, e2, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 2, y: 0 });
    let (w9, e3) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w8);
    let w10 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, e3, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 30, y: 0 });
    let w11 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w10, e3, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 3, y: 0 });
    let (w12, e4) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w11);
    let w13 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w12, e4, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 40, y: 0 });
    let w14 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w13, e4, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 4, y: 0 });
    let (w15, e5) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w14);
    let w16 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w15, e5, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 50, y: 0 });
    let w17 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w16, e5, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 5, y: 0 });
    let (w18, e6) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w17);
    let w19 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w18, e6, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 60, y: 0 });
    let w20 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w19, e6, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 6, y: 0 });

    let first_five: Vec<Entity> = Vec::new();
    first_five.push(e1);
    first_five.push(e2);
    first_five.push(e3);
    first_five.push(e4);
    first_five.push(e5);

    let all_positions = table_erased_world_query_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w20, TABLE_ERASED_POS_TYPE);
    let pos_combinations5 = table_erased_query_combinations5<EntityItem<TableErasedPos>>(all_positions);
    if len(pos_combinations5.items) != 6 { panic(12225); };
    if pos_combinations5.items[0].first.entity.id != e1.id { panic(12226); };
    if pos_combinations5.items[0].fifth.entity.id != e5.id { panic(12227); };
    if pos_combinations5.items[5].first.entity.id != e2.id { panic(12228); };
    if pos_combinations5.items[5].fifth.entity.id != e6.id { panic(12229); };
    let pos_combinations6 = table_erased_query_combinations6<EntityItem<TableErasedPos>>(all_positions);
    if len(pos_combinations6.items) != 1 { panic(12230); };
    if pos_combinations6.items[0].first.entity.id != e1.id { panic(12231); };
    if pos_combinations6.items[0].sixth.entity.id != e6.id { panic(12232); };
    let first_five_positions = table_erased_query_entity_item_get_many<TableErasedPos>(all_positions, first_five);
    let too_large_positions = table_erased_query_combinations6<EntityItem<TableErasedPos>>(first_five_positions);
    if len(too_large_positions.items) != 0 { panic(12233); };

    let all_pairs = table_erased_world_query_pair_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w20, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE);
    let pair_combinations5 = table_erased_query_combinations5<TableErasedPair<TableErasedPos, TableErasedVel>>(all_pairs);
    if len(pair_combinations5.items) != 6 { panic(12234); };
    if pair_combinations5.items[0].first.entity.id != e1.id { panic(12235); };
    if pair_combinations5.items[0].fifth.entity.id != e5.id { panic(12236); };
    if pair_combinations5.items[5].first.entity.id != e2.id { panic(12237); };
    if pair_combinations5.items[5].fifth.entity.id != e6.id { panic(12238); };
    let pair_combinations6 = table_erased_query_combinations6<TableErasedPair<TableErasedPos, TableErasedVel>>(all_pairs);
    if len(pair_combinations6.items) != 1 { panic(12239); };
    if pair_combinations6.items[0].first.entity.id != e1.id { panic(12240); };
    if pair_combinations6.items[0].sixth.entity.id != e6.id { panic(12241); };

    let all_movers = table_erased_world_query_pair_mut_first_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w20, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE);
    let mover_combinations5 = table_erased_query_pair_mut_combinations5<TableErasedPos, TableErasedVel>(all_movers);
    if len(mover_combinations5.items) != 6 { panic(12242); };
    if mover_combinations5.items[0].first.first.entity.id != e1.id { panic(12243); };
    if mover_combinations5.items[0].fifth.first.entity.id != e5.id { panic(12244); };
    if mover_combinations5.items[5].first.first.entity.id != e2.id { panic(12245); };
    if mover_combinations5.items[5].fifth.first.entity.id != e6.id { panic(12246); };
    if entity_eq(mover_combinations5.items[0].first.first.entity, mover_combinations5.items[0].fifth.first.entity) { panic(12247); };
    let mover_combinations6 = table_erased_query_pair_mut_combinations6<TableErasedPos, TableErasedVel>(all_movers);
    if len(mover_combinations6.items) != 1 { panic(12248); };
    if mover_combinations6.items[0].first.first.entity.id != e1.id { panic(12249); };
    if mover_combinations6.items[0].sixth.first.entity.id != e6.id { panic(12250); };
    if entity_eq(mover_combinations6.items[0].first.first.entity, mover_combinations6.items[0].sixth.first.entity) { panic(12251); };
    let first_five_movers = table_erased_query_pair_mut_get_many<TableErasedPos, TableErasedVel>(all_movers, first_five);
    let too_large_movers = table_erased_query_pair_mut_combinations6<TableErasedPos, TableErasedVel>(first_five_movers);
    if len(too_large_movers.items) != 0 { panic(12252); };
}

@test "table erased pair mut without filter excludes marker archetypes"() {
    let w0 = table_erased_test_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let (w2, velocity) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, table_erased_vel_drop);
    let (w3, marker) = table_erased_world_register_sparse_set<TableErasedTime, TableErasedEvent>(w2, TABLE_ERASED_MARKER_TYPE, table_erased_marker_drop);
    let (w4, e1) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let (w5, e2) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w4);
