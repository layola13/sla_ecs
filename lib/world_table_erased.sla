    if len(any_marker_auto.items) != 1 { panic(11674); };
    if any_marker_auto.items[0].entity.id != e2.id { panic(11675); };
    let missing_either = table_erased_world_query_or_without_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_MARKER_TYPE);
    if len(missing_either.items) != 1 { panic(11687); };
