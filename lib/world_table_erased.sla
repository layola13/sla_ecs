    if len(triple_marker_velocity_pos.items) != 1 { panic(11756); };
    if triple_marker_velocity_pos.items[0].entity.id != e2.id { panic(11757); };
    if triple_marker_velocity_pos.items[0].first.value != 1 { panic(11758); };
    if triple_marker_velocity_pos.items[0].second.x != 8 { panic(11759); };
    if triple_marker_velocity_pos.items[0].third.x != 40 { panic(11760); };
    let triple_marked = table_erased_world_query_triple_with_auto<TableErasedMarker, TableErasedVel, TableErasedPos, TableErasedTime, TableErasedEvent>(w10, TABLE_ERASED_MARKER_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_MARKER_TYPE);
    if len(triple_marked.items) != 1 { panic(11761); };
    if triple_marked.items[0].entity.id != e2.id { panic(11762); };
    let triple_unmarked = table_erased_world_query_triple_without_auto<TableErasedMarker, TableErasedVel, TableErasedPos, TableErasedTime, TableErasedEvent>(w10, TABLE_ERASED_MARKER_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_MARKER_TYPE);
