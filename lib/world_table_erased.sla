fn table_erased_index_combination_copy(current: Vec<i64>) -> TableErasedIndexCombination {
    let indices: Vec<i64> = Vec::new();
    let i: i64 = 0;
    let cnt = len(current) as i64;
    while i < cnt {
        indices.push(current[i]);
        i = i + 1;
    }
    return TableErasedIndexCombination { indices: indices };
}

fn table_erased_index_combinations(count: i64, k: i64) -> Query<TableErasedIndexCombination> {
    let result = query_new<TableErasedIndexCombination>();
    if k <= 0 { return result; };
    if k > count { return result; };

    let current: Vec<i64> = Vec::new();
    let init: i64 = 0;
    while init < k {
        current.push(init);
        init = init + 1;
    }

    let active = true;
    while active {
        result.items.push(table_erased_index_combination_copy(current));

