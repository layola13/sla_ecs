@test "table erased spawned filter and spawn details"() {
    let w0 = table_erased_test_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let (w2, velocity) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, table_erased_vel_drop);
    let (w3, e1) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w2);
    let w4 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w3, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 1, y: 0 });
    let w5 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w4, e1, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 10, y: 0 });
    let first_tick = w5.registry.change_tick;

    let first_details = table_erased_world_query_spawn_details<TableErasedTime, TableErasedEvent>(w5, 0);
    if len(first_details.items) != 1 { panic(11830); };
    if first_details.items[0].entity.id != e1.id { panic(11831); };
    if first_details.items[0].spawn_tick() != first_tick { panic(11832); };
    if first_details.items[0].is_spawned() != true { panic(11833); };
    if first_details.items[0].has_spawned_by() { panic(12120); };
    if table_erased_world_spawned_by<TableErasedTime, TableErasedEvent>(w5, e1).is_some() { panic(12121); };
    let repeated_spawned = table_erased_world_query_entities_spawned<TableErasedTime, TableErasedEvent>(w5, first_tick);
    if len(repeated_spawned.items) != 0 { panic(11834); };

    let w6 = table_erased_world_increment_tick<TableErasedTime, TableErasedEvent>(w5);
    let source_location = table_erased_spawn_location_new(77, 120, 9);
    let (w7, e2) = table_erased_world_spawn_with_location<TableErasedTime, TableErasedEvent>(w6, source_location);
    let w8 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w7, e2, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 2, y: 0 });
    let w9 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w8, e2, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 20, y: 0 });
    let second_tick = w9.registry.change_tick;
    let direct_spawned_by = table_erased_world_spawned_by<TableErasedTime, TableErasedEvent>(w9, e2);
    if direct_spawned_by.is_some() != true { panic(12122); };
    if direct_spawned_by.file_id != 77 { panic(12123); };
    if direct_spawned_by.line != 120 { panic(12124); };
    if direct_spawned_by.column != 9 { panic(12125); };

    let spawned_entities = table_erased_world_query_entities_spawned<TableErasedTime, TableErasedEvent>(w9, first_tick);
    if len(spawned_entities.items) != 1 { panic(11835); };
    if spawned_entities.items[0].id != e2.id { panic(11836); };
    let spawned_positions = table_erased_world_query_spawned_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, TABLE_ERASED_POS_TYPE, first_tick);
    if len(spawned_positions.items) != 1 { panic(11837); };
    if spawned_positions.items[0].entity.id != e2.id { panic(11838); };
    if spawned_positions.items[0].value.x != 2 { panic(11839); };

    let positions_with_details = table_erased_world_query_with_spawn_details_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, TABLE_ERASED_POS_TYPE, first_tick);
    if len(positions_with_details.items) != 2 { panic(11840); };
    let detail_spawned_count: i32 = 0;
    let detail_tick_sum: i32 = 0;
    let i: i64 = 0;
    let detail_count = len(positions_with_details.items) as i64;
    while i < detail_count {
        if positions_with_details.items[i].details.is_spawned() { detail_spawned_count = detail_spawned_count + 1; };
        detail_tick_sum = detail_tick_sum + positions_with_details.items[i].details.spawn_tick();
        i = i + 1;
    }
    if detail_spawned_count != 1 { panic(11841); };
    if detail_tick_sum != first_tick + second_tick { panic(11842); };
    let second_detail_location = positions_with_details.items[1].details.spawned_by();
    if second_detail_location.file_id != 77 { panic(12126); };
    if second_detail_location.line != 120 { panic(12127); };
    if second_detail_location.column != 9 { panic(12128); };

    let spawned_pairs = table_erased_world_query_pair_spawned_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w9, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, first_tick);
    if len(spawned_pairs.items) != 1 { panic(11843); };
    if spawned_pairs.items[0].entity.id != e2.id { panic(11844); };
    let pair_details = table_erased_world_query_pair_with_spawn_details_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w9, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, first_tick);
    if len(pair_details.items) != 2 { panic(11845); };
    if pair_details.items[1].details.spawned_by().file_id != 77 { panic(12129); };

    let spawned_movers = table_erased_world_query_pair_mut_first_spawned_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w9, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, first_tick);
    if len(spawned_movers.items) != 1 { panic(11846); };
    if spawned_movers.items[0].first.entity.id != e2.id { panic(11847); };
    let detail_movers = table_erased_world_query_pair_mut_first_with_spawn_details_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w9, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, first_tick);
    if len(detail_movers.items) != 2 { panic(11848); };
    let detail_slot: i64 = -1;
    let j: i64 = 0;
    let mover_count = len(detail_movers.items) as i64;
    while j < mover_count {
        if detail_movers.items[j].first.entity.id == e2.id { detail_slot = j + 0; };
        j = j + 1;
    }
    if detail_slot < 0 { panic(11849); };
    if detail_movers.items[detail_slot].details.is_spawned_after(first_tick) != true { panic(11850); };
    if detail_movers.items[detail_slot].details.spawned_by().file_id != 77 { panic(12130); };
    let w10 = table_erased_world_pair_mut_with_spawn_details_write_first<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w9, detail_movers.items[detail_slot], TableErasedPos { x: detail_movers.items[detail_slot].first.value.x + detail_movers.items[detail_slot].second.x, y: 0 });
    if table_erased_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, e2, position.id, TABLE_ERASED_POS_TYPE).x != 22 { panic(11851); };

    let w11 = table_erased_world_despawn<TableErasedTime, TableErasedEvent>(w10, e2);
    let spawned_after_despawn = table_erased_world_query_entities_spawned<TableErasedTime, TableErasedEvent>(w11, first_tick);
    if len(spawned_after_despawn.items) != 0 { panic(11852); };
}

@test "table erased anyof nested in tuple query data"() {
    let w0 = table_erased_test_world_new();
    let (w1, position) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, table_erased_pos_drop);
    let (w2, velocity) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, table_erased_vel_drop);
    let (w3, marker) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w2, TABLE_ERASED_MARKER_TYPE, table_erased_marker_drop);
    let (w4, tag) = table_erased_world_register_table<TableErasedTime, TableErasedEvent>(w3, TABLE_ERASED_TAG_TYPE, table_erased_tag_drop);
    let (w5, e1) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let (w6, e2) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w5);
    let (w7, e3) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w6);
    let (w8, e4) = table_erased_world_spawn<TableErasedTime, TableErasedEvent>(w7);
    let w9 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w8, e1, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 1, y: 0 });
    let w10 = table_erased_world_insert<TableErasedTag, TableErasedTime, TableErasedEvent>(w9, e1, tag.id, TABLE_ERASED_TAG_TYPE, TableErasedTag { value: 10 });
    let w11 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, e2, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 2, y: 0 });
    let w12 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w11, e2, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 20, y: 0 });
    let w13 = table_erased_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w12, e3, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 3, y: 0 });
    let w14 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w13, e3, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 30, y: 0 });
    let w15 = table_erased_world_insert<TableErasedMarker, TableErasedTime, TableErasedEvent>(w14, e3, marker.id, TABLE_ERASED_MARKER_TYPE, TableErasedMarker { value: 300 });
    let w16 = table_erased_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w15, e4, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 40, y: 0 });
    let w17 = table_erased_world_insert<TableErasedTag, TableErasedTime, TableErasedEvent>(w16, e4, tag.id, TABLE_ERASED_TAG_TYPE, TableErasedTag { value: 400 });

    let pos_any = table_erased_world_query_with_any_of2_auto<TableErasedPos, TableErasedTag, TableErasedMarker, TableErasedTime, TableErasedEvent>(w17, TABLE_ERASED_POS_TYPE, TABLE_ERASED_TAG_TYPE, TABLE_ERASED_MARKER_TYPE, table_erased_tag_default, table_erased_marker_default);
    if len(pos_any.items) != 2 { panic(11800); };
    let tag_present: i32 = 0;
    let marker_present: i32 = 0;
    let pos_sum: i32 = 0;
    let i: i64 = 0;
    let cnt = len(pos_any.items) as i64;
    while i < cnt {
        pos_sum = pos_sum + pos_any.items[i].value.x;
        if pos_any.items[i].any_first.has_value { tag_present = tag_present + 1; };
        if pos_any.items[i].any_second.has_value { marker_present = marker_present + 1; };
        i = i + 1;
    }
    if tag_present != 1 { panic(11801); };
    if marker_present != 1 { panic(11802); };
    if pos_sum != 4 { panic(11803); };

    let pos_vel_any = table_erased_world_query_pair_with_any_of2_auto<TableErasedPos, TableErasedVel, TableErasedTag, TableErasedMarker, TableErasedTime, TableErasedEvent>(w17, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_TAG_TYPE, TABLE_ERASED_MARKER_TYPE, table_erased_tag_default, table_erased_marker_default);
    if len(pos_vel_any.items) != 1 { panic(11804); };
    if pos_vel_any.items[0].entity.id != e3.id { panic(11805); };
    if pos_vel_any.items[0].first.x != 3 { panic(11806); };
    if pos_vel_any.items[0].second.x != 30 { panic(11807); };
    if pos_vel_any.items[0].any_first.has_value { panic(11808); };
    if pos_vel_any.items[0].any_second.has_value != true { panic(11809); };
    if pos_vel_any.items[0].any_second.value.value != 300 { panic(11810); };
}
