    let changed_marked_positions = table_erased_world_query_filter_and_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_FILTER_CHANGED, TABLE_ERASED_POS_TYPE, before_change, TABLE_ERASED_FILTER_WITH, TABLE_ERASED_MARKER_TYPE, 0);
    if len(changed_marked_positions.items) != 1 { panic(11729); };
    if changed_marked_positions.items[0].entity.id != e2.id { panic(11730); };
    let pair_any_changed = table_erased_world_query_pair_or_changed_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_MARKER_TYPE, before_change);
    if len(pair_any_changed.items) != 1 { panic(11683); };
    if pair_any_changed.items[0].entity.id != e2.id { panic(11684); };
    let changed_marked_pairs = table_erased_world_query_pair_filter_and_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_FILTER_CHANGED, TABLE_ERASED_POS_TYPE, before_change, TABLE_ERASED_FILTER_WITH, TABLE_ERASED_MARKER_TYPE, 0);
    if len(changed_marked_pairs.items) != 1 { panic(11731); };
    if changed_marked_pairs.items[0].entity.id != e2.id { panic(11732); };
    let triple_changed = table_erased_world_query_triple_changed_auto<TableErasedMarker, TableErasedVel, TableErasedPos, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_MARKER_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_POS_TYPE, before_change);
    if len(triple_changed.items) != 1 { panic(11771); };
    if triple_changed.items[0].entity.id != e2.id { panic(11772); };
    if triple_changed.items[0].third.x != 48 { panic(11773); };
    let mut_changed = table_erased_world_query_pair_mut_first_changed_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, before_change);
    if len(mut_changed.items) != 1 { panic(11657); };
    if mut_changed.items[0].first.entity.id != e2.id { panic(11658); };
    let mut_any_changed = table_erased_world_query_pair_mut_first_or_changed_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, TABLE_ERASED_MARKER_TYPE, before_change);
    if len(mut_any_changed.items) != 1 { panic(11685); };
    if mut_any_changed.items[0].first.entity.id != e2.id { panic(11686); };
    let changed_marked_movers = table_erased_world_query_pair_mut_first_filter_and_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_FILTER_CHANGED, TABLE_ERASED_POS_TYPE, before_change, TABLE_ERASED_FILTER_WITH, TABLE_ERASED_MARKER_TYPE, 0);
    if len(changed_marked_movers.items) != 1 { panic(11733); };
