}

fn table_erased_world_despawn<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> TableErasedWorld<R, M> {
    if table_erased_world_is_alive<R, M>(world, entity) != true { return world; };
    world = table_erased_world_record_removed_current_row<R, M>(world, entity);
    world = table_erased_world_drop_row<R, M>(world, entity);
    world = table_erased_world_detach_no_drop<R, M>(world, entity);
    world.registry = registry_world_despawn(world.registry, entity);
    return world;
}

