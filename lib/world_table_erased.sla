    if triple_changed.items[0].third.x != 48 { panic(11773); };
    let mut_changed = table_erased_world_query_pair_mut_first_changed_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, TABLE_ERASED_POS_TYPE, before_change);
    if len(mut_changed.items) != 1 { panic(11657); };
