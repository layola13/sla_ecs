fn table_erased_world_ensure_location<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> TableErasedWorld<R, M> {
    while (len(world.locations) as i32) < entity.id + 1 {
        let next_id = len(world.locations) as i32;
        world.locations.push(table_erased_location_empty(next_id));
    }
    while (len(world.spawn_ticks) as i32) < entity.id + 1 {
        world.spawn_ticks.push(0);
    }
    while (len(world.spawn_locations) as i32) < entity.id + 1 {
        world.spawn_locations.push(table_erased_spawn_location_none());
    }
    return world;
}

fn table_erased_world_signature_for_entity<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> Vec<i32> {
