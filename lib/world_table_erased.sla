    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        let j = i + 1;
        while j < cnt {
            let k = j + 1;
            while k < cnt {
                let l = k + 1;
                while l < cnt {
                    let m = l + 1;
                    while m < cnt {
                        result.items.push(TableErasedCombination5<T> { first: query.items[i], second: query.items[j], third: query.items[k], fourth: query.items[l], fifth: query.items[m] });
                        m = m + 1;
                    }
                    l = l + 1;
                }
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn table_erased_query_pair_mut_combinations5<A, B>(query: Query<TableErasedPairMut<A, B>>) -> Query<TableErasedCombination5<TableErasedPairMut<A, B>>> {
    let result = query_new<TableErasedCombination5<TableErasedPairMut<A, B>>>();
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        let j = i + 1;
        while j < cnt {
            let k = j + 1;
            while k < cnt {
                let l = k + 1;
                while l < cnt {
                    let m = l + 1;
                    while m < cnt {
                        if entity_eq(query.items[i].first.entity, query.items[j].first.entity) { panic(12200); };
                        if entity_eq(query.items[i].first.entity, query.items[k].first.entity) { panic(12201); };
                        if entity_eq(query.items[i].first.entity, query.items[l].first.entity) { panic(12202); };
                        if entity_eq(query.items[i].first.entity, query.items[m].first.entity) { panic(12203); };
                        if entity_eq(query.items[j].first.entity, query.items[k].first.entity) { panic(12204); };
                        if entity_eq(query.items[j].first.entity, query.items[l].first.entity) { panic(12205); };
                        if entity_eq(query.items[j].first.entity, query.items[m].first.entity) { panic(12206); };
                        if entity_eq(query.items[k].first.entity, query.items[l].first.entity) { panic(12207); };
                        if entity_eq(query.items[k].first.entity, query.items[m].first.entity) { panic(12208); };
                        if entity_eq(query.items[l].first.entity, query.items[m].first.entity) { panic(12209); };
                        result.items.push(TableErasedCombination5<TableErasedPairMut<A, B>> { first: query.items[i], second: query.items[j], third: query.items[k], fourth: query.items[l], fifth: query.items[m] });
                        m = m + 1;
                    }
                    l = l + 1;
                }
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn table_erased_query_combinations6<T>(query: Query<T>) -> Query<TableErasedCombination6<T>> {
    let result = query_new<TableErasedCombination6<T>>();
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        let j = i + 1;
        while j < cnt {
            let k = j + 1;
            while k < cnt {
                let l = k + 1;
                while l < cnt {
                    let m = l + 1;
                    while m < cnt {
                        let n = m + 1;
                        while n < cnt {
                            result.items.push(TableErasedCombination6<T> { first: query.items[i], second: query.items[j], third: query.items[k], fourth: query.items[l], fifth: query.items[m], sixth: query.items[n] });
                            n = n + 1;
                        }
                        m = m + 1;
                    }
                    l = l + 1;
                }
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn table_erased_query_pair_mut_combinations6<A, B>(query: Query<TableErasedPairMut<A, B>>) -> Query<TableErasedCombination6<TableErasedPairMut<A, B>>> {
    let result = query_new<TableErasedCombination6<TableErasedPairMut<A, B>>>();
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        let j = i + 1;
        while j < cnt {
            let k = j + 1;
            while k < cnt {
                let l = k + 1;
                while l < cnt {
                    let m = l + 1;
                    while m < cnt {
                        let n = m + 1;
                        while n < cnt {
                            if entity_eq(query.items[i].first.entity, query.items[j].first.entity) { panic(12210); };
                            if entity_eq(query.items[i].first.entity, query.items[k].first.entity) { panic(12211); };
                            if entity_eq(query.items[i].first.entity, query.items[l].first.entity) { panic(12212); };
                            if entity_eq(query.items[i].first.entity, query.items[m].first.entity) { panic(12213); };
                            if entity_eq(query.items[i].first.entity, query.items[n].first.entity) { panic(12214); };
                            if entity_eq(query.items[j].first.entity, query.items[k].first.entity) { panic(12215); };
                            if entity_eq(query.items[j].first.entity, query.items[l].first.entity) { panic(12216); };
                            if entity_eq(query.items[j].first.entity, query.items[m].first.entity) { panic(12217); };
                            if entity_eq(query.items[j].first.entity, query.items[n].first.entity) { panic(12218); };
                            if entity_eq(query.items[k].first.entity, query.items[l].first.entity) { panic(12219); };
                            if entity_eq(query.items[k].first.entity, query.items[m].first.entity) { panic(12220); };
                            if entity_eq(query.items[k].first.entity, query.items[n].first.entity) { panic(12221); };
                            if entity_eq(query.items[l].first.entity, query.items[m].first.entity) { panic(12222); };
                            if entity_eq(query.items[l].first.entity, query.items[n].first.entity) { panic(12223); };
                            if entity_eq(query.items[m].first.entity, query.items[n].first.entity) { panic(12224); };
                            result.items.push(TableErasedCombination6<TableErasedPairMut<A, B>> { first: query.items[i], second: query.items[j], third: query.items[k], fourth: query.items[l], fifth: query.items[m], sixth: query.items[n] });
                            n = n + 1;
                        }
                        m = m + 1;
                    }
                    l = l + 1;
                }
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn table_erased_world_def_slot<R, M>(world: TableErasedWorld<R, M>, component_id: i32) -> i64 {
    let i: i64 = 0;
    let cnt = len(world.component_defs) as i64;
    while i < cnt {
        if world.component_defs[i].component_id == component_id { return i; };
        i = i + 1;
    }
    return -1;
}

fn table_erased_world_def_for<R, M>(world: TableErasedWorld<R, M>, component_id: i32) -> TableErasedColumnDef {
    let slot = table_erased_world_def_slot<R, M>(world, component_id);
    if slot < 0 { panic(11600); };
    return world.component_defs[slot];
}

fn table_erased_world_def_slot_by_type<R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> i64 {
    let i: i64 = 0;
    let cnt = len(world.component_defs) as i64;
    while i < cnt {
        if world.component_defs[i].type_id == type_id { return i; };
        i = i + 1;
    }
    return -1;
}

fn table_erased_world_def_for_type<R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> TableErasedColumnDef {
    let slot = table_erased_world_def_slot_by_type<R, M>(world, type_id);
    if slot < 0 { panic(11606); };
    return world.component_defs[slot];
}

fn table_erased_world_component_id_for_type<R, M>(world: TableErasedWorld<R, M>, type_id: i32) -> i32 {
    return table_erased_world_def_for_type<R, M>(world, type_id).component_id;
}

fn table_erased_archetype_new<R, M>(world: TableErasedWorld<R, M>, id: i32, component_ids: Vec<i32>) -> TableErasedArchetype {
    let entity_ids: Vec<i32> = Vec::new();
    let columns: Vec<TableErasedColumn> = Vec::new();
    let i: i64 = 0;
    let cnt = len(component_ids) as i64;
    while i < cnt {
        columns.push(table_erased_column_new(table_erased_world_def_for<R, M>(world, component_ids[i])));
        i = i + 1;
    }
    return TableErasedArchetype { id: id, component_ids: component_ids, entity_ids: entity_ids, columns: columns };
}

fn table_erased_world_new<R, M>(default_r: R, default_m: M) -> TableErasedWorld<R, M> {
    let component_defs: Vec<TableErasedColumnDef> = Vec::new();
    let archetypes: Vec<TableErasedArchetype> = Vec::new();
    let locations: Vec<TableErasedLocation> = Vec::new();
    let spawn_ticks: Vec<i32> = Vec::new();
    let spawn_locations: Vec<TableErasedSpawnLocation> = Vec::new();
    let world = TableErasedWorld<R, M> {
        registry: registry_world_new(),
        component_defs: component_defs,
        archetypes: archetypes,
        locations: locations,
        spawn_ticks: spawn_ticks,
        spawn_locations: spawn_locations,
        resource: resource_slot_new<R>(default_r),
        messages: messages_new<M>(default_m),
        resource_added_tick: 0,
        resource_changed_tick: 0,
    };
    world.archetypes.push(table_erased_archetype_new<R, M>(world, 0, table_erased_signature_empty()));
    return world;
}

fn table_erased_world_register_table<R, M>(world: TableErasedWorld<R, M>, type_id: i32, drop_fn: fn(*u8) -> void) -> (TableErasedWorld<R, M>, ComponentInfo) {
    if table_erased_world_def_slot_by_type<R, M>(world, type_id) >= 0 { panic(11607); };
    let (registry, info) = registry_world_register_table(world.registry);
    world.registry = registry;
    world.component_defs.push(table_erased_column_def_new(info.id, type_id, drop_fn));
    return (world, info);
}

fn table_erased_world_register_sparse_set<R, M>(world: TableErasedWorld<R, M>, type_id: i32, drop_fn: fn(*u8) -> void) -> (TableErasedWorld<R, M>, ComponentInfo) {
    if table_erased_world_def_slot_by_type<R, M>(world, type_id) >= 0 { panic(11607); };
    let (registry, info) = registry_world_register_sparse_set(world.registry);
    world.registry = registry;
    world.component_defs.push(table_erased_column_def_new(info.id, type_id, drop_fn));
    return (world, info);
}

fn table_erased_signature_equals(left: Vec<i32>, right: Vec<i32>) -> bool {
    let left_len = len(left) as i64;
    let right_len = len(right) as i64;
    if left_len != right_len { return false; };
    let i: i64 = 0;
    while i < left_len {
        if left[i] != right[i] { return false; };
        i = i + 1;
    }
    return true;
}

fn table_erased_signature_has(signature: Vec<i32>, component_id: i32) -> bool {
    let i: i64 = 0;
    let cnt = len(signature) as i64;
    while i < cnt {
        if signature[i] == component_id { return true; };
        i = i + 1;
    }
    return false;
}

fn table_erased_world_find_archetype<R, M>(world: TableErasedWorld<R, M>, component_ids: Vec<i32>) -> i64 {
    let i: i64 = 0;
    let cnt = len(world.archetypes) as i64;
    while i < cnt {
        if table_erased_signature_equals(world.archetypes[i].component_ids, component_ids) { return i; };
        i = i + 1;
    }
    return -1;
}

fn table_erased_world_get_or_create_archetype<R, M>(world: TableErasedWorld<R, M>, component_ids: Vec<i32>) -> (TableErasedWorld<R, M>, i64) {
    let existing = table_erased_world_find_archetype<R, M>(world, component_ids);
    if existing >= 0 { return (world, existing); };
    let id = len(world.archetypes) as i32;
    world.archetypes.push(table_erased_archetype_new<R, M>(world, id, component_ids));
    return (world, id as i64);
}

fn table_erased_world_column_slot<R, M>(world: TableErasedWorld<R, M>, archetype_slot: i64, component_id: i32) -> i64 {
    let i: i64 = 0;
    let cnt = len(world.archetypes[archetype_slot].columns) as i64;
    while i < cnt {
        if world.archetypes[archetype_slot].columns[i].component_id == component_id { return i; };
        i = i + 1;
    }
    return -1;
}

fn table_erased_world_ensure_location<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> TableErasedWorld<R, M> {
    while (len(world.locations) as i32) < entity.id + 1 {
        let next_id = len(world.locations) as i32;
        world.locations.push(table_erased_location_empty(next_id));
    }
    while (len(world.spawn_ticks) as i32) < entity.id + 1 {
        world.spawn_ticks.push(0);
    }
    while (len(world.spawn_locations) as i32) < entity.id + 1 {
        world.spawn_locations.push(table_erased_spawn_location_none());
    }
    return world;
}

fn table_erased_world_signature_for_entity<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> Vec<i32> {
    let ids: Vec<i32> = Vec::new();
    let i: i64 = 0;
    let cnt = len(world.registry.columns) as i64;
    while i < cnt {
        let component_id = world.registry.columns[i].info.id;
        if registry_world_has_component(world.registry, entity, component_id) { ids.push(component_id); };
        i = i + 1;
    }
    return ids;
}

fn table_erased_world_is_alive<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> bool { return registry_world_is_alive(world.registry, entity); }
fn table_erased_world_has<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32) -> bool { return registry_world_has_component(world.registry, entity, component_id); }

fn table_erased_world_has_type<R, M>(world: TableErasedWorld<R, M>, entity: Entity, type_id: i32) -> bool {
    return table_erased_world_has<R, M>(world, entity, table_erased_world_component_id_for_type<R, M>(world, type_id));
}

fn table_erased_world_entity_archetype_id<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> i32 {
    if entity.id >= (len(world.locations) as i32) { return -1; };
    return world.locations[entity.id].archetype_id;
}

fn table_erased_world_entity_row<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> i64 {
    if entity.id >= (len(world.locations) as i32) { return -1; };
    return world.locations[entity.id].row;
}

fn table_erased_world_archetype_entity_count<R, M>(world: TableErasedWorld<R, M>, archetype_id: i32) -> i64 {
    if archetype_id < 0 { return 0; };
    return len(world.archetypes[archetype_id].entity_ids) as i64;
}

fn table_erased_world_value_unchecked<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32) -> ErasedComponentValue {
    let location = world.locations[entity.id];
    let archetype_slot = location.archetype_id as i64;
    let column_slot = table_erased_world_column_slot<R, M>(world, archetype_slot, component_id);
    if column_slot < 0 { panic(11601); };
    return world.archetypes[archetype_slot].columns[column_slot].values[location.row];
}

fn table_erased_world_get<T, R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32, type_id: i32) -> T {
    if table_erased_world_has<R, M>(world, entity, component_id) != true { panic(11602); };
    return registry_erased_value_read<T>(table_erased_world_value_unchecked<R, M>(world, entity, component_id), type_id);
}

fn table_erased_world_get_auto<T, R, M>(world: TableErasedWorld<R, M>, entity: Entity, type_id: i32) -> T {
    let component_id = table_erased_world_component_id_for_type<R, M>(world, type_id);
    return table_erased_world_get<T, R, M>(world, entity, component_id, type_id);
}

fn table_erased_world_collect_values<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_ids: Vec<i32>, extra_component_id: i32, extra_value: ErasedComponentValue) -> Vec<ErasedComponentValue> {
    let values: Vec<ErasedComponentValue> = Vec::new();
    let extra_index: i64 = -1;
    let find: i64 = 0;
    let cnt = len(component_ids) as i64;
    while find < cnt {
        if component_ids[find] == extra_component_id { extra_index = find + 0; };
        find = find + 1;
    }
    if extra_index < 0 { panic(11603); };
    let i: i64 = 0;
    while i < extra_index {
        values.push(table_erased_world_value_unchecked<R, M>(world, entity, component_ids[i]));
        i = i + 1;
    }
    values.push(extra_value);
    let j = extra_index + 1;
    while j < cnt {
        values.push(table_erased_world_value_unchecked<R, M>(world, entity, component_ids[j]));
        j = j + 1;
    }
    return values;
}

fn table_erased_world_collect_existing_values<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_ids: Vec<i32>) -> Vec<ErasedComponentValue> {
    let values: Vec<ErasedComponentValue> = Vec::new();
    let i: i64 = 0;
    let cnt = len(component_ids) as i64;
    while i < cnt {
        values.push(table_erased_world_value_unchecked<R, M>(world, entity, component_ids[i]));
        i = i + 1;
    }
    return values;
}

fn table_erased_world_drop_value<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32) -> TableErasedWorld<R, M> {
    let location = world.locations[entity.id];
    let archetype_slot = location.archetype_id as i64;
    let column_slot = table_erased_world_column_slot<R, M>(world, archetype_slot, component_id);
    if column_slot < 0 { return world; };
    let drop_fn = world.archetypes[archetype_slot].columns[column_slot].drop_fn;
    drop_fn(world.archetypes[archetype_slot].columns[column_slot].values[location.row].raw);
    return world;
}

fn table_erased_world_drop_row<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> TableErasedWorld<R, M> {
    if entity.id >= (len(world.locations) as i32) { return world; };
    let location = world.locations[entity.id];
    if location.archetype_id < 0 { return world; };
    let archetype_slot = location.archetype_id as i64;
    let c: i64 = 0;
    let cnt = len(world.archetypes[archetype_slot].columns) as i64;
    while c < cnt {
        let drop_fn = world.archetypes[archetype_slot].columns[c].drop_fn;
        drop_fn(world.archetypes[archetype_slot].columns[c].values[location.row].raw);
        c = c + 1;
    }
    return world;
}

fn table_erased_world_detach_no_drop<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> TableErasedWorld<R, M> {
    if entity.id >= (len(world.locations) as i32) { return world; };
    let location = world.locations[entity.id];
    if location.archetype_id < 0 { return world; };
    let archetype_slot = location.archetype_id as i64;
    let last = (len(world.archetypes[archetype_slot].entity_ids) as i64) - 1;
    if location.row != last {
        let moved_entity_id = world.archetypes[archetype_slot].entity_ids[last];
        world.archetypes[archetype_slot].entity_ids[location.row] = moved_entity_id;
        world.locations[moved_entity_id].row = location.row;
        let c: i64 = 0;
        let column_count = len(world.archetypes[archetype_slot].columns) as i64;
        while c < column_count {
            world.archetypes[archetype_slot].columns[c] = table_erased_column_copy_last_to(world.archetypes[archetype_slot].columns[c], location.row, last);
            c = c + 1;
        }
    };
    let removed_entity = world.archetypes[archetype_slot].entity_ids.remove(last);
    let r: i64 = 0;
    let remove_column_count = len(world.archetypes[archetype_slot].columns) as i64;
    while r < remove_column_count {
        world.archetypes[archetype_slot].columns[r] = table_erased_column_remove_last(world.archetypes[archetype_slot].columns[r], last);
        r = r + 1;
    }
    world.locations[entity.id].archetype_id = -1;
    world.locations[entity.id].row = -1;
    return world;
}

fn table_erased_world_attach_with_values<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_ids: Vec<i32>, values: Vec<ErasedComponentValue>) -> TableErasedWorld<R, M> {
    world = table_erased_world_ensure_location<R, M>(world, entity);
    let (next_world, archetype_slot) = table_erased_world_get_or_create_archetype<R, M>(world, component_ids);
    world = next_world;
    let row = len(world.archetypes[archetype_slot].entity_ids) as i64;
    world.archetypes[archetype_slot].entity_ids.push(entity.id);
    let i: i64 = 0;
    let cnt = len(world.archetypes[archetype_slot].columns) as i64;
    while i < cnt {
        world.archetypes[archetype_slot].columns[i].values.push(values[i]);
        i = i + 1;
    }
    world.locations[entity.id].entity_id = entity.id;
    world.locations[entity.id].archetype_id = world.archetypes[archetype_slot].id;
    world.locations[entity.id].row = row;
    return world;
}

fn table_erased_world_attach_empty<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> TableErasedWorld<R, M> {
    let values: Vec<ErasedComponentValue> = Vec::new();
    return table_erased_world_attach_with_values<R, M>(world, entity, table_erased_signature_empty(), values);
}

fn table_erased_world_spawn_with_location<R, M>(world: TableErasedWorld<R, M>, spawned_by: TableErasedSpawnLocation) -> (TableErasedWorld<R, M>, Entity) {
    let (registry, entity) = registry_world_spawn(world.registry);
    world.registry = registry;
    world = table_erased_world_attach_empty<R, M>(world, entity);
    world.spawn_ticks[entity.id] = world.registry.change_tick;
    world.spawn_locations[entity.id] = spawned_by;
    return (world, entity);
}

fn table_erased_world_spawn<R, M>(world: TableErasedWorld<R, M>) -> (TableErasedWorld<R, M>, Entity) {
    return table_erased_world_spawn_with_location<R, M>(world, table_erased_spawn_location_none());
}

fn table_erased_world_replace_existing<T, R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32, type_id: i32, value: T) -> TableErasedWorld<R, M> {
    let def = table_erased_world_def_for<R, M>(world, component_id);
    if def.type_id != type_id { panic(11604); };
    let erased = registry_erased_value_new<T>(type_id, value);
    world = table_erased_world_drop_value<R, M>(world, entity, component_id);
    let location = world.locations[entity.id];
    let archetype_slot = location.archetype_id as i64;
    let column_slot = table_erased_world_column_slot<R, M>(world, archetype_slot, component_id);
    world.archetypes[archetype_slot].columns[column_slot].values[location.row] = erased;
    world.registry = registry_world_insert_component(world.registry, entity, component_id);
    return world;
}

fn table_erased_world_insert_new<T, R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32, type_id: i32, value: T) -> TableErasedWorld<R, M> {
    let def = table_erased_world_def_for<R, M>(world, component_id);
    if def.type_id != type_id { panic(11604); };
    let erased = registry_erased_value_new<T>(type_id, value);
    world.registry = registry_world_insert_component(world.registry, entity, component_id);
    let signature = table_erased_world_signature_for_entity<R, M>(world, entity);
    let values = table_erased_world_collect_values<R, M>(world, entity, signature, component_id, erased);
    world = table_erased_world_detach_no_drop<R, M>(world, entity);
    return table_erased_world_attach_with_values<R, M>(world, entity, signature, values);
}

fn table_erased_world_replace_erased_existing<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32, value: ErasedComponentValue) -> TableErasedWorld<R, M> {
    let def = table_erased_world_def_for<R, M>(world, component_id);
    if def.type_id != value.type_id { panic(11605); };
    world = table_erased_world_drop_value<R, M>(world, entity, component_id);
    let location = world.locations[entity.id];
    let archetype_slot = location.archetype_id as i64;
    let column_slot = table_erased_world_column_slot<R, M>(world, archetype_slot, component_id);
    world.archetypes[archetype_slot].columns[column_slot].values[location.row] = value;
    world.registry = registry_world_insert_component(world.registry, entity, component_id);
    return world;
}

fn table_erased_world_insert_erased_new<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32, value: ErasedComponentValue) -> TableErasedWorld<R, M> {
    let def = table_erased_world_def_for<R, M>(world, component_id);
    if def.type_id != value.type_id { panic(11605); };
    world.registry = registry_world_insert_component(world.registry, entity, component_id);
