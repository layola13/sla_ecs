    let changed_marked_entities = table_erased_world_query_entities_filter_and_auto<TableErasedTime, TableErasedEvent>(w13, TABLE_ERASED_FILTER_CHANGED, TABLE_ERASED_POS_TYPE, before_change, TABLE_ERASED_FILTER_WITH, TABLE_ERASED_MARKER_TYPE, 0);
