fn table_erased_query_entities_iter_many(query: Query<Entity>, entities: Vec<Entity>) -> Query<Entity> {
    let result = query_new<Entity>();
    let i: i64 = 0;
    let cnt = len(entities) as i64;
    while i < cnt {
        let j: i64 = 0;
        let query_count = len(query.items) as i64;
        while j < query_count {
            if entity_eq(query.items[j], entities[i]) { result.items.push(query.items[j]); };
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn table_erased_query_entities_get(query: Query<Entity>, entity: Entity) -> Entity {
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        if query.items[i] == entity { return query.items[i]; };
        i = i + 1;
    }
    panic(12800);
}

fn table_erased_query_entities_get_many(query: Query<Entity>, entities: Vec<Entity>) -> Query<Entity> {
    let result = query_new<Entity>();
    let i: i64 = 0;
    let cnt = len(entities) as i64;
    while i < cnt {
        result.items.push(table_erased_query_entities_get(query, entities[i]));
        i = i + 1;
    }
    return result;
}

fn table_erased_query_entities_get_many_unique(query: Query<Entity>, entities: Vec<Entity>) -> Query<Entity> {
    if table_erased_entity_vec_has_duplicate(entities) { panic(12801); };
    return table_erased_query_entities_get_many(query, entities);
}

