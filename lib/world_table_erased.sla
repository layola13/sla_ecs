fn table_erased_world_remove<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32) -> TableErasedWorld<R, M> {
    if table_erased_world_has<R, M>(world, entity, component_id) != true { return world; };
    world = table_erased_world_record_removed<R, M>(world, entity, component_id);
    world = table_erased_world_drop_value<R, M>(world, entity, component_id);
    world.registry = registry_world_remove_component(world.registry, entity, component_id);
    let signature = table_erased_world_signature_for_entity<R, M>(world, entity);
    let values = table_erased_world_collect_existing_values<R, M>(world, entity, signature);
    world = table_erased_world_detach_no_drop<R, M>(world, entity);
    return table_erased_world_attach_with_values<R, M>(world, entity, signature, values);
}

fn table_erased_world_remove_auto<R, M>(world: TableErasedWorld<R, M>, entity: Entity, type_id: i32) -> TableErasedWorld<R, M> {
