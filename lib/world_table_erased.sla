fn table_erased_world_changed_since<R, M>(world: TableErasedWorld<R, M>, entity: Entity, component_id: i32, tick: i32) -> bool { return registry_world_component_changed_since(world.registry, entity, component_id, tick); }
fn table_erased_world_spawn_tick<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> i32 {
    if table_erased_world_is_alive<R, M>(world, entity) != true { return -1; };
    if entity.id >= (len(world.spawn_ticks) as i32) { return -1; };
    return world.spawn_ticks[entity.id];
}

fn table_erased_world_spawned_by<R, M>(world: TableErasedWorld<R, M>, entity: Entity) -> TableErasedSpawnLocation {
    if table_erased_world_is_alive<R, M>(world, entity) != true { return table_erased_spawn_location_none(); };
    if entity.id >= (len(world.spawn_locations) as i32) { return table_erased_spawn_location_none(); };
    return world.spawn_locations[entity.id];
}

fn table_erased_world_spawned_since<R, M>(world: TableErasedWorld<R, M>, entity: Entity, tick: i32) -> bool {
    let spawn_tick = table_erased_world_spawn_tick<R, M>(world, entity);
    if spawn_tick < 0 { return false; };
    if spawn_tick <= tick { return false; };
    return spawn_tick <= world.registry.change_tick;
}

fn table_erased_world_spawn_details<R, M>(world: TableErasedWorld<R, M>, entity: Entity, last_run_tick: i32) -> TableErasedSpawnDetails {
    let spawn_tick = table_erased_world_spawn_tick<R, M>(world, entity);
