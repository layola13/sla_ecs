    if len(and_mobile_movers.items) != 1 { panic(11722); };
    if and_mobile_movers.items[0].first.entity.id != e1.id { panic(11723); };
    let added = table_erased_world_query_added<TableErasedPos, TableErasedTime, TableErasedEvent>(w10, position.id, TABLE_ERASED_POS_TYPE, 0);
    if len(added.items) != 2 { panic(11645); };
