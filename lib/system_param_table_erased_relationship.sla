    let (w5, child) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let w6 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, child, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 8, y: 0 });
    let w7 = table_erased_relationship_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w6, child, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 3, y: 0 });
    let w8 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w7, kind.id, child, root);
    let before = w8.table.registry.change_tick;
    let w9 = table_erased_relationship_run_pair_mut_commands_system_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w8, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, table_erased_relationship_pair_mut_commands_system);
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, child, position.id, TABLE_ERASED_POS_TYPE).x != 11 { panic(12508); };
    if table_erased_world_changed_since<TableErasedTime, TableErasedEvent>(w9.table, child, position.id, before - 1) != true { panic(12509); };
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w9, kind.id, root) != 2 { panic(12527); };
    if entity_eq(table_erased_relationship_world_related<TableErasedTime, TableErasedEvent>(w9, kind.id, child), root) != true { panic(12528); };
