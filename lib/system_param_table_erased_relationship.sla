    let w8 = table_erased_relationship_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w7, child_a, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 2, y: 0 });
    let w9 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w8, child_b, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 23, y: 0 });
    let w10 = table_erased_relationship_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w9, child_b, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 5, y: 0 });
    let w11 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w10, kind.id, child_a, root);
    let w12 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w11, kind.id, child_b, root);
    let before = w12.table.registry.change_tick;
    let w13 = table_erased_relationship_run_pair_mut_readonly_pair_param_set_system_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w12, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, table_erased_relationship_pair_mut_readonly_pair_param_set_system);
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w13, child_a, position.id, TABLE_ERASED_POS_TYPE).x != 39 { panic(12503); };
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w13, child_b, position.id, TABLE_ERASED_POS_TYPE).x != 58 { panic(12504); };
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w13, kind.id, root) != 2 { panic(12505); };
    if table_erased_world_changed_since<TableErasedTime, TableErasedEvent>(w13.table, child_b, position.id, before - 1) != true { panic(12506); };
    if table_erased_world_query_pair_count_auto<TableErasedTime, TableErasedEvent>(w13.table, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE) != 2 { panic(12507); };
}

@test "table erased relationship pair mut commands param writes query before commands apply"() {
    let w0 = table_erased_relationship_test_world_new();
