    let read_query = table_erased_world_query_pair<A, B, R, M>(world.table, first_component_id, first_type_id, second_component_id, second_type_id);
    let param0 = table_erased_relationship_pair_mut_readonly_pair_param_set<A, B>(mut_query, read_query);
    let param1 = run(param0);
    return table_erased_relationship_apply_pair_mut_updates<A, B, R, M>(world, param1.mut_query);
}

