    if len(query.items) != 2 { panic(12529); };
    let found_spawned = false;
    let spawned = entity_placeholder();
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        if query.items[i].first.x == 88 {
            found_spawned = true;
            spawned = query.items[i].entity;
            if query.items[i].second.x != 7 { panic(12530); };
        };
        i = i + 1;
    }
    if found_spawned != true { panic(12531); };
