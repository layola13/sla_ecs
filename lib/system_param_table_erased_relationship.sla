fn table_erased_relationship_run_message_writer_system<R, M>(world: TableErasedRelationshipWorld<R, M>, run: fn(MessageWriter<M>) -> MessageWriter<M>) -> TableErasedRelationshipWorld<R, M> {
    let writer0 = message_writer_new<M>();
    let writer1 = run(writer0);
    world.table.messages = messages_apply_writer<M>(world.table.messages, writer1);
    return world;
}

fn table_erased_relationship_run_message_writer_commands_system<R, M>(world: TableErasedRelationshipWorld<R, M>, run: fn(TableErasedRelationshipMessageWriterCommandsParam<R, M>) -> TableErasedRelationshipMessageWriterCommandsParam<R, M>) -> TableErasedRelationshipWorld<R, M> {
    let param0 = table_erased_relationship_message_writer_commands_param<R, M>(message_writer_new<M>(), table_erased_relationship_commands_param_new<R, M>(world));
    let param1 = run(param0);
    param1.commands.world.table.messages = messages_apply_writer<M>(param1.commands.world.table.messages, param1.writer);
    let (world2, cleared) = table_erased_relationship_commands_apply<R, M>(param1.commands.world, param1.commands.commands);
    return world2;
}

fn table_erased_relationship_run_message_reader_writer_param_set_system<R, M>(world: TableErasedRelationshipWorld<R, M>, reader: MessageReader, default_message: M, run: fn(TableErasedRelationshipMessageReaderWriterParamSet<M>) -> TableErasedRelationshipMessageReaderWriterParamSet<M>) -> (TableErasedRelationshipWorld<R, M>, MessageReader) {
    let read = table_erased_world_read_message<R, M>(world.table, reader, default_message);
    let param0 = table_erased_relationship_message_reader_writer_param_set<M>(read, message_writer_new<M>());
    let param1 = run(param0);
    world.table.messages = messages_apply_writer<M>(world.table.messages, param1.writer);
    return (world, param1.read.reader);
}

fn table_erased_relationship_param_movement_system(query: Query<TableErasedPairMut<TableErasedPos, TableErasedVel>>) -> Query<TableErasedPairMut<TableErasedPos, TableErasedVel>> {
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        query.items[i].first.value = TableErasedPos { x: query.items[i].first.value.x + query.items[i].second.x, y: query.items[i].first.value.y + query.items[i].second.y };
        i = i + 1;
    }
    return query;
}

fn table_erased_relationship_pair_mut_readonly_pair_param_set_system(param: TableErasedRelationshipPairMutReadonlyPairParamSet<TableErasedPos, TableErasedVel>) -> TableErasedRelationshipPairMutReadonlyPairParamSet<TableErasedPos, TableErasedVel> {
    let read_sum: i32 = 0;
    let ri: i64 = 0;
    let read_cnt = len(param.read_query.items) as i64;
    while ri < read_cnt {
        read_sum = read_sum + param.read_query.items[ri].first.x;
        ri = ri + 1;
    }
    let wi: i64 = 0;
    let write_cnt = len(param.mut_query.items) as i64;
    while wi < write_cnt {
        param.mut_query.items[wi].first.value = TableErasedPos { x: param.mut_query.items[wi].first.value.x + param.mut_query.items[wi].second.x + read_sum, y: param.mut_query.items[wi].first.value.y };
        wi = wi + 1;
    }
    return table_erased_relationship_pair_mut_readonly_pair_param_set<TableErasedPos, TableErasedVel>(param.mut_query, param.read_query);
}

