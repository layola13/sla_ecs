// SA-native system parameter adapters for TableErasedRelationshipWorld<R, M>.
@import "schedule_table_erased_relationship.sla"

struct TableErasedRelationshipCommandsParam<R, M> {
    world: TableErasedRelationshipWorld<R, M>,
    commands: TableErasedRelationshipCommands<R, M>,
}

struct TableErasedRelationshipQueryResourceParam<R> {
    related: RelationshipEntityQuery,
    resource: R,
}

struct TableErasedRelationshipItemQueryResourceParam<I, R> {
    query: Query<I>,
    resource: R,
}

struct TableErasedRelationshipResMutMessageReadParam<R, M> {
    resource: ResMut<R>,
    read: MessageRead<M>,
}

struct TableErasedRelationshipMessageReaderWriterParamSet<M> {
    read: MessageRead<M>,
    writer: MessageWriter<M>,
}

fn table_erased_relationship_commands_param_new<R, M>(world: TableErasedRelationshipWorld<R, M>) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: world, commands: table_erased_relationship_commands_new<R, M>() };
}

fn table_erased_relationship_commands_param_reserve_entity<R, M>(param: TableErasedRelationshipCommandsParam<R, M>) -> (TableErasedRelationshipCommandsParam<R, M>, Entity) {
    let (world, commands, entity) = table_erased_relationship_commands_reserve_entity<R, M>(param.world, param.commands);
    return (TableErasedRelationshipCommandsParam<R, M> { world: world, commands: commands }, entity);
}

fn table_erased_relationship_commands_param_reserve_entity_with_location<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, spawned_by: TableErasedSpawnLocation) -> (TableErasedRelationshipCommandsParam<R, M>, Entity) {
    let (world, commands, entity) = table_erased_relationship_commands_reserve_entity_with_location<R, M>(param.world, param.commands, spawned_by);
    return (TableErasedRelationshipCommandsParam<R, M> { world: world, commands: commands }, entity);
}

fn table_erased_relationship_commands_param_spawn_related<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, relationship_kind_id: i32, target: Entity) -> (TableErasedRelationshipCommandsParam<R, M>, Entity) {
    let (world, commands, entity) = table_erased_relationship_commands_spawn_related<R, M>(param.world, param.commands, relationship_kind_id, target);
    return (TableErasedRelationshipCommandsParam<R, M> { world: world, commands: commands }, entity);
}

fn table_erased_relationship_commands_param_spawn_related_with_location<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, relationship_kind_id: i32, target: Entity, spawned_by: TableErasedSpawnLocation) -> (TableErasedRelationshipCommandsParam<R, M>, Entity) {
    let (world, commands, entity) = table_erased_relationship_commands_spawn_related_with_location<R, M>(param.world, param.commands, relationship_kind_id, target, spawned_by);
    return (TableErasedRelationshipCommandsParam<R, M> { world: world, commands: commands }, entity);
}

fn table_erased_relationship_commands_param_insert<T, R, M>(param: TableErasedRelationshipCommandsParam<R, M>, entity: Entity, component_id: i32, type_id: i32, value: T) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_insert<T, R, M>(param.commands, entity, component_id, type_id, value) };
}

fn table_erased_relationship_commands_param_insert_auto<T, R, M>(param: TableErasedRelationshipCommandsParam<R, M>, entity: Entity, type_id: i32, value: T) -> TableErasedRelationshipCommandsParam<R, M> {
    let component_id = table_erased_world_component_id_for_type<R, M>(param.world.table, type_id);
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_insert<T, R, M>(param.commands, entity, component_id, type_id, value) };
}

fn table_erased_relationship_commands_param_set_related<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, relationship_kind_id: i32, source: Entity, target: Entity) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_set_related<R, M>(param.commands, relationship_kind_id, source, target) };
}

fn table_erased_relationship_commands_param_set_related_at<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, relationship_kind_id: i32, source: Entity, target: Entity, index: i64) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_set_related_at<R, M>(param.commands, relationship_kind_id, source, target, index) };
}

fn table_erased_relationship_commands_param_remove_related<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, relationship_kind_id: i32, target: Entity, related: Vec<Entity>) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_remove_related<R, M>(param.commands, relationship_kind_id, target, related) };
}

fn table_erased_relationship_commands_param_detach_all_related<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, relationship_kind_id: i32, target: Entity) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_detach_all_related<R, M>(param.commands, relationship_kind_id, target) };
}

fn table_erased_relationship_commands_param_despawn_related<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, relationship_kind_id: i32, target: Entity) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_despawn_related<R, M>(param.commands, relationship_kind_id, target) };
}

fn table_erased_relationship_commands_param_replace_related<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, relationship_kind_id: i32, target: Entity, related: Vec<Entity>) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_replace_related<R, M>(param.commands, relationship_kind_id, target, related) };
}

fn table_erased_relationship_commands_param_replace_related_with_difference<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, relationship_kind_id: i32, target: Entity, entities_to_unrelate: Vec<Entity>, entities_to_relate: Vec<Entity>, newly_related_entities: Vec<Entity>) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_replace_related_with_difference<R, M>(param.commands, relationship_kind_id, target, entities_to_unrelate, entities_to_relate, newly_related_entities) };
}

fn table_erased_relationship_commands_param_despawn<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, entity: Entity) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_despawn<R, M>(param.commands, entity) };
}

fn table_erased_relationship_commands_param_insert_resource<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, value: R) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_insert_resource<R, M>(param.commands, value) };
}

fn table_erased_relationship_commands_param_write_message<R, M>(param: TableErasedRelationshipCommandsParam<R, M>, value: M) -> TableErasedRelationshipCommandsParam<R, M> {
    return TableErasedRelationshipCommandsParam<R, M> { world: param.world, commands: table_erased_relationship_commands_write_message<R, M>(param.commands, value) };
}

fn table_erased_relationship_query_resource_param<R>(related: RelationshipEntityQuery, resource: R) -> TableErasedRelationshipQueryResourceParam<R> {
    return TableErasedRelationshipQueryResourceParam<R> { related: related, resource: resource };
}

fn table_erased_relationship_item_query_resource_param<I, R>(query: Query<I>, resource: R) -> TableErasedRelationshipItemQueryResourceParam<I, R> {
    return TableErasedRelationshipItemQueryResourceParam<I, R> { query: query, resource: resource };
}

fn table_erased_relationship_item_query_resource_count<I, R>(param: TableErasedRelationshipItemQueryResourceParam<I, R>) -> i64 {
    return len(param.query.items) as i64;
}

fn table_erased_relationship_resmut_message_read_param<R, M>(resource: ResMut<R>, read: MessageRead<M>) -> TableErasedRelationshipResMutMessageReadParam<R, M> {
    return TableErasedRelationshipResMutMessageReadParam<R, M> { resource: resource, read: read };
}

fn table_erased_relationship_message_reader_writer_param_set<M>(read: MessageRead<M>, writer: MessageWriter<M>) -> TableErasedRelationshipMessageReaderWriterParamSet<M> {
    return TableErasedRelationshipMessageReaderWriterParamSet<M> { read: read, writer: writer };
}

fn table_erased_relationship_run_pair_mut_system<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_component_id: i32, first_type_id: i32, second_component_id: i32, second_type_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedRelationshipWorld<R, M> {
    let query = table_erased_world_query_pair_mut_first<A, B, R, M>(world.table, first_component_id, first_type_id, second_component_id, second_type_id);
    let updated = run(query);
    let i: i64 = 0;
    let cnt = len(updated.items) as i64;
    while i < cnt {
        let item = updated.items[i];
        world.table = table_erased_world_pair_write_first<A, B, R, M>(world.table, item, item.first.value);
        i = i + 1;
    }
    return world;
}

fn table_erased_relationship_run_pair_mut_system_auto<A, B, R, M>(world: TableErasedRelationshipWorld<R, M>, first_type_id: i32, second_type_id: i32, run: fn(Query<TableErasedPairMut<A, B>>) -> Query<TableErasedPairMut<A, B>>) -> TableErasedRelationshipWorld<R, M> {
    let first_component_id = table_erased_world_component_id_for_type<R, M>(world.table, first_type_id);
    let second_component_id = table_erased_world_component_id_for_type<R, M>(world.table, second_type_id);
    return table_erased_relationship_run_pair_mut_system<A, B, R, M>(world, first_component_id, first_type_id, second_component_id, second_type_id, run);
}

fn table_erased_relationship_run_relation_resource_system<R, M>(world: TableErasedRelationshipWorld<R, M>, relationship_kind_id: i32, target: Entity, run: fn(TableErasedRelationshipQueryResourceParam<R>) -> TableErasedRelationshipQueryResourceParam<R>) -> TableErasedRelationshipWorld<R, M> {
    let related = relationship_world_sources(world.relationships, relationship_kind_id, target);
    let param0 = table_erased_relationship_query_resource_param<R>(related, table_erased_world_get_resource<R, M>(world.table));
    let param1 = run(param0);
    world.table = table_erased_world_insert_resource<R, M>(world.table, param1.resource);
    return world;
}

fn table_erased_relationship_run_removed_components_query_resource_system<R, M>(world: TableErasedRelationshipWorld<R, M>, component_id: i32, since_tick: i32, run: fn(TableErasedRelationshipItemQueryResourceParam<Entity, R>) -> TableErasedRelationshipItemQueryResourceParam<Entity, R>) -> TableErasedRelationshipWorld<R, M> {
    let query = table_erased_relationship_world_removed_components<R, M>(world, component_id, since_tick);
    let param0 = table_erased_relationship_item_query_resource_param<Entity, R>(query, table_erased_world_get_resource<R, M>(world.table));
    let param1 = run(param0);
    world.table = table_erased_world_insert_resource<R, M>(world.table, param1.resource);
    return world;
}

fn table_erased_relationship_run_removed_components_query_resource_system_auto<R, M>(world: TableErasedRelationshipWorld<R, M>, type_id: i32, since_tick: i32, run: fn(TableErasedRelationshipItemQueryResourceParam<Entity, R>) -> TableErasedRelationshipItemQueryResourceParam<Entity, R>) -> TableErasedRelationshipWorld<R, M> {
    let component_id = table_erased_world_component_id_for_type<R, M>(world.table, type_id);
    return table_erased_relationship_run_removed_components_query_resource_system<R, M>(world, component_id, since_tick, run);
}

fn table_erased_relationship_run_commands_system<R, M>(world: TableErasedRelationshipWorld<R, M>, run: fn(TableErasedRelationshipCommandsParam<R, M>) -> TableErasedRelationshipCommandsParam<R, M>) -> TableErasedRelationshipWorld<R, M> {
    let param0 = table_erased_relationship_commands_param_new<R, M>(world);
    let param1 = run(param0);
    let (world2, cleared) = table_erased_relationship_commands_apply<R, M>(param1.world, param1.commands);
    return world2;
}

fn table_erased_relationship_run_res_mut_system<R, M>(world: TableErasedRelationshipWorld<R, M>, run: fn(ResMut<R>) -> ResMut<R>) -> TableErasedRelationshipWorld<R, M> {
    let param0 = table_erased_world_res_mut<R, M>(world.table);
    let param1 = run(param0);
    world.table = table_erased_world_res_mut_write<R, M>(world.table, param1, param1.value);
    return world;
}

fn table_erased_relationship_run_message_reader_res_mut_system<R, M>(world: TableErasedRelationshipWorld<R, M>, reader: MessageReader, default_message: M, run: fn(TableErasedRelationshipResMutMessageReadParam<R, M>) -> TableErasedRelationshipResMutMessageReadParam<R, M>) -> (TableErasedRelationshipWorld<R, M>, MessageReader) {
    let read = table_erased_world_read_message<R, M>(world.table, reader, default_message);
    let param0 = table_erased_relationship_resmut_message_read_param<R, M>(table_erased_world_res_mut<R, M>(world.table), read);
    let param1 = run(param0);
    world.table = table_erased_world_res_mut_write<R, M>(world.table, param1.resource, param1.resource.value);
    return (world, param1.read.reader);
}

fn table_erased_relationship_run_message_writer_system<R, M>(world: TableErasedRelationshipWorld<R, M>, run: fn(MessageWriter<M>) -> MessageWriter<M>) -> TableErasedRelationshipWorld<R, M> {
    let writer0 = message_writer_new<M>();
    let writer1 = run(writer0);
    world.table.messages = messages_apply_writer<M>(world.table.messages, writer1);
    return world;
}

fn table_erased_relationship_run_message_reader_writer_param_set_system<R, M>(world: TableErasedRelationshipWorld<R, M>, reader: MessageReader, default_message: M, run: fn(TableErasedRelationshipMessageReaderWriterParamSet<M>) -> TableErasedRelationshipMessageReaderWriterParamSet<M>) -> (TableErasedRelationshipWorld<R, M>, MessageReader) {
    let read = table_erased_world_read_message<R, M>(world.table, reader, default_message);
    let param0 = table_erased_relationship_message_reader_writer_param_set<M>(read, message_writer_new<M>());
    let param1 = run(param0);
    world.table.messages = messages_apply_writer<M>(world.table.messages, param1.writer);
    return (world, param1.read.reader);
}

fn table_erased_relationship_param_movement_system(query: Query<TableErasedPairMut<TableErasedPos, TableErasedVel>>) -> Query<TableErasedPairMut<TableErasedPos, TableErasedVel>> {
    let i: i64 = 0;
    let cnt = len(query.items) as i64;
    while i < cnt {
        query.items[i].first.value = TableErasedPos { x: query.items[i].first.value.x + query.items[i].second.x, y: query.items[i].first.value.y + query.items[i].second.y };
        i = i + 1;
    }
    return query;
}

fn table_erased_relationship_param_count_system(param: TableErasedRelationshipQueryResourceParam<TableErasedTime>) -> TableErasedRelationshipQueryResourceParam<TableErasedTime> {
    return table_erased_relationship_query_resource_param<TableErasedTime>(param.related, TableErasedTime { tick: len(param.related.items) as i32 });
}

fn table_erased_relationship_param_entity_count_system(param: TableErasedRelationshipItemQueryResourceParam<Entity, TableErasedTime>) -> TableErasedRelationshipItemQueryResourceParam<Entity, TableErasedTime> {
    return table_erased_relationship_item_query_resource_param<Entity, TableErasedTime>(param.query, TableErasedTime { tick: len(param.query.items) as i32 });
}

fn table_erased_relationship_param_commands_system(param: TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent> {
    let (param1, root) = table_erased_relationship_commands_param_reserve_entity_with_location<TableErasedTime, TableErasedEvent>(param, table_erased_spawn_location_new(97, 32, 6));
    let (param2, child) = table_erased_relationship_commands_param_spawn_related_with_location<TableErasedTime, TableErasedEvent>(param1, 1, root, table_erased_spawn_location_new(98, 33, 7));
    let param3 = table_erased_relationship_commands_param_insert_auto<TableErasedPos, TableErasedTime, TableErasedEvent>(param2, child, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 12, y: 0 });
    let param4 = table_erased_relationship_commands_param_insert_resource<TableErasedTime, TableErasedEvent>(param3, TableErasedTime { tick: 7 });
    return table_erased_relationship_commands_param_write_message<TableErasedTime, TableErasedEvent>(param4, TableErasedEvent { amount: 5 });
}

fn table_erased_relationship_param_ordered_commands_system(param: TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent> {
    let (param1, root) = table_erased_relationship_commands_param_reserve_entity<TableErasedTime, TableErasedEvent>(param);
    let (param2, first) = table_erased_relationship_commands_param_reserve_entity<TableErasedTime, TableErasedEvent>(param1);
    let (param3, second) = table_erased_relationship_commands_param_reserve_entity<TableErasedTime, TableErasedEvent>(param2);
    let (param4, third) = table_erased_relationship_commands_param_reserve_entity<TableErasedTime, TableErasedEvent>(param3);
    let param5 = table_erased_relationship_commands_param_set_related<TableErasedTime, TableErasedEvent>(param4, 1, first, root);
    let param6 = table_erased_relationship_commands_param_set_related<TableErasedTime, TableErasedEvent>(param5, 1, second, root);
    return table_erased_relationship_commands_param_set_related_at<TableErasedTime, TableErasedEvent>(param6, 1, third, root, 1);
}

fn table_erased_relationship_param_collection_commands_system(param: TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent> {
    let (param1, root) = table_erased_relationship_commands_param_reserve_entity<TableErasedTime, TableErasedEvent>(param);
    let (param2, first) = table_erased_relationship_commands_param_reserve_entity<TableErasedTime, TableErasedEvent>(param1);
    let (param3, second) = table_erased_relationship_commands_param_reserve_entity<TableErasedTime, TableErasedEvent>(param2);
    let (param4, third) = table_erased_relationship_commands_param_reserve_entity<TableErasedTime, TableErasedEvent>(param3);
    let (param5, fourth) = table_erased_relationship_commands_param_reserve_entity<TableErasedTime, TableErasedEvent>(param4);
    let param6 = table_erased_relationship_commands_param_set_related<TableErasedTime, TableErasedEvent>(param5, 1, first, root);
    let param7 = table_erased_relationship_commands_param_set_related<TableErasedTime, TableErasedEvent>(param6, 1, second, root);
    let param8 = table_erased_relationship_commands_param_set_related_at<TableErasedTime, TableErasedEvent>(param7, 1, third, root, 1);
    let remove: Vec<Entity> = Vec::new();
    remove.push(second);
    let param9 = table_erased_relationship_commands_param_remove_related<TableErasedTime, TableErasedEvent>(param8, 1, root, remove);
    let replace: Vec<Entity> = Vec::new();
    replace.push(third);
    replace.push(first);
    replace.push(fourth);
    let param10 = table_erased_relationship_commands_param_replace_related<TableErasedTime, TableErasedEvent>(param9, 1, root, replace);
    let unrelate: Vec<Entity> = Vec::new();
    unrelate.push(first);
    let relate: Vec<Entity> = Vec::new();
    relate.push(second);
    relate.push(third);
    relate.push(fourth);
    let newly: Vec<Entity> = Vec::new();
    newly.push(second);
    return table_erased_relationship_commands_param_replace_related_with_difference<TableErasedTime, TableErasedEvent>(param10, 1, root, unrelate, relate, newly);
}

fn table_erased_relationship_param_detach_commands_system(param: TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent> {
    if len(param.world.relationships.targets) <= 0 { return param; };
    let target_entry = param.world.relationships.targets[0];
    return table_erased_relationship_commands_param_detach_all_related<TableErasedTime, TableErasedEvent>(param, target_entry.kind_id, target_entry.target);
}

fn table_erased_relationship_param_despawn_related_commands_system(param: TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipCommandsParam<TableErasedTime, TableErasedEvent> {
    if len(param.world.relationships.targets) <= 0 { return param; };
    let target_entry = param.world.relationships.targets[0];
    return table_erased_relationship_commands_param_despawn_related<TableErasedTime, TableErasedEvent>(param, target_entry.kind_id, target_entry.target);
}

fn table_erased_relationship_param_writer_system(writer: MessageWriter<TableErasedEvent>) -> MessageWriter<TableErasedEvent> {
    let writer1 = message_writer_send<TableErasedEvent>(writer, TableErasedEvent { amount: 2 });
    return message_writer_send<TableErasedEvent>(writer1, TableErasedEvent { amount: 3 });
}

fn table_erased_relationship_param_reader_resmut_system(param: TableErasedRelationshipResMutMessageReadParam<TableErasedTime, TableErasedEvent>) -> TableErasedRelationshipResMutMessageReadParam<TableErasedTime, TableErasedEvent> {
    if param.read.has_value { param.resource.value = TableErasedTime { tick: param.resource.value.tick + param.read.value.amount }; };
    return param;
}

fn table_erased_relationship_param_reader_writer_param_set_system(param: TableErasedRelationshipMessageReaderWriterParamSet<TableErasedEvent>) -> TableErasedRelationshipMessageReaderWriterParamSet<TableErasedEvent> {
    let writer = param.writer;
    if param.read.has_value { writer = message_writer_send<TableErasedEvent>(writer, TableErasedEvent { amount: param.read.value.amount + 40 }); };
    writer = message_writer_send<TableErasedEvent>(writer, TableErasedEvent { amount: 55 });
    return table_erased_relationship_message_reader_writer_param_set<TableErasedEvent>(param.read, writer);
}

@test "table erased relationship pair mut param writes back"() {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, position) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, velocity) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, ecs_box_drop<TableErasedVel>);
    let (w3, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w2, true, false);
    let (w4, root) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let (w5, child) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let w6 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, child, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 8, y: 0 });
    let w7 = table_erased_relationship_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w6, child, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 4, y: 0 });
    let w8 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w7, kind.id, child, root);
    let before = w8.table.registry.change_tick;
    let w9 = table_erased_relationship_run_pair_mut_system_auto<TableErasedPos, TableErasedVel, TableErasedTime, TableErasedEvent>(w8, TABLE_ERASED_POS_TYPE, TABLE_ERASED_VEL_TYPE, table_erased_relationship_param_movement_system);
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, child, position.id, TABLE_ERASED_POS_TYPE).x != 12 { panic(12500); };
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w9, kind.id, root) != 1 { panic(12501); };
    if table_erased_world_changed_since<TableErasedTime, TableErasedEvent>(w9.table, child, position.id, before - 1) != true { panic(12502); };
}

@test "table erased relationship relation resource and message params"() {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w0, true, false);
    let (w2, root) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w1);
    let (w3, child_a) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w2);
    let (w4, child_b) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let w5 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w4, kind.id, child_a, root);
    let w6 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w5, kind.id, child_b, root);
    w6.table = table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(w6.table, TableErasedTime { tick: 0 });
    let w7 = table_erased_relationship_run_relation_resource_system<TableErasedTime, TableErasedEvent>(w6, kind.id, root, table_erased_relationship_param_count_system);
    let w8 = table_erased_relationship_run_message_writer_system<TableErasedTime, TableErasedEvent>(w7, table_erased_relationship_param_writer_system);
    let read1 = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w8.table, message_reader_new(), table_erased_event_default());
    let (w9, reader2) = table_erased_relationship_run_message_reader_res_mut_system<TableErasedTime, TableErasedEvent>(w8, read1.reader, table_erased_event_default(), table_erased_relationship_param_reader_resmut_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(w9.table).tick != 5 { panic(12510); };
    if read1.value.amount != 2 { panic(12511); };
    if reader2.cursor != 2 { panic(12512); };
}

@test "table erased relationship message reader writer param set batches conflicts"() {
    let w0 = table_erased_relationship_test_world_new();
    let w1 = TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_write_message<TableErasedTime, TableErasedEvent>(w0.table, TableErasedEvent { amount: 8 }), relationships: w0.relationships };
    let (w2, reader1) = table_erased_relationship_run_message_reader_writer_param_set_system<TableErasedTime, TableErasedEvent>(w1, message_reader_new(), table_erased_event_default(), table_erased_relationship_param_reader_writer_param_set_system);
    if reader1.cursor != 1 { panic(12513); };
    let read1 = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w2.table, reader1, table_erased_event_default());
    let read2 = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w2.table, read1.reader, table_erased_event_default());
    let read3 = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w2.table, read2.reader, table_erased_event_default());
    if read1.has_value != true { panic(12514); };
    if read1.value.amount != 48 { panic(12515); };
    if read2.has_value != true { panic(12516); };
    if read2.value.amount != 55 { panic(12517); };
    if read3.has_value != false { panic(12518); };
}

@test "table erased relationship system params expose removed components"() {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, position) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, velocity) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w1, TABLE_ERASED_VEL_TYPE, ecs_box_drop<TableErasedVel>);
    let (w3, marker) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w2, TABLE_ERASED_MARKER_TYPE, ecs_box_drop<TableErasedMarker>);
    let (w4, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w3, true, false);
    let (w5, root) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let (w6, child) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w5);
    let (w7, other) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w6);
    let w8 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w7, child, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 1, y: 0 });
    let w9 = table_erased_relationship_world_insert<TableErasedMarker, TableErasedTime, TableErasedEvent>(w8, child, marker.id, TABLE_ERASED_MARKER_TYPE, TableErasedMarker { value: 100 });
    let w10 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w9, other, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 2, y: 0 });
    let w11 = table_erased_relationship_world_insert<TableErasedVel, TableErasedTime, TableErasedEvent>(w10, other, velocity.id, TABLE_ERASED_VEL_TYPE, TableErasedVel { x: 20, y: 0 });
    let w12 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w11, kind.id, child, root);

    let remove_since = w12.table.registry.change_tick;
    let w13 = TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_increment_tick<TableErasedTime, TableErasedEvent>(w12.table), relationships: w12.relationships };
    let w14 = table_erased_relationship_world_remove_auto<TableErasedTime, TableErasedEvent>(w13, child, TABLE_ERASED_MARKER_TYPE);
    let w14r = TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(w14.table, TableErasedTime { tick: 0 }), relationships: w14.relationships };
    let marker_removed = table_erased_relationship_run_removed_components_query_resource_system_auto<TableErasedTime, TableErasedEvent>(w14r, TABLE_ERASED_MARKER_TYPE, remove_since, table_erased_relationship_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(marker_removed.table).tick != 1 { panic(12560); };
    let marker_current = table_erased_relationship_run_removed_components_query_resource_system<TableErasedTime, TableErasedEvent>(w14r, marker.id, w14r.table.registry.change_tick, table_erased_relationship_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(marker_current.table).tick != 0 { panic(12561); };
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w14, kind.id, root) != 1 { panic(12562); };

    let despawn_since = w14.table.registry.change_tick;
    let w15 = TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_increment_tick<TableErasedTime, TableErasedEvent>(w14.table), relationships: w14.relationships };
    let w16 = table_erased_relationship_world_despawn<TableErasedTime, TableErasedEvent>(w15, other);
    let w16r = TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(w16.table, TableErasedTime { tick: 0 }), relationships: w16.relationships };
    let pos_removed = table_erased_relationship_run_removed_components_query_resource_system<TableErasedTime, TableErasedEvent>(w16r, position.id, despawn_since, table_erased_relationship_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(pos_removed.table).tick != 1 { panic(12563); };
    let vel_removed = table_erased_relationship_run_removed_components_query_resource_system_auto<TableErasedTime, TableErasedEvent>(w16r, TABLE_ERASED_VEL_TYPE, despawn_since, table_erased_relationship_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(vel_removed.table).tick != 1 { panic(12564); };
    let marker_after_despawn = table_erased_relationship_run_removed_components_query_resource_system<TableErasedTime, TableErasedEvent>(w16r, marker.id, despawn_since, table_erased_relationship_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(marker_after_despawn.table).tick != 0 { panic(12565); };

    let w17 = table_erased_relationship_world_clear_removed_components<TableErasedTime, TableErasedEvent>(w16);
    let w17r = TableErasedRelationshipWorld<TableErasedTime, TableErasedEvent> { table: table_erased_world_insert_resource<TableErasedTime, TableErasedEvent>(w17.table, TableErasedTime { tick: 0 }), relationships: w17.relationships };
    let removed_after_clear = table_erased_relationship_run_removed_components_query_resource_system_auto<TableErasedTime, TableErasedEvent>(w17r, TABLE_ERASED_POS_TYPE, 0, table_erased_relationship_param_entity_count_system);
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(removed_after_clear.table).tick != 0 { panic(12566); };
}

@test "table erased relationship commands param applies relation resources and messages"() {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, position) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w1, true, false);
    let w3 = table_erased_relationship_run_commands_system<TableErasedTime, TableErasedEvent>(w2, table_erased_relationship_param_commands_system);
    let root = entity_new(1, w3.table.registry.entities.generations[1]);
    let child = table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w3, kind.id, root, 0);
    let read = table_erased_world_read_message<TableErasedTime, TableErasedEvent>(w3.table, message_reader_new(), table_erased_event_default());
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w3, kind.id, root) != 1 { panic(12520); };
    if table_erased_relationship_world_get<TableErasedPos, TableErasedTime, TableErasedEvent>(w3, child, position.id, TABLE_ERASED_POS_TYPE).x != 12 { panic(12521); };
    if table_erased_world_get_resource<TableErasedTime, TableErasedEvent>(w3.table).tick != 7 { panic(12522); };
    if read.value.amount != 5 { panic(12523); };
    let root_by = table_erased_world_spawned_by<TableErasedTime, TableErasedEvent>(w3.table, root);
    let child_by = table_erased_world_spawned_by<TableErasedTime, TableErasedEvent>(w3.table, child);
    if root_by.file_id != 97 { panic(12524); };
    if child_by.file_id != 98 { panic(12525); };
    if child_by.column != 7 { panic(12526); };
}

@test "table erased relationship commands param supports ordered insertion"() {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w0, true, false);
    let w2 = table_erased_relationship_run_commands_system<TableErasedTime, TableErasedEvent>(w1, table_erased_relationship_param_ordered_commands_system);
    let root = entity_new(1, w2.table.registry.entities.generations[1]);
    let first = entity_new(2, w2.table.registry.entities.generations[2]);
    let second = entity_new(3, w2.table.registry.entities.generations[3]);
    let third = entity_new(4, w2.table.registry.entities.generations[4]);
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w2, kind.id, root) != 3 { panic(12540); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w2, kind.id, root, 0), first) != true { panic(12541); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w2, kind.id, root, 1), third) != true { panic(12542); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w2, kind.id, root, 2), second) != true { panic(12543); };
}

@test "table erased relationship commands param supports collection maintenance"() {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w0, true, false);
    let w2 = table_erased_relationship_run_commands_system<TableErasedTime, TableErasedEvent>(w1, table_erased_relationship_param_collection_commands_system);
    let root = entity_new(1, w2.table.registry.entities.generations[1]);
    let second = entity_new(3, w2.table.registry.entities.generations[3]);
    let third = entity_new(4, w2.table.registry.entities.generations[4]);
    let fourth = entity_new(5, w2.table.registry.entities.generations[5]);
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w2, kind.id, root) != 3 { panic(12544); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w2, kind.id, root, 0), second) != true { panic(12545); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w2, kind.id, root, 1), third) != true { panic(12546); };
    if entity_eq(table_erased_relationship_world_source_at<TableErasedTime, TableErasedEvent>(w2, kind.id, root, 2), fourth) != true { panic(12547); };
    let detach_w0 = table_erased_relationship_test_world_new();
    let (detach_w1, detach_kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(detach_w0, true, false);
    let (w3a, detach_root) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(detach_w1);
    let (w3b, detach_first) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w3a);
    let (w3c, detach_second) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w3b);
    let w3d = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w3c, detach_kind.id, detach_first, detach_root);
    let w3e = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w3d, detach_kind.id, detach_second, detach_root);
    let w3 = table_erased_relationship_run_commands_system<TableErasedTime, TableErasedEvent>(w3e, table_erased_relationship_param_detach_commands_system);
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w3, detach_kind.id, detach_root) != 0 { panic(12548); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w3, detach_first) != true { panic(12549); };
}

@test "table erased relationship commands param despawns related sources only"() {
    let w0 = table_erased_relationship_test_world_new();
    let (w1, position) = table_erased_relationship_world_register_table<TableErasedTime, TableErasedEvent>(w0, TABLE_ERASED_POS_TYPE, ecs_box_drop<TableErasedPos>);
    let (w2, kind) = table_erased_relationship_world_register_many<TableErasedTime, TableErasedEvent>(w1, true, false);
    let (w3, root) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w2);
    let (w4, child) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w3);
    let (w5, grandchild) = table_erased_relationship_world_spawn<TableErasedTime, TableErasedEvent>(w4);
    let w6 = table_erased_relationship_world_insert<TableErasedPos, TableErasedTime, TableErasedEvent>(w5, child, position.id, TABLE_ERASED_POS_TYPE, TableErasedPos { x: 88, y: 0 });
    let w7 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w6, kind.id, child, root);
    let w8 = table_erased_relationship_world_set_related<TableErasedTime, TableErasedEvent>(w7, kind.id, grandchild, child);
    let w9 = table_erased_relationship_run_commands_system<TableErasedTime, TableErasedEvent>(w8, table_erased_relationship_param_despawn_related_commands_system);
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w9, root) != true { panic(12550); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w9, child) != false { panic(12551); };
    if table_erased_relationship_world_is_alive<TableErasedTime, TableErasedEvent>(w9, grandchild) != false { panic(12552); };
    if table_erased_relationship_world_has<TableErasedTime, TableErasedEvent>(w9, child, position.id) != false { panic(12553); };
    if table_erased_relationship_world_source_count<TableErasedTime, TableErasedEvent>(w9, kind.id, root) != 0 { panic(12554); };
}
